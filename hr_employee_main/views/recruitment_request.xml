        <record id="recr_request_tree" model="ir.ui.view">
            <field name="name">Recruitment Request</field>
            <field name="model">recruitment.request</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="recr_request_form_search" model="ir.ui.view">
            <field name="name">Recruitment Request</field>
            <field name="model">recruitment.request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>


        <record id="recr_request_action" model="ir.actions.act_window">
            <field name="name">Recruitment Request</field>
            <field name="res_model">recruitment.request</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem name="Recruitment Request" id="recr_request"
                  parent="recr_plan_root"
                  groups="hr.group_hr_user,base_rida.rida_group_line_manager"
                  action="recr_request_action"/>

    </data>
</odoo>
