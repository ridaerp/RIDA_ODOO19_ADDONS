<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <record id="trip_permission_form_view" model="ir.ui.view">
            <field name="name">Trip Permission Request</field>
            <field name="model">trip.permission</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Validate" name="action_validate" type="object" invisible="state != 'wha'"  class="oe_highlight"
                                groups="hr_holidays.group_hr_holidays_manager"/>
                        <button string="Approve" name="action_approve" type="object" class="oe_highlight"  invisible="state != 'wlm'"
                                groups="base_rida.rida_group_line_manager"/>
                        <button string="Approve" name="action_hr_manager_approve" type="object" class="oe_highlight"
                              invisible="state != 'whmp'"
                                groups="base_rida.rida_hr_manager_notify"/>
                        <button string="Submit" name="action_submit" type="object" class="oe_highlight" invisible="state != 'draft'"
                                groups="base.group_user"/>
                        <button string="Approve" name="approve_finance_manager" type="object" invisible="state != 'wfm'"
                                class="oe_highlight" groups="base_rida.rida_finance_manager"/>
                        <button string="Approve" name="approve_internal_audit" type="object" invisible="state != 'internal_aud'"
                                class="oe_highlight" groups="base_rida.rida_internal_audit"/>
                        <button string="Approve" name="approve_operation_director" type="object" invisible="state != 'wod'"
                                class="oe_highlight" groups="base_rida.rida_group_site_manager"/>
                        <button string="Approve" name="approve_ccso" type="object" invisible="state != 'ccso'"
                                class="oe_highlight" groups="base_rida.rida_group_CCSO"/>
                        <button string="Post Journal Entries" name="approve_accountant" type="object" invisible="state != 'wd'"
                                class="oe_highlight" groups="account.group_account_user"/>
                        <button name="action_register_payment" id="account_invoice_payment_btn" invisible="state != 'wdp'"
                                type="object" class="oe_highlight" context="{'dont_redirect_to_payments': True}"
                                string="Register Payment" groups="account.group_account_user"/>
                        <button string="Set to Draft" name="action_draft"
                                groups="base_rida.rida_group_site_manager,base_rida.rida_hr_manager_notify,base_rida.rida_finance_manager,base_rida.rida_group_CCSO,base_rida.rida_group_line_manager"
                                type="object" invisible="state != 'reject'"/>
                        <button name="action_reject" type="object"
                               invisible="state in ['wha', 'wlm', 'wfm', 'internal_aud', 'ccso', 'wod', 'whmp']"  string="Reject"
                                groups="base_rida.rida_group_site_manager,base.group_user,base_rida.rida_hr_manager_notify,base_rida.rida_finance_manager,base_rida.rida_group_CCSO,base_rida.rida_group_line_manager"
                        />
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,wlm,whmp,wha,wfm,internal_aud,wod,wd,wdp,paid"
                               invisible="user_type == 'hq'"/>
                        <field name="state_ccso" widget="statusbar" invisible="user_type != 'hq'"
                               statusbar_visible="draft,wlm,whmp,wha,wfm,internal_aud,ccso,wd,wdp,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" name="get_payment"
                                    invisible="state != 'paid'"
                                    groups="account.group_account_user" string="Payment" type="object"
                                    icon="fa-list"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="user_type" invisible="1"/>
                                <field name="req_id" readonly="1"/>
                                <field name="department_id"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1" readonly="state != 'draft'"/>
                                <field name="company_id"
                                       required="1" readonly="state != 'draft'"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                />
                                <field name="origin_point"
                                       required="1" readonly="state != 'draft'"/>
                                <field name="prop_date"
                                       required="1" readonly="state != 'draft'"/>
                                <field name="number_of_days" readonly="state != 'draft'"/>
                                <field name="currency_id" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="comments"
                                       required="1" readonly="state != 'draft'"/>
                                <field name="date"
                                       required="1" readonly="state != 'draft'"/>
                                <field name="return_date"
                                       required="1" readonly="state != 'draft'"/>
                                <field name="expense_type"
                                       widget="radio" required="1" readonly="state != 'draft'"/>
                                <field name="trip_type" readonly="state != 'draft'"/>

                                <field name="journal_id"
                                       invisible="journal_id == False"
                                       groups="account.group_account_user"/>
                                <field name="journal_payment_id"
                                       domain="[('type','in',['bank','cash']),('company_id','=',company_id)]"
                                       invisible="journal_id == False" readonly="state == 'paid'"
                                       groups="account.group_account_user"/>

                            </group>
                        </group>
                        <notebook>
                            <page string="Employees">
                                <field name="employees_line_ids" readonly="state != 'draft'"
                                       required="1" nolabel="1">
                                    <list string="Employees" editable="bottom">
                                        <field name="employee_id" readonly="parent.department_id == False"
                                               domain="['|',('department_id.parent_id', '=',parent.department_id),'|',('department_id.parent_id.parent_id', '=',parent.department_id),('department_id', '=',parent.department_id),('company_id', '=',parent.company_id)]"
                                               options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                               required="1"/>
                                        <field name="analytic_account_id"
                                        column_invisible="parent.state in [('','in',['draft','wlm','whmp','wha'])]"/>
                                        <field name="b_account"
                                               readonly="1"
                                        column_invisible="parent.state in [('','in',['draft','wlm','whmp','wha'])]"/>
                                        <field name="job_id"/>
                                        <field name="number_of_days"/>
                                        <field name="number_of_night"/>
                                        <field name="Location"/>
                                        <field name="gross" groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site" invisible="parent.trip_type != 'internal'"/>
                                        <field name="per_diem"/>
                                        <field name="accommodation" invisible="parent.trip_type != 'external'"/>
                                        <field name="total"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                 <chatter/>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="res_config_settings_view_trip_form">
            <field name="name">res.config.settings.view.form.inherit.trip.overtime</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                    <div class="app_settings_block" data-string="hr_account" string="HR Accounts" data-key="hr_accounts"
                         groups="hr.group_hr_manager">
                        <h2>Employees Trip</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <span class="o_form_label">Trip Permission Account Configuration</span>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label string="Trip Permission Account" for="trip_bussiness_account_id"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="trip_bussiness_account_id"
                                               domain="[('company_ids','=', company_id)]"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="trip_permission_tree" model="ir.ui.view">
            <field name="name">Trip Permission Request</field>
            <field name="model">trip.permission</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="trip_permission_form_search" model="ir.ui.view">
            <field name="name">Trip Permission Request</field>
            <field name="model">trip.permission</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="trip_permission_action" model="ir.actions.act_window">
            <field name="name">Trip Permission Request</field>
            <field name="res_model">trip.permission</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem name="Trip Permission" id="trip_permission"
                  parent="base_rida.cus_menu_hr_root"
                  groups="hr.group_hr_user,base_rida.rida_group_line_manager"
                  action="hr_employee_main.trip_permission_action"/>

    </data>
</odoo>
