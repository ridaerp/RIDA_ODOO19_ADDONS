<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


       <record model="ir.ui.view" id="rotation_request_custom_form_custom1">
            <field name="name">request.rotation.form.inherit</field>
            <field name="model">rotation.batch</field>
            <field name="inherit_id" ref="hr_leave_main.rotation_request_custom_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='b_account']" position="after">
                    <field name="partner_id"
                           column_invisible="parent.state in ['draft', 'wlm', 'wha']"/>
                    <field name="account_payable"
                           column_invisible="parent.state in ['draft', 'wlm', 'wha']"/>
                    <field name="account_payable" column_invisible="1" />

                </xpath>
            </field>
        </record>


        <record model="ir.ui.view" id="view_employee_form_inherit_custom_emp_code">
            <field name="name">hr.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="before">
                    <group>
                        <group>
                            <field name="rida_employee_type"/>
                        </group>
                    </group>
                </xpath>

                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="allow_pasi"/>
                </xpath>
                <xpath expr="//field[@name='bank_account_ids']" position="replace">
                    <field name="bank_account_id"/>
                </xpath>                                                   
                <xpath expr="//field[@name='allow_pasi']" position="after">
                    <field name="location_id" string="City"
                           options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                           groups="hr.group_hr_user"/>
                    <field name="residence_area" options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                           groups="hr.group_hr_user"/>
                </xpath>
                <xpath expr="//field[@name='user_id']"
                       position="after">
                    <field name="is_susupend"/>
                    <field name="employee_partner_id" groups="hr.group_hr_user"/>
                    <field name="allowed_department_ids" widget="many2many_tags"/>
                </xpath>

                <xpath expr="//field[@name='department_id']" position="before">
                    <field name="arabic_name" placeholder="Arabic Name"/>
                    <field name="emp_code" groups="hr.group_hr_user"/>
                </xpath>
                <xpath expr="//field[@name='passport_id']" position="after">
                    <field name="passport_expiry_date" invisible="passport_id in  [None,False]"/>
                </xpath>
                <xpath expr="//field[@name='identification_id']" position="after">
                    <field name="id_expiry_date" invisible="identification_id in  [None,False]"/>
                </xpath>
                <xpath expr="//field[@name='parent_id']" position="replace">
                    <field name="parent_id"/>
                </xpath>
                <field name="birthday" position="after">
                    <field name="age"/>
                </field>

                <field name="birthday" position="replace">
                    <field name="birthday" groups="hr.group_hr_user"/>
                </field>


                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="domain">[]</attribute>
                </xpath>
                <xpath expr="//notebook" position="inside">

                    <page string="Dependents" groups="hr.group_hr_user">
                        <field name="relative_ids" nolabel="1"/>
                    </page>

                    <page string="Training History" groups="hr.group_hr_user">
                        <group col="1" colspan="1">
                            <field name="training_ids" nolabel="1"  colspan="2" class="o_full_width">
                                <list editable="top">
                                    <field name="name"/>
                                    <field name="provider"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="Certification"/>
                                    <field name="attachment"/>
                                </list>
                            </field>
                        </group>
                    </page>

                    <page string="Custody" groups="hr.group_hr_user">
                        <group col="1" colspan="1">
                            <field name="custody_id" nolabel="1" colspan="2" class="o_full_width">
                                <list editable="top">
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="state"/>
                                    <field name="clear_date"/>
                                </list>
                            </field>
                        </group>
                    </page>
                </xpath>
                <xpath expr="//field[@name='department_id']" position="replace">
                    <field name="dep" widget='radio' options="{'horizontal': true}"/>
                    <label for="department_id" string="Division" invisible="dep != 'division'"
                           style="font-weight:bold;"/>
                    <label for="department_id" string="Department" invisible="dep != 'department'"
                           style="font-weight:bold;"/>
                    <label for="department_id" string="Section" invisible="dep != 'section'"
                           style="font-weight:bold;"/>
                    <label for="department_id" string="Unit" invisible="dep != 'unit'"
                           style="font-weight:bold;"/>
                    <field name="department_id" nolabel="1"/>
                </xpath>

            </field>
        </record>

        <record id="hr_employee_relative_view_tree" model="ir.ui.view">
            <field name="name">hr.employee.relative.view.tree</field>
            <field name="model">hr.employee.relative</field>
            <field name="arch" type="xml">
                <list string="Employee Dependents" editable="bottom">
                    <field name="relation_id"/>
                    <field name="name"/>
                    <field name="gender"/>
                    <field name="date_of_birth"/>
                    <field name="age" readonly="1"/>
                    <field name="phone_number"/>
                    <field name="job"/>
                    <field name="notes"/>
                </list>
            </field>
        </record>

        <!-- Search View Filter By Emp_code -->
        <record id="view_employee_filter_inherit_emp_code" model="ir.ui.view">
            <field name="name">view.employee.filter.inherit</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field name="emp_code" filter_domain="[('emp_code','ilike',self)]"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
