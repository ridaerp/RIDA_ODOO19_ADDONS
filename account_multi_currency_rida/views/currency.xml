<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <record id="res_currency_custom" model="ir.ui.view">
            <field name="name">Res Currency Form</field>
            <field name="model">res.currency</field>
            <field name="inherit_id"
                   ref="base.view_currency_form"/>
            <field name="arch" type="xml">


                <xpath expr="//field[@name='currency_subunit_label']" position="after">
                    <field name="fixed_rate"/>
                    <field name="usd_rate" invisible="fixed_rate != True"/>
                </xpath>

               <!--  <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='rates']/field[@name='rate_ids']/tree[1]/field[@name='inverse_company_rate']"
                       position="after">
                    <field name="usd_rate"/>
                </xpath>
 -->
            </field>
        </record>

        <record id="account_move_custom" model="ir.ui.view">
            <field name="name">Account move</field>
            <field name="model">account.move</field>
            <field name="inherit_id"
                   ref="account.view_move_form"/>
            <field name="arch" type="xml">


                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='aml_tab']/field[@name='line_ids']/tree[1]/field[@name='amount_currency']"
                       position="after">
                    <field name="amount_in_usd" widget="monetary" options="{'currency_field': 'custom_currency_id'}" optional="hide"/>
                </xpath>
            </field>
        </record>


    </data>
</odoo>

