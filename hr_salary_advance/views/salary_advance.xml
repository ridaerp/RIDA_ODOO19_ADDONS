<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_salary_advance_form" model="ir.ui.view">
            <field name="name">salary.advance.form</field>
            <field name="model">salary.advance</field>
            <field name="arch" type="xml">
                <form string="Salary Advance">
                    <!-- HQ employee workflow-->
                    <header>
                        <!-- draft state buttons for hr officer-->
                        <button name="action_submit" string="Submit T" type="object" invisible="state != 'draft'" class="oe_highlight"
                                groups="hr.group_hr_user"/>
                        <button name="cancel" string="Cancel" type="object" invisible="state != 'draft'"
                                groups="hr_payroll.group_hr_payroll_user"/>
                        <!-- hr manager approval state buttons for hr manager-->
                        <button name="action_hr_manager" string="HR Manager Approve" type="object"  invisible="state != 'hr_manager'"
                                class="oe_highlight" groups="hr.group_hr_manager"/>
                        <!-- ccso approval buttons for ccso-->
                        <button name="action_ccso" string="COO Approve" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"
                                type="object"  invisible="state != ['ccso' , 'coo']" class="oe_highlight"/>
                        <button name="reject" string="Reject" type="object" invisible="state != 'hr_manager'"
                                groups="hr.group_hr_manager"/>
                        

                     <!--    <button name="action_c_level_approve" string="Approve" groups="base_rida.group_c_level"
                                type="object"  invisible="state != 'c_level'" class="oe_highlight"/>
                        <button name="reject" string="Reject" groups="base_rida.group_c_level" type="object"
                                invisible="state != 'c_level'"/> -->
                        <!-- finance payment  buttons for accountant-->
                        <button name="action_fainance" string="Paid" groups="account.group_account_user" type="object"
                                invisible="state != 'finance'" class="oe_highlight"/>
                        <button name="reject" string="Reject" groups="account.group_account_user" type="object"
                                invisible="state != 'finance'"/>
                        <!-- cancle and rejected state buttons for hr manager-->
                        <button name="set_draft" string="Set To Draft" type="object" invisible="state not in ['cancel', 'reject']"
                                groups="hr_payroll.group_hr_payroll_user"/>
                        <!--  statusbar field-->
                        <field name="state" widget="statusbar" statusbar_visible="draft,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box" groups="hr.group_hr_user,hr.group_hr_manager">
                            <button class="oe_stat_button" name="smart_count_of_last_salary" type="object"
                                    icon="fa-dollar">
                                <field name="last_salary"/>
                            </button>
                        </div>
                        <div class="oe_title oe_left">
                            <h2>
                                <field name="name" class="oe_inline" readonly="1"/>
                            </h2>
                        </div>
                        <group>
                            <group name="employee_info">
                                <field name="employee_id" readonly="state in ['approve', 'cancel', 'reject','paid']"/>
                                <field name="rida_employee_type" invisible="1"/>
                                <field name="department" readonly="state in ['approve', 'cancel', 'reject','paid']"/>
                                <field name="date" readonly="state in ['approve', 'cancel', 'reject','paid']"/>
                                <field name="reason" readonly="state in ['approve', 'cancel', 'reject','paid']"/>
                                <field name="exceed_condition" readonly="state in ['approve', 'cancel', 'reject','paid']"
                                       groups="hr.group_hr_manager,hr.group_hr_user"/>
                            </group>
                            <group name="adv_info">
                                <field name="advance" readonly="state in ['approve', 'cancel', 'reject','paid']"/>
                                <field name="currency_id" readonly="state in ['approve', 'cancel', 'reject','paid']"
                                       groups="base.group_multi_currency"/>
                                <field name="company_id" readonly="state in ['approve', 'cancel', 'reject','paid']"
                                        />
                                <field name="employee_contract_id" invisible="state == 'draft' or state == 'approve'"
                                       readonly="state in ['approve', 'cancel', 'reject','paid']"
                                       groups="hr.group_hr_manager,hr.group_hr_user"/>
                            </group>
                        </group>
                    </sheet>
                        <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="view_salary_advance_tree">
            <field name="name">salary.advance.tree</field>
            <field name="model">salary.advance</field>
            <field name="arch" type="xml">
                <tree string="Salary Advance">
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="advance"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_salary_advance_filter" model="ir.ui.view">
            <field name="name">salary.advance.select</field>
            <field name="model">salary.advance</field>
            <field name="arch" type="xml">
                <search string="Search">
                    <field name="name" string="Salary Advance" filter_domain="['|',('name','ilike',self)]"/>
                    <field name="employee_id"/>
                    <field name="employee_code"/>
                    <field name="state"/>
                    <filter string="My Requests" domain="[('employee_id.user_id.id','=',uid)]"
                            name="my_requests_filter"/>
                    <filter domain="[('state', '=', 'draft')]" string="To Submit" name="to_report" help="New Requests"/>
                    <filter domain="[('state','in',['hr_officer','hr_manager','ceo'])]" string="To Approve"
                            name="submitted" help="Submitted Requests"/>
                    <filter domain="[('state', '=', 'approve')]" string="Approved" name="approved"
                            help="Approved Requests"/>
                    <separator/>
                    <filter string="Employee" name="employee_id" domain="[]" context="{'group_by':'employee_id'}"/>
                    <filter name="State" string="State" domain="[]" context="{'group_by':'state'}"/>
                    <filter string="Date" domain="[]" name="date" context="{'group_by':'date'}"/>
                </search>
            </field>
        </record>

        <record id="action_my_salary_advance" model="ir.actions.act_window">
            <field name="name">Salary Advance</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">salary.advance</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_salary_advance_filter"/>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create Requests.
                </p>
            </field>
        </record>

        <record id="action_my_salary_advance_request_approved" model="ir.actions.act_window">
            <field name="name">Salary Advance</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">salary.advance</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_salary_advance_filter"/>
            <field name="context">{'search_default_approved':1}</field>
            <field name="domain">[('employee_id.user_id', '=', uid)]</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create Requests.
                </p>
            </field>
        </record>

        <record id="action_salary_advance_to_approve" model="ir.actions.act_window">
            <field name="name">Salary Advance</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">salary.advance</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_salary_advance_filter"/>
            <field name="context">{'search_default_submitted': 1}</field>
            <field name="domain"></field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create Requests.
                </p>
            </field>
        </record>

        <record id="ir_seq_hr_advance" model="ir.sequence">
            <field name="name">My Salary Advance</field>
            <field name="code">salary.advance.seq</field>
            <field name="prefix">SAR</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>


        <menuitem id="parent_menum_salary_advance" name="Salary Advance" parent="base_rida.cus_menu_hr_root"
                  sequence="21"/>
        <menuitem id="menu_my_salary_advance" action="action_my_salary_advance" parent="parent_menum_salary_advance"
                  name="Salary Advance Requests" sequence="1"/>
        <menuitem id="menu_salary_advance" action="action_salary_advance_to_approve"
                  parent="parent_menum_salary_advance" name="Salary Advance To Approve" sequence="3"
                  groups="hr.group_hr_manager,hr.group_hr_user"/>
        <menuitem id="menu_my_salary_advance_approved" action="action_my_salary_advance_request_approved"
                  parent="parent_menum_salary_advance" name="My Salary Advance" sequence="2"/>
    </data>

