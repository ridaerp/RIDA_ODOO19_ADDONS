<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--        Hot Permit      -->
        <record id="hot_work_permit_department_rule" model="ir.rule">
            <field name="name">Hot Work Permit:User Request</field>
            <field name="model_id" ref="model_hot_work_permit"/>
            <field name="domain_force">['|', ('create_uid', '=', user.id), ('department_id', 'child_of', [d.id for d in user.employee_ids.department_id])]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="hot_work_permit_safety_officer_rule" model="ir.rule">
            <field name="name">Hot Work Permit: Full Access for Safety Officers</field>
            <field name="model_id" ref="model_hot_work_permit"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base_rida.rida_group_safety_officer')), (4, ref('base_rida.rida_group_senior_officer'))]"/>
        </record>

