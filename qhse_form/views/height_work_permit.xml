<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_work_height_permit_list" model="ir.ui.view">
        <field name="name">work.height.permit.list</field>
        <field name="model">work.height.permit</field>
        <field name="arch" type="xml">
            <list string="Work at Height Permits" decoration-info="state == 'draft'" decoration-success="state == 'issued'">
                <field name="name"/>
                <field name="date"/>
                <field name="work_at_height_type"/>
                <field name="work_site"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_work_height_permit_form" model="ir.ui.view">
        <field name="name">work.height.permit.form</field>
        <field name="model">work.height.permit</field>
        <field name="arch" type="xml">
            <form string="Work at Height Permit">
                <header>
                    <button name="action_submit" type="object" string="إرسال / Submit" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_dept_approve" string="اعتماد القسم المعني" type="object" 
                                invisible="state != 'dept_approval'" class="oe_highlight" 
                                groups="base_rida.rida_group_line_manager"/>
                    <button name="action_authorize" type="object" string="مصادقة / Authorize" class="oe_highlight" invisible="state != 'submitted'"
                            groups="base_rida.rida_group_safety_officer"/>
                    <button name="action_extend" string="تمديد / Extend" type="object"
                            groups="base_rida.rida_group_safety_officer"
                            invisible="state != 'pending_extension'"/>
                    <button name="action_request_extension" string="طلب تمديد" type="object" invisible="state != 'issued'"/>
                    <button name="action_request_close" string="طلب إغلاق" type="object" invisible="state not in ['issued','extended']"/>
                    <button name="action_suspend" type="object" string="تجميد / Suspension" class="btn-primary"
                            groups="base_rida.rida_group_safety_officer" invisible="state not in ['issued','extended']"/>
                    <button name="action_revoked" type="object" string="ملغى / Revoked" class="btn-danger"
                            groups="base_rida.rida_group_safety_officer" invisible="state not in ['issued','extended']" />
                    <button name="action_close" string="إغلاق / Close" type="object"
                            groups="base_rida.rida_group_safety_officer"
                            invisible="state not in ['pending_close']"/>
                    <button name="action_done" string="تم / Done" type="object"
                            invisible="state not in ['reject']"/>
                    <button name="%(maintenance_fleet_inherit.rejection_wizard_reject_action)d" string="Reject"
                            invisible="state not in ['submitted']"
                            groups="base_rida.rida_group_safety_officer"
                            type="action"/>
                    <button name="action_reactivate"
                        string="إعادة تنشيط / Reactivate"
                        type="object"
                        class="oe_highlight"
                        invisible="state not in ['suspend', 'revoked']"/>
                    <button name="action_create_related_ptw"
                        string="إنشاء التصريح المرتبط"
                        type="object"
                        invisible="is_need_ptw == False or linked_ptw_count > 0"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,dept_approval,submitted,issued,revoked,suspend,closed"/>
                </header>
                <sheet>
                    <div class="oe_title text-center" style="background-color: #77309D; color: white; padding: 15px; margin-top: 10px; border-radius: 5px;">
                            <h1 style="color: #ffffff; margin-bottom: 0;">Work at Height Permit / تصريح العمل في المرتفعات</h1>
                            
                        <div style="background-color: #77309D; color: white; padding: 15px; margin-top: 10px; border-radius: 5px;">
                            <p style="margin: 0; font-size: 1.2rem; line-height: 1.6; direction: rtl;">
 يُستخدم عند تنفيذ أعمال غير روتينية على ارتفاع يزيد عن 3 أمتار، حيث يكون هناك خطر السقوط ويستلزم اتخاذ إجراءات حماية خاصة. 
                            </p>
                        </div>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_linked_ptw"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-external-link"
                                invisible="linked_ptw_count == 0">
                            <field name="linked_ptw_count" widget="statinfo" string="Related PTW"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group string="Part #01: General Information">
                        <group>
                            <field name="date"/>
                            <field name="work_site" options="{'no_create': True, 'no_create_edit': True}" required="True"/>
                            <field name="work_at_height_type" widget="radio" options="{'horizontal': true}" required="True"/>
                            <field name="department_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="date_from" required="True"/>
                            <field name="date_to" required="True"/>
                            <field name="number_of_workers" required="True"/>
                        </group>
                        <group>
                            <field name="is_need_ptw" invisible="state != 'draft'"/>
                            <field name="type_of_ptw" required="is_need_ptw == True" invisible="state != 'draft' or is_need_ptw == False"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Hazards &amp; Precautions">
                            <separator string="Working at Height Hazards / المخاطر المرتبطة بالعمل في المرتفعات" class="mt32"/>
                            <group col="3">
                                <group>
                                    <field name="hazard_fall_height" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_flying_particles" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_moving_vehicles" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_height_other" placeholder="أخرى..."/>
                                </group>
                                <group>
                                    <field name="hazard_falling_objects_height" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_trip_slip" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_damaged_equipment" widget="radio" options="{'horizontal': true}" required="True"/>
                                </group>
                                <group>
                                    <field name="hazard_fragile_surfaces" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_overhead_power" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_mobile_scaffold" widget="radio" options="{'horizontal': true}" required="True"/>
                                </group>
                                <group>
                                    <field name="hazard_working_below" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_energized_equipment" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="hazard_weather_conditions" widget="radio" options="{'horizontal': true}" required="True"/>
                                </group>
                            </group>
                        </page>
                        <page string="Required Precautions">
                            <separator string="Required Precautions / الاحتياطات المطلوبة (02ب)" class="mt32"/>
                            <group>
                                <group string="التخطيط والحماية / Planning &amp; Protection">
                                    <field name="prec_height_ms_jsa" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prec_height_fall_measures" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prec_height_inspection" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prec_height_access_egress" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prec_height_floor_openings" widget="radio" options="{'horizontal': true}" required="True"/>
                                </group>
                                <group string="الموقع والفريق / Site &amp; Personnel">
                                    <field name="prec_height_wind_speed" widget="radio" options="{'horizontal': true}" class="oe_edit_only"/>
                                    <div class="alert alert-danger" invisible="prec_height_wind_speed != 'yes'" role="alert" style="margin-bottom:10px;">
                                        ⚠️ <b>تحذير:</b> إذا كانت سرعة الرياح تتجاوز 32 كم/ساعة، يجب إيقاف العمل فوراً!
                                    </div>
                                    <field name="prec_height_scaffold_inspected" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prec_height_loto_required" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prec_height_barriers" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prec_height_team_qualified" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prec_height_scope_communicated" widget="radio" options="{'horizontal': true}" required="True"/>
                                </group>
                            </group>
                            <group string="إجراءات إضافية">
                                <field name="prec_height_additional_ctrl" placeholder="اكتب أي إجراءات تحكم إضافية هنا..."/>
                            </group>
                        </page>
                        <page string="Inspection &amp; Preparation">
                            <separator string="Inspection &amp; Preparation / الفحص والتحضير (02ج)" class="mt32"/>
                            <group col="3">
                                <group string="Equipment Preparation / تحضير المعدات">
                                    <field name="prep_warning_signs" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_lighting" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_safety_barriers" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_fall_protection_net" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_fall_arrester" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_safety_harness_hooks" widget="radio" options="{'horizontal': true}" required="True"/>
                                </group>

                                <group string="Communication / الاتصال">
                                    <field name="prep_jsa_planning" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_personnel_training" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_pre_task_meeting" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_method_review" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_comm_method" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_emergency_plan" widget="radio" options="{'horizontal': true}" required="True"/>
                                </group>

                                <group string="PPE Preparation / تحضير الوقاية الشخصية">
                                    <field name="prep_helmet_chinstrap" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_non_slip_shoes" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_hi_vis_vest" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_safety_goggles" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_dust_masks" widget="radio" options="{'horizontal': true}" required="True"/>
                                    <field name="prep_ear_protection" widget="radio" options="{'horizontal': true}" required="True"/>
                                </group>
                            </group>
                        </page>
                        <page string="Task Description">
                            <field name="task_description" placeholder="Describe the task..." required="True"/>
                        </page>
                    </notebook>
                    <notebook>
                        <page string="الاعتماد والتوقيعات / Authorization" name="authorization">
                            <div class="alert alert-info" role="alert" style="margin-bottom: 20px;">
                                <field name="worker_statement" readonly="1" nolabel="1"/>
                            </div>
                            <group>
                                <group>
                                    <field name="worker_id" options="{'no_create': True}" required="True"/>
                                    <field name="worker_signature" widget="signature"/>
                                    <field name="worker_date" required="True"/>
                                </group>
                            </group>

                            <hr/>

                            <div class="alert alert-warning" role="alert" style="margin-bottom: 20px;">
                                <field name="authorizer_statement" readonly="1" nolabel="1"/>
                            </div>
                            <group col="3">
                                <group string="الأطراف المعنية 1">
                                    <field name="concerned_party_1_id"/>
                                    <field name="concerned_party_1_signature" widget="signature"/>
                                    <field name="concerned_party_1_date"/>
                                </group>
                                <group string="الأطراف المعنية 2">
                                    <field name="concerned_party_2_id"/>
                                    <field name="concerned_party_2_signature" widget="signature"/>
                                    <field name="concerned_party_2_date"/>
                                </group>
                                <group string="المُصرِّح (مهندس/مشرف)">
                                    <field name="authorizer_id" required="state == 'submitted'"/>
                                    <field name="authorizer_signature" widget="signature"/>
                                    <field name="authorizer_date"/>
                                </group>
                            </group>

                            <hr/>

                            <div class="alert alert-success" role="alert" style="margin-bottom: 20px;">
                                <field name="issuer_statement" readonly="1" nolabel="1"/>
                            </div>
                            <group>
                                <group>
                                    <field name="issuer_id" required="state == 'authorized'"/>
                                    <field name="issuer_signature" widget="signature"/>
                                    <field name="issuer_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="التمديد والمصادقة / Extension &amp; Authentication">
                            <group string="بيانات التمديد / Extension" invisible="state != 'extended' and extension_date_from == False">
                                <group>
                                    <field name="extension_date_from"/>
                                </group>
                                <group>
                                    <field name="extension_date_to"/>
                                </group>
                            </group>
                            <group string="الاعتمادات / Approvals">
                                <field name="supervisor_id" options="{'no_create': True}" required="True"/>
                                <field name="authorizer_id" options="{'no_create': True}" required="True"/>
                                <field name="issuer_id" options="{'no_create': True}"/>
                            </group>
                        </page>
                    </notebook>
                    <group>
                        <field name="closure_date" readonly="1"/>
                    </group>
                    <group>
                        <group string="تفاصيل الإجراءات">
                            <field name="extension_reason" required="state == 'pending_extension'" invisible="state not in ['pending_extension', 'extended']"/>
                            <field name="closing_reason" invisible="state not in ['pending_close', 'closed']"/>
                            <field name="reason_reject" invisible="state != 'reject'"/>
                        </group>
                    </group>
                    <group string="الموافقة والتعهد / Confirmation" class="mt-3">
                        <field name="confirmation_check" widget="boolean_toggle"
                               string="أقر بأن جميع البيانات صحيحة وموافق على كافة إرشادات السلامة / I confirm that all information is correct and I agree to all safety instructions"/>
                    </group>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>


    <record id="action_work_height_permit" model="ir.actions.act_window">
        <field name="name">Work at Height / العمل على الارتفاع</field>
        <field name="res_model">work.height.permit</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_work_height_permit"
              name="Work at Height / الارتفاعات"
              parent="menu_safety_root_dual"
              action="action_work_height_permit"
              sequence="6"/>
</odoo>