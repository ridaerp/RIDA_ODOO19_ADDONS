<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ppe_replacement_form" model="ir.ui.view">
        <field name="name">ppe.replacement.form</field>
        <field name="model">ppe.replacement</field>
        <field name="arch" type="xml">
            <form string="PPE Replacement Document">
                <header>
                    <button name="action_ln" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_officer" string="Send to Safety Officer" type="object" class="oe_highlight" invisible="state != 'wlm_approve'"/>

                    <button name="action_manager" string="Confirm" type="object" class="oe_highlight"
                            groups="base_rida.rida_group_safety_officer,base_rida.rida_group_senior_officer" invisible="state != 'officer'"/>

                    <button name="action_done" string="Approve" type="object" class="oe_highlight"
                            groups="base_rida.rida_group_qhse_manager" invisible="state != 'manager'"/>

                    <button name="%(maintenance_fleet_inherit.rejection_wizard_reject_action)d" string="Reject"
                            invisible="state in ['draft', 'done']"
                            groups="base_rida.rida_group_safety_officer,base_rida.rida_group_qhse_manager,base_rida.rida_group_senior_officer" type="action"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,officer,manager,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_receipts" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="receipt_count == 0">
                            <field name="receipt_count" string="Receipts" widget="statinfo"/>
                        </button>

                        <button name="action_view_deductions" type="object" class="oe_stat_button" icon="fa-money" invisible="deduction_count == 0">
                            <field name="deduction_count" string="Deduction" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="text-center" style="margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <h2 style="color: #714B67;">
                            <field name="doc_no" readonly="1"/>
                        </h2>
                        <div class="text-muted">PPE Replacement Document (For Individuals)</div>
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Sequence Number"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group string="Employee &amp; Supervisor Information">
                        <group>
                            <field name="requester_id"/>
                            <field name="department_id" required="1" options="{'no_create': True}"/>
                        </group>
                        <group>
                        <field name="line_supervisor_id" options="{'no_create': True}" readonly="state != 'draft'" force_save="1"/>
                            <field name="position_id"/>
                            <field name="date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Damaged PPE Details" name="damaged_details">
                            <field name="ppe_line_ids" readonly="state == 'done'">
                                <list editable="bottom">
                                    <field name="employee_id" options="{'no_create': True}" optional="show" domain="[('department_id', 'child_of', parent.department_id), ('company_id', '=', parent.company_id)]"/>
                                    <field name="ppe_type" options="{'no_create': True}" domain="[('categ_id', 'child_of', 'QHSE / PPE')]"/>
                                    <field name="brand_sn" readonly="1" force_save="1"/>
                                    
                                    <field name="qty_hand" string="Stock" readonly="1" force_save="1" groups="base_rida.rida_group_safety_officer"/>
                                    
                                    <field name="last_data" string="Last Issued" readonly="1" force_save="1"/>
                                    
                                    <field name="quantity" string="Req. Qty" readonly="parent.state != 'draft'"/>
        
                                    <field name="qty_approved" string="Appr. Qty" 
                                           column_invisible="parent.state == 'draft'"
                                           required="parent.state != 'draft'"/>
                                </list>
                            </field>
                            <group string="Reasons &amp; Justification" col="2">
                                <field name="justification" colspan="2" required='True' placeholder="Explain why the replacement is needed..."/>
                            </group>
                        </page>

                        <page string="Safety Officer Review" invisible="state == 'draft'">
                            <group col="2">
                                <group string="Officer Data">
                                    <field name="responsible_safety_officer_id" readonly="1" force_save="1"/>
                                    <field name="damage_reason" widget="radio" options="{'horizontal': true}"/>
                                    <field name="other" invisible="damage_reason != 'other'"/>
                                </group>
                                <group string="Assessment">
                                    <field name="damage_percentage" widget="progressbar" options="{'current_value': 'damage_percentage', 'max_value': 100, 'editable': True}"/>
                                </group>

                                <separator string="Impact &amp; Recommendation" colspan="2"/>
                                <field name="safety_effect" colspan="2" placeholder="Effect of damaged PPE to employee safety..."/>
                                <field name="recommendation" colspan="2" placeholder="Officer recommendation..."/>
                            </group>
                        </page>

                        <page string="Manager Approval" invisible="state not in ['manager', 'done']">
                            <group col="2">
                                <group string="Approval Details">
                                    <field name="qhse_manager_approval" readonly="1" force_save="1"/>
                                    <field name="date_approval" readonly="1" force_save="1"/>
                                </group>
                                <field name="qhse_comment" colspan="2" placeholder="Manager final comments..."/>
                            </group>
                        </page>
                    </notebook>

                    <group invisible="not reason_reject">
                        <field name="reason_reject" readonly="1" decoration-danger="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ppe_replacement_tree" model="ir.ui.view">
       <field name="name">ppe.replacement.list</field>
        <field name="model">ppe.replacement</field>
        <field name="arch" type="xml">
            <list string="PPE Replacements">
                <field name="name"/>
                <field name="requester_id"/>
                <field name="date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state in ['officer', 'manager']" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="action_ppe_replacement" model="ir.actions.act_window">
        <field name="name">PPE Replacements</field>
        <field name="res_model">ppe.replacement</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ppe_replacement" name="Replacement Requests" parent="menu_ppe_root" action="action_ppe_replacement" sequence="2"/>
</odoo>