<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_work_site_list" model="ir.ui.view">
            <field name="name">cwork.site.list</field>
            <field name="model">work.site</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_work_site_form" model="ir.ui.view">
            <field name="name">work.site.form</field>
            <field name="model">work.site</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="name" required="True"/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_work_site" model="ir.actions.act_window">
            <field name="name">Work Site</field>
            <field name="res_model">work.site</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>

    <menuitem id="menu_work_site"
          name="Work Site" groups="base_rida.rida_group_qhse_manager"
          parent="qhse.qhse_conf_menu"
          action="action_work_site"
          sequence="2"/>
</odoo>