<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ppe_medical_list" model="ir.ui.view">
        <field name="name">ppe.medical.list</field>
        <field name="model">ppe.medical</field>
        <field name="arch" type="xml">
            <list string="PPE Medical Cases">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="emp_code"/>
                <field name="date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('line_supervisor', 'senior_health')"
                       decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_ppe_medical_form" model="ir.ui.view">
        <field name="name">ppe.medical.form</field>
        <field name="model">ppe.medical</field>
        <field name="arch" type="xml">
            <form string="PPE Medical Case">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            invisible="state != 'draft'" class="oe_highlight"/>

                    <button name="action_approve_supervisor" string="Approve" type="object"
                            groups="base_rida.rida_group_line_manager" invisible="state != 'line_supervisor'" class="oe_highlight"/>

                    <button name="action_approve_health" string="Approve" type="object"
                            groups="medicare.group_medicare_doctor" invisible="state != 'senior_health'" class="oe_highlight"/>

                    <button name="action_approve_safety" string="Approve" type="object"
                            groups="base_rida.rida_group_senior_officer" invisible="state != 'senior_safety'" class="oe_highlight"/>

                    <button name="action_approve_manager" string="Approve" type="object"
                            groups="base_rida.rida_group_qhse_manager" invisible="state != 'manager'" class="oe_highlight"/>

                    <button name="action_complete_hr" string="HR Action" type="object"
                            groups="base_rida.rida_hr_manager_notify" invisible="state != 'hr_action'" class="oe_highlight"/>
                    <button name="%(maintenance_fleet_inherit.rejection_wizard_reject_action)d" string="Reject"
                            invisible="state in ['draft', 'done']"
                            groups="base_rida.rida_group_qhse_manager,base_rida.rida_group_senior_officer" type="action"/>
                    <button name="action_create_product_request"
                            string="Create Product Request"
                            type="object"
                            class="oe_highlight"
                            invisible="final_decision != 'new_ppe' or product_request_count &gt; 0 or state != 'done'"/>
                    <button name="action_create_mr_from_medical"
                            string="Create Material Request"
                            type="object"
                            class="oe_highlight"
                            invisible="not is_product_done or state != 'done' or mr_count &gt; 0"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,line_supervisor,senior_health,senior_safety,manager,hr_action,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_product_requests"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible="product_request_count == 0">
                            <field name="product_request_count" widget="statinfo" string="Product Requests"/>
                        </button>

                        <button name="action_view_mrs"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list"
                                invisible="mr_count == 0">
                            <field name="mr_count" widget="statinfo" string="Material Requests"/>
                        </button>
                    </div>
                    <div class="text-center" style="margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <h2 style="color: #714B67;">
                            <field name="doc_no" readonly="1"/>
                        </h2>
                        <div class="text-muted">PPE for Medical Case Form</div>
                        <p style="margin: 0; font-size: 1.2rem; line-height: 1.6; direction: rtl;">
 يُستخدم لطلب معدات وقاية شخصية بديلة أو مخصصة لأسباب طبية، بناءً على تقرير طبي يوضح الحالة ومتطلبات المعدة المناسبة. 
                        </p>
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Sequence Number"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Employee Information">
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="emp_code"/>
                            <field name="job_id"/>
                            <field name="emp_department_id"/>
                        </group>
                        <group string="Request Details">
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="requester_id" readonly="1"/>
                            <field name="line_supervisor_id" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Case Details" name="case_details">
                            <group>
                                <field name="affected_body_part"/>
                                <field name="concerned_ppe"/>
                                <field name="job_nature"/>
                            </group>
                        </page>

                        <page string="Medical &amp; Safety Evaluation" name="evaluation">
                            <group>
                                <group string="Authorized Physician Section">
                                    <field name="diagnoses_results"/>
                                    <field name="medical_condition"/>
                                    <field name="current_ppe_effect"/>
                                    <field name="physician_recommendation"/>
                                    <!-- <field name="physician_signature_date"/> -->
                                </group>
                                <group string="QHSE Evaluation">
                                    <field name="new_ppe_safety_eval"/>
                                    <field name="risk_rating_new_ppe"/>
                                    <field name="final_decision"/>
                                </group>
                            </group>
                        </page>

                        <page string="Approvals / Signatures" name="approvals">
                            <group>
                                <group string="Internal Approvals">
                                    <field name="line_supervisor_user_id"/>
                                    <field name="senior_health_user_id"/>
                                    <field name="senior_safety_user_id"/>
                                </group>
                                <group string="Post-Approval Actions">
                                    <field name="update_risk_register"/>
                                    <field name="update_jsa"/>
                                    <field name="training_staff"/>
                                </group>
                                <group string="Final Management">
                                    <field name="manager_user_id"/>
                                    <field name="hr_action_user_id"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ppe_medical" model="ir.actions.act_window">
        <field name="name">PPE Medical Case</field>
        <field name="res_model">ppe.medical</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first PPE Deduction request!
            </p>
        </field>
    </record>

    <menuitem id="menu_ppe_medical" name="PPE Medical Cases"
              parent="menu_ppe_root" action="action_ppe_medical" sequence="4"/>

</odoo>