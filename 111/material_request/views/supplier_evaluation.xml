<odoo>
    <data>


        <record id="view_supplier_performance_form" model="ir.ui.view">
            <field name="name">supplier.performance.evaluation.form</field>
            <field name="model">supplier.performance.evaluation</field>
            <field name="arch" type="xml">
                <form string="Supplier Performance Evaluation">
                    <header>
                        <button string="Submit" name="set_submit" type="object"  invisible="state != 'draft'"
                                class="oe_highlight" groups="material_request.group_buyers"/>
                        <button string="Confirm" name="set_confirm" type="object" invisible="state != 'w_proc_manager'"
                                class="oe_highlight" groups="base_rida.rida_group_supply_chain_manager"/>
                        <button string="Approve" name="set_approve" type="object" invisible="state != 'w_scm_director'"
                                class="oe_highlight" groups="base_rida.rida_group_supply_chain_director"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,w_proc_manager,w_scm_director,approved"/>
                        <button string="Set to Draft" name="action_draft"
                                groups="base_rida.rida_group_supply_chain_manager,base_rida.rida_group_supply_chain_director"
                                type="object" invisible="state != 'reject'"   />
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                              invisible="state not in ['w_proc_manager','w_scm_director']" string="Reject"
                                groups="base_rida.rida_group_supply_chain_manager,base_rida.rida_group_supply_chain_director"
                        />
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_purchase_orders"
                                    type="object" class="oe_stat_button" icon="fa-list-alt">
                                <field name="po_count" string="Purchase Orders" widget="statinfo"/>
                            </button>
                            <button name="action_view_contract"
                                    type="object" class="oe_stat_button" icon="fa-list-alt">
                                <field name="contract_count" string="Purchase Contracts" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="vendor_name" readonly="state != 'draft'"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                                <field name="rating" readonly="1"  style="font-weight: bold;color: green;"/>
                                <field name="approve_date"/>
                            </group>
                            <group>
                                <field name="quarter" readonly="state != 'draft'"/>
                                <label for="date_from" string="Evaluation Period"/>
                                <div>
                                    <field name="date_from" invisible="1"/>
                                    <field name="date_to" invisible="1"/>
                                    <div class="o_row o_row_readonly o_hr_holidays_dates">
                                        <span class="oe_inline">
                                            From
                                        </span>
                                        <field name="date_from" readonly="state != 'draft'"
                                               required="1" class="oe_inline" nolabel="1"/>
                                        <span class="oe_inline">
                                            To
                                        </span>
                                        <field name="date_to" readonly="state != 'draft'"
                                               required="1" class="oe_inline"/>
                                    </div>
                                </div>
                                <field name="req_id" readonly="1"/>
                                <field name="approve_by"/>
                            </group>
                        </group>
                        <h3>Supplier Performance Evaluation</h3>
                        <field name="sup_lines_ids"
                               nolabel="1" readonly="state != 'draft'">
                            <list editable="bottom" create="false" delete="false" decoration-success="is_colored"
                                  decoration-bf="is_colored">
                                <field name="evaluation_category" widget="html" readonly="1"/>
                                <field name="evaluation_sub_category" widget="html" readonly="1"/>
                                <field name="sup_weight" sum="Sum of Weight" readonly="1"
                                 invisible="display_type != 'line_section'"/>
                                <field name="sup_rating"
                                       invisible="display_type != 'line_section'"/>
                                <field name="sup_score" sum="TOTAL WEIGHTED SCORE"
                                       style="font-weight: bold;color: green;"
                                       invisible="display_type != 'line_section'"/>
                                <field name="display_type" invisible="1"/>
                                <field name="is_colored" invisible="1"/>
                            </list>
                        </field>
                        <group>
                            <group>
                                <table border="1" style="text-align:center">
                                    <tr style="background-color: #f2f2f2;">
                                        <th>
                                            <p>RATING</p>
                                        </th>
                                        <th>
                                            <p>RATING LABEL</p>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th>
                                            <p>5</p>
                                        </th>
                                        <th>
                                            <h4>Excellent</h4>
                                        </th>
                                    </tr>

                                    <tr>
                                        <th>
                                            <p>4</p>
                                        </th>
                                        <th>
                                            <h4>Good</h4>
                                        </th>
                                    </tr>

                                    <tr>
                                        <th>
                                            <p>3</p>
                                        </th>
                                        <th>
                                            <h4>Satisfactory</h4>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th>
                                            <p>2</p>
                                        </th>
                                        <th>
                                            <h4>Fair</h4>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th>
                                            <p>1</p>
                                        </th>
                                        <th>
                                            <h4>Poor</h4>
                                        </th>
                                    </tr>
                                    <tr>

                                    </tr>
                                </table>
                                <table border="1" style="text-align:center">
                                    <tr style="background-color: #f2f2f2;">
                                        <th>
                                            <p>Evaluation Result</p>
                                        </th>
                                        <th>
                                            <p>Performance Status</p>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th>
                                            <p>Less Than 50 %</p>
                                        </th>
                                        <th>
                                            <h4>Disqualified</h4>
                                        </th>
                                    </tr>

                                    <tr>
                                        <th>
                                            <p>Between 50%-60%</p>
                                        </th>
                                        <th>
                                            <h4>Improvement Needed</h4>
                                        </th>
                                    </tr>

                                    <tr>
                                        <th>
                                            <p>Greater Than 60%</p>
                                        </th>
                                        <th>
                                            <h4>Meet Expectations</h4>
                                        </th>
                                    </tr>
                                </table>

                            </group>
                        </group>

                        <group string="COMMENTS">
                            <field name="overall_eval_comment" readonly="state == 'approved'" />
                            <br/>
                            <field name="recommendation" readonly="state == 'approved'"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_supplier_performance_tree" model="ir.ui.view">
            <field name="name">supplier.performance.evaluation.tree</field>
            <field name="model">supplier.performance.evaluation</field>
            <field name="arch" type="xml">
                <list string="Supplier Performance Evaluation">
                    <field name="name"/>
                    <field name="vendor_name"/>
                    <field name="rating"/>
                    <field name="req_id"/>
                    <field name="create_date"/>
                    <field name="approve_by"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="vendor_supplier_performance_form_search" model="ir.ui.view">
            <field name="name">Supplier Performance Evaluations Search</field>
            <field name="model">supplier.performance.evaluation</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="vendor_name"/>
                </search>
            </field>
        </record>

        <record id="action_supplier_performance" model="ir.actions.act_window">
            <field name="name">Supplier Performance Evaluations</field>
            <field name="res_model">supplier.performance.evaluation</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem name="Evaluations" id="menu_evaluations_root"
                  parent="purchase.menu_purchase_root"
                  groups="material_request.group_buyers" sequence="2"
        />
        <menuitem name="Supplier Performance Evaluations" id="menu_supplier_performance"
                  action="action_supplier_performance" sequence="2"
                  parent="menu_evaluations_root"
                  groups="material_request.group_buyers"
        />
    </data>
</odoo>
