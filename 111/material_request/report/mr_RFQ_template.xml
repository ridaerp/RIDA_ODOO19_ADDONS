<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--- the blew chde added by ekhlas code-->
<template id="report_quotation_inherit" inherit_id="purchase.report_purchasequotation_document">


<xpath expr="//t[@t-call='web.external_layout']" position="replace">

    <t t-call="web.external_layout">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-set="address">
            <div t-field="o.partner_id"
            t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
            <p t-if="o.partner_id.vat"><t t-esc="o.company_id.country_id.vat_label or 'Tax ID'"/>: <span t-field="o.partner_id.vat"/></p>
        </t>
        <t t-if="o.dest_address_id">
            <t t-set="information_block">
                <strong>Shipping address:</strong>
                <div t-field="o.dest_address_id"
                    t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}' name="purchase_shipping_address"/>
            </t>
        </t>
        <div class="page">
            <div class="oe_structure"/>

          <br/>
              <h2 t-if="o.request_id" > Material Requisition: <span t-field="o.request_id"/>
          </h2>
          <h3 t-if="o.name" > Request for Quotation <span t-field="o.name"/>
          </h3>

           <h4 t-if="o.eq_fleet" > Machine Data:<h4/>
          </h4>

            <table class="table table-sm">
                <thead style="display: table-row-group" t-if="o.request_id.user_type=='fleet'">
                    <tr>
                     
                        <th t-if="o.eq_fleet" name="th_quantity" ><strong>Equiment</strong></th>
                        <th t-if="o.code" name="th_partner_numner" ><strong>Code</strong></th>
                        <th t-if="o.brand" name="th_partner_numner" ><strong>Brand</strong></th>
                        <th t-if="o.year" name="th_partner_numner" ><strong>Year</strong></th>
                        <th t-if="o.plate" name="th_partner_numner" ><strong>Plate</strong></th>
                        <th   t-if="o.category" name="th_partner_numner" ><strong>Category</strong></th>
                        <th t-if="o.vin" name="th_partner_numner" ><strong>Vin#</strong></th>
                        <th  t-if="o.engine" name="th_partner_numner" ><strong>Engine</strong></th>
                        <th t-if="o.engine_serial" name="th_partner_numner" ><strong>Engine Serial</strong></th>
                    </tr>
                </thead>

                 <tbody>
                        <tr t-att-class="'bg-200 font-weight-bold o_line_section'" >
                              <td t-if="o.eq_fleet"> 
                                    <span t-field="o.eq_fleet.name"/>
                                </td>
                                 <td t-if="o.code"> 
                                    <span t-field="o.code"/>
                                </td>
                                 <td t-if="o.brand"> 
                                    <span t-field="o.brand"/>
                                </td>
                                 <td t-if="o.year"> 
                                    <span t-field="o.year"/>
                                </td>
                                 <td t-if="o.plate"> 
                                    <span t-field="o.plate"/>
                                </td>
                                 <td t-if="o.category"> 
                                    <span t-field="o.category"/>
                                </td>
                                 <td t-if="o.vin"> 
                                    <span t-field="o.vin"/>
                                </td>
                                 <td t-if="o.engine"> 
                                    <span t-field="o.engine"/>
                                </td>
                                 <td t-if="o.engine_serial"> 
                                    <span t-field="o.engine_serial"/>
                                </td>

                       </tr>
                </tbody>
            </table>

            
          <br/>

            <!-- <h2>Request for Quotation <span t-field="o.name"/></h2> -->

            <table class="table table-sm">
                <thead style="display: table-row-group">
                    <tr>
                        <th name="th_description"><strong>Description</strong></th>
                       <!--  <th name="th_expected_date" class="text-center"><strong>Expected Date</strong></th> -->

                        

                        <th name="th_quantity" ><strong>Qty</strong></th>
                        <th name="th_partner_numner" ><strong>Part Number</strong></th>
                        <th name="th_partner_numner" ><strong>Brand</strong></th>
                        <th name="th_partner_numner" ><strong>Model</strong></th>





                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="o.order_line" t-as="order_line">
                        <tr t-att-class="'bg-200 font-weight-bold o_line_section' if order_line.display_type == 'line_section' else 'font-italic o_line_note' if order_line.display_type == 'line_note' else ''">
                            <t t-if="not order_line.display_type">
                                <td id="product"> 
                                    <span t-field="order_line.name"/>
                                </td>
                                <!-- <td class="text-center">
                                    <span t-field="order_line.date_planned"/>
                                </td> -->

          
                                <td>
                                    <span t-field="order_line.product_qty"/>
                                    <span t-field="order_line.product_uom" groups="uom.group_uom"/>
                                </td>

                                  <td>
                                          <span  t-field="order_line.product_id.part_number"/>
                                      </td>


                                  <td class="text-center">
                <span t-field="order_line.product_id.categ_id.name"/>
            </td>
            <td class="text-center">
                <span t-field="order_line.product_id.model"/>
            </td>



            



                            </t>
                            <t t-else="">
                                <td colspan="99" id="section">
                                    <span t-field="order_line.name"/>
                                </td>
                            </t>
                        </tr>
                    </t>
                </tbody>
            </table>

            <p t-field="o.notes"/>

            <div class="oe_structure"/>
        </div>
</t>
</xpath>
</template>




    <record id="action_report_purchase_requisitions1" model="ir.actions.report">
        <field name="name">Contract</field>
        <field name="model">purchase.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">material_request.report_purchasecontracts</field>
        <field name="report_file">material_request.report.report_purchasecontracts</field>
        <field name="print_report_name">'Tender - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_purchase_contract"/>
        <field name="binding_type">report</field>
    </record>



<!-- add partnumber in PO -->
<template id="report_quotation_inherit" inherit_id="purchase.report_purchaseorder_document">


<xpath expr="//t[@t-call='web.external_layout']" position="replace">


   <t t-call="web.external_layout">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-set="address">
            <div t-field="o.partner_id"
            t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
            <p t-if="o.partner_id.vat"><t t-esc="o.company_id.country_id.vat_label or 'Tax ID'"/>: <span t-field="o.partner_id.vat"/></p>
        </t>
        <t t-if="o.dest_address_id">
            <t t-set="information_block">
                <strong>Shipping address:</strong>
                <div t-if="o.dest_address_id">
                    <div t-field="o.dest_address_id"
                        t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}' name="purchase_shipping_address"/>
                </div>

            </t>
        </t>
        <div class="page">
            <div class="oe_structure"/>

            <h2 t-if="o.state == 'draft'">Request for Quotation #<span t-field="o.name"/></h2>
            <h2 t-if="o.state in ['sent', 'to approve']">Purchase Order #<span t-field="o.name"/></h2>
            <h2 t-if="o.state in ['purchase', 'done']">Purchase Order #<span t-field="o.name"/></h2>
            <h2 t-if="o.state == 'cancel'">Cancelled Purchase Order #<span t-field="o.name"/></h2>

            <div id="informations" class="row mt32 mb32">
                <div t-if="o.user_id" class="col-3 bm-2">
                    <strong>Purchase Representative:</strong>
                    <p t-field="o.user_id" class="m-0"/>
                </div>
                <div t-if="o.partner_ref" class="col-3 bm-2">
                    <strong>Your Order Reference:</strong>
                    <p t-field="o.partner_ref" class="m-0"/>
                </div>

                 

                <div t-if="o.create_date" class="col-3 bm-2">
                    <strong>RFQ Date:</strong>
                    <p t-field="o.create_date" class="m-0"/>
                </div>

                <div t-if="o.x_studio_vendor_invoice_no" class="col-3 bm-2">
                    <strong>Suppleir Invoice No. :</strong>
                    <p t-field="o.x_studio_vendor_invoice_no" class="m-0"/>
                </div>



                <div t-if="o.date_order" class="col-3 bm-2">
                    <strong>Order Date:</strong>
                    <p t-field="o.date_order" class="m-0"/>
                </div>
                 </div>
                   <br/>

                 <div id="informat" class="row mt32 mb32">

                     <div t-if="o.request_id" class="col-3 bm-2">
                    <strong>MR No.</strong>
                    <p t-field="o.request_id" class="m-0"/>
                </div>


                  <div t-if="o.payment_term_id" class="col-3 bm-2">
                    <strong>Payment Terms:</strong>
                    <p t-field="o.payment_term_id" class="m-0"/>
                     <br/><br/></div>
                   
                    <div t-if="o.x_studio_delivery_period" class="col-3 bm-2">
                    <strong>Delivery Period:</strong>
                    <p t-field="o.x_studio_delivery_period" class="m-0"/>
                     <br/><br/></div>

 
                    <div t-if="o.date_planned" class="col-3 bm-2">
                    <strong>Delivery Date:</strong>
                    <p t-field="o.date_planned" class="m-0"/>
                     <br/><br/></div>

                    <div t-if="o.incoterm_id" class="col-3 bm-2">
                    <strong>Delivery Terms:</strong>
                    <p t-field="o.incoterm_id" class="m-0"/>
                     <br/><br/></div>

               </div>



            <table class="table table-sm o_main_table">
                <thead>
                    <tr>
                        <th name="th_description"><strong>Description</strong></th>
                        <th name="th_partner_numner" ><strong>Part Number</strong></th>

                        <th name="th_taxes"><strong>Taxes</strong></th>
<!--                         <th name="th_date_req" class="text-center"><strong>Date Req.</strong></th>
 -->                        <th name="th_quantity" class="text-right"><strong>Qty</strong></th>
                        <th name="th_price_unit" class="text-right"><strong>Unit Price</strong></th>
                        <th name="th_amount" class="text-right"><strong>Amount</strong></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="current_subtotal" t-value="0"/>
                    <t t-foreach="o.order_line" t-as="line">
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                        <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                            <t t-if="not line.display_type">
                                <td id="product">
                                    <span t-field="line.name"/>
                                </td>
                                <td>
                                <span  t-field="line.product_id.part_number"/>
                                </td>
                                <td name="td_taxes">
                                    <span t-esc="', '.join(map(lambda x: x.name, line.taxes_id))"/>
                                </td>
                               <!--  <td class="text-center">
                                    <span t-field="line.date_planned"/>
                                </td> -->
                                <td class="text-right">
                                    <span t-field="line.product_qty"/>
                                    <span t-field="line.product_uom.name" groups="uom.group_uom"/>
                                </td>
                                <td class="text-right">
                                    <span t-field="line.price_unit"/>
                                </td>
                                <td class="text-right">
                                    <span t-field="line.price_subtotal"
                                        t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                </td>
                            </t>
                            <t t-if="line.display_type == 'line_section'">
                                <td colspan="99" id="section">
                                    <span t-field="line.name"/>
                                </td>
                                <t t-set="current_section" t-value="line"/>
                                <t t-set="current_subtotal" t-value="0"/>
                            </t>
                            <t t-if="line.display_type == 'line_note'">
                                <td colspan="99" id="note">
                                    <span t-field="line.name"/>
                                </td>
                            </t>
                        </tr>
                        <t t-if="current_section and (line_last or o.order_line[line_index+1].display_type == 'line_section')">
                            <tr class="is-subtotal text-right">
                                <td colspan="99" id="subtotal">
                                    <strong class="mr16">Subtotal</strong>
                                    <span
                                        t-esc="current_subtotal"
                                        t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                    />
                                </td>
                            </tr>
                        </t>
                    </t>
                </tbody>
            </table>

            <div id="total" class="row justify-content-end">
                <div class="col-4">
                    <table class="table table-sm">
                        <tr class="border-black">
                            <td name="td_subtotal_label"><strong>Subtotal</strong></td>
                            <td class="text-right">
                                <span t-field="o.amount_untaxed"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                        <tr>
                            <td name="td_taxes_label">Taxes</td>
                            <td class="text-right">
                                <span t-field="o.amount_tax"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                        <tr class="border-black o_total">
                            <td name="td_amount_total_label"><strong>Total</strong></td>
                            <td class="text-right">
                                <span t-field="o.amount_total"
                                    t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>



<strong class="mr16" t-if="o.note">Other Terms  &#38;Conditions</strong>
            <p t-field="o.note"/>



