<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_loan_form_custom_inherited" model="ir.ui.view">
            <field name="name">hr.loan.form.inherited</field>
            <field name="model">hr.loan</field>
            <field name="inherit_id" ref="hr_loan_base.view_hr_loan_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="replace">
                    <header invisible="rida_employee_type != 'hq'">
                        
                       
                        <!-- Draft -->
                        <button name="action_submit" type="object" class="btn btn-primary" string="Submit" invisible="state != 'draft'" groups='base.group_user'/>"
                        <!-- HR officer -->
                        <button name="action_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'hr_officer'" groups='hr_payroll.group_hr_payroll_user'/>
                        <button name="reject_hr_officer" type="object" string="Reject" invisible="state != 'hr_officer'" groups="hr_payroll.group_hr_payroll_user"/>
                        <!-- HR manager -->
                        <button name="manager_approve" type="object" class="btn btn-primary" string="Approve"  invisible="state != 'hr_approve'"  groups='hr_payroll.group_hr_payroll_manager,hr_payroll.group_hr_payroll_user'/>
                        <button name="reject_hr_manager" type="object" string="Reject"  invisible="state != 'hr_approve'"  groups="hr_payroll.group_hr_payroll_manager,hr_payroll.group_hr_payroll_user"/>
                        <!-- fianance -->
                        <button name="finance_action_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'finance'" groups='base_rida.rida_finance_manager'/>
                        <button name="reject_finance_manager" type="object" string="Reject" invisible="state != 'finance'"  groups="base_rida.rida_finance_manager"/>
                        <!-- internal audit -->
                        <button name="internal_audit_action_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'internal_audit'"   groups='base_rida.rida_internal_audit'/>
                        <button name="reject_internal_audit" type="object" string="Reject" invisible="state != 'internal_audit'" groups="base_rida.rida_internal_audit"/>
                        <!-- CCSO -->
                        <button name="ccso_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'ccso'" groups='base_rida.rida_group_CCSO,base_rida.rida_group_COO'/>
                        <button name="reject_ccso" type="object" string="Reject" invisible="state != 'ccso'" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <!-- accountant -->
                        <!-- <button name="accountant_action_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'accountant'" groups='account.group_account_user'/> -->
                        <button name="action_register_payment" string="Register Payment" type="object" class="oe_highlight" groups="account.group_account_user" invisible="state not in ('accountant') or register_payment != False"/>
                        <button name="accountnt_action_refuse" type="object" string="Reject" invisible="state != 'accountant'" groups="account.group_account_user"/>
                        
                        <!-- <button name="action_create_entries" type="object" class="btn btn-primary" string="Create Entry" states="approve" groups="account.group_account_user"/> -->
                         <!-- payment -->
                         <!-- <button name="action_post" string="Paid" groups="account.group_account_user" type="object" states="approve" class="oe_highlight" /> -->
                         <!-- paid , cancel, reject -->
                        <button name="action_set_to_draft" type="object" string="Set To Draft" invisible="state != 'refuse'"  groups="hr.group_hr_manager"/>
                        <button name="%(hr_loan_base.action_hr_loan_clear_button)d" type="action" invisible="state != 'paid'" string="Loan Clear" groups="hr.group_hr_user"/>
                        <button name="%(hr_loan_base.action_hr_loan_recalculation_button)d" type="action" invisible="state not in ('draft', 'paid')" string="Loan Recalculate" groups="hr.group_hr_user"/>
                        <field name="state" widget="statusbar" statusbar_colors='{"proforma":"blue","proforma2":"blue"}' statusbar_visible="draft,paid"/>
                    </header>
                    <header invisible="employee_id == True or rida_employee_type != 'site'">
                        <!-- Draft -->
                        <button name="action_submit" type="object" class="btn btn-primary" string="Submit" invisible="state != 'draft'"  groups='base.group_user'/>
                        <!-- HR officer -->
                        <button name="action_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'hr_officer'" ggroups='hr_payroll.group_hr_payroll_user'/>
                        <button name="reject_hr_officer" type="object" string="Reject" invisible="state != 'hr_officer'" groups='hr_payroll.group_hr_payroll_user'/>
                        <!-- HR manager -->
                        <button name="manager_approve" type="object" class="btn btn-primary" string="Approve"  invisible="state != 'hr_approve'"  groups='hr_payroll.group_hr_payroll_manager,hr_payroll.group_hr_payroll_user'/>
                        <button name="reject_hr_manager" type="object" string="Reject"  invisible="state != 'hr_approve'"  groups="hr_payroll.group_hr_payroll_manager,hr_payroll.group_hr_payroll_user"/>
                        <!-- Site manager -->
                        <button name="action_site_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'site_manager'"  groups='base_rida.rida_group_site_manager'/>
                        <button name="reject_site" type="object" string="Reject" invisible="state != 'site_manager'" groups="base_rida.rida_group_site_manager"/>
                        <!-- fianance -->
                        <button name="finance_action_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'finance'" groups='base_rida.rida_finance_manager'/>
                        <button name="reject_finance_manager" type="object" string="Reject" invisible="state != 'finance'" groups="base_rida.rida_finance_manager"/>
                        <!-- internal audit -->
                        <button name="internal_audit_action_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'internal_audit'" groups='base_rida.rida_internal_audit'/>
                        <button name="reject_internal_audit" type="object" string="Reject" invisible="state != 'internal_audit'" groups="base_rida.rida_internal_audit"/>
                        <!-- CCSO -->
                        <button name="ccso_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'ccso'"  groups='base_rida.rida_group_CCSO,base_rida.rida_group_COO'/>
                        <button name="reject_site" type="object" string="Reject" invisible="state != 'ccso'" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <!-- accountant -->
                        <!-- <button name="accountant_action_approve" type="object" class="btn btn-primary" string="Approve" invisible="state != 'accountant'" groups='account.group_account_user'/> -->
                        <button name="action_register_payment" string="Register Payment" type="object" class="oe_highlight" groups="account.group_account_user" invisible="state not in ('accountant') or register_payment != False"/>



                        <button name="accountnt_action_refuse" type="object" string="Reject" invisible="state != 'accountant'"   groups="account.group_account_user"/>
                        
                        <!-- <button name="action_create_entries" type="object" class="btn btn-primary" string="Create Entry" states="approve" groups="account.group_account_user"/> -->
                        <!-- payment -->
                        <!-- <button name="action_post" string="Paid" groups="account.group_account_user" type="object" states="approve" class="oe_highlight" /> -->
                        <!-- paid , cancel, reject -->
                        <button name="action_set_to_draft" type="object" string="Set To Draft" invisible="state != 'refuse'" groups="hr.group_hr_manager"/>
                        <button name="%(hr_loan_base.action_hr_loan_clear_button)d" type="action" invisible="state != 'paid'" string="Loan Clear" groups="hr.group_hr_user"/>
                        <button name="%(hr_loan_base.action_hr_loan_recalculation_button)d" type="action" invisible="state not in ('draft', 'paid')" string="Loan Recalculate" groups="hr.group_hr_user"/>
                        <field name="state" widget="statusbar" statusbar_colors='{"proforma":"blue","proforma2":"blue"}' statusbar_visible="draft,approve,paid" />
                    </header>
                </xpath>
                <xpath expr="//field[@name='loan_amount']" position="after">
                   <field name="employee_account_id" invisible="state not in ('accountant', 'approve', 'paid')" readonly="state == 'paid'" required="state == 'accountant'" domain="[('account_type', '=', 'asset_receivable')]"/>
                   <!--  <field name="treasury_account_id" invisible = "state  not in ('approve', 'paid')" readonly = "state = 'paid'" domain="[('user_type_id','=',3)]"/> -->
                    <field name="journal_id" invisible="state not in ('accountant', 'paid')" 
readonly="state == 'paid'" domain="[('type','in',['bank','cash'])]"/>
                </xpath>
                <xpath expr="//sheet/div" position="before">
                    <div class="oe_button_box">
                        <button class="oe_stat_button" name="button_payment" invisible="state not in ('approve', 'paid')"  string="Payment" type="object" icon="fa-usd" />
                        <button class="oe_stat_button" name="button_journal_entries" invisible="state not in ('approve', 'paid')" string="Journal Entiry" type="object"  icon="fa-folder-open-o"/>
					</div>
                </xpath>
                <xpath expr="//form/sheet/notebook/page/field[@name='loan_line_ids']" position="before">
                    <group>
                        <field name="move_id" groups="account.group_account_user"/>
                        <field name="rida_employee_type" invisible='1'/>
                        <field name="register_payment" invisible='1'/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
