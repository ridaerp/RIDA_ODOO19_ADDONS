<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="view_salary_advance_form_inherit" model="ir.ui.view">
            <field name="name">view.salary.advance.form_inherit</field>
            <field name="model">salary.advance</field>
            <field name="inherit_id" ref="hr_salary_advance.view_salary_advance_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="replace">
                    <!-- HQ employee workflow-->
                    <header invisible="employee_id == False or rida_employee_type == 'site'">
                        <!-- Draft -->
                        <button name="action_submit" string="Submit" type="object" invisible="state != 'draft'"
                                class="oe_highlight"/>

                        <!-- HR_Officer -->
                        <button name="action_hr_officer" string="Approve" type="object"
                                invisible="state != 'hr_officer'" class="oe_highlight"
                                groups="hr_payroll.group_hr_payroll_user"/>
                        <button name="reject" string="Reject" type="object" invisible="state != 'hr_officer'"
                                groups="hr.group_hr_user"/>
                        <!--  <button name="cancel" string="Cancel" type="object" invisible="state != 'hr_officer'" groups="hr.group_hr_user" /> -->

                        <!-- HR_manager -->
                        <button name="action_hr_manager" string="Approve" type="object"
                                invisible="state != 'hr_manager'" class="oe_highlight"
                                groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site"/>
                        <button name="reject_hr_manager" string="Reject" type="object" invisible="state != 'hr_manager'"
                                groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site"/>
                        <!-- <button name="cancel" string="Cancel" type="object" invisible="state != 'hr_manager'" groups="hr.group_hr_manager" /> -->

                        <!-- Finance -->
                        <button name="action_fainance" string="Approve" type="object" invisible="state != 'finance'"
                                class="oe_highlight" groups="base_rida.rida_finance_manager"/>
                        <button name="reject_finance_manager" string="Reject" type="object"
                                invisible="state != 'finance'" groups="base_rida.rida_finance_manager"/>
                        <!--  <button name="cancel" string="Cancel" type="object" invisible="state != 'finance'" groups="base_rida.rida_finance_manager" /> -->

                        <!-- internal_audit -->
                        <button name="action_internal_audit" string="Approve" type="object"
                                invisible="state != 'internal_audit'" class="oe_highlight"
                                groups="base_rida.rida_internal_audit"/>
                        <button name="reject_internal_audit" string="Reject" type="object"
                                invisible="state != 'internal_audit'" groups="base_rida.rida_internal_audit"/>
                        <!--  <button name="cancel" string="Cancel" type="object" invisible="state != 'internal_audit'" groups="base_rida.rida_internal_audit" /> -->

                        <!-- CCSO -->
                         <button name="action_site_manager" string="Approve" groups="base_rida.rida_group_COO,base_rida.rida_group_CCSO"
                                type="object" invisible="state != 'site_manager'" class="oe_highlight"/> 
                        <button name="action_site_manager" string="Reject" type="object" invisible="state != 'site_manager'"
                                groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <!--  <button name="cancel" string="Cancel" type="object" invisible="state != 'ccso'" groups="base_rida.rida_group_CCSO" /> -->

                        <!-- accountant -->
                        <!-- comment by ekhlas  <button name="approve_request_acc_dept" string="Approve" type="object" invisible="state != 'accountant'" class="oe_highlight" groups="account.group_account_user" /> -->
                        <button name="action_register_payment" string="Register Payment" type="object"
                                class="oe_highlight" groups="account.group_account_user"
                                invisible="state not in ('accountant') or register_payment != False"/>


                        <button name="reject_account" string="Reject" type="object" invisible="state != 'accountant'"
                                groups="account.group_account_user"/>
                        <!--  <button name="cancel" string="Cancel" type="object" invisible="state != 'accountant'" groups="hr.group_hr_manager,account.group_account_user" />
  -->
                        <!-- payment -->
                        <button name="action_post" string="Paid" groups="account.group_account_user" type="object"
                                invisible="state != 'approve'" class="oe_highlight"/>
                         <!-- ccso approval buttons for ccso-->
                        <button name="action_ccso" string="COO Approve" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"
                                type="object"  invisible="state != 'ccso'" class="oe_highlight"/>

                        <!--  <button name="cancel" string="Cancel" groups="account.group_account_user" type="object" invisible="state != 'approve'" /> -->

                        <!-- Cancel-->
                        <button name="set_draft" string="Set To Draft" type="object"
                                invisible="state not in ['cancel', 'reject']"
                                groups="hr_payroll.group_hr_payroll_user"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,approve"/>
                    </header>
                    <!-- site employee workflow-->
                    <header invisible="employee_id == False or rida_employee_type == 'hq'">
                        <!-- Draft -->
                        <button name="action_submit" string="Submit" type="object" invisible="state != 'draft'"
                                class="oe_highlight"/>

                        <!-- HR_Officer -->
                        <button name="action_hr_officer" string="Approve" type="object"
                                invisible="state != 'hr_officer'" class="oe_highlight"
                                groups="hr_payroll.group_hr_payroll_user"/>
                        <button name="reject" string="Reject" type="object" invisible="state != 'hr_officer'"
                                groups="hr_payroll.group_hr_payroll_user"/>
                        <button name="cancel" string="Cancel" type="object" invisible="state != 'hr_officer'"
                                groups="hr_payroll.group_hr_payroll_user"/>

                        <!-- HR_manager -->
                        <button name="action_hr_manager" string="Approve" type="object"
                                invisible="state != 'hr_manager'" class="oe_highlight"
                                groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site"/>
                        <button name="reject_hr_manager" string="Reject" type="object" invisible="state != 'hr_manager'"
                                groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site"/>
                        <!--  <button name="cancel" string="Cancel" type="object" invisible="state != 'hr_manager'" groups="hr_payroll.group_hr_payroll_manager" /> -->

                        <!-- Site_manager -->
                        <button name="action_site_manager" string="Approve" type="object"
                                invisible="state != 'site_manager'" class="oe_highlight"
                                groups="base_rida.rida_group_site_manager"/>
                        <button name="reject_site" string="Reject" type="object" invisible="state != 'site_manager'"
                                groups="base_rida.rida_group_site_manager"/>
                        <!--  <button name="cancel" string="Cancel" type="object" invisible="state != 'site_manager'" groups="base_rida.rida_group_site_manager" /> -->

                        <!-- Finance -->
                        <button name="action_fainance" string="Approve" type="object" invisible="state != 'finance'"
                                class="oe_highlight" groups="base_rida.rida_finance_manager"/>
                        <button name="reject_finance_manager" string="Reject" type="object"
                                invisible="state != 'finance'" groups="base_rida.rida_finance_manager"/>
                        <!--  <button name="cancel" string="Cancel" type="object" invisible="state != 'finance'" groups="base_rida.rida_finance_manager" /> -->

                        <!-- internal_audit -->
                        <button name="action_internal_audit" string="Approve" type="object"
                                invisible="state != 'internal_audit'" class="oe_highlight"
                                groups="base_rida.rida_internal_audit"/>
                        <button name="reject_internal_audit" string="Reject" type="object"
                                invisible="state != 'internal_audit'" groups="base_rida.rida_internal_audit"/>
                        <!-- <button name="cancel" string="Cancel" type="object" invisible="state != 'internal_audit'" groups="base_rida.rida_internal_audit" />
                        -->
                        <!-- CCSO -->
                     <!--    <button name="action_c_level_approve" string="Approve" groups="base_rida.group_c_level"
                                type="object" invisible="state != 'c_level'" class="oe_highlight"/> -->
                               

                                <button name="action_ccso" string="Approve" groups="base_rida.rida_group_COO,base_rida.rida_group_CCSO"
                                type="object" invisible="state != 'ccso'" class="oe_highlight"/>
                                
                        <button name="reject_ccso" string="Reject" type="object" invisible="state != 'ccso'"
                                groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <!-- <button name="cancel" string="Cancel" type="object" invisible="state != 'ccso'" groups="base_rida.rida_group_CCSO" /> -->

                        <!-- accountant -->
                        <!--comment by ekhlas code  <button name="approve_request_acc_dept" string="Approve" type="object" invisible="state != 'accountant'" class="oe_highlight" groups="account.group_account_user" />  -->
                        <button name="action_register_payment" string="Register Payment" type="object"
                                class="oe_highlight" groups="account.group_account_user"
                                invisible="state not in ('accountant') or register_payment != False"/>
                        <button name="reject_account" string="Reject" type="object" invisible="state != 'accountant'"
                                groups="account.group_account_user"/>
                        <!--   <button name="cancel" string="Cancel" type="object" invisible="state != 'accountant'" groups="hr.group_hr_manager,account.group_account_user" /> -->

                        <!-- payment -->
                        <button name="action_post" string="Paid" groups="account.group_account_user" type="object"
                                invisible="state != 'approve'" class="oe_highlight"/>

                        <!--  <button name="cancel" string="Cancel" groups="account.group_account_user" type="object" invisible="state != 'approve'" /> -->

                        <!-- Cancel-->
                        <button name="set_draft" string="Set To Draft" type="object"
                                invisible="state not in ['cancel', 'reject']"
                                groups="hr_payroll.group_hr_payroll_user"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,approve"/>
                    </header>
                </xpath>
                <xpath expr="//sheet/div" position="inside">
                    <button class="oe_stat_button" name="button_payment"
                            invisible="state not in ['accountant', 'approve','paid']" string="Payment" type="object"
                            icon="fa-usd"/>
                    <button class="oe_stat_button" name="button_journal_entries"
                            invisible="state not in ['accountant', 'approve','paid']" string="Journal Entiry"
                            type="object" icon="fa-folder-open-o"/>

                </xpath>

                <xpath expr="//group[@name='adv_info']" position="after">
                    <!-- Add your fields or attributes here -->
                    <group>

                        <field name="account_id" invisible="state not in ('accountant', 'approve', 'paid')"
                               readonly="state == 'paid'" required="state == 'accountant'"
                               domain="[('account_type', '=', 'asset_receivable'),('company_id','=',company_id)]"/>


                        <!--                        <field name="account_id"  domain="[('user_type_id.type','=','receivable'),('company_id','=',company_id)]" invisible="state not in ['accountant', 'cancel', 'reject', 'paid']"-->
                        <!-- readonly="state in ['cancel', 'reject', 'paid']" groups="account.group_account_user" /> -->
                        <!-- <field name="credit" attrs="{'invisible':[('state','not in',['accountant','approve'])],'readonly':[('state','in',['approve','cancel','reject'])]}" groups="account.group_account_user" /> -->
                        <!-- <field name="debit" attrs="{'invisible':[('state','not in',['accountant','approve'])],'readonly':[('state','in',['approve','cancel','reject'])]}" groups="account.group_account_user" /> -->
                        <field name="journal"
                               invisible="state not in ['accountant', 'approve', 'cancel', 'reject', 'paid']"
                               readonly="state in ['approve', 'cancel', 'reject', 'paid']"
                               groups="account.group_account_user" domain="[('type','in',['bank','cash']),('company_id','=',company_id)]"/>
                        <field name="move_id" invisible="state not in ['approve', 'cancel', 'reject', 'paid']"
                               readonly="1" groups="account.group_account_user"/>
                        <field name="register_payment" invisible='1'/>

                        <!-- <field name="pay_id" attrs="{'invisible':[('state','not in',['accountant','approve'])],'readonly':[('state','in',['approve','finance','cancel','reject'])]}" groups="account.group_account_user" /> -->

                    </group>
                </xpath>

            </field>
        </record>


        <record id="view_salary_advance_filter_inherit" model="ir.ui.view">
            <field name="name">view.salary.advance.filter.inherit</field>
            <field name="model">salary.advance</field>
            <field name="inherit_id" ref="hr_salary_advance.view_salary_advance_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='submitted']" position="replace">
                    <filter domain="[('state','in',['hr_officer','hr_manager','ceo','finance'])]" string="To Approve"
                            name="submitted" help="Submitted Requests"/>
                </xpath>
            </field>
        </record>


        <menuitem id="hr_salary_advance.menu_salary_advance" action="hr_salary_advance.action_salary_advance_to_approve"
                  parent="hr_salary_advance.parent_menum_salary_advance" name="Salary Advance To Approve" sequence="3"
                  groups="hr.group_hr_manager,hr.group_hr_user,account.group_account_user,base_rida.rida_group_CCSO,base_rida.rida_group_COO,base_rida.rida_group_site_manager,base_rida.rida_internal_audit"/>


    </data>
</odoo>
