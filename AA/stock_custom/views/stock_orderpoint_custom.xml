<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_warehouse_orderpoint_tree_custom" model="ir.ui.view">
        <field name="name">stock.warehouse.orderpoint.tree.custom</field>
        <field name="model">stock.warehouse.orderpoint</field>
        <field name="inherit_id" ref="stock.view_warehouse_orderpoint_tree_editable"/>
        <!-- <field name="inherit_id" ref="stock.view_warehouse_orderpoint_tree_editable_config"/>
        <field name="inherit_id" ref="purchase_stock.view_warehouse_orderpoint_tree_editable_inherited_mrp"/> -->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id']" position="after">
                <field name="state"/>
                <field name="max_month_cons" optional="show"/>
                <field name="min_month_cons" optional="show"/>
                <field name="conumption_rate" optional="show"/>
                <field name="month_lead_time" optional="show"/>
                <field name="lead_time_stock" optional="show"/>
                <field name="max_delay" optional="show"/>
                <field name="safety_stock" optional="show"/>
                <field name="max_avg" optional="show"/>
                <field name="ssc" optional="show"/>
                <field name="tss" optional="show"/>
                <field name="roundup_tss" optional="show"/>
                <field name="reorder_level" optional="show"/>
                <field name="reorder_stock" optional="show"/>
                <field name="max_stock" optional="show"/>
                <field name="order_qty" optional="show"/>
                <field name="spec_cons" optional="show"/>

            </xpath>
        </field>
    </record>
    <record model="ir.actions.server" id="action_store_manager_approve">
        <field name="name">Store Supervisor Approval</field>
        <field name="model_id" ref="model_stock_warehouse_orderpoint"/>
        <field name="binding_model_id" ref="model_stock_warehouse_orderpoint" />
        <field name="state">code</field>
        <field name="code">
            if records:
                records.write({'state': 'store_manager'})
    
        </field>
        <field name="group_ids" eval="[(4, ref('base.group_user'))]"/>

    </record>
    
    <record model="ir.actions.server" id="action_store_manager_approval">
        <field name="name">Store Manager Approval</field>
        <field name="model_id" ref="model_stock_warehouse_orderpoint"/>
        <field name="binding_model_id" ref="model_stock_warehouse_orderpoint" />
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_store_manager_approve()
        </field>
        <field name="group_ids" eval="[(4, ref('base.group_user'))]"/>

    </record>
    <record model="ir.actions.server" id="action_site_manager_approval">
        <field name="name">Operation Director Approval</field>
        <field name="model_id" ref="model_stock_warehouse_orderpoint"/>
        <field name="binding_model_id" ref="model_stock_warehouse_orderpoint" />
        <field name="state">code</field>
        <field name="code">
            if records:
                records.action_site_manager_approve()
        </field>
        <field name="group_ids" eval="[(4, ref('base.group_user'))]"/>

    </record>
     

  
    
</odoo>
