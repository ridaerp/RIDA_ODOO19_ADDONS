<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="rotation_request_form" model="ir.ui.view">
            <field name="name">request.rotation.form</field>
            <field name="model">rotation.batch</field>
            <field name="arch" type="xml">
                <form>
                    <header>

                        <button string="Verify" name="action_validate" invisible="state != 'wha'" type="object"
                                class="oe_highlight"
                                groups="hr_holidays.group_hr_holidays_manager"/>
                        <button string="Approve" name="action_approve" type="object" class="oe_highlight"
                                invisible="state != 'wlm'"
                                groups="base_rida.rida_group_line_manager"/>
                        <button string="Approve" name="action_hr_manager_approve" type="object" class="oe_highlight"
                                invisible="state != 'whmp'"
                                groups="base_rida.rida_hr_manager_notify"/>
                        <button string="Submit" name="action_submit" type="object" class="oe_highlight"
                                invisible="state != 'draft'"
                                groups="base.group_user"/>
                        <button string="Approve" name="approve_finance_manager" type="object" invisible="state != 'wfm'"
                                class="oe_highlight" groups="base_rida.rida_finance_manager"/>
                        <button string="Approve" name="approve_internal_audit" type="object"
                                invisible="state != 'internal_aud'"
                                class="oe_highlight" groups="base_rida.rida_internal_audit"/>
                        <button string="Approve" name="approve_ccso" type="object" invisible="state != 'ccso'"
                                class="oe_highlight" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <button string="Post Journal Entries" name="approve_accountant" type="object"
                                invisible="state != 'wd'"
                                class="oe_highlight" groups="account.group_account_user"/>
                        <button name="action_register_payment" id="account_invoice_payment_btn"
                                invisible="state != 'wdp'"
                                type="object" class="oe_highlight" context="{'dont_redirect_to_payments': True}"
                                string="Register Payment" groups="account.group_account_user"/>
                        <button name="action_reject" type="object"
                                invisible="state not in ['wha', 'wlm', 'wfm', 'internal_aud', 'ccso', 'wod', 'whmp']"
                                string="Reject"
                                groups="base_rida.rida_group_site_manager,base.group_user,base_rida.rida_hr_manager_notify,base_rida.rida_finance_manager,base_rida.rida_group_CCSO,base_rida.rida_group_COO,base_rida.rida_group_line_manager"
                        />
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,wlm,wha,whmp,wfm,wd,internal_aud,wdp,paid"
                               invisible="user_type == 'hq'"/>
                        <field name="state_ccso" widget="statusbar" invisible="user_type != 'hq'"
                               statusbar_visible="draft,wlm,wha,whmp,wfm,wd,internal_aud,wdp,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" name="get_timeoff"
                                    invisible="type in ['out']"
                                    groups="hr_holidays.group_hr_holidays_manager" string="Time Off" type="object"
                                    icon="fa-list"/>
                            <button class="oe_stat_button" name="get_payment"
                                    invisible="state not in ['paid']"
                                    groups="account.group_account_user" string="Payment" type="object"
                                    icon="fa-list"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="user_type" invisible="1"/>
                                <field name="holiday_status_id"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       domain="[('leave_type','in',['annual'])]" required="1"
                                       readonly="state != 'draft'"/>
                                <field name="department_id"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1" readonly="state != 'draft'"/>
                                <field name="req_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="date" required="1"/>
                                <field name="type" invisible="1"/>
                                <field name="expense_account_id"
                                       domain="[('company_ids','=', company_id)]"
                                       invisible="state in ['draft', 'wlm', 'wha', 'reject']"
                                       readonly="state not in ['wfm', 'wd']"
                                       required="state in ['wfm']"
                                       groups="account.group_account_user"/>
                                <field name="journal_id"
                                       invisible="not journal_id"
                                       groups="account.group_account_user"/>


                                <field name="journal_payment_id"
                                       domain="[('type','in',['bank','cash']),('company_id','=',company_id)]"
                                       invisible="not journal_id"
                                       readonly="state == 'paid'"
                                       groups="account.group_account_user"/>


                                <field name="company_id" readonly="state != 'draft'"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Employees">
                                <field name="employees_line_ids" nolabel="1"
                                       readonly="state not in ['draft', 'wha']" required="1">
                                    <list string="Employees" editable="bottom">
                                        <field name="employee_id"
                                               domain="['|',('department_id.parent_id', '=',parent.department_id),'|',('department_id.parent_id.parent_id', '=',parent.department_id),('department_id', '=',parent.department_id),('company_id', '=',parent.company_id)]"
                                               readonly="not parent.department_id"
                                               options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                               required="1"/>
                                        <field name="b_account"/>
                                        <field name="analytic_account_id"
                                               column_invisible="parent.state in ['draft', 'wlm', 'wha']"/>
                                        <field name="date_from" required="1"
                                               column_invisible="parent.state not in ['draft', 'wlm', 'wha'] or parent.type in ['out']"
                                               column_required="parent.type not in ['out']"

                                        />
                                        <field name="date_to" required="1"
                                               column_invisible="parent.state not in ['draft', 'wlm', 'wha'] or parent.type in ['out']"
                                               column_required="parent.type not in ['out']"

                                        />
                                        <field name="date_arrival"
                                               column_invisible="parent.type in ['out']"
                                               required="parent.type in ['out']"
                                        />
                                        <field name="number_of_days"
                                               column_invisible="parent.type in ['out']"/>
                                        <field name="location_id"/>
                                        <field name="num_bus" readonly="parent.state not in ['wha']"/>
                                        <field name="num_ticket" readonly="parent.state not in ['wha']"/>
                                        <field name="need_money_for_rotation" string="Paid"/>
                                        <field name="amount" sum="Total" required="1"/>
                                    </list>
                                </field>

                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>


        <record id="rotation_request_list" model="ir.ui.view">
            <field name="name">rotation.request.list</field>
            <field name="model">rotation.batch</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="holiday_status_id"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="rotation_request_form_search" model="ir.ui.view">
            <field name="name">rotation.request.search</field>
            <field name="model">rotation.batch</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <filter string="Status" name="state" domain="[]"
                                context="{'group_by':'state'}"/>
                    <filter string="Department" name="department" domain="[]"
                                context="{'group_by':'department_id'}"/>
                </search>
            </field>
        </record>


        <record id="rotation_request_act" model="ir.actions.act_window">
            <field name="name">Time Off By Department</field>
            <field name="res_model">rotation.batch</field>
            <field name="view_mode">list,form</field>
            <field name="context">{ 'default_type': 'in' }</field>
            <field name="domain">[('type','!=','out')]</field>
        </record>

        <record id="arrival_request_act" model="ir.actions.act_window">
            <field name="name">Arrival Ticket</field>
            <field name="res_model">rotation.batch</field>
            <field name="view_mode">list,form</field>
            <field name="context">{ 'default_type': 'out' }</field>
            <field name="domain">[('type','=','out')]</field>
        </record>


        <record id="location_detail_form" model="ir.ui.view">
            <field name="name">location detail form</field>
            <field name="model">locations.detail</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="amount" readonly="1" invisible="city == False"/>
                            <field name="city" invisible="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="location_detail_list" model="ir.ui.view">
            <field name="name">location detail list</field>
            <field name="model">locations.detail</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="amount" invisible="city == False"/>
                    <field name="city" invisible="1"/>
                </list>
            </field>
        </record>

        <record id="location_detail_action" model="ir.actions.act_window">
            <field name="name">Location Detail</field>
            <field name="res_model">locations.detail</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('city', '=', False)]</field>
        </record>

        <record id="city_transportation_detail_action" model="ir.actions.act_window">
            <field name="name">City Transportation Fees</field>
            <field name="res_model">locations.detail</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_city': 'True'}</field>
            <field name="domain">[('city', '=', 'True')]</field>
        </record>

        <record id="rotation_request_account_act" model="ir.actions.act_window">
            <field name="name">Time Off By Department</field>
            <field name="res_model">rotation.batch</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state','=',['wfm','wd', 'wdp','wod','ccso','internal_aud','paid'])]</field>
            <field name="context">{'edit': 1,'create': 0}</field>
        </record>

        <record model="ir.actions.server" id="action_time_arrival_confirm">
            <field name="name">Confirm</field>
            <field name="model_id" ref="hr_leave_main.model_rotation_batch"/>
            <field name="binding_model_id" ref="hr_leave_main.model_rotation_batch"/>
            <field name="state">code</field>
            <field name="code">
                action = records.action_multiple_confirm()
            </field>
            <field name="group_ids" eval="[(4, ref('account.group_account_user'))]"/>
        </record>

        <record model="ir.actions.server" id="action_payment_confirm">
            <field name="name">Payment</field>
            <field name="model_id" ref="hr_leave_main.model_rotation_batch"/>
            <field name="binding_model_id" ref="hr_leave_main.model_rotation_batch"/>
            <field name="state">code</field>
            <field name="code">
                action = records.action_multiple_payment()
            </field>
            <field name='group_ids' eval="[(4, ref('base_rida.rida_group_COO'))]"/>
        </record>

        <menuitem name="Leaves" id="menu_leave_custom" parent="hr_holidays.menu_hr_holidays_root"
                  action="rotation_request_act" groups="base.group_user"/>
        <menuitem name="Time Off Request" id="rotation_menu" parent="menu_leave_custom"
                  action="rotation_request_act" groups="base.group_user"/>
        <menuitem name="Arrival Tickets" id="arrival_ticket_menu" parent="menu_leave_custom"
                  action="arrival_request_act" groups="base.group_user"/>
        <menuitem name="Employee Transporation Fees" id="rotation_account_menu" parent="account.menu_finance_payables"
                  action="rotation_request_account_act"/>
        <menuitem name="City Transporation Fees" id="city_detail_new_menu"
                  parent="hr_holidays.menu_hr_holidays_configuration"
                  action="city_transportation_detail_action"
                  groups="hr_holidays.group_hr_holidays_manager,hr_holidays.group_hr_holidays_manager"/>
        <menuitem name="Locations" id="location_details_menu"
                  parent="hr_holidays.menu_hr_holidays_configuration"
                  action="location_detail_action"
                  groups="hr_holidays.group_hr_holidays_manager,hr_holidays.group_hr_holidays_manager"/>

    </data>
</odoo>
