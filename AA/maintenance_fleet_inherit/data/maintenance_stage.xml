<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Standard stages for Maintenance Request -->
          <record id="mr_stage_0" model="maintenance.stage">
              <field name="name">Draft W.O</field>
              <field name="sequence" eval="1" />
              <field name="fold" eval="False" />
              <field name="stage_visible" eval="True" />
          </record>
             <record id="mr_stage_oper_mov" model="maintenance.stage">
              <field name="name">Waiting Operation/Movement</field>
              <field name="sequence" eval="22" />
              <field name="fold" eval="False" />
              <field name="stage_visible" eval="True" />
          </record>


       <record id="mr_stage_1" model="maintenance.stage">
              <field name="name">Waiting Maintenance Engineer</field>
              <field name="sequence" eval="2" />
              <field name="fold" eval="False" />
              <field name="stage_visible" eval="True" />
          </record>





          <record id="mr_stage_3" model="maintenance.stage">
              <field name="name">Waiting Inspection</field>
              <field name="sequence" eval="3" />
              <field name="fold" eval="False" />
              <field name="done" eval="False" />
          </record>



           <record id="mr_stage_5" model="maintenance.stage">
              <field name="name">Waiting Material/Service Request</field>
              <field name="sequence" eval="5" />
              <field name="fold" eval="False" />
              <field name="stage_visible" eval="True" />
              <field name="done" eval="False" />
          </record>
           <record id="mr_stage_6" model="maintenance.stage">
              <field name="name">Under Maintenance</field>
              <field name="sequence" eval="6" />
              <field name="fold" eval="False" />
              <field name="stage_visible" eval="True" />
              <field name="done" eval="False" />
          </record>

          <record id="mr_stage_7" model="maintenance.stage">
              <field name="name">Completed</field>
              <field name="sequence" eval="7" />
              <field name="fold" eval="False" />
              <field name="done" eval="False" />
          </record>

          <record id="mr_stage_8" model="maintenance.stage">
              <field name="name">Closed</field>
              <field name="sequence" eval="8" />
              <field name="fold" eval="False" />
              <field name="done" eval="False" />
          </record>



          <record id="mr_stage_9" model="maintenance.stage">
              <field name="name">Rejected</field>
              <field name="sequence" eval="9" />
              <field name="fold" eval="True" />
              <field name="done" eval="True" />
          </record>


              <record id="mr_stage_10" model="maintenance.stage">
              <field name="name">Cancelled</field>
              <field name="sequence" eval="10" />
              <field name="fold" eval="True" />
              <field name="done" eval="True" />
          </record>


<!--    <record id="mr_stage_11" model="maintenance.stage">
              <field name="name">Waiting Equipment Request</field>
              <field name="sequence" eval="11" />
              <field name="fold" eval="False" />
              <field name="stage_visible" eval="True" />
              <field name="done" eval="False" />
          </record>
 -->


           <record id="status_1" model="maintenance.equipment.status">
              <field name="name">Running</field>
              <field name="sequence" eval="1" />
          </record>

          <record id="status_0" model="maintenance.equipment.status">
              <field name="name">Down</field>
              <field name="sequence" eval="2" />
          </record>
        <record id="admin_approval_stage" model="maintenance.stage">
            <field name="name">Waiting Admin Approval</field>
            <field name="sequence" eval="15"/>
            <field name="stage_visible" eval="True"/>
        </record>
  <record id="line_approval_stage" model="maintenance.stage">
            <field name="name">Waiting Manager Approval</field>
            <field name="sequence" eval="14"/>
            <field name="stage_visible" eval="True"/>
        </record>

    </data>
</odoo>
