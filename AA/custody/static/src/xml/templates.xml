<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-extend="ClientDetailsEdit">
    <t t-jquery=".client-details-right .client-detail:last-child" t-operation="replace">
        <div class='client-detail'>
            <div class='client-detail'>
            <span class='label'>Description</span>
            <input class='detail partner_description'      placeholder="Custmer Product Description"     name='partner_description'     t-att-value='partner.partner_description || ""'></input>
        </div>
        </div>
    </t>
    </t>
    <t t-extend="ClientDetails">
    <t t-jquery=".client-details-right .client-detail:last-child" t-operation="replace">
        <div class='client-detail'>
            <span class='label'>Description</span>
            <t t-if='partner.partner_description'>
                <span class='detail vat'><t t-esc='partner.partner_description'/></span>
            </t>
            <t t-if='!partner.partner_description'>
                <span class='detail partner_description empty'>N/A</span>
            </t>
        </div>
        <style>
            .pos .clientlist-screen .client-detail > .label{
                text-align: left;
            }
        </style>
    </t>
    </t>
    <t t-extend="PosTicket">
    <t t-jquery=".pos-sale-ticket" t-operation="replace">
            <div class="pos-sale-ticket">
               <center>
                   <h1>كلير-كوت</h1>
                    <p>حماية ضد الخدوش</p>
                    <h1>Clear-Coat</h1>
                    <p><b>Scratch Protection</b></p>
                    <p><i>أعمال ش.م.م - عمان</i></p>
                    <p><i>AAMAAL L.L.C - OMAN</i></p>
                    <h3>
                        <span style="float: left">Invoice</span>
                        <span style="margin-right: -65%">فاتورة</span>
                    </h3>

               </center>
            <div class="pos-center-align"><t t-esc="moment().format('L LT')"/> <t t-esc="order.name"/></div>
<!--
            <br />
            <t t-esc="widget.pos.company.name"/><br />
            Phone: <t t-esc="widget.pos.company.phone || ''"/><br />
            User: <t t-esc="widget.pos.cashier ? widget.pos.cashier.name : widget.pos.user.name"/><br />
            <br />
-->
            <t t-if="receipt.header">
                <div style='text-align:center'>
                    <t t-esc="receipt.header" />
                </div>
                <br />
            </t>
            <br/>
            <table class='receipt-orderlines'>
                <colgroup>
                    <col width='50%' />
                    <col width='25%' />
                    <col width='25%' />
                </colgroup>
                        <thead>
                            <tr>
                                <th>البيان</th>
                                <th>الكمية</th>
                                <th>المبلغ</th>
                            </tr>
                            <tr>
                                <th><b>Description</b></th>
                                <th><b>Qty</b></th>
                                <th><b>Amount</b></th>
                            </tr>
                            <tr>
                                <th></th>
                                <th></th>
                                <th></th>
                            </tr>
                        </thead>
                <tr t-foreach="orderlines" t-as="orderline" style="margin-top: 20px">
                    <td>
                        <t t-esc="orderline.get_product().display_name"/>
                         <t t-if="orderline.get_discount() > 0">
                            <div class="pos-disc-font">
                                With a <t t-esc="orderline.get_discount()"/>% discount
                            </div>
                        </t>
                    </td>
                    <td class="pos-right-align">
                        <t t-esc="orderline.get_quantity_str_with_unit()"/>
                    </td>
                    <td class="pos-right-align">
                        <t t-esc="widget.format_currency(orderline.get_display_price())"/>
                    </td>
                </tr>
            </table>
            <br />
            <hr/>
            <table class='receipt-total'>
                <tr>
                   <td>صافي الإجمالي</td>
                    <td>Subtotal:</td>
                    <td class="pos-right-align">
                        <t t-esc="widget.format_currency(order.get_total_without_tax())"/>
                    </td>
                </tr>
                <t t-foreach="order.get_tax_details()" t-as="taxdetail">
                    <tr>
                        <td><t t-esc="taxdetail.name" /></td>
                        <td class="pos-right-align">
                            <t t-esc="widget.format_currency(taxdetail.amount)" />
                        </td>
                    </tr>
                </t>
                <tr>
                   <td>الخصم</td>
                    <td>Discount:</td>
                    <td class="pos-right-align">
                        <t t-esc="widget.format_currency(order.get_total_discount())"/>
                    </td>
                </tr>
                <tr class="emph">
                   <td style="font-size: 12px">الإجمالي</td>
                    <td>Total:</td>
                    <td class="pos-right-align">
                        <t t-esc="widget.format_currency(order.get_total_with_tax())"/>
                    </td>
                </tr>
            </table>
            <br />
            <hr/>
            <table class='receipt-paymentlines'>
                <t t-foreach="paymentlines" t-as="line">
                  <tr>
                      <td>
                          المستلم
                      </td>
                      <td>
                          Recieved:
                      </td>
                      <td class="pos-right-align">
                          <t t-esc="widget.format_currency(line.get_amount())"/>
                      </td>
                  </tr>
                </t>
            </table>
            <br />
            <table class='receipt-change'>
                <tr>
                  <td>الباقي </td>
                  <td>Balance:</td>
                   <td class="pos-right-align">
                    <t t-esc="widget.format_currency(order.get_change())"/>
                    </td></tr>
            </table>
            <t t-if="receipt.footer">
                <br />
                <div style='text-align:center'>
                    <t t-esc="receipt.footer" />
                </div>
            </t>
            <hr/>
            <div>
                <p style="text-align: right">
                    يرجى الاحتفاظ بهذه الفاتورة و <span style="color: white;background: black;">ملصق كلير كوت </span> على جهازك للمطالبة باستبدال المنتج في حالة التلف
                </p>
                <p>Kindly retain this invoice and the <span style="color: white;background: black;">Clear-Coat Sticker</span> on your device to claim Lifetime Replacement Warranty. </p>
            </div>
            <hr/>
            <div>
                <p>
                    تطبق رسوم خدمة الاستبدال بعد مرور <span style="color: white;background: black;">15 يوما </span> من تاريخ الشراء الأول و/أو <span style="color: white;background: black;">عند ابراز الفاتورة</span>
                </p>
                <p>
                    Replacement Service Charges are applicable after <span style="color: white;background: black;">15 days</span> from the date of original purchase and/or if <span style="color: white;background: black;">invoice is not present.</span>
                </p>
            </div>
            <hr/>
            <div>
                <center>
                    <p>
                    نتمنى لكم تجربة محمية من الخدوش
                    </p>
                    <p><b>
                        Wishing You A Scratch Protection Experience
                    </b></p>
                </center>
                <hr/>
            </div>
        </div>
    </t>
