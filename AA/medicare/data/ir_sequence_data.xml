<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="clinic_visit_request" model="ir.sequence">
            <field name="name">Doctor Visit Request</field>
            <field name="code">doctor.visit</field>
            <field name="prefix">DV</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="lab_request" model="ir.sequence">
            <field name="name">Lab Request</field>
            <field name="code">lab.code</field>
            <field name="prefix">LAB</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="medicare_scrap_order_request" model="ir.sequence">
            <field name="name">Scrap Order Request</field>
            <field name="code">medicare.product.scrap</field>
            <field name="prefix">SP</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="minor_request" model="ir.sequence">
            <field name="name">Minor Room Request</field>
            <field name="code">room.code</field>
            <field name="prefix">RR</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="med_scrap_order_request" model="ir.sequence">
            <field name="name">Issuance Request</field>
            <field name="code">med.issuance.request</field>
            <field name="prefix">ISS</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
