<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="lab_request_forms" model="ir.ui.view">
            <field name="name">lab.request.form</field>
            <field name="model">lab.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Accept" groups="medicare.group_medicare_doctor" name="sample_close"
                                class="oe_highlight" invisible="state != 'doctor_accept'"
                                type="object" />
                        <button string="Complete" groups="medicare.group_medicare_lab_special" name="complete_sample"
                                class="oe_highlight"  invisible="state != 'test_in_progress'"
                                type="object" />
                        <button string="Test Samples" groups="medicare.group_medicare_lab_special" name="test_samples"
                                class="oe_highlight" invisible="state != 'sample_collected'"
                                type="object" />
                        <button string="Sample Collected" groups="medicare.group_medicare_lab_special"
                                name="sample_collected" class="oe_highlight"
                                type="object" invisible="state != 'draft'"/>
                        <button string="Lab Consumable Request" groups="medicare.group_medicare_lab_special"
                                name="action_lab_consumable"
                                class="oe_highlight"
                                type="object" invisible="state not in ['draft','sample_collected','test_in_progress']"/>
                        <button string="Redo" groups="medicare.group_medicare_lab_special" name="action_draft"
                                type="object" invisible="state not in ['reject','doctor_accept']" />
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                groups="medicare.group_medicare_lab_special"
            invisible="state not in ['draft','sample_collected','test_in_progress','doctor_accept']" string="Reject"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,sample_collected,test_in_progress,doctor_accept,close"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="set_lab_consumable" invisible="lab_consumble_count == 0"
                                    type="object" class="oe_stat_button" icon="fa-list-alt">
                                <field name="lab_consumble_count" string="Lab Consumable" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="req_id"/>
                                <field name="doctor_visitor_id" invisible="doctor_visitor_id == False"
                                       readonly="1"/>
                                <field name="patient" invisible="1"/>
                                <field name="responsible_id" required="1"
                                       readonly="state not in ['draft','sample_collected']"
                                       domain="[('group_ids.name', '=', 'MED-LAB Technician')]"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="p_employee"
                                       invisible="type != 'employee'" required="type == 'employee'"
                                       readonly="state != 'draft'"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="p_contractor"
                                       invisible="type != 'contractor'" required="type == 'contractor'"
                                       readonly="state != 'draft'" options="{'no_create': True,'no_open':True}"/>
                                <field name="p_quest"
                                       invisible="type != 'quest'" required="type == 'quest'"
                                       readonly="state != 'draft'" options="{'no_create': True,'no_open':True}"/>
                                <field name="department_id"
                                       invisible="type != 'employee'" required="type == 'employee'"
                                       readonly="state != 'draft'"
                                />
                                <field name="account_analytic_id" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="company_id"
                                       invisible="type != 'employee'" readonly="state != 'draft'"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="type" required="1" widget="radio"
                                       readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group>
                            <field name="description" string="Symptoms"
                                   readonly="state in ['doctor_accept','close']"/>
                        </group>
                        <group>
                            <group>
                                <field name="routine"
                                       readonly="state in  ['doctor_accept','test_in_progress','close']"/>
                                <field name="serology"
                                       readonly="state in  ['doctor_accept','test_in_progress','close']"/>
                                <field name="chemistry"
                                       readonly="state in  ['doctor_accept','test_in_progress','close']"/>
                            </group>
                            <group string="Duration"
                                   invisible="state not in ['reject','doctor_accept','close']">
                                <field name="duration_day"/>
                                <field name="duration_mintus"/>
                                <field name="duration_second"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Routine Lab">
                                <group>
                                    <field name="routine_list_ids" options="{'no_create': True,'no_open':True}"
                                           domain="[('lab_invest_id.name', 'ilike', 'Routine')]"
                                           widget="many2many_checkboxes" invisible="routine != True"
                                           readonly="state in ['doctor_accept','test_in_progress','close']"/>
                                    <field name="lab_result_routine_ids"
                                           invisible="routine != True" readonly="state in ['doctor_accept','close']">
                                        <list editable="bottom">
                                            <field name="investigation_name"/>
                                            <field name="lab_attribute_id" required="1"
                                                   readonly="parent.state not in ['draft','sample_collected']"
                                                   domain="[('investigations_list_id.lab_invest_id.name', 'ilike', 'Routine')]"/>
                                            <field name="normal_range"/>
                                            <field name="result"
                                                   readonly="parent.state not in ['test_in_progress']"/>
                                            <field name="is_selected" invisible="1"/>
                                            <field name="selected_result"
                                                   readonly="parent.state not in ['test_in_progress'] or is_selected != True"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Serology Lab">
                                <group>
                                    <field name="serology_list_ids" options="{'no_create': True,'no_open':True}"
                                           domain="[('lab_invest_id.name', 'ilike', 'Serology')]"
                                           widget="many2many_checkboxes" invisible="serology != True"
                                           readonly="state in ['doctor_accept', 'test_in_progress', 'close']"/>
                                    <field name="lab_result_serology_ids"
                                           readonly="state in ['doctor_accept', 'close']">
                                        <list editable="bottom">
                                            <field name="investigation_name"/>
                                            <field name="lab_attribute_id" required="1"
                                                   readonly="parent.state not in ['draft', 'sample_collected']"
                                                   domain="[('investigations_list_id.lab_invest_id.name', 'ilike', 'Serology')]"/>
                                            <field name="normal_range"/>
                                            <field name="result"
                                                   readonly="parent.state not in ['test_in_progress']"/>
                                            <field name="is_selected" invisible="1"/>
                                            <field name="selected_result"
                                                   readonly="parent.state not in ['test_in_progress'] or is_selected != True"
                                            />

                                        </list>
                                    </field>
                                </group>
                            </page>

                            <page string="Chemistry Lab">
                                <group>
                                    <field name="chemistry_list_ids" options="{'no_create': True,'no_open':True}"
                                           domain="[('lab_invest_id.name', 'ilike', 'Chemistry')]"
                                           widget="many2many_checkboxes"
                                           invisible="chemistry != True" readonly="state in ['doctor_accept', 'test_in_progress', 'close']"/>
                                    <field name="lab_result_chemistry_ids"
                                           invisible="chemistry != True" readonly="state in ['doctor_accept', 'close']">
                                        <list editable="bottom">
                                            <field name="investigation_name"/>
                                            <field name="lab_attribute_id" required="1"
                                          readonly="parent.state not in ['draft','sample_collected']"
                                                   domain="[('investigations_list_id.lab_invest_id.name', 'ilike', 'Chemistry')]"/>
                                            <field name="normal_range"/>
                                            <field name="result"
                                                   readonly="parent.state not in ['test_in_progress']"
                                                   />
                                            <field name="is_selected" invisible="1"/>
                                            <field name="selected_result"
                                                   readonly="parent.state not in ['test_in_progress'] or is_selected != True"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Invoice">
                                <group>
                                    <field name="invoice_prices_ids" options="{'no_create': True,'no_open':True}">
                                        <list>
                                            <field name="investigation_name"/>
                                            <field name="investigation_invest_id"/>
                                            <field name="price" sum="Total"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Result">
                                <group>
                                    <field name="result"
                                           readonly="state in ['doctor_accept','close']"/>
                                    <field name="extra_info"
                                           readonly="state in ['doctor_accept','close']"/>
                                </group>
                                <group>
                                    <group>
                                        <field name="emp_approval"/>
                                    </group>
                                    <group>
                                        <field name="date_of_analysis" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>

        <record id="lab_medcare_forms" model="ir.ui.view">
            <field name="name">pharmacy product medicare form</field>
            <field name="model">product.medicare</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" required="1"/>
                        </h1>
                        <group>
                            <group>
                                <field name="product_id"
                                       domain="['|','|',('categ_id.parent_id', 'ilike','%Laboratory%'),('categ_id', 'ilike','%Laboratory%'),('categ_id.parent_id.parent_id', 'ilike','%Laboratory%')]"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="uom_id" options="{'no_create': True,'no_open':True}" required="1"/>
                                <field name="qty_available"/>
                                <field name="qty"/>
                                <field name="price"/>
                                <field name="manufacture"/>
                                <field name="site_effect"/>
                            </group>
                            <group>
                                <field name="default_code" options="{'no_create': True,'no_open':True}" required="1"/>
                                <field name="categ_id" options="{'no_create': True,'no_open':True}" required="1"/>
                                <field name="dosage_instruction"/>
                                <field name="expire_date"/>
                                <field name="description"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="lab_request_tree" model="ir.ui.view">
            <field name="name">Lab Request Tree</field>
            <field name="model">lab.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="doctor_visitor_id"/>
                    <field name="type"/>
                    <field name="patient"/>
                    <field name="responsible_id"/>
                    <field name="date"/>
                    <field name="date_of_analysis"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="all_lab_request_act_window" model="ir.actions.act_window">
            <field name="name">Lab Request</field>
            <field name="res_model">lab.request</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="lab_request_act_window" model="ir.actions.act_window">
            <field name="name">Lab Request</field>
            <field name="res_model">lab.request</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state','=','draft')]</field>
        </record>

        <record id="lab_request_today_act_window" model="ir.actions.act_window">
            <field name="name">Today's Draft Lab Requests</field>
            <field name="res_model">lab.request</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('is_today', '=',True),('state','=','draft')]</field>
        </record>


        <record id="lab_product_act_window" model="ir.actions.act_window">
            <field name="name">Lab Consumable</field>
            <field name="res_model">product.medicare</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_type_product' : 'lab'}</field>
            <field name="domain">[('type_product', '=', 'lab')]</field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('medicare.product_medcare_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('medicare.lab_medcare_forms')})]"/>
        </record>

        <record id="lab_scrap_act_window" model="ir.actions.act_window">
            <field name="name">Scrap Orders</field>
            <field name="res_model">medicare.product.scrap</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_type_product' : 'lab'}</field>
            <field name="domain">[('type_product', '=', 'lab')]</field>
        </record>

        <record id="lab_issuance_request_act_window" model="ir.actions.act_window">
            <field name="name">Lab Consumable Request</field>
            <field name="res_model">medicare.issuance.request</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_type_product' : 'lab'}</field>
            <field name="domain">[('type_product', '=', 'lab')]</field>
        </record>

        <menuitem name="Laboratory" groups="medicare.group_medicare_lab_special" id="laboratory_root" sequence="3"
                  parent="medicare.medicare_menu"/>
        <menuitem name="All Lab Requests" groups="medicare.group_medicare_lab_special" id="menu_medicare_lab_requests"
                  parent="laboratory_root"
                  sequence="3" action="all_lab_request_act_window"/>
        <menuitem name="Draft Lab Requests" groups="medicare.group_medicare_lab_special" id="menu_med_draft_req"
                  parent="laboratory_root" sequence="2" action="lab_request_act_window"/>
        <menuitem name="Today's Draft Lab Requests" groups="medicare.group_medicare_lab_special"
                  id="sub_today_draft_req"
                  parent="laboratory_root" sequence="1" action="lab_request_today_act_window"/>
        <menuitem name="Lab Consumable" groups="medicare.group_medicare_lab_special" id="menu_lab_product"
                  parent="laboratory_root"
                  sequence="5" action="lab_product_act_window"/>
        <menuitem name="Scrap" groups="medicare.group_medicare_lab_special" id="menu_lab_scrap"
                  parent="laboratory_root"
                  sequence="6" action="lab_scrap_act_window"/>
        <menuitem name="Lab Consumable Request" groups="medicare.group_medicare_lab_special"
                  id="menu_lab_issuance_request"
                  parent="laboratory_root"
                  sequence="4" action="lab_issuance_request_act_window"/>
    </data>
</odoo>