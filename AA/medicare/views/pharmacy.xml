<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="pharmacy_product_forms" model="ir.ui.view">
            <field name="name">pharmacy product medicare form</field>
            <field name="model">product.medicare</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" required="1"/>
                        </h1>
                        <group>
                            <group>
                                <field name="product_id"
                                       domain="['|','|',('categ_id.parent_id', 'ilike','%Pharmacy%'),('categ_id', 'ilike','%Pharmacy%'),('categ_id.parent_id.parent_id', 'ilike','%Pharmacy%')]"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="uom_id" options="{'no_create': True,'no_open':True}" required="1"/>
                                <field name="qty_available"/>
                                <field name="qty"/>
                                <field name="price"/>
                                <field name="manufacture"/>
                                <field name="site_effect"/>
                            </group>
                            <group>
                                <field name="default_code" required="1"/>
                                <field name="categ_id" options="{'no_create': True,'no_open':True}" required="1"/>
                                <field name="dosage_instruction"/>
                                <field name="expire_date"/>
                                <field name="description"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="pharmacy_product_act_window" model="ir.actions.act_window">
            <field name="name">Medicines</field>
            <field name="res_model">product.medicare</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_type_product' : 'pharmacy'}</field>
            <field name="domain">[('type_product', '=', 'pharmacy')]</field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('medicare.product_medcare_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('medicare.pharmacy_product_forms')})]"/>
        </record>


        <record id="pharmacy_scrap_act_window" model="ir.actions.act_window">
            <field name="name">Scrap Orders</field>
            <field name="res_model">medicare.product.scrap</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_type_product' : 'pharmacy'}</field>
            <field name="domain">[('type_product', '=', 'pharmacy')]</field>
        </record>

        <record id="pharmacy_issuance_request_act_window" model="ir.actions.act_window">
            <field name="name">Medicine Request</field>
            <field name="res_model">medicare.issuance.request</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_type_product' : 'pharmacy'}</field>
            <field name="domain">[('type_product', '=', 'pharmacy')]</field>
        </record>

        <menuitem name="Pharmacy" groups="medicare.group_medicare_pharmacy" id="pharmacy_root" sequence="5" parent="medicare.medicare_menu"/>
        <menuitem name="Medicines" groups="medicare.group_medicare_pharmacy" id="menu_pharmacy_product"
                  parent="pharmacy_root"
                  sequence="2" action="pharmacy_product_act_window"/>
        <menuitem name="Scrap" groups="medicare.group_medicare_pharmacy" id="menu_pharmacy_scrap"
                  parent="pharmacy_root"
                  sequence="3" action="pharmacy_scrap_act_window"/>
        <menuitem name="Medicine Request" groups="medicare.group_medicare_pharmacy" id="menu_pharmacy_issuance_request"
                  parent="pharmacy_root"
                  sequence="1" action="pharmacy_issuance_request_act_window"/>
    </data>
</odoo>