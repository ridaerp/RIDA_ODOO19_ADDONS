<odoo>
    <record id="view_stock_scrap_form_inherit_gold" model="ir.ui.view">
    <field name="name">stock.scrap.form.inherit.gold</field>
    <field name="model">stock.scrap</field>
    <field name="inherit_id" ref="stock.stock_scrap_form_view2"/>
    <field name="arch" type="xml">
         <xpath  expr="//form/group/group/field[@name='product_id']" position="after">
                <field name="quantity"/>
        </xpath>
        <xpath  expr="//form/group" position="inside">
            <group string="Gold Calibration">
                <field name="actual_gold_percentage"/>
                <field name="net_gold_weight" readonly="1"/>
                <field name="scrap_qty_ca" readonly="1"/>
               
            </group>
        </xpath>
    </field>
</record>

</odoo>
