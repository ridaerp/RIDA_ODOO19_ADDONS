<odoo>
    <data>


        <record id="hr_overtime_request_form" model="ir.ui.view">
            <field name="name">Overtime By Batch form</field>
            <field name="model">hr.overtime.batch</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="action_submit" type="object" class="oe_highlight" invisible="state != 'draft'"
                                groups="base.group_user"/>
                        <button name="action_approve" string="Approve"
                                invisible="state != 'wlm'"
                                class="oe_highlight" groups="base_rida.rida_group_line_manager" type="object"/>
                        <button string="Approve" name="action_off_approve" type="object" class="oe_highlight"
                                invisible="state != 'hr_off'"
                                groups="hr.group_hr_user"/>
                        <button string="Approve" name="action_hr_manager_approve" type="object" class="oe_highlight"
                               invisible="state != 'w_hr_m'"
                                groups="base_rida.rida_hr_manager_notify"/>
                        <button string="Approve" name="approve_finance_manager" type="object" invisible="state != 'wfm'"
                                class="oe_highlight" groups="base_rida.rida_finance_manager"/>
                        <button string="Approve" name="approve_internal_audit" type="object"  invisible="state != 'internal_aud'"
                                class="oe_highlight" groups="base_rida.rida_internal_audit"/>
                        <button string="Approve" name="approve_operation_director" type="object" invisible="state != 'wod'"
                                class="oe_highlight" groups="base_rida.rida_group_site_manager"/>
                        <button string="Approve" name="approve_ccso" type="object" invisible="state != 'ccso'"
                                class="oe_highlight" groups="base_rida.rida_group_CCSO"/>
                        <button string="Set to Draft" name="action_draft"
                                groups="hr.group_hr_user,base_rida.rida_hr_manager_notify,base_rida.rida_finance_manager,base_rida.rida_internal_audit,base_rida.rida_group_site_manager,base_rida.rida_group_CCSO"
                                type="object" invisible="state != 'reject'"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['wlm', 'hr_off', 'w_hr_m', 'wfm', 'internal_aud', 'ccso', 'wod']" string="Reject"
                                groups="base_rida.rida_group_site_manager,base_rida.rida_hr_manager_notify,base_rida.rida_finance_manager,base_rida.rida_group_CCSO,base_rida.rida_group_line_manager,hr.group_hr_user"
                        />
                        <button string="Post Journal Entries" name="approve_accountant" type="object" invisible="state != 'wd'"
                                class="oe_highlight" groups="account.group_account_user"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,wlm,hr_off,w_hr_m,wfm,internal_aud,wod,wd"
                               invisible="user_type == 'hq'"/>
                        <field name="state_ccso" widget="statusbar" invisible="user_type != 'hq'"
                               statusbar_visible="draft,wlm,hr_off,w_hr_m,wfm,internal_aud,ccso,wd"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="user_type" invisible="1"/>
                                <field name="overtime_auth_id" string="Overtime Authorized" readonly="1"/>
                                <field name="req_id" readonly="1"/>
                                <field name="job_req_id" readonly="1"/>
                                <field name="department_id"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"
                                       readonly="state not in ['draft', 'wlm'] or overtime_auth_id"/>
                                <field name="company_id"
                                       required="1"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       readonly="state not in ['draft', 'wlm'] or overtime_auth_id"
                                />
                            </group>
                            <group>
                                <field name="description"
                                       readonly="state not in ['draft', 'wlm'] or overtime_auth_id"
                                       required="1" string="Detailed explanation why overtime is needed?"/>
                                <field name="month_selection"
                                       readonly="state not in ['draft', 'wlm'] or overtime_auth_id"
                                       required="1"/>
                                <field name="date"
                                       readonly="state not in ['draft', 'wlm'] or overtime_auth_id"
                                       required="1"/>

                            </group>
                        </group>
                        <group>
                            <group string="Overtime" invisible="state in ['draft', 'wlm']">
                                <field name="total_overtime" groups="account.group_account_user,hr.group_hr_user" readonly="1"/>
                                <field name="total_tax" groups="account.group_account_user,hr.group_hr_user" readonly="1"/>
                                <field name="total_net_overtime" groups="account.group_account_user,hr.group_hr_user" readonly="1"/>
                            </group>
                            <group string="Overtime Accounts" invisible="state in ['draft','wlm','hr_off','w_hr_m']"
                            >
                                <field name="overtime_account_id" groups="account.group_account_user"/>
                                <field name="tax_account_id" groups="account.group_account_user"/>
                                <field name="net_overtime_account_id" groups="account.group_account_user"/>
                                <field name="journal_id"
                                       invisible="not journal_id"
                                       groups="account.group_account_user"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Employees">
                                <field name="employees_line_ids" nolabel="1" readonly="state not in ['draft', 'wlm']"
                                       required="1">
                                    <list string="Employees" editable="bottom">

                                        <field name="employee_id"
                                               domain="['|',('department_id.parent_id', '=',parent.department_id),'|',('department_id.parent_id.parent_id', '=',parent.department_id),('department_id', '=',parent.department_id),('company_id', '=',parent.company_id)]"
                                               readonly="parent.overtime_auth_id"
                                               options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                               required="1"/>
                                        <field name="job_id"
                                               column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m']"/>
                                        <field name="work_from" required="1"
                                               column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m']"
                                        />
                                        <field name="work_to" required="1"
                                               column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m']"/>
                                        <field name="normal_hours" required="1"
                                               column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m']"/>
                                        <field name="amount_normal_hours"
                                               column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                               groups="hr.group_hr_user"/>
                                        <field name="holiday_hours" required="1"
                                               column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m','internal_aud']"/>
                                        <field name="amount_holiday_hours"
                                               column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                               groups="hr.group_hr_user"/>
                                        <field name="work_nat_hours"
                                               column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m','internal_aud']"/>
                                        <field name="amount_work_nat_hours"
                                               column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                               groups="hr.group_hr_user"/>
                                        <field name="gross" groups="hr_payroll.group_hr_payroll_user"
                                               column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"/>
                                        <field name="hour_rate"
                                               column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                               groups="hr.group_hr_user"/>
                                        <field name="amount_overtime_hour"
                                               column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                               groups="hr.group_hr_user"/>
                                        <field name="analytic_account_id"
                                               column_invisible="parent.state in ['draft', 'wlm']"/>
                                        <field name="overtime" sum="Total Overtime"
                                               column_invisible="parent.state in ['draft', 'wlm']"
                                               groups="hr_payroll.group_hr_payroll_user"/>
                                        <field name="tax" sum="Total Tax"
                                               column_invisible="parent.state in ['draft', 'wlm']"
                                               groups="hr_payroll.group_hr_payroll_user"/>
                                        <field name="net_overtime" sum="Total Net Overtime"
                                               column_invisible="parent.state in ['draft', 'wlm']"
                                               groups="hr_payroll.group_hr_payroll_user"/>
                                        <field name="remarks" string="Name of the project they will support"
                                               column_invisible="parent.state not in ['hr_off', 'w_hr_m']"/>
                                    </list>

                                    <form>
                                        <sheet>
                                            <group>
                                                <field name="employee_id"
                                                       domain="['|',('department_id.parent_id', '=',parent.department_id),'|',('department_id.parent_id.parent_id', '=',parent.department_id),('department_id', '=',parent.department_id),('company_id', '=',parent.company_id)]"
                                                       column_invisible="parent.state not in ['hr_off', 'w_hr_m']"
                                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                                       required="1"/>
                                                <field name="job_id"
                                                       column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m']"/>
                                                <field name="work_from" required="1"
                                                       column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m']"
                                                       readonly="parent.overtime_auth_id"

                                                />
                                                <field name="work_to" required="1"
                                                       column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m']"
                                                       readonly="parent.overtime_auth_id"
                                                />
                                                <field name="normal_hours" required="1"
                                                       column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m']"/>
                                                <field name="amount_normal_hours"
                                                       column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                                       groups="hr.group_hr_user"/>
                                                <field name="holiday_hours" required="1"
                                                       column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m','internal_aud']"/>
                                                <field name="amount_holiday_hours"
                                                       column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                                       groups="hr.group_hr_user"/>
                                                <field name="work_nat_hours"
                                                       column_invisible="parent.state not in ['draft', 'wlm', 'hr_off', 'w_hr_m','internal_aud']"/>
                                                <field name="amount_work_nat_hours"
                                                       column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                                       groups="hr.group_hr_user"/>
                                                <field name="gross" groups="hr_payroll.group_hr_payroll_user"
                                                       column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"/>
                                                <field name="hour_rate"
                                                       column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                                       groups="hr.group_hr_user"/>
                                                <field name="amount_overtime_hour"
                                                       column_invisible="parent.state not in ['hr_off', 'w_hr_m','internal_aud']"
                                                       groups="hr.group_hr_user"/>
                                                <field name="analytic_account_id"
                                                       column_invisible="parent.state in ['draft', 'wlm']"/>
                                                <field name="overtime" sum="Total Overtime"
                                                       column_invisible="parent.state in ['draft', 'wlm']"
                                                       groups="hr_payroll.group_hr_payroll_user"/>
                                                <field name="tax" sum="Total Tax"
                                                       column_invisible="parent.state in ['draft', 'wlm']"
                                                       groups="hr_payroll.group_hr_payroll_user"/>
                                                <field name="net_overtime" sum="Total Net Overtime"
                                                       column_invisible="parent.state in ['draft', 'wlm']"
                                                       groups="hr_payroll.group_hr_payroll_user"/>
                                                <field name="remarks" string="Name of the project they will support"
                                                       readonly="parent.overtime_auth_id"/>
                                            </group>
                                        </sheet>

                                    </form>

                                </field>


                            </page>
                        </notebook>
                    </sheet>
                     <chatter/>
                </form>
            </field>
        </record>

        <record id="hr_overtime_tree" model="ir.ui.view">
            <field name="name">Overtime By Batch tree</field>
            <field name="model">hr.overtime.batch</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="month_selection"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        <record id="overtime_batch_line_sheet_tree" model="ir.ui.view">
            <field name="name">Overtime Batch Sheet tree</field>
            <field name="model">overtime.batch.line</field>
            <field name="arch" type="xml">
                <list string="Overtime Bank Sheet">
                    <field name="request_id"/>
                    <field name="month_selection"/>
                    <field name="date"/>
                    <field name="company_id"/>
                    <field name="analytic_account_id"/>
                    <field name="employee_id"/>
                    <field name="b_account"/>
                    <field name="overtime"/>
                    <field name="tax"/>
                    <field name="net_overtime"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        <record id="overtime_batch_line_sheet" model="ir.actions.act_window">
            <field name="name">Overtime Bank Sheet</field>
            <field name="res_model">overtime.batch.line</field>
            <field name="view_mode">list</field>
            <field name="domain">[('request_state','=','posted')]</field>
            <field name="context">{'edit': 0,'create': 0}</field>
            <field name="view_id" ref="overtime_batch_line_sheet_tree"/>
        </record>
        <record id="hr_overtime_form_search" model="ir.ui.view">
            <field name="name">OverTime By Batch Search</field>
            <field name="model">hr.overtime.batch</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="department_id"/>
                    <group string="Group By">
                                                <filter name="by_year" string="By Year" domain="[]" context="{'group_by':'date:year'}"/>

                        <filter name="by_month" string="By Month" domain="[]" context="{'group_by':'month_selection'}"/>
                        <filter name="by_company" string="By Company" context="{'group_by':'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record model="ir.actions.server" id="action_hr_over_approve_confirm">
            <field name="name">Confirm</field>
            <field name="model_id" ref="rida_hr_overtime.model_hr_overtime_batch"/>
            <field name="binding_model_id" ref="rida_hr_overtime.model_hr_overtime_batch"/>
            <field name="state">code</field>
            <field name="code">
                action = records.action_multiple_confirm()
            </field>
            <field name='group_ids'
                   eval="[(4, ref('base_rida.rida_group_site_manager')),(4, ref('base_rida.rida_group_CCSO'))]"/>
        </record>

        <record id="hr_overtime_request_act" model="ir.actions.act_window">
            <field name="name">OverTime By Batch</field>
            <field name="res_model">hr.overtime.batch</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_by_year':1,'search_default_by_month':1}</field>
        </record>
        <menuitem name="Overtime" id="overtime_root_menu" parent="base_rida.cus_menu_hr_root" groups="base.group_user"/>
        <menuitem name="Overtime By Batch" id="overtime_menu" parent="overtime_root_menu"
                  action="hr_overtime_request_act"
                  groups="base_rida.rida_hr_manager_notify,hr.group_hr_user,account.group_account_user"/>
        <menuitem name="Overtime Bank Sheet" id="overtime_bank_batch" parent="overtime_root_menu"
                  action="overtime_batch_line_sheet" groups="hr.group_hr_user"/>
    </data>
</odoo>