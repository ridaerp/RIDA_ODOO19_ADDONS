<odoo>
    <data>


        <record id="hr_overtime_authorization_request_form" model="ir.ui.view">
            <field name="name">Overtime Authorization Request</field>
            <field name="model">overtime.auth</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="action_submit" type="object" class="oe_highlight"
                                invisible="state != 'draft'"
                                groups="base.group_user"/>
                        <button name="action_approve" string="Approve"
                                invisible="state != 'wlm'" class="oe_highlight"
                                groups="base_rida.rida_group_line_manager"
                                type="object"/>
                        <button string="Approve" name="action_off_approve" type="object" class="oe_highlight"
                                invisible="state != 'hr_off'"
                                groups="hr.group_hr_user"/>
                        <button string="Approve" name="action_hr_manager_approve" type="object" class="oe_highlight"
                                invisible="state != 'w_hr_m'"
                                groups="base_rida.rida_hr_manager_notify"/>
                        <button string="Approve" name="approve_operation_director" type="object"
                                invisible="state != 'wod'"
                                class="oe_highlight" groups="base_rida.rida_group_site_manager"/>
                        <button string="Approve" name="approve_ccso" type="object" invisible="state != 'ccso'"
                                class="oe_highlight" groups="base_rida.rida_group_CCSO"/>
                        <button string="Set to Draft" name="action_draft"
                                groups="base_rida.rida_hr_manager_notify,base_rida.rida_group_site_manager,base_rida.rida_group_CCSO,base_rida.rida_group_line_manager"
                                type="object" invisible="state != 'reject'"/>
                        <!--  <button string="Create Overtime" name="create_overtime_by_batch" type="object"
                                 class="oe_highlight"
                                 attrs="{'invisible': ['|',('show_button', '=', False),('state', '!=', 'auth')]}"/> -->

                        <button string="Create Overtime" name="create_overtime_by_batch" type="object"
                                class="oe_highlight"
                                invisible="state != 'auth'"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['wlm', 'hr_off', 'w_hr_m', 'ccso', 'wod']" string="Reject"
                                groups="hr.group_hr_user,base_rida.rida_group_site_manager,base_rida.rida_hr_manager_notify,base_rida.rida_group_CCSO,base_rida.rida_group_line_manager"
                        />
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,wlm,hr_off,w_hr_m,wod,auth"
                               invisible="user_type == 'hq'"/>
                        <field name="state_ccso" widget="statusbar" invisible="user_type != 'hq'"
                               statusbar_visible="draft,wlm,hr_off,w_hr_m,ccso,auth"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="set_overtime_by_batch" invisible="state != 'auth'"
                                    type="object" class="oe_stat_button" icon="fa-list-alt">
                                <field name="overtime_count" string="Overtime" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="user_type" invisible="1"/>
                                <!--                                <field name="show_button" invisible="1"/>-->
                                <field name="req_id" readonly="1"/>
                                <field name="job_req_id" readonly="1"/>
                                <field name="department_id"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       readonly="state not in ['draft']" required="1"/>
                                <field name="company_id"
                                       required="1"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       readonly="state not in ['draft']"
                                />
                            </group>
                            <group>
                                <field name="description" readonly="state not in ['draft']"
                                       required="1"/>
                                <field name="month_selection" readonly="state not in ['draft']"
                                       required="1"/>
                                <field name="date" readonly="state not in ['draft']"
                                       required="1"/>

                            </group>
                        </group>

                        <notebook>
                            <page string="Employees">
                                <field name="employees_line_ids" nolabel="1"
                                       readonly="state not in ['draft']">
                                    <list string="Employees" editable="bottom">
                                        <field name="employee_id"
                                               domain="[('department_id', 'child_of', parent.department_id), ('company_id', '=', parent.company_id)]"
                                               readonly="not parent.department_id"
                                               options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                               required="1"/>
                                        <field name="job_id"/>
                                        <field name="work_from" readonly="work_from" required="1"/>
                                        <field name="work_to" readonly="work_from" required="1"/>
                                        <field name="normal_hours" required="1"/>
                                        <field name="holiday_hours"/>
                                        <field name="work_nat_hours"/>
                                        <field name="department_id"/>
                                        <field name="remarks" required="1"
                                               string="Name of the project they will support"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="hr_overtime_authorization_tree" model="ir.ui.view">
            <field name="name">Overtime Authorization Request</field>
            <field name="model">overtime.auth</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="month_selection"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="hr_overtime_authorization_form_search" model="ir.ui.view">
            <field name="name">Overtime Authorization Request</field>
            <field name="model">overtime.auth</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="department_id"/>
                    <!-- <group string="Group By"> -->
                        <filter name="by_year" string="By Year" domain="[]" context="{'group_by':'date:year'}"/>
                        <filter name="by_month" string="By Month" domain="[]" context="{'group_by':'month_selection'}"/>
                        <filter name="by_company" string="By Company" context="{'group_by':'company_id'}"/>
                    <!-- </group> -->
                </search>

            </field>
        </record>


        <record id="hr_overtime_authorization" model="ir.actions.act_window">
            <field name="name">Overtime Authorization Request</field>
            <field name="res_model">overtime.auth</field>
            <field name="view_mode">list,form</field>
                        <field name="context">{'search_default_by_year':1,'search_default_by_month':1}</field>

        </record>

        <record model="ir.actions.server" id="action_hr_auth_over_approve_confirm">
            <field name="name">Confirm</field>
            <field name="model_id" ref="rida_hr_overtime.model_overtime_auth"/>
            <field name="binding_model_id" ref="rida_hr_overtime.model_overtime_auth"/>
            <field name="state">code</field>
            <field name="code">
                action = records.action_multiple_confirm()
            </field>
            <field name='group_ids'
                   eval="[(4, ref('base_rida.rida_group_site_manager')),(4, ref('base_rida.rida_group_CCSO'))]"/>
        </record>


        <menuitem name="Overtime Authorization Request" id="overtime_auth_request"
                  parent="rida_hr_overtime.overtime_root_menu"
                  action="hr_overtime_authorization" sequence="0"/>
    </data>
</odoo>