<odoo>
    <record id='view_stock_landed_cost_form_custom4' model='ir.ui.view'>
        <field name="name">stock.landed.cost.form</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_journal_id']" position="after">
                <field
                    name="currency_id"
                    readonly="state in ['done']"
                    groups="base.group_multi_currency"
                />
            </xpath>
            <xpath expr="//field[@name='cost_lines']//list/field[@name='name']" position="after">
                <field name="price_unit" force_save="1" groups="base.group_multi_currency"/>
                <field name="currency_price_unit" />
                <field name="currency_id" invisible="1" />
            </xpath>
        </field>
    </record>
</odoo>
