<?xml version="1.0" ?>
<odoo>
    <data>

        <!-- QHSE NCR -->

        <record model="ir.rule" id="rule_check_quality_ncr_creator">
            <field name="name">Check Creator</field>
            <field name="model_id" ref="model_quality_ncr"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record model="ir.rule" id="rule_employee_ncr_mng">
            <field name="name">Employee Ncr</field>
            <field name="model_id" ref="model_quality_ncr"/>
            <field name="domain_force">[('emp_assign_id', '=', user.id)]</field>
            <field name="groups"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

      <record id="quality_ncr_department_manager_rule" model="ir.rule">
            <field name="name">Department Managers Can See Their NCRs and Sub-Departments</field>
            <field name="model_id" ref="model_quality_ncr"/>
           <!--  <field name="domain_force">[
                ('department_id', 'child_of', user.employee_id.department_id.id)
                ]
            </field> -->
            <field name="domain_force">[(1, '=', 1)]</field>

            <field name="groups" eval="[(4, ref('base_rida.rida_group_line_manager'))]"/>
        </record>

        <record model="ir.rule" id="rule_check_ncr_mng">
            <field name="name">Manager Ncr</field>
            <field name="model_id" ref="model_quality_ncr"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('base_rida.rida_group_qhse_manager'))]"/>
        </record>


    </data>


</odoo>
