<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

    <!--  User modification request -->
    <record model="ir.rule" id="rule_check_mod_request_creator">
        <field name="name">Check Creator</field>
        <field name="model_id" ref="model_modification_request"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="groups"
               eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!--  Line Manager modification request -->
     <record model="ir.rule" id="rule_check_mod_request_l_mng">
        <field name="name">Line Manager Mod Request</field>
        <field name="model_id" ref="model_modification_request"/>
        <!-- <field name="domain_force">[('req_id.line_manager_id', '=', user.id)]</field> -->
            <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base_rida.rida_group_line_manager'))]"/>
    </record>
 
    <!--  Manager related to modification request -->
      <record model="ir.rule" id="rule_check_mod_request_mng">
            <field name="name">Manager Mod Request</field>
            <field name="model_id" ref="model_modification_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('base_rida.rida_group_hr_director')),(4, ref('base_rida.rida_group_ceo')),(4, ref('base_rida.rida_group_qhse_manager')),(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.group_fleet_director')),(4, ref('base_rida.rida_group_site_manager')),(4, ref('base_rida.rida_group_ict_team'))]"/>
        </record>

    </data>
</odoo>
