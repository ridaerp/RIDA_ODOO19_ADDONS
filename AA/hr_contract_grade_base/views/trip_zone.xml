<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="trip_permission_form_inherit_custom" model="ir.ui.view">
            <field name="name">trip.permission.form.inherit.custom</field>
            <field name="model">trip.permission</field>
            <field name="inherit_id" ref="hr_employee_main.trip_permission_form_view"/>   <!-- ضع هنا اسم الموديول الأصلي -->
            <field name="arch" type="xml">
                <xpath expr="//field[@name='trip_type']" position="after">
                    <field name="zone_id"
                           options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                           invisible="trip_type != 'external'" readonly="state != 'draft'" />
                </xpath>
            </field>
        </record>
    </data>
</odoo>