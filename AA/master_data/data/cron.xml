<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"> <record id="ir_cron_revoke_permission_access" model="ir.cron">
            <field name="name">Permission Request: Auto Revoke Expired Access</field>
            <field name="model_id" ref="model_permission_request"/> <field name="state">code</field>
            <field name="code">model._cron_revoke_expired_permissions()</field>
            <field name="user_id" ref="base.user_root"/> <field name="interval_number">1</field>
            <field name="interval_type">days</field> 
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + relativedelta(days=1)).strftime('%Y-%m-%d 00:00:01')"/>
        </record>

    </data>
</odoo>