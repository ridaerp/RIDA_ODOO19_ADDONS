<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="request_account_status" model="mail.message.subtype">
            <field name="name">Status Changed</field>
            <field name="res_model">request.account.account</field>
            <field name="default" eval="True"/>
            <field name="description">The Request Account Has been created</field>
        </record>
        <record id="request_account_rej_status" model="mail.message.subtype">
            <field name="name">Status Changed</field>
            <field name="res_model">request.account.account</field>
            <field name="default" eval="True"/>
            <field name="description">The Request Account Has been Rejected</field>
        </record>

        <record id="view_request_account_account_form" model="ir.ui.view">
            <field name="name">request.account.form</field>
            <field name="model">request.account.account</field>
            <field name="arch" type="xml">
                <form string="Request Account">
                    <header>
                        <button string="Submit" name="set_confirm" type="object" invisible="state not in ['draft']"
                                class="oe_highlight" groups="account.group_account_user"/>
                        <button string="Approve" name="set_advisor_confirm" type="object" invisible="state not in ['w_adv']"
                                class="oe_highlight" groups="account.group_account_manager"/>
                        <button string="Create Account" name="create_account" type="object" invisible="state not in ['md']"
                                class="oe_highlight" groups="base_rida.rida_group_master_data_manager"/>

                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                             invisible="state not in ['w_adv','md']"  string="Reject"
                                groups="account.group_account_manager,base_rida.rida_group_master_data_manager"
                        />

                        <field name="state" widget="statusbar" statusbar_visible="draft,w_adv,md,done"/>
                    </header>
                    <sheet string="Account">
                        <div class="oe_title">
                            <h1>
                                <field name="code_seq"/>
                            </h1>
                        </div>

                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" class="oe_inline" required="1"
                               readonly="state == 'done'"/>
                            </h1>
                        </div>
                        <br/>
                        <group>
                            <field name="new_account" invisible="state != 'done'"/>
                        </group>
                        <div name="project"/>
                        <group name="main">
                            <group>
                                <field name="code" string='Code'
                                  required="state == 'w_adv'" readonly="state not in ['w_adv','md']" />
                                <field name="reconcile"
                                    required="state == 'w_adv'" readonly="state not in ['w_adv','md']"/>
                                <field name="description" readonly="state not in ['w_adv','md']"/>

                            </group>
                            <group>
                                <field name="user_type_id" options="{'no_create': True}"
                                     required="state == 'w_adv'" readonly="state not in ['w_adv','md']"/>
                                <field name="company_id" options="{'no_create': True}"
                                       groups="base.group_multi_company"
                                     required="state == 'w_adv'" readonly="state not in ['w_adv','md']"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>


        <record id="master_acconut_tree_view" model="ir.ui.view">
            <field name="name">master account tree</field>
            <field name="model">request.account.account</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code_seq"/>
                    <field name="date"/>
                    <field name="req_id"/>
                    <field name="name"/>
                    <field name="user_type_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="account_request_form_search" model="ir.ui.view">
            <field name="name">acconut.request.search</field>
            <field name="model">request.account.account</field>
            <field name="arch" type="xml">
                <search>
                    <field name="code_seq"/>
                </search>
            </field>
        </record>


        <record id="account_request_act_window" model="ir.actions.act_window">
            <field name="name">Account Request</field>
            <field name="res_model">request.account.account</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem name="Generic Account" id="account_request_menu" parent="master_data"
                  action="account_request_act_window"
                  groups="account.group_account_user,base_rida.rida_group_master_data_manager"/>




 <menuitem id="menu_action_payment_term_form_scm" parent="purchase.menu_purchase_config" action="account.action_payment_term_form" sequence="1"/>



    </data>
</odoo>
