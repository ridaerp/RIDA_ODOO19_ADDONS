<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="trasnportation_fees_request_form_view" model="ir.ui.view">
            <field name="name">trasnportation.fees.price.form</field>
            <field name="model">update.transportation.prices</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="get_transpoartion_fees"
                                string="Get Locations Prices" type="object"
                                class="oe_highlight"
                                groups="hr_holidays.group_hr_holidays_manager,base_rida.rida_group_CCSO,base_rida.rida_group_COO"
                                invisible="state != 'draft'"/>
                        <button string="Confirm" name="set_confirm" type="object" class="oe_highlight" invisible="state != 'draft'"
                                groups="hr_holidays.group_hr_holidays_manager"/>
                        <button string="Submit" name="action_submit" type="object" class="oe_highlight" invisible="state != 'wlm_approve'"
                                groups="hr_holidays.group_hr_holidays_manager,base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                          <button string="Approve" name="approve_finance_manager" type="object" invisible="state != 'wfm'"
                                class="oe_highlight" groups="base_rida.rida_finance_manager"/>
                        <button string="Approve" name="update_transportation_price" type="object" invisible="state != 'coo'"
                                class="oe_highlight"
                                groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                           invisible="state != 'coo'"  string="Reject"
                                groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"
                        />
                        <button name="set_draft" string="Set To Draft" type="object" invisible="state != 'reject'"
                                groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,wlm_approve,wfm,coo,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="req_id"/>
                                <field name="department_id" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="description" readonly="state == 'done'"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Update Transportation Fees For Rotation">
                                <field name="update_transportation_price_line_ids"
                                       nolabel="1">
                                    <list string="Update Transportation Fees For Rotation"
                                          decoration-success="is_colored" decoration-bf="is_colored" editable="bottom"
                                          create="false" delete="false">
                                        <field name="location" readonly="1"/>
                                        <field name="previous_amount" readonly="1"/>
                                        <field name="new_amount" readonly="parent.state != 'draft'"/>
                                        <field name="is_colored" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>


                </form>
            </field>
        </record>


        <record id="master_data_update_transportation_price_search_tree_view" model="ir.ui.view">
            <field name="name">update transportation price tree</field>
            <field name="model">update.transportation.prices</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="department_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="master_data_update_transportation_price_search" model="ir.ui.view">
            <field name="name">update.transportation.price.search</field>
            <field name="model">update.transportation.prices</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="master_data_update_trasnportation_price_action" model="ir.actions.act_window">
            <field name="name">Update Transportation Fees For Rotation</field>
            <field name="res_model">update.transportation.prices</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Update Transportation Fees For Rotation" id="master_data_update_trasnportation_price"
                  parent="master_data"
                  action="master_data_update_trasnportation_price_action"
                  sequence="20"
                  groups="hr_holidays.group_hr_holidays_manager,base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
    </data>
</odoo>