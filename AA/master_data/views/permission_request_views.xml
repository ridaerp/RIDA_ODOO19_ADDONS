<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_permission_request_tree" model="ir.ui.view">
            <field name="name">permission.request.tree</field>
            <field name="model">permission.request</field>
            <field name="arch" type="xml">
                <list decoration-info="state == 'draft'" decoration-warning="state in ('manager', 'ict')" decoration-success="state == 'approved'">
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="requester_id"/>
                    <field name="create_date" string="Request Date"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state in ('manager', 'ict')" decoration-success="state == 'approved'"/>
                </list>
            </field>
        </record>

        <record id="view_permission_request_form" model="ir.ui.view">
            <field name="name">permission.request.form</field>
            <field name="model">permission.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_submit" string="Submit" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                        <button name="action_manager_approve" string="Approve" type="object" invisible="state != 'manager'" class="oe_highlight"/>
                        <button name="action_ict_approve" string="Confirm (ICT)" type="object" invisible="state != 'ict'" class="oe_highlight" groups="base.group_system,base_rida.rida_group_master_data_manager"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action" invisible="state not in ['manager', 'ict']" string="Reject" groups="base_rida.rida_group_master_data_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,manager,ict,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="request_type" widget="radio" options="{'horizontal': true}" readonly="state != 'draft'"/>
                                <field name="employee_id"
                                       invisible="request_type == 'new'"
                                       required="request_type == 'existing'"
                                       domain="[('user_id', '!=', False), ('user_id.share', '=', False)]"
                                       readonly="state != 'draft'"/>
                                <field name="user_id" string="Related User" invisible="request_type == 'new'" readonly="1" force_save="1"/>
                                <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="requester_id"/>
                                <field name="is_temporary" readonly="state != 'draft'"/>
                                <field name="date_to" invisible="not is_temporary" required="is_temporary" readonly="state != 'draft'"/>
                            </group>
                        </group>

                        <group string="Employee Information">
                            <group>
                                <field name="employee_name" required="1" readonly="state != 'draft' or request_type == 'existing'" force_save="1"/>
                            </group>
                            <group>
                                <field name="employee_email" required="1" readonly="state != 'draft' or request_type == 'existing'" force_save="1"/>
                            </group>
                        </group>

                        <group>
                            <field name="requested_access_description" placeholder="e.g. I need access to create Sales Orders and view Reports" readonly="state != 'draft'"/>
                            <field name="reason" placeholder="Why do you need these permissions?" readonly="state != 'draft'"/>
                        </group>

                        <notebook>
                            <page string="Access Details">
                                <group string="Companies Access Rights">
                                    <field name="requested_company_ids" widget="many2many_tags"
                                           options="{'no_create': True}"
                                           readonly="state == 'approved'"
                                           placeholder="Select companies to grant access..."/>
                                </group>

                                <group string="Current Groups Status" invisible="request_type == 'new'">
                                    <field name="existing_group_ids" widget="many2many_tags" readonly="1"/>
                                </group>

                                <group string="Access Rights Assignment (ICT Only)">
                                    <field name="user_type" invisible="request_type != 'new'" required="request_type == 'new' and state == 'ict'"/>
                                    <group string="Add Permissions">
                                        <field name="group_ids" widget="many2many_tags"
                                               options="{'no_create': True}"
                                               domain="[('id', 'not in', existing_group_ids)]"
                                               readonly="state == 'approved'"/>
                                    </group>
                                    <group string="Remove Permissions" invisible="request_type == 'new'">
                                        <field name="groups_to_remove_ids" widget="many2many_tags"
                                               options="{'no_create': True}"
                                               domain="[('id', 'in', existing_group_ids),]"
                                               readonly="state == 'approved'"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_permission_request_search" model="ir.ui.view">
            <field name="name">permission.request.search</field>
            <field name="model">permission.request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="requester_id"/>
                    <filter string="My Requests" name="my_requests" domain="[('requester_id', '=', uid)]"/>
                    <filter string="Waiting Manager" name="waiting_manager" domain="[('state', '=', 'manager')]"/>
                    <filter string="Waiting ICT" name="waiting_ict" domain="[('state', '=', 'ict')]"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                </search>
            </field>
        </record>

        <record id="action_permission_request" model="ir.actions.act_window">
            <field name="name">Permission Requests</field>
            <field name="res_model">permission.request</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_permission_request_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first permission request!
                </p>
            </field>
        </record>

        <menuitem id="menu_permission_request_act"
                  name="User/Permission Request"
                  parent="master_data"
                  action="action_permission_request"
                  sequence="7"/>
    </data>
</odoo>