        <field name="name">Purchase Contracts</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">purchase.contract</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="material_request.view_purchase_contract_filter"/>
             
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create Contract 
              </p>
            </field>
        </record>



 <record id="action_purchase_contract_to_so" model="ir.actions.act_window">
        <field name="name">Purchase Contracts</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">purchase.contract</field>
            <!-- <field name="view_id" ref="purchase.purchase_order_kpis_tree"/> -->
            <field name="search_view_id" ref="purchase.purchase_order_view_search"/>
             <field name="context">{'default_contract_id':active_id,
                            'default_user_id': False,}</field>
            <field name="domain">[('contract_id','=',active_id)] </field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create Contract Payment
              </p>
            </field>
        </record>

 


            <record id="purchase_payment_order_tree" model="ir.ui.view">
            <field name="name">request.quotation.inherit</field>
            <field name="model">purchase.order</field>
            <field name="arch" type="xml">
                <list edit="1" create="1">
                
                    <field name="name" string="Reference" readonly="1"/>
                    <field name="date_order" invisible="not context.get('quotation_only', False)" optional="show"/>
                    <field name="date_approve" invisible="context.get('quotation_only', False)" optional="show"/>
                    <field name="partner_id" readonly="1"/>
                    <field name="company_id" readonly="1" options="{'no_create': True}" groups="base.group_multi_company" optional="show"/>
                    <field name="date_planned" invisible="context.get('quotation_only', False)" optional="show"/>
                    <field name="user_id" optional="show"/>
                    <field name="origin" optional="show"/>
                    <field name="state" optional="show"/>
                    <field name="invoice_status" optional="hide"/>
                    <field name="activity_exception_decoration" widget="activity_exception"/>
                </list></field>
            </record>
            

       <record id="action_payment_tree_inerhit" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="material_request.purchase_payment_order_tree"/>
            <field name="act_window_id" ref="material_request.action_purchase_contract_to_so"/>
        </record>

        <record id="action_payment_request_inerit" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="material_request.payment_request_form"/>
            <field name="act_window_id" ref="material_request.action_purchase_contract_to_so"/>
        </record>

     



