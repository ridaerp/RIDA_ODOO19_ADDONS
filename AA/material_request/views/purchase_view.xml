<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <record id="purchase_order_form_inherit" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="replace">
                    <header>
                        <button name="action_rfq_send" invisible="state != 'draft'" string="Send by Email" type="object"
                                context="{'send_rfq':True}" class="oe_highlight" groups="purchase.group_purchase_user"/>


                        <button name="print_quotation" string="Print RFQ" type="object" invisible="state != 'draft'"
                                class="oe_highlight" groups="purchase.group_purchase_user"/>
                        <button name="go_to_prm" type="object" string="Send To Procurement Manager" class="oe_highlight"
                                invisible="state not in ['sent', 'draft'] or user_type_ == 'rohax'"
                                groups="purchase.group_purchase_user"/>


                        <button name="line_approve" invisible="state != 'line_approve'" string="Approve" type="object" context="{'send_rfq':True}" class="oe_highlight" groups="base_rida.rida_group_line_manager"/>




                        <button name="button_approve" type="object" invisible="state != 'to_approve'"
                                string="Approve Order"
                                class="oe_highlight" groups="purchase.group_purchase_manager"/>
                        <button name="action_create_invoice" string="Create Bill" type="object" class="oe_highlight"
                                context="{'create_bill':True}"
                                invisible="state not in ('purchase', 'done') or invoice_status in ('no', 'invoiced')"
                                groups="purchase.group_purchase_user"/>


                        <button name="make_landed_cost_in_po" string="Create Landed Costs" type="object"
                                invisible="state not in ('purchase', 'done')"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>

                        <button name="make_ovearses_wizard" string="Create Overseas Payment" type="object"
                                groups="base_rida.rida_group_supply_chain_director" invisible="contract_purchased == True or state !='purchase'"/>

                         <button name="make_ovearses_wizard" string="Create Overseas Payment" type="object"  context="{'default_is_contract': True}"
                                groups="material_request.group_contract_manager" invisible="contract_purchased == False or state !='purchase'"/>             


                        <button name="action_create_sale_order"
                                type="object"
                                string="Create Sale Order"
                                class="btn-primary" invisible="state not in ('purchase', 'done')"/>

                        <button string="Advance Payment" type="object" name="action_advance_payment"
                                invisible="state not in ['purchase']"
                                groups="account.group_account_user"/>

                        <button name="action_open_certificates" type="object" string="Certificate of Achievement"  class="btn-secondary"
                                 invisible="has_service_lines != True"
                                   />
                <button name="go_to_sum" type="object"
                        invisible="state not in ['sent','prm','sum','contract_manager'] or contract_purchased"
                        string="Approve"
                        class="oe_highlight"
                        groups="base_rida.rida_group_supply_chain_manager,material_request.group_contract_manager"/>

                        <button name="go_to_sud" type="object" invisible="state != 'sud'" string="SCD Approve "
                                class="oe_highlight"
                                groups="base_rida.rida_group_supply_chain_director"/>

                        <button name="go_to_fm" type="object" invisible="state != 'fm'"
                                string="Finance Manager Approval "
                                class="oe_highlight"
                                groups="base_rida.rida_finance_manager"/>

                        <button name="action_rfq_send" string="Re-Send by Email" type="object"
                                context="{'send_rfq':True}"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>
                        <button name="print_quotation" string="Print RFQ" type="object" invisible="state != 'sent'"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>

                        <button name="%(purchase_order_reject_action)d" type="action"
                                invisible="state not in ['prm','sum']" string="Reject"
                                groups="base.group_user"/>

                        <button name="%(purchase_order_reject_action)d" type="action"
                                invisible="state not in ['sud','contract_manager']"
                                string="Reject" groups="base.group_user"/>

                        <button name="button_confirm" type="object"
                                invisible="state not in ['site','ccso','fleet_director']"
                                string="Confirm Order" class="oe_highlight"
                                groups="base_rida.rida_group_site_manager,base_rida.rida_group_CCSO"/>

                        <button name="button_confirm" type="object"
                                invisible="user_type_ != 'rohax' or state == 'purchase'"
                                string="Confirm Order" class="oe_highlight"
                        />
                        <button name="button_confirm" type="object" invisible="state != 'contract_manager'"  string="Confirm Order" class="oe_highlight" id="bid_confirm" groups="material_request.group_contract_manager"/>

                        <button name="%(purchase_order_reject_action)d" type="action"
                                invisible="state not in ['ccso','site','finance_manager']"
                                string="Reject"
                                groups="base_rida.rida_group_site_manager,base_rida.rida_group_CCSO"/>


                        <button name="action_rfq_send" invisible="state not in ['purchase']" string="Send PO by Email"
                                type="object"
                                context="{'send_rfq':False}"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>
                        <button name="action_create_invoice" string="Create Bill" type="object"
                                context="{'create_bill':True}"
                                invisible="state not in ('purchase', 'done') or invoice_status not in ('no', 'invoiced') or order_line == []"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>
                        <button name="button_draft" invisible="state not in ['cancel','reject']" string="Set to Draft"
                                type="object"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>

                        <button name="button_cancel"
                                invisible="state not in ['draft','to_approve','sent','purchase','ccso','site']"
                                string="Cancel" type="object"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user,base_rida.rida_group_site_manager,base_rida.rida_group_CCSO"/>


                        <button name="button_lock" type="object" string="Lock" invisible="state != 'purchase'"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>
                        <button name="button_unlock" type="object" string="Unlock" invisible="state != 'done'"
                                groups="purchase.group_purchase_manager"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,sent,purchase" readonly="1"/>

                        <field name="contract_purchased" invisible="1"/>

                    </header>
                </xpath>

                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </xpath>


                <xpath expr="//field[@name='partner_ref']" position="after">
                    <field name="po_overeas_ref" readonly="1"/>
                    <field name="supplier_overseas" readonly="1"/>
                    <field name="has_service_lines" invisible="1"/>
                </xpath>


                <xpath expr="//field[@name='partner_ref']" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </xpath>

                <xpath expr="//field[@name='currency_id']" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </xpath>
                <xpath expr="//field[@name='date_order']" position="attributes">
                    <attribute name="readonly">state in ('draft', 'sent')</attribute>
                </xpath>

                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </xpath>
                <xpath expr="//field[@name='fiscal_position_id']" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </xpath>
                <xpath expr="//field[@name='payment_term_id']" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </xpath>
                <xpath expr="//field[@name='effective_date']" position="attributes">
                    <attribute name="string">Warehouse Receive</attribute>
                </xpath>


                <!-- Add smart button for Certificates -->
                <xpath expr="//sheet//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button" type="object" name="action_open_certificates" icon="fa-certificate"
                          invisible="has_service_lines != True">
                        <field string="Certificates" name="certificate_ids" widget="statinfo"/>
                    </button>
                </xpath>





                <xpath expr="//button[@name='action_view_invoice']" position="after">


                    <button string="Landed Costs" type="object"
                            name="action_view_landed_costs" invisible="state not in ['purchase']"
                            class="oe_stat_button" icon="fa-plus-square"
                            groups="stock.group_stock_user,purchase.group_purchase_user,account.group_account_user"
                    />

                    <button string="Overseas Payment" type="object"
                            name="action_view_overseas_payment"
                            class="oe_stat_button" icon="fa-plus-square"
                            groups="base_rida.rida_group_CCSO,base_rida.group_finance_director,base_rida.rida_group_supply_chain_director,base_rida.rida_group_supply_chain_manager,purchase.group_purchase_user"
                    />
                </xpath>


                <!-- change notes to new field -->
                <!-- <xpath expr="//field[@name='notes']" position="replace">
                    <field name="other_note"/>
                </xpath> -->

             <xpath expr="//field[@name='picking_type_id']" position="after">
                                    <field name="purchase_type" 
                                           readonly="state == 'purchase'" 
                                    />
                                     <field name="payment_company_id" 
                                           readonly="state == 'purchase'"  invisible="contract_purchased == False or purchase_type !='overseas'"
                                    />
                </xpath>


                <xpath expr="//field[@name='currency_id']" position="before">
                    <field name="date_planned" readonly="state not in ('draft', 'sent')"
                           string="Delivery Date"/>
                    <field name="request_id" force_save="1"
                           readonly="1" string="Main Material Request"
                    />
                    
                    <field name="request_ids" force_save="1" widget="many2many_tags"
                           readonly="1" string="Material Request Merged"
                    />
                  
                    <field name="ovearseas_id" force_save="1"
                           readonly="1"
                    />

                 <field name="assigned_data"/>
                    <field name="order_cycle_days"/>
                    <field name="processed_days"/>
                    <field name="weight_request_id" readonly="1" invisible="ore_purchased != True"/>

                    <field name="department_id" force_save="1"
                           readonly="1"
                    />
                    <field name="is_selected" readonly="0"/>



                    <!-- <field name="paid_amount" readonly="1"/> -->

                    <field name="user_type_" invisible="1"

                    />

                    <!-- marsa -->
                    <field name="inspection_id" invisible="1"/>


                    <field name="ore_purchased" invisible="1"/>
                   

                </xpath>

                <xpath expr="//field[@name='tax_totals']" position="after">
                    <field name="paid_amount" colspan="2" readonly="1"/>
                    <field name="amount_due" colspan="2" readonly="1"/>
                </xpath>


                <xpath expr="//notebook" position="inside">
                    <page string="Notes">

                        <group>
                            <field name="note" placeholder="Internal Note"/>
                            <field name="user_type" invisible="0"/>

                        </group>

                    </page>

                    <!-- ekhlas code add fleet info to PO-->
                    <page string="Equipments" invisible="user_type != 'fleet'">
                        <group>
                            <group>
                                <field name="eq_fleet" readonly="1"/>
                                <field name="code"/>
                                <field name="model"/>
                                <field name="engine"/>
                                <field name="year"/>
                            </group>
                            <group>
                                <field name="plate"/>
                                <field name="type"/>
                                <field name="category"/>
                                <field name="vin"/>
                                <field name="engine_serial"/>

                            </group>

                        </group>
                    </page>


                </xpath>

            </field>
        </record>

        <record id="purchase_order_form_service_inherit" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">


                <xpath expr="//field[@name='partner_ref']" position="after">
                    <!-- <field name="request_id"/> -->
                    <field name="has_mr" invisible="1"/>
                    <field name="payment_state" invisible="1"/>
                    <field name="item_type" string="PO Type"
                           invisible="1"
                           required="0" readonly="state not in ('draft', 'sent')"/>
                </xpath>

                <xpath expr="//field[@name='date_order']" position="after">
                    <field name="priority1" readonly="state not in ('draft', 'sent')"/>

                </xpath>

                <xpath expr="//field[@name='amount_total']" position="after">
                    <field name="has_mr" invisible="1"/>

                    <field name="mr_total" widget="monetary" options="{'currency_field': 'company_currency'}"
                           groups="account.group_account_manager" invisible="has_mr == False"/>
                </xpath>

                <!-- added by ekhlas -->
                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="required">state == 'draft'</attribute>
                    <attribute name="context">{'user_id': uid}</attribute>

                </xpath>

                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="part_number"/>
                </xpath>


                <xpath expr="//field[@name='price_subtotal']" position="after">
                    <field name="request_line_id"/>
                </xpath>


            </field>
        </record>

        <record id="view_purchase_order_filter_inherit" model="ir.ui.view">
            <field name="name">request.quotation.select.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <filter name="group_state" string="Status" context="{'group_by':'state'}"/>
                </xpath>
            </field>
        </record>


        <!--      Inherit purchase list view -->
        <!-- add lines ekhlas. code -->

        <record id="po_inherit_list" model="ir.ui.view">
            <field name="name">Purchase Order List</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_view_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='date_approve']" position="before">
                    <field name="create_date" string="Order Date" optional="show"/>
                </xpath>

                <xpath expr="//field[@name='company_id']" position="before">
                    <field name="department_id" string="Department"/>

                </xpath>
                <!-- payment status -->
                <xpath expr="//field[@name='state']" position="before">
                    <field name="payment_state" widget="badge"/>

                </xpath>


                <xpath expr="//field[@name='company_id']" position="attributes">
                    <field name="readonly">True</field>

                </xpath>


            </field>
        </record>


        <record id="purchase_order_tree_view_qutation" model="ir.ui.view">
            <field name="name">purchase.order.tree.qutation</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="arch" type="xml">
                <field name="state" position="after">
                    <field name="payment_state" widget="badge"/>
                </field>
            </field>
        </record>


        <record model="ir.actions.server" id="action_po_confirm">
            <field name="name">Confirm PO</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="binding_model_id" ref="purchase.model_purchase_order"/>
            <field name="state">code</field>
            <field name="code">
                action = records.action_multiple_confirm()
            </field>
            <field name='group_ids' eval="[(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.rida_group_site_manager'))]"/>
        </record>


        <!-- add lines ekhlas code -->


        <record id="purchase_order_tree_view_inherit" model="ir.ui.view">
            <field name="name">purchase.order.tree.inherit.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="create_date" string="Order Date"/>
                </xpath>


                <xpath expr="//field[@name='company_id']" position="before">
                    <field name="department_id" string="Department"/>

                </xpath>

                <xpath expr="//field[@name='activity_ids']" position="after">
                    <field name="ore_purchased" invisible="1"/>
                    <field name="average" invisible="ore_purchased != True"/>
                    <field name="weight_request_qty" invisible="ore_purchased != True"/>
                </xpath>


            </field>
        </record>

        <!-- update processing days  run schedule-->

        <record id="ir_cron_update_processed_days" model="ir.cron">
            <field name="name">Update Processed Days</field>
            <field name="model_id" ref="model_purchase_order"/>
            <field name="state">code</field>
            <field name="code">model._update_processed_days()</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="active" eval="True"/>
        </record>

        <record id="purchase_order_form_inherit1" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <field name="partner_id" position="replace">
                    <field name="partner_id" widget="res_partner_many2one" string="Vendor"
                           domain="[('category_id','not ilike','rock'),('category_id','not ilike','tail')]"
                           context="{'search_default_supplier': 1,'res_partner_search_mode': 'supplier', 'default_is_company': True, 'default_supplier_rank': 1}"
                           readonly="state in ['purchase', 'done', 'cancel']"
                           placeholder="Name, TIN, Email, or Reference" force_save="1"/>
                </field>
                <field name="partner_ref" position="after">
                    <field name="contract_id"
                           domain="[('state', 'in', ('in_progress', 'open', 'ongoing')), ('vendor_id', 'in', (partner_id, False)), ('company_id', '=', company_id)]"/>
                </field>
            </field>
        </record>

        <record id="purchase_order_search_inherit1" model="ir.ui.view">
            <field name="name">purchase.order.list.select.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='approved']" position="after">
                    <filter string="Contract" name="contract" domain="[('contract_id', '!=', False)]"
                            help="Purchase Orders with contract"/>
                </xpath>
            </field>
        </record>


        <record id="view_stock_landed_costs_form_inherit_custom2" model="ir.ui.view">
            <field name="name">stock.landed.cost.inherit</field>
            <field name="model">stock.landed.cost</field>
            <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='vendor_bill_id']" position="before">
                    <field name="partner_id"/>
                    <field name="analytic_account_id"/>

                </xpath>


            </field>
        </record>


        <record id="view_purchase_order_search_inherit" model="ir.ui.view">
            <field name="name">request.quotation.search.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="request_id"/>

                </xpath>
            </field>
        </record>


        <record id="purchase_orde_tree" model="ir.ui.view">
            <field name="name">request.quotation.inherit</field>
            <field name="model">purchase.order</field>
            <field name="arch" type="xml">
                <list edit="1" create="0">

                    <field name="name" string="Reference" readonly="1"/>
                    <field name="date_order" invisible="not context.get('quotation_only', False)" optional="show"/>
                    <field name="date_approve" invisible="context.get('quotation_only', False)" optional="show"/>
                    <field name="partner_id" readonly="1"/>
                    <field name="company_id" readonly="1" options="{'no_create': True}"
                           groups="base.group_multi_company" optional="show"/>
                    <field name="date_planned" invisible="context.get('quotation_only', False)" optional="show"/>
                    <field name="user_id" optional="show"/>
                    <field name="origin" optional="show"/>
                    <field name="state" optional="show"/>
                    <field name="invoice_status" optional="hide"/>
                    <field name="activity_exception_decoration" widget="activity_exception"/>
                </list>
            </field>
        </record>

        <record id="landed_cost_inherit_tree" model="ir.ui.view">
            <field name="name">stock.landed.cost.inherit.tree</field>
            <field name="model">stock.landed.cost</field>
            <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='state']" position="before">
                    <field name="payment_state"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
