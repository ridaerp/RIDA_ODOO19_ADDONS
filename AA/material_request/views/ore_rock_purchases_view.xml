<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ORe Purchase -->

        <record id="action_ore_po_purchases" model="ir.actions.act_window">
            <field name="name">Ore/Rock Purcharses</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('ore_purchased','=',True)]</field>
            <field name="context">{'default_ore_purchased':True}</field>
            <field name="search_view_id" ref="purchase.purchase_order_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create ORE/ROCK PURCHASES
                </p>
            </field>
        </record>


        <record id="purchase.purchase_rfq" model="ir.actions.act_window">
            <field name="name">Requests for Quotation</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">list,kanban,form,pivot,graph,calendar,activity</field>
            <field name="view_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="domain">[('ore_purchased','=',False),
                ('contract_purchased','=',False)
                ]
            </field>
            <field name="search_view_id" ref="purchase.view_purchase_order_filter"/>
            <field name="context">{'quotation_only': True}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No request for quotation found. Let's create one!
                </p>
                <p>
                    Requests for quotation are documents that will be sent to your suppliers to request prices for
                    different products you consider buying.
                    Once an agreement has been found with the supplier, they will be confirmed and turned into purchase
                    orders.
                </p>
            </field>
        </record>


        <record id="purchase.purchase_form_action" model="ir.actions.act_window">
            <field name="name">Purchase Orders</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">list,kanban,form,pivot,graph,calendar,activity</field>
            <field name="view_id" ref="purchase.purchase_order_view_tree"/>
            <field name="domain">[('ore_purchased','=',False),
                ('contract_purchased','=',False) ]
            </field>
            <field name="search_view_id" ref="purchase.purchase_order_view_search"/>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No purchase order found. Let's create one!
                </p>
                <p>
                    Once you ordered your products to your supplier, confirm your request for quotation and it will turn
                    into a purchase order.
                </p>
            </field>
        </record>


        <record id="purchase_order_form_inherith" model="ir.ui.view">
            <field name="name">purchase.order.form</field>
            <field name="model">purchase.order</field>
            <field name="arch" type="xml">
                <form string="Purchase Order" class="o_purchase_order">
                    <header>
                        <button name="action_rfq_send" invisible="state not in ['draft']" string="Send by Email"
                                type="object" context="{'send_rfq':True}" class="oe_highlight"/>
                        <button name="print_quotation" string="Print RFQ" type="object"
                                invisible="state not in ['draft']" class="oe_highlight" groups="base.group_user"/>
                        <button name="go_to_prm" type="object" invisible="state not in ('sent') or has_mr == False"
                                string="Send To Procurement Manager" class="oe_highlight"/>
                        <button name="button_approve" type="object" invisible="state not in ['to_approve']"
                                string="Approve Order" class="oe_highlight"
                                groups="material_request.group_ore_rock_supply_chain_manager"/>
                        <button name="action_create_invoice" string="Create Bill" type="object" class="oe_highlight"
                                context="{'create_bill':True}"
                                invisible="state not in ('purchase', 'done') or invoice_status in ('no', 'invoiced')"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>
                        <button name="button_draft" invisible="state not in ['reject','cancel']" string="Set to Draft"
                                type="object"/>
                        <button name="button_create_landed_costs" string="Create Landed Costs" type="object"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"
                                invisible="state not in ['purchase']"/>
                        <button name="action_rfq_send" string="Re-Send by Email" type="object"
                                context="{'send_rfq':True}"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>
                        <button name="print_quotation" string="Print RFQ" type="object"
                                invisible="state not in ['sent']" groups="base.group_user"/>
                        <button name="go_to_prm" type="object" string="Send To Procurement Manager"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"
                                invisible="state not in ('draft','sent')"/>
                        <button name="%(purchase_order_reject_action)d" type="action" invisible="state != 'prm'"
                                string="Reject" groups="base.group_user"/>
                        <button name="go_to_ccso" type="object" invisible="state != 'sum'" string="Approve"
                                class="oe_highlight"
                                groups="material_request.group_ore_rock_supply_chain_manager"/>
                        <button name="%(purchase_order_reject_action)d" type="action" invisible="state != 'sum'"
                                string="Reject" groups="material_request.group_ore_rock_supply_chain_manager"/>
                        <button name="button_confirm" type="object"
                                invisible="state not in ['site','fleet_director','ccso']" string="Confirm Order"
                                class="oe_highlight"
                                groups="base_rida.rida_group_site_manager,base_rida.rida_group_CCSO,base_rida.rida_group_COO,base_rida.group_fleet_director"/>
                        <button name="%(purchase_order_reject_action)d" type="action"
                                invisible="state not in ('ccso', 'site')" string="Reject"
                                groups="base_rida.rida_group_site_manager,base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <button name="action_rfq_send" invisible="state not in ['purchase']" string="Send PO by Email"
                                type="object" context="{'send_rfq':False}"/>
                        <button name="action_create_invoice" string="Create Bill" type="object"
                                context="{'create_bill':True}"
                                invisible="state not in ('purchase', 'done') or invoice_status not in ('no', 'invoiced') and not order_line"
                                groups="purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"/>
                        <button name="button_draft" invisible="state not in ['cancel']" string="Set to Draft"
                                type="object"/>
                        <button name="button_cancel"
                                groups="stock.group_stock_user,purchase.group_purchase_user,material_request.group_ore_rock_purchase_user,base_rida.rida_group_site_manager,base_rida.rida_group_CCSO,base_rida.rida_group_COO,base_rida.group_fleet_director"
                                invisible="state not in ['draft','to_approve','purchase','sent','ccso','site']"
                                string="Cancel" type="object"/>
                        <button name="button_lock" type="object" string="Lock" invisible="state not in ['purchase']"/>
                        <button name="button_unlock" type="object" string="Unlock" invisible="state not in ['done']"
                                groups="material_request.group_ore_rock_supply_chain_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,sent,purchase" readonly="1"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button type="object" name="action_view_invoice"
                                    class="oe_stat_button"
                                    icon="fa-pencil-square-o"
                                    invisible="invoice_count == 0 or state in ('draft','sent','to approve')">
                                <field name="invoice_count" widget="statinfo" string="Vendor Bills"/>
                                <field name='invoice_ids' invisible="1"/>
                            </button>
                            <button type="object"
                                    name="action_view_picking"
                                    class="oe_stat_button"
                                    icon="fa-truck" invisible="picking_ids == []">
                                <field name="incoming_picking_count" widget="statinfo" string="Receipt"
                                       help="Incoming Shipments"/>
                                <field name="picking_ids" invisible="1"/>
                            </button>

                            <button string="Landed Costs" type="object"
                                    name="action_view_landed_costs" invisible="state not in ['purchase']"
                                    class="oe_stat_button" icon="fa-plus-square"
                                    groups="stock.group_stock_user,purchase.group_purchase_user,material_request.group_ore_rock_purchase_user"
                            />

                        </div>
                        <div class="oe_title">
                            <span class="o_form_label" invisible="state not in ('draft','sent')">Request for Quotation
                            </span>
                            <span class="o_form_label" invisible="state in ('draft','sent')">Purchase Order</span>
                            <h1>
                                <field name="priority" widget="priority" class="mr-3"/>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                         <group>
                            <group>
                                <field name="partner_id" readonly="state in ['purchase', 'done', 'cancel']"
                                   widget="res_partner_many2one"
                                   context="{'res_partner_search_mode': 'supplier', 'show_vat': True}"
                                   placeholder="Name, TIN, Email, or Reference" force_save="1"/>
                                <field name="partner_ref"/>
                                <field name="requisition_id" domain="[('state', 'in', ('in_progress', 'open', 'ongoing')), ('vendor_id', 'in', (partner_id, False))]"/>
                                <field name="currency_id" groups="base.group_multi_currency" force_save="1"/>
                                <field name="is_shipped" invisible="1"/>
                                <field name="id" invisible="1"/>
                                <field name="has_mr" invisible="1"/>

                            </group>
                            <group>
                                <field name="x_studio_transporter"/>
                                <field name="x_studio_many2one_field_t3bCi"/>
                                <field name="average"
                                       groups="material_request.group_ore_rock_purchase_user,material_request.group_ore_rock_db_geology_user,material_request.group_ore_reader_planning"
                                       readonly="1"/>

                                <field name="weight_request_id" readonly="1"/>
                                
                                <field name="is_opu_po" string="MMU POs" readonly="1" groups="material_request.group_opu_user"/>
                                <field name="lot_id" readonly="1" groups="material_request.group_opu_user"/>

                                <field name="weight_request_qty" readonly="1"
                                       groups="material_request.group_ore_rock_purchase_user,material_request.group_ore_rock_db_geology_user,material_request.group_ore_reader_planning"/>

                                <field name="date_order" invisible="state in ('purchase','done')"/>


                                <label for="date_approve" invisible="state not in ('purchase','done')"/>
                                <div name="date_approve" invisible="state not in ('purchase','done')" class="o_row">
                                    <field name="date_approve"/>
                                    <span class="text-muted">(confirmed by
                                        vendor)
                                    </span>
                                </div>
                                <label for="date_planned"/>

                                <div name="date_planned_div" class="o_row">
                                    <button name="%(purchase_stock.action_purchase_vendor_delay_report)d"
                                            invisible="state in ['purchase', 'done'] or partner_id==False"
                                            class="oe_link" type="action"
                                            context="{'search_default_partner_id': partner_id}">
                                        <span invisible="on_time_rate &lt; 0"><field name="on_time_rate"
                                                                                     widget="integer"
                                                                                     class="oe_inline"/>% On-Time
                                            Delivery
                                        </span>
                                        <span invisible="on_time_rate &gt; 0">No On-time Delivery Data</span>
                                    </button>
                                    <field name="date_planned"
                                           readonly="state not in ('draft', 'sent', 'to approve', 'purchase')"/>
                                    <span class="text-muted">(confirmed by
                                        vendor)
                                    </span>
                                </div>
                                <label for="receipt_reminder_email" invisible='1'/>
                                <div name="reminder" class="o_row" groups='purchase.group_send_reminder'
                                     invisible="effective_date != False"
                                     title="Automatically send a confirmation email to the vendor X days before the expected receipt date, asking him to confirm the exact date.">
                                    <field name="receipt_reminder_email"/>
                                    <span>Ask confirmation</span>
                                    <div class="o_row oe_inline" invisible="receipt_reminder_email == False">
                                        <field name="reminder_date_before_receipt" class="oe_inline"/>
                                        day(s) before
                                        <widget name='toaster_button' button_name="send_reminder_preview"
                                                title="Preview the reminder email by sending it to yourself."
                                                invisible="id == False"/>
                                    </div>
                                </div>
                                <field name="effective_date" invisible="effective_date == False"/>
                                <field name="origin" invisible="origin == False"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Products" name="products">
                                <field name="order_line"
                                       widget="section_and_note_one2many"
                                       mode="list,kanban"
                                       context="{'default_state': 'draft'}"
                                       readonly="state in ('purchase','done', 'cancel')">
                                    <list string="Purchase Order Lines" editable="bottom">
                                        <control>
                                            <create name="add_product_control" string="Add a product"/>
                                            <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                            <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                        </control>
                                        <field name="display_type" column_invisible="1"/>
                                        <field name="currency_id" column_invisible="1"/>
                                        <field name="state" column_invisible="1"/>
                                        <field name="product_type" column_invisible="1"/>
                                        <field name="invoice_lines" column_invisible="1"/>
                                        <field name="sequence" widget="handle"/>
                                        <field name="name" widget="section_and_note_text"/>
                                        <field name="is_landed_costs_line" string="Landed Costs" optional="show"/>
                                        <field name="date_planned" optional="hide" required="display_type == False" force_save="1"/>
                                        <field name="move_dest_ids" column_invisible="1"/>
                                        <field name="product_qty"/>

                                        <field name="qty_received_manual" column_invisible="1"/>
                                        <field name="qty_received_method" column_invisible="1"/>
                                        <field name="qty_received" string="Received" readonly="product_type in ('consu', 'product')" column_invisible="parent.state not in ('purchase', 'done')"/>
                                        <field name="qty_invoiced" string="Billed"/>
                                        <field name="product_uom_id" string="UoM" groups="uom.group_uom"
                                               readonly="state in ['purchase', 'done', 'cancel']"
                                               required="display_type == False" force_save="1"
                                               optional="show"/>
                                        <field name="price_unit" readonly="invoice_lines != []"/>

                                            <field name="incentive_price" readonly="1"
                                                invisible="is_landed_costs_line == True"/>

                                        <field name="discount" readonly="1"/>

                                        <field name="percentage" readonly="1" optional="show" groups="material_request.group_opu_user,base_rida.rida_group_COO,base_rida.rida_group_CCSO"/>

                                        <field name="price_subtotal" widget="monetary"/>
                                    </list>
                                    <form string="Purchase Order Line">
                                        <field name="state" invisible="1"/>
                                        <field name="display_type" invisible="1"/>
                                        <group invisible="display_type != False">
                                            <group>
                                                <label for="product_qty"/>
                                                <div class="o_row">
                                                    <field name="product_qty"/>
                                                    <field name="product_uom_id" groups="uom.group_uom"
                                                           required="display_type == False"/>
                                                </div>
                                                <field name="qty_received_method" invisible="1"/>
                                                <field name="qty_received" string="Received Quantity"
                                                       readonly="qty_received_method != 'manual'"
                                                       invisible="parent.state not in ('purchase', 'done')"/>
                                                <field name="qty_invoiced" string="Billed Quantity"
                                                       invisible="parent.state not in ('purchase', 'done')"/>
                                                <field name="price_unit"/>
                                                <field name="discount" readonly="parent.invoice_status == 'invoiced'"/>
                                            </group>
                                            <group>
                                                <field name="date_planned" widget="date"
                                                       required="display_type == False"/>
                                            </group>
                                            <group colspan="12">
                                                <notebook>
                                                    <page string="Notes" name="notes">
                                                        <field name="name"/>
                                                    </page>
                                                    <page string="Invoices and Incoming Shipments"
                                                          name="invoices_incoming_shiptments">
                                                        <field name="invoice_lines"/>
                                                        <field name="move_ids"/>
                                                    </page>
                                                </notebook>
                                            </group>
                                        </group>
                                        <label for="name" string="Section Name (eg. Products, Services)"
                                               invisible="display_type != 'line_section'"/>
                                        <label for="name" string="Note" invisible="display_type != 'line_note'"/>
                                        <field name="name" nolabel="1" invisible="display_type == False"/>
                                    </form>
                                    <kanban class="o_kanban_mobile">
                                        <field name="name"/>
                                        <field name="product_id"/>
                                        <field name="product_qty"/>
                                        <field name="product_uom_id" groups="uom.group_uom"/>
                                        <field name="price_subtotal"/>
                                        <field name="price_tax" invisible="1"/>
                                        <field name="price_total" invisible="1"/>
                                        <field name="price_unit"/>
                                        <field name="discount" readonly="parent.invoice_status == 'invoiced'" />
                                        <field name="display_type" invisible="1"/>
                                        <field name="tax_ids" invisible="1"/>
                                        <templates>
                                            <t t-name="card">
                                                <div t-attf-class="oe_kanban_card oe_kanban_global_click {{ record.display_type.raw_value ? 'o_is_' + record.display_type.raw_value : '' }}">
                                                    <t t-if="!record.display_type.raw_value">
                                                        <div class="row">
                                                            <div class="col-8">
                                                                <strong>
                                                                    <span t-esc="record.product_id.value"/>
                                                                </strong>
                                                            </div>
                                                            <div class="col-4">
                                                                <strong>
                                                                    <span t-esc="record.price_subtotal.value"
                                                                          class="float-right text-right"/>
                                                                </strong>
                                                            </div>
                                                        </div>
                                                        <div class="row">
                                                            <div class="col-12 text-muted">
                                                                <span>
                                                                    Quantity:
                                                                    <t t-esc="record.product_qty.value"/>
                                                                    <t t-esc="record.product_uom_id.value"/>
                                                                </span>
                                                            </div>
                                                        </div>
                                                        <div class="row">
                                                            <div class="col-12 text-muted">
                                                                <span>
                                                                    Unit Price:
                                                                    <t t-esc="record.price_unit.value"/>
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </t>
                                                    <div
                                                            t-elif="record.display_type.raw_value === 'line_section' || record.display_type.raw_value === 'line_note'"
                                                            class="row">
                                                        <div class="col-12">
                                                            <span t-esc="record.name.value"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                    <field name="amount_untaxed" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_tax" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <div class="oe_subtotal_footer_separator oe_inline">
                                        <label for="amount_total"/>
                                    </div>
                                    <field name="amount_total" nolabel="1" class="oe_subtotal_footer_separator"
                                           widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <field name="note" class="oe_inline"
                                       placeholder="Define your terms and conditions ..."/>
                                <div class="oe_clear"/>
                            </page>
                            <page string="Other Information" name="purchase_delivery_invoice">
                                <group>

                                        <field name="picking_type_id"
                                           domain="[('code','=','incoming'), ('warehouse_id.code','=','Rock')]"
                                           options="{'no_create': True}"/>

                                    <field name="dest_address_id" groups="stock.group_stock_multi_locations"
                                           invisible="default_location_dest_id_usage != 'customer'"
                                           required="default_location_dest_id_usage == 'customer'"/>
                                    <field name="default_location_dest_id_usage" invisible="1"/>
                                    <field name="incoterm_id"/>
                                    <group name="other_info">
                                        <field name="user_id" domain="[('share', '=', False)]"
                                               widget="many2one_avatar_user"/>
                                        <field name="company_id"
                                               options="{'no_create': True}"/>
                                    </group>
                                    <group name="invoice_info">
                                        <field name="invoice_status"
                                               invisible="state in ('draft', 'sent', 'to approve', 'cancel')"/>
                                    </group>
                                </group>
                            </page>
                        </notebook> 
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_po_form_inerit" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="purchase_order_form_inherith"/>
            <field name="act_window_id" ref="material_request.action_ore_po_purchases"/>
        </record>

        <record id="account_move_landed_view" model="ir.ui.view">
            <field name="name">account.move.view.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='ref']" position="after">
                    <field name="landed_cost_id" readonly="1"/>
                    <field name="landed_cost_po_id" readonly="1"/>
                </xpath>
            </field>
        </record>


        <menuitem id="menu_ore_poo_maiin" name="Ore/Rock Purcharses"
                  groups="material_request.group_ore_rock_purchase_user,base_rida.rida_group_site_manager"/>

        <menuitem id="meniu_ore_poo_root" parent="menu_ore_poo_maiin" action="action_ore_po_purchases"
                  groups="material_request.group_ore_rock_purchase_user,base_rida.rida_group_site_manager"/>

    </data>
</odoo>
