<odoo>
    <record id="account_statement_pdf_form" model="ir.ui.view">
        <field name="name">Account Statement Wizard</field>
        <field name="model">account.statement.pdf</field>
        <field name="arch" type="xml">
            <form string="Sales Details">
                <group  col="4">
                    <field name="from_date"/>
                    <field name="to_date"/>
                    <field name="account_id"/>
                 </group>
                <footer>
                    <button name="print_report" string="Print"  type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
    <record id="account_statement_pdf_action" model="ir.actions.act_window">
        <field name="name">Account Statement</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.statement.pdf</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="account_statement_pdf_form"/>
        <field name="target">new</field>
    </record>
    <menuitem name="Account Statement" action="account_statement_pdf_action" id="account_statement_pdf_menu" parent="account.account_reports_management_menu" />

</odoo>