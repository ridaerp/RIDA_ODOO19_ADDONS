<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hr_employee_view_form_inherited_benefit" model="ir.ui.view">
            <field name="name">hr.employee.form.inherited</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">               
                <xpath expr="//group[@name='payroll_group']" position="after">
                    <group string="Benefits" name="benefits_group">
                        <group>
                            <button name="get_benifits" string="Get Benefits" type="object"/>
                        </group>
                        <field name="salary_benefit_ids" nolabel="1">
                            <list editable="top" create="false" >
                                <field name="name" readonly="True" force_save="1" required="1"/>
                                <field name="code" readonly="True" force_save="1" required="1"/>
                                <field name="type" readonly="1" force_save="1"/>
                                <field name="percentage" readonly="type == 'fixed'" force_save="1"/>
                                <field name="amount" readonly="type != 'fixed'" force_save="1"/>
                            </list>
                        </field>
                        <group>
                            <field name="total_allowance"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

        