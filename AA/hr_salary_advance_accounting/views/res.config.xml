<odoo>
    <data>

        <record model="ir.ui.view" id="res_config_settings_view_form_salary">
            <field name="name">res.config.settings.view.form.inherit.salary</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                    <div class="app_settings_block" data-string="Salary Advance" string="Salary Advance" data-key="hr_salary_advance"
                         groups="hr.group_hr_manager">
                        <h2> Salary Advance</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-xs-12 col-md-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <span class="o_form_label"> Salary Advance Configuration</span>
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label string="Salary Account" for="sal_account_id"
                                               class="col-lg-3 o_light_label"/>
                                        <field name="sal_account_id" domain="[('company_ids','=', company_id)]" />
                                    </div>
                                   
                                   
                                </div>
                            </div>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>