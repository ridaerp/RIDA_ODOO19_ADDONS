<odoo>
    <data>
        <!-- Location Form View -->
      <record id="view_rida_location_form" model="ir.ui.view">
            <field name="name">view.location.form</field>
            <field name="model">rida.location</field>
            <field name="arch" type="xml">
                 <form string="Location">
                    <sheet>
                      <group>
                        <field name="name"/>
                      </group>
                    </sheet>
                 </form>
            </field>
      </record>

        <!-- Location Tree View -->
      <record id="view_rida_location_tree" model="ir.ui.view">
            <field name="name">view.location.tree</field>
            <field name="model">rida.location</field>
            <field name="arch" type="xml">
                 <list string="Location">
                      <field name="name"/>
                 </list>
            </field>
      </record>

        <!-- Menu Action -->
      <record id="action_rida_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">rida.location</field>
        <field name="view_mode">list,form</field>
    </record>
   
    <!-- Action Menu Item Related To Above Action Window adding to config menu-->
    <menuitem
        id="action_configration_sub_menu_rida_location"
        action="action_rida_location"
        parent="hr.menu_human_resources_configuration"
        name="Locations"
        sequence="10"/>
    </data>
</odoo>