<odoo>
    <data>

        <record id="recr_plan_request_form" model="ir.ui.view">
            <field name="name">Recruitment Plan Request</field>
            <field name="model">recruitment.plan</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="action_submit" type="object" class="oe_highlight" invisible="state != 'draft'" groups="hr.group_hr_user,base_rida.rida_group_line_manager"/>
                        <button string="Approve" name="action_hr_manager_approve" type="object" class="oe_highlight" invisible="state != 'w_hr_m'" groups="base_rida.rida_hr_manager_notify"/>
                        <button string="Approve" name="approve_operation_director" type="object" invisible="state != 'coo'" class="oe_highlight" groups="base_rida.rida_group_site_manager"/>
                        <button string="Approve" name="approve_ccso" type="object" invisible="state != 'ccso'" class="oe_highlight" groups="base_rida.rida_group_CCSO"/>
                        <button string="Create Recruitment Request" name="create_recr_req" type="object" class="oe_highlight" groups="base_rida.rida_group_line_manager" invisible="state != 'approved'" />
                        <button string="Set to Draft" name="action_draft" groups="hr.group_hr_user,base_rida.rida_group_line_manager" type="object" invisible="state != 'reject'"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action" invisible="state in ['w_hr_m', 'coo', 'ccso']"  string="Reject" groups="hr.group_hr_user,base_rida.rida_group_line_manager"/>
                        />
                        <field name="state" widget="statusbar" statusbar_visible="draft,w_hr_m,coo,approved" invisible="user_type == 'hq'"/>
                        <field name="state_ccso" widget="statusbar" invisible="user_type != 'hq'" statusbar_visible="draft,w_hr_m,ccso,approved"/>
                    </header>
                    <br/>
                    <b>
                        <p align="center">Doc. No. UMC-HRADM-QP-HR-RFC/01
                            -
                            Issue/Rev 03/00
                        </p>
                    </b>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="set_recruitment_request" invisible="state != 'approved'" string="Recruitment" type="object" class="oe_stat_button" icon="fa-list-alt">
                                <field name="recruitment_count" string="Recruitment" widget="statinfo"/>
                            </button>
                        </div>
                        <center>
                            <h3>
                                <b>RECRUITMENT PLAN</b>
                            </h3>
                        </center>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="recruitment_count" invisible="1"/>
                                <field name="user_type" invisible="1"/>
                                <field name="req_id" readonly="1"/>
                                <field name="job_req_id" readonly="1"/>
                                <field name="department_id" options="{'no_open':True,'no_create': True, 'no_create_edit':True}" required="1"  readonly="state == 'approved'"/>
                                <field name="company_id" required="1" options="{'no_open':True,'no_create': True, 'no_create_edit':True}" readonly="state == 'approved'"
                                />
                            </group>
                            <group>
                                <field name="description" required="1"  readonly="state == 'approved'"/>
                                <field name="date" required="1"  readonly="state == 'approved'"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Recruitment Line">
                                <field name="recr_plain_line_ids" nolabel="1" readonly="state == 'approved'">
                                    <list string="Recruitment Line" editable="bottom">
                                        <field name="job_id" required="1" options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>
                                        <field name="number_required" required="1"/>
                                        <field name="hiring_date" required="1"/>
                                        <field name="remarks" required="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="recr_plan_tree" model="ir.ui.view">
            <field name="name">Recruitment Plan Request</field>
            <field name="model">recruitment.plan</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="recr_plan_form_search" model="ir.ui.view">
            <field name="name">Recruitment Plan Request</field>
            <field name="model">recruitment.plan</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="recr_plan_Action" model="ir.actions.act_window">
            <field name="name">Recruitment Plan Request</field>
            <field name="res_model">recruitment.plan</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Recruitments" id="recr_plan_root" parent="base_rida.cus_menu_hr_root" groups="hr.group_hr_user,base_rida.rida_group_line_manager"/>
        <menuitem name="Recruitment Plan" id="recr_plan" parent="recr_plan_root" sequence="0" action="recr_plan_Action"/>


    </data>
</odoo>