<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <!--  User trip permission Request -->
        <record model="ir.rule" id="rule_trip_permission_creator">
            <field name="name">Check Creator</field>
            <field name="model_id" ref="model_trip_permission"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!--  Line Manager trip permission Request -->
        <record model="ir.rule" id="rule_check_trip_permission_l_mng">
            <field name="name">Line Manager Trip Permission</field>
            <field name="model_id" ref="model_trip_permission"/>
            <field name="domain_force">[('req_id.line_manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base_rida.rida_group_line_manager'))]"/>
        </record>

        <!--  Manager related to trip permission Request -->
        <record model="ir.rule" id="rule_trip_permission_mng">
            <field name="name">Manager trip_permission</field>
            <field name="model_id" ref="model_trip_permission"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('base_rida.rida_group_site_manager')),(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.rida_internal_audit')),(4, ref('base_rida.rida_hr_manager_notify')),(4, ref('hr_holidays.group_hr_holidays_manager')),(4, ref('account.group_account_user'))]"/>
        </record>

        <!--  User Recruitment Request -->
        <record model="ir.rule" id="rule_recr_request_creator">
            <field name="name">Check Creator</field>
            <field name="model_id" ref="model_recruitment_request"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!--   Recruitment  Request -->
        <record model="ir.rule" id="rule_recr_request_mng">
            <field name="name">Recruitment Request Manager</field>
            <field name="model_id" ref="model_recruitment_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('hr.group_hr_user')),(4, ref('base_rida.rida_group_site_manager')),(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.rida_hr_manager_notify'))]"/>
        </record>

        <!--  User Recruitment Plan Request -->
        <record model="ir.rule" id="rule_recr_plan_request_creator">
            <field name="name">Check Creator</field>
            <field name="model_id" ref="model_recruitment_plan"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>


   <!--  Line Manager Recuitment -->
        <record model="ir.rule" id="rule_recuirment_batch_l_mng">
            <field name="name">Line Manager Recuitment</field>
            <field name="model_id" ref="model_recruitment_plan"/>
            <field name="domain_force">[('req_id.line_manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base_rida.rida_group_line_manager'))]"/>
        </record>


   <!--  Line Manager Recuitment -->
        <record model="ir.rule" id="rule_recuirment_line_request">
            <field name="name">Line Manager Recuitment</field>
            <field name="model_id" ref="model_recruitment_request"/>
            <field name="domain_force">[('req_id.line_manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base_rida.rida_group_line_manager'))]"/>
        </record>



        <!--  User Recruitment Plan Request -->
        <record model="ir.rule" id="rule_recr_plan_request_mng">
            <field name="name">Recruitment Auth</field>
            <field name="model_id" ref="model_recruitment_plan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('hr.group_hr_user')),(4, ref('base_rida.rida_group_site_manager')),(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.rida_hr_manager_notify'))]"/>
        </record>

    </data>
</odoo>