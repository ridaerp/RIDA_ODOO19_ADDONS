<odoo>
    <data>
        <!-- chemical samples -->
      <record id="seq_metallurgical_request" model="ir.sequence">
            <field name="name">metallurgical Reference</field>
            <field name="code">metallurgical.sequence</field>
            <field name="prefix">META-LAB-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False" />
        </record>


 <record id="metallurgical_request_tree" model="ir.ui.view">
            <field name="name">metallurgical Reference</field>
            <field name="model">metallurgical.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="date_request"/>
                    <field name="sample_category"/>
                    <field name="sample_type"/>
                    <field name="sample_wight"/>
                    <field name="test_type"/>
                    <field name="company_id"/>
                    <field name="state"/>

                </list>
            </field>
        </record>




        <record id="metallurgical_request_form" model="ir.ui.view">
            <field name="name">metallurgical Reference</field>
            <field name="model">metallurgical.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                    <button name="button_submit" invisible="state != 'draft'"  string="Submit" type="object" groups="material_request.ore_lab_requester" />


                       <!--                    Set to Draft-->
                    <button name="button_draft" invisible="state not in ['cancel','reject']"  string="Set as Draft" type="object" />


                    <button name="button_receive" invisible="state != 'metallurgist'"  string="Approve" type="object" groups="material_request.group_meta_lab_Metallurgist_user" />


                    <button name="button_approve" invisible="state != 'met_lab_Manager'"  string="Confirm" type="object" groups="material_request.group_meta_lab_manager" />
                    <button name="operation_director_approve" invisible="state != 'operation_director'" string="Confirm" type="object" groups="base_rida.rida_group_site_manager" />

                    
                     <button name="%(material_request.purchase_order_reject_action)d" type="action" invisible="state not in ['metallurgist','met_lab_Manager']"  string="Reject" />



                   
                          <field name="state" widget="statusbar" statusbar_visible="draft,metallurgist,met_lab_Manager,operation_director,reject,close"  />

                    </header>
                        <sheet>


                        <div class="oe_edit_only">
                            <label for="name" class="oe_inline" />
                        </div>
                        <h1>
                          
                            <field name="name" readonly="1" />
                        </h1>
                          <group>

                            <group>
                                <field name="production_id" readonly="1"
                                 groups="mrp.group_mrp_user"/>
                           <field name="date_request"  readonly="1"  />
                           <field name="sample_no" readonly="state != 'draft'"/>

                        <label for="sample_wight" string="Sample Wight"/>
                            <div class="o_row">                         
                            <field name="sample_wight"  readonly="state != 'draft'" />                
                            <label for="sample_wight" string="KG" />  

                            </div> 
                           <field name="Sample_contained" readonly="state !='draft'"/>
                              <field name="test_type" widget="selection" readonly="state != 'draft'"/>


                        </group>
                        <group>
                                 <field name="sample_category" widget="radio" readonly="state != 'draft'" />


                           <field name="sample_type"  readonly="state != 'draft'"/>
                           <field name="other" readonly="state != 'draft'" invisible="sample_type != 'other'" required="sample_type == 'other'"/>
                           <field name="core_type" readonly="state != 'draft'" invisible="sample_type != 'core'" required="sample_type == 'core'"/>
                           <!-- <separator string="Samples being sent to Met Lab may contain the following hazardous materials"/> -->
                           <field name="hazardous" readonly="state != 'draft'"/>
                           <field name="hazardous_other" readonly="state != 'draft'" invisible="hazardous != 'other'" required="hazardous == 'other'"/>

                            </group>
                            
                                 </group>
                                 <separator style="margin-right:10px;"/>
                            <group>
                                <group>
                           <field name="requested_by"  readonly="1"/>
                           <field name="email" readonly="state != 'draft'"/>
                           <field name="department_id" readonly="state != 'draft'"/>
                           <field name="phone" readonly="state != 'draft'"/>
                           <field name="company_id" readonly="state != 'draft'"/>

                           </group>
                           <group>
                           <field name="metallurgist_date" readonly="1" />
                           <field name="metallurgist" readonly="1" />
                           <field name="meta_manager" readonly="1"/>
                           <field name="approved_date" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>


        </record>






    <record model="ir.actions.act_window" id="meta_request_action">
        <field name="name">Metallurgical Request</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">metallurgical.request</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
            Click to start a new Metallurgical request.
          </p>
           
        </field>
    </record>

        <record id="meta_request_search" model="ir.ui.view">
            <field name="name">Metallurgical Request</field>
            <field name="model">metallurgical.request</field>

            <field name="arch" type="xml">
                <search string="Metallurgical">
                    <field name="name" string="Request No." />
                    <field name="sample_type" string="Sample Type" />
                    <field name="department_id" string="Department" />
                    <field name="state" string="Status" />
                    <separator />
                    
                    <field name="requested_by" />
                  <filter domain="[('requested_by','=', uid)]" name="my_request" help="My requests" />

                    <filter name="group_state" string="Status" context="{'group_by':'state'}" />
                    <filter name="group_sample_type" string="Sample Type" context="{'group_by':'sample_type'}" />
                    <filter name="group_sample_category" string="Internal/External" context="{'group_by':'sample_category'}" />
                    <filter string="Requested by" icon="terp-personal" name="request_by" domain="[]" context="{'group_by':'requested_by'}" />
                    <filter string="Department" icon="terp-personal" name="department_id" domain="[]" context="{'group_by':'department_id'}" />
                  
                </search>
            </field>
        </record>




 <record id="metallurgical_test_type_tree" model="ir.ui.view">
            <field name="name">Test Type</field>
            <field name="model">meta.test.type</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                </list>
            </field>
        </record>

 <record id="metallurgical_test_type_fomr" model="ir.ui.view">
            <field name="name">Test Type</field>
            <field name="model">meta.test.type</field>
            <field name="arch" type="xml">
                <form >
                    <sheet>
                        <group>

                         <field name="name"/>
                     </group>
                 </sheet>
             </form>
            </field>
        </record>


 
    <record model="ir.actions.act_window" id="meta_test_type_action">
            <field name="name">Test Type</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">meta.test.type</field>
            <field name="view_mode">list,form</field>

            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                Click to start a new Test Type .
              </p>
               
            </field>
        </record>



     <menuitem id="menu_meta_lab_menu" sequence="5"  
        name="Metallurgical Lab" groups="material_request.ore_lab_requester,material_request.group_ore_reader_user"
         action="meta_request_action"  web_icon="material_request,static/description/meta.png"/>

         <menuitem id="menu_meta_lab_conf_menu" sequence="1" parent="menu_meta_lab_menu"   name="Configuration" 
    groups="base_rida.rida_group_master_data_manager" />

<menuitem id="menu_meta_lab_test_type" sequence="0" parent="menu_meta_lab_conf_menu"   name="Test Type" groups="base_rida.rida_group_master_data_manager" action="meta_test_type_action" />




</data>
</odoo>
