<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="order_reject_wizard" model="ir.ui.view">
            <field name="name">reject.wizard_wizard</field>
            <field name="model">reject.wizard</field>
            <field name="arch" type="xml">
                <form string="Rejection Reason">
                    <sheet>
                        <field name="id" invisible="1"/>
<!--
                        <div class="oe_title">
                            <h3>Rejection Reason</h3>
                        </div>
-->
                        <group>
                            <group>
                                <field name="reason_reject" required="1"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button string='Ok' name="action_validate" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="order_reject_action" model="ir.actions.act_window">
            <field name="name">Reject</field>
            <field name="res_model">reject.wizard</field>
<!--            <field name="view_type">form</field>-->
            <field name="view_mode">form</field>
            <field name="view_id" ref="order_reject_wizard"/>
            <field name="target">new</field>

        </record>

</odoo>