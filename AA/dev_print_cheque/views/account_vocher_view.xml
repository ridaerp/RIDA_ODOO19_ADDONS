    <record id="view_inherit_journal_accounting" model="ir.ui.view">
        <field name="name">view.inherit.journal.accounting</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='type']" position="after">
                <field name="check_template" invisible="1"/>
            </xpath>
        </field>
    </record>    
    <record id="view_account_cheque_formate_form" model="ir.ui.view">
        <field name="name">account.voucher.formate.form.view</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form[1]/sheet[1]/group[1]" position="after">
                <group string="Check Info" name="check_info" invisible="payment_method_code != 'check_printing'">
                    <group>
<!--                        <field name="cheque_formate_id"  invisible="payment_method_code != 'check_printing'" required="payment_method_code == 'check_printing'"/>-->
                        <field name="cheque_formate_id"  invisible="payment_method_code != 'check_printing'" />
                        <field name="check_date" invisible="payment_method_code != 'check_printing'" required="payment_method_code == 'check_printing'"/>
                        <field name="partner_text" invisible="payment_method_code != 'check_printing'"/>
                        <field name="cheque_no"  invisible="payment_method_code != 'check_printing'" required="payment_method_code == 'check_printing'"/>
                        <field name="text_free" invisible="payment_method_code != 'check_printing'"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//button[@name='print_checks']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
