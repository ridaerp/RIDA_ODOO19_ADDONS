<?xml version="1.0" encoding="utf-8"?>
<odoo>




    <record id="view_move_rida_new_form" model="ir.ui.view">
        <field name="name">account.move.form.view</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="stock_landed_costs.account_view_move_form_inherited"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="landed_costs_ids" invisible="1"/>
                <button string="Landed Costs" type="object" name="action_view_landed_costs" class="oe_stat_button"
                        icon="fa-plus-square" groups="stock.group_stock_manager"
                        invisible="not landed_costs_ids"/>
            </xpath>


        </field>
    </record>




    <record id="view_picking_rida_form_new" model="ir.ui.view">
        <field name="name">stock.picking_rida.form.view</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <data>

                <xpath expr="//button[@name='%(stock.act_stock_return_picking)d']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="/form/header/field[@name='state']" position="after">
                    <field name="return_state" widget="statusbar"
                           invisible="return_state not in ('warehouse_manager', 'user_department_manager')"/>
                    <!-- <field name="return_state"  widget="statusbar"  attrs="{'invisible': [('state', '!=', 'done'),('return_state','not in', ('warehouse_manager,user_department_manager'))]}"  /> -->
                </xpath>
                <xpath expr="/form/header/button[last()]" position="after">
                    <button name="button_supervice_manager_approve" string="Supervice Manager Return Approval"
                            type="object"
                            invisible="state != 'done' or return_state != 'supervice_manager'"
                            groups="stock.group_stock_user"/>
                    <button name="button_warehouse_manager_approve" string="warehouse Manager Return Approval"
                            type="object" invisible="return_state != 'warehouse_manager'"
                            groups="stock.group_stock_user"/>
                    <button name="button_user_department_manager_approve"
                            string="User Department Manager Return Approval" type="object"
                            invisible="return_state != 'user_department_manager'"
                            groups="stock.group_stock_user"/>
                    <button name="%(stock.act_stock_return_picking)d" string="Return" type="action"
                            invisible="state != 'done' and return_state != 'supply_chain_manager'"
                            groups="stock.group_stock_manager"/>
                </xpath>

                <xpath expr="//sheet/group/group" position="inside">
                    <field name="inspection_date"/>
                    <field name="issuance_request_id" invisible="0" readonly="1"/>
                    <field name="security_number_issuance" invisible="1"/>
                    <label string="Receipt Confirmation Number" for="security_number" style="color: green;"
                           invisible="security_number_issuance == 0"/>
                    <field name="security_number" style="color: green;" nolabel="1"
                           readonly="state == 'done'" invisible="security_number_issuance == 0"/>
                    <label string="Receipt By" for="receipt_id" style="color: green;"
                           invisible="security_number_issuance == 0"/>
                    <field name="receipt_id" style="color: green;" nolabel="1"
                           readonly="state == 'done'" invisible="security_number_issuance == 0" options="{'no_create': True, 'no_open': True}"/>
                    <field name="inspector" options="{'no_create': 1, 'no_open': 1}"/>
                    <field name="emp_type" invisible="1"/>
<!--                    <field name="analytic_account_id" options="{'no_create': True, 'no_open': True}"/>-->

                </xpath>

                <xpath expr="//group[@name='other_infos']" position="before">
                    <group name='Rida_data' string="Rida Information">
                        <field name="driver_name"/>
                        <field name="driver_mobile" widget="phone"/>
                        <field name="truk_no"/>
                        <field name="truk_cap"/>
                    </group>
                </xpath>

                <xpath expr="//field[@name='product_qty']" position="after">
                    <field name="batch_no"/>
                    <field name="lot_ids" widget="many2many_tags"/>
                    <field name="average"/>
                </xpath>

            </data>
        </field>
    </record>

    <record id="view_picking_batch_rida_form" model="ir.ui.view">
        <field name="name">stock.picking.batch_rida.form.view</field>
        <field name="model">stock.picking.batch</field>
        <field name="inherit_id" ref="stock_picking_batch.stock_picking_batch_form"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='scheduled_date']" position="after">
                    <!-- <field name="inspection_date"/> -->
                    <field name="inspector"/>
                    <field name="driver_name"/>
                    <field name="driver_mobile" widget="phone"/>
                    <field name="truk_no"/>
                    <field name="truk_cap"/>
                </xpath>

            </data>
        </field>
    </record>
</odoo>
