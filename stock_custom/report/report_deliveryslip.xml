<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_report_delivery_custom" model="ir.actions.report">
        <field name="name">MATERIAL ISSUANCE VOUCHER (MIV)</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_custom.report_deliveryslip_custom</field>
        <field name="report_file">stock_custom.report_deliveryslip_custom</field>
        <field name="print_report_name">'MIV - %s' % (object.name)</field>
        <field name="attachment">'MIV_%s.pdf' % (object.name)</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_deliveryslip_custom">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <!-- <t t-foreach="docs" t-as="o"> -->
                <!-- <t t-call="web.html_container"> -->

                <!-- <div class="page"> -->

                <div class="page">
                    <t t-if="docs[0].state == 'done'">
                        <center>
                            <h3>MATERIAL ISSUANCE VOUCHER (MIV)</h3>
                        </center>
                        <center>
                            <h3>طلب صرف مواد</h3>
                        </center>
                        <br/>
                        <div style="text-align:right">
                            <h2>
                                <b>S/N (
                                    <span style="text-decoration:underline dotted">
                                        <t t-esc="docs[0].name"/>
                                    </span>
                                    )
                                </b>
                            </h2>
                        </div>
                        <t t-if="docs[0].origin != False">
                        <div style="text-align:right">
                            <h2>
                                <b>Issuance Request (
                                    <span style="text-decoration:underline dotted">
                                        <t t-esc="docs[0].origin"/>
                                    </span>
                                    )
                                </b>
                            </h2>
                        </div>
                        </t>
                        <br/>
                        <table border="3" style="width:100%;">
                            <tr style="font-weight:bold;">
                                <td>
                                    <h4>Date</h4>
                                </td>
                                <td>
                                    <center>
                                        <h4 style="border: 1px solid black;">
                                            <span t-field="docs[0].date_done"/>
                                        </h4>
                                    </center>
                                </td>

                                <t t-if="docs[0].analytic_account_id">
                                    <td style="padding-left: 15px;">
                                        <h2>Cost Center</h2>
                                    </td>
                                    <td>
                                        <center>
                                            <h4 style="border: 1px solid black;">
                                                <span t-field="docs[0].analytic_account_id"/>
                                            </h4>
                                        </center>
                                    </td>
                                </t>
                            </tr>
                        </table>
                        <style>
                            .custom-table {
                            width: 100%;
                            border-collapse: collapse;
                            }
                            .custom-table td {
                            text-align: center;
                            border: 1px solid black;
                            }
                            .custom-table-footer {
                            width: 100%;
                            border-collapse: collapse;
                            }
                            .custom-table-footer td {
                            text-align: center;
                            }
                            .custom-table th {
                            background-color: #f2f2f2;
                            text-align: center;
                            border: 1px solid black;
                            }
                            .custom-table-footer th {
                            text-align: center;
                            }
                            .empty-box {
                            border: 1px solid black;
                            width: 50%;
                            display: inline-block;
                            height: 70; /* Adjust the height as needed */
                            }

                            .data-entry-box {
                            border-bottom: 2px solid black;
                            width: 50%;
                            display: inline-block;
                            height: 70; /* Adjust the height as needed */
                            }
                        </style>
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th rowspan="2">Item No</th>
                                    <th rowspan="2">Item Name</th>
                                    <th colspan="3">Description</th>
                                </tr>
                                <tr>
                                    <th>Unit</th>
                                    <th>QTY</th>
                                    <th>Remark</th>
                                </tr>

                            </thead>
                            <tbody>
                                <t t-set="lines" t-value="docs[0].move_lines.filtered(lambda x: x.product_uom_qty)"/>
                                <tr t-foreach="lines" t-as="move">
                                    <tr>
                                        <td>
                                            <span t-field="move.x_studio_part_number"/>
                                        </td>
                                        <td>
                                            <span t-field="move.product_id"/>
                                        </td>
                                        <td>
                                            <span t-field="move.product_uom"/>
                                        </td>
                                        <td>
                                            <span t-field="move.quantity_done"/>
                                        </td>
                                        <td>
                                            <span t-field="move.description_picking"/>
                                        </td>
                                    </tr>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                    <t t-if="docs[0].state != 'done'">
                        <div class="text-center">
                            <h2>Report is only available for Done records</h2>
                        </div>
                    </t>
                    <br/>


                    <table class="custom-table-footer">
                        <thead>
                            <tr>
                                <th>
                                    <h6>Store Keeper</h6>
                                </th>
                                <th>
                                    <h6>.....................................</h6>
                                </th>
                                <th>
                                    <h6 style="padding-left:6%">Receiver</h6>
                                </th>
                                <th>
                                    <h6>..............................</h6>
                                </th>
                                <th>
                                    <h6>Data Entry</h6>
                                </th>
                                <th>
                                    <h6>
                                        <span t-field="docs[0].create_uid"/>
                                    </h6>
                                </th>
                            </tr>
                            <tr>
                                <th>
                                    <h6>أمين المخزن</h6>
                                </th>
                                <th>
                                    <h6></h6>
                                </th>
                                <th>
                                    <h6>المستلم</h6>
                                </th>
                                <th>
                                    <h6></h6>
                                </th>
                                <th>
                                    <h6>مدخل البيانات</h6>
                                </th>
                                <th>
                                    <h6></h6>
                                </th>
                            </tr>
                            <tr>
                                <th>
                                    <h6>Sign</h6>
                                </th>
                                <th>
                                    <h6>.....................................</h6>
                                </th>
                                <th>
                                    <h6>Sign</h6>
                                </th>
                                <th>
                                    <h6>..............................</h6>
                                </th>
                                <th>
                                    <h6>Sign</h6>
                                </th>
                                <th>
                                    <h6>...............................................</h6>
                                </th>
                            </tr>
                            <tr>
                                <th>
                                    <h6>اﻟﺘﻮﻗﻴﻊ</h6>
                                </th>
                                <th>
                                    <h6></h6>
                                </th>
                                <th>
                                    <h6>اﻟﺘﻮﻗﻴﻊ</h6>
                                </th>
                                <th>
                                    <h6></h6>
                                </th>
                                <th>
                                    <h6>اﻟﺘﻮﻗﻴﻊ</h6>
                                </th>
                                <th>
                                    <h3></h3>
                                </th>
                            </tr>
                        </thead>
                        <tbody>

                        </tbody>
                    </table>
                </div>
            </t>
        </t>

    </template>

</odoo>
