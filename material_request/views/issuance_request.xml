        <record id="view_issuance_request_search" model="ir.ui.view">
            <field name="name">issuance.request.list.select</field>
            <field name="model">issuance.request</field>
            <field name="arch" type="xml">
                <search string="Search Issuance Request">
                    <field name="name" string="Issuance Request"/>
                    <field name="title" string="Issuance Request Title"/>
                    <separator/>
                    <field name="state"/>
                    <field name="delivery_address"/>
                    <field name="requested_by"/>
                    <field name="product_id"/>
                    <field name="department_id"/>
                    <field name="analytic_account_id"/>
                    <field name="issuance_type"/>


                    <filter domain="[('requested_by','=', uid)]" name="my_request" help="My requests"/>

                    <filter domain="[('state','in', ['line_approve','to_inventory'])]" name="to_approve"
                            help="To Approve"/>
                    <filter name="group_state" string="Status" context="{'group_by':'state'}"/>
                    <group expand="0" string="Group By...">
                        <filter string="Requested by" icon="terp-personal" name="request_by" domain="[]"
                                context="{'group_by':'requested_by'}"/>
                    </group>


                    <group expand="0" string="Group By...">
                        <filter string="Product" icon="terp-personal" name="request_by" domain="[]"
                                context="{'group_by':'product_id'}"/>
                    </group>


                </search>
            </field>
        </record>


        <!--    To Approve-->
        <record model="ir.actions.act_window" id="issuance_request_form_approve_action">
