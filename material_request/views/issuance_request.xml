<odoo>
    <data>

        <record id="seq_issuance_request" model="ir.sequence">
            <field name="name">Issuance Request Refrence</field>
            <field name="code">issuance_request.sequence</field>
            <field name="prefix">ISS-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="view_issuance_request_form" model="ir.ui.view">
            <field name="name">Issuance Request</field>
            <field name="model">issuance.request</field>
            <field name="arch" type="xml">
                <form string="Issuance Request">
                    <header>
                        <!--                    Set to Draft-->
                        <button name="button_draft"
                                invisible="state  in ['done','draft']"
                                string="Set as Draft"
                                type="object"

                        />

                        <!--                    User Submit-->
                        <button name="button_to_lm" invisible="state not in ['draft']"
                                string="Submit" type="object"
                                class="oe_highlight"/>


                        <button name="action_approve_sheets" invisible="state not in ['line_approve']" string="Approve"
                                type="object"
                                groups="base_rida.rida_group_line_manager"
                                class="oe_highlight o_expense_sheet_approve"/>


                        <!--          <button name="button_cancel" states="draft"
                                         string="Cancel" type="object"

                                         class=""/> -->

                        <!--                    Inventory -->
                        <button name="action_stock_delivery"
                                string="Approve"
                                type="object"
                                invisible="state not in ['to_inventory']"
                                groups="stock.group_stock_user,stock.group_stock_user"
                                class="oe_highlight"
                        />


                        <button name="button_cancel" invisible="state not in ['draft','line_approve','to_inventory']"

                                string="Cancel" type="object"
                                confirm="You are about to cancel this request and its related records. Please confirm!"
                                class=""/>

                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,done"
                               statusbar_colors='{"manager_approved":"blue"}'/>


                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button type="object"
                                    name="action_view_picking"
                                    class="oe_stat_button"
                                    groups="stock.group_stock_user"
                                    icon="fa-truck" invisible="picking_count == 0">
                                <field name="picking_count" string="Shipment" widget="statinfo"/>
                            </button>


                        </div>

                        <div class="oe_edit_only">
                            <label for="name" class="oe_inline"/>
                        </div>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <div class="oe_edit_only">
                            <label for="title" class="oe_inline"/>
                        </div>
                        <h1>
                            <field name="title" readonly="state not in ('draft')"/>
                        </h1>
                        <group>
                            <group>
                                <field name="requested_by" readonly="1" options="{'no_create': 1, 'no_open': 1}"
                                />

                                <field name="department_id" readonly="1" options="{'no_create': 1, 'no_open': 1}"
                                />
                                <field name="equipment_id" options="{'no_create': 1, 'no_open': 1}"
                                       readonly="state not in ('draft')"/>

                                <field name="analytic_account_id" readonly="state not in ('draft')"
                                       options="{'no_create': 1, 'no_open': 1}"


                                       domain="['|',('company_id','=',company_id),('company_id','=',False),('active','=',True)]"/>


                                <field name="company_id" options="{'no_create': 1, 'no_open': 1}" required="1"
                                       readonly="state == 'done'"/>
                                <field name="currency_id" invisible="1"
                                       readonly="state not in ('draft')"/>

                                <field name="issuance_type"/>
                                <field name="delivery_address" invisible="issuance_type != 'external_issuance'"
                                       required="issuance_type == 'external_issuance'"/>
                                <field name="show_button" invisible="1"/>
                                <label string="Receipt Confirmation Number" for="security_number" style="color: green;"
                                       invisible="show_button == False"/>
                                <field name="security_number" style="color: green;" nolabel="1"
                                       invisible="show_button == False" readonly="1"/>
                                <field name="user_ids" invisible="show_button == False" readonly="state != 'draft'"
                                       widget="many2many_tags"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>


                            </group>
                            <group>

                                <field name="request_date"
                                       readonly="state not in ('draft')"/>
                                <!--comment by ekhlas <field name="dest_location"
                                   attrs="{'readonly': [('state','in', ('draft'))]}"/> -->
                                <!-- line by ekhlas -->
                                <field name="warehouse_id" domain="[('company_id','=', company_id)]"


                                       readonly="state in ('draft')"/>
                                <field name="issuance_new_location" domain="[('company_id','=', company_id)]"
                                       readonly="state in ('cancel','done')"/>

                                <field name="store_keeper"
                                       readonly="1"
                                />
                                <field name="origin"
                                       readonly="1"
                                />

                                <field name="request_id"
                                       readonly="1"
                                />


                                <field name="status"
                                       readonly="1"/>

                                <!--  <field name="delivered"
                                      readonly="1"
                                />
                                <button name="get_shipment_status" string="do" type="object"/>
-->

                            </group>

                        </group>
                        <notebook>
                            <page string="Products">
                                <field name="line_ids">
                                    <tree editable="bottom">
                                        <field name="product_id"
                                               readonly="parent.state not in ('draft')"/>
                                        <field name="name"
                                               readonly="parent.state not in ('draft')"/>
                                        <field name="qty_available" invisible="0"/>
                                        <field name="qty_requested" string="Requested Qty"
                                               readonly="parent.state not in 'draft'"/>
                                        <field name="lot_ids" options="{'no_create': True,'no_open':True}"
                                               widget="many2many_tags" invisible="product_id != 63325"/>
                                        <field name="qty_issued" string="Issued Qty"
                                               readonly="parent.state not in ('to_inventory')"/>
                                        <field name="product_uom_id"
                                               readonly="parent.state not in ('draft')"/>

                                        <field name="company_id" column_invisible="1"/>

                                        <field name="analytic_account_id" readonly="0"
                                               domain="['|',('company_id','=',parent.company_id),('company_id','=',False)]"
                                               options="{'no_create': 1, 'no_open': 1}"/>


                                        <field name="equipment_id" readonly="0" optional="show"
                                               domain="['|',('company_id','=',parent.company_id),('company_id','=',False)]"
                                               options="{'no_create': 1, 'no_open': 1}"/>


                                        <field name="currency_id" column_invisible="1"/>
                                        <field name="request_id" column_invisible="1"/>

                                        <field name="remarks"
                                               readonly="parent.state not in ('draft')"/>

                                    </tree>
                                    <form>
                                        <sheet>
                                            <group>
                                                <group>

                                                    <field name="product_id"/>
                                                    <field name="name"/>

                                                    <div>
                                                        <field name="qty_requested"
                                                               class="oe_inline"/>
                                                        <field name="product_uom_id"

                                                               class="oe_inline"/>
                                                    </div>
                                                    <field name="qty_available"/>
                                                    <field name="qty_requested"/>
                                                    <field name="qty_issued"/>

                                                </group>
                                            </group>

                                            <notebook>
                                            </notebook>
                                        </sheet>
                                    </form>
                                </field>
                            </page>

                            <page string="Other Information">
                                <group>
                                    <group>
                                        <field name="create_date" readonly="0"/>
                                    </group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                    </group>
                                </group>

                            </page>
                        </notebook>

                    </sheet>

                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="view_issuance_request_tree">
            <field name="name">issuance.request.tree</field>
            <field name="model">issuance.request</field>
            <field name="arch" type="xml">
                <tree decoration-bf="message_needaction==True"
                      decoration-info="state in ('draft')"
                      decoration-muted="state in ('reject')"
                      string="Material Request">
                    <field name="message_needaction" invisible="1"/>
                    <field name="name"/>
                    <field name="request_date"/>
                    <field name="requested_by"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="mr_type"/>
                    <!-- <field name="status"/> -->

                    <field name="state"/>
                </tree>
            </field>
        </record>


