<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_lowest_price_evaluation_form" model="ir.ui.view">
            <field name="name">lowest.price.evaluation.form</field>
            <field name="model">lowest.price.evaluation</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Approve" name="action_w_proc_exective" type="object" class="oe_highlight"
                             invisible="state != 'draft'"  groups="material_request.group_buyers"
                        />
                        <button string="Approve" name="action_w_proc_manager" type="object" class="oe_highlight"
                            invisible="state != 'w_proc_manager'"  groups="base_rida.rida_group_supply_chain_manager"
                        />
                        <button string="Set to Draft" name="action_draft"
                                groups="material_request.group_buyers"
                                type="object" invisible="state != 'reject'"/>

                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                              invisible="state != 'w_proc_manager'"  string="Reject"
                                groups="base_rida.rida_group_supply_chain_manager"
                        />
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,w_proc_manager,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button type="object" name="action_view_purchase_order" class="oe_stat_button"
                                    groups="purchase.group_purchase_user" icon="fa-shopping-cart">
                                <field name="purchase_count" string="Purchase" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <table class="table table-bordered">
                                    <tr>
                                        <th style="text-align:center">
                                            <p>Supplier No</p>
                                        </th>
                                        <th style="text-align:center">
                                            <p>Supplier Name</p>
                                        </th>
                                    </tr>
                                    <tr>
                                        <th style="text-align:center">
                                            <p>Sup 1</p>
                                        </th>
                                        <td style="text-align:center">
                                            <field name="a_supplier_id" readonly="1"/>
                                        </td>
                                    </tr>
                                    <tr invisible="b_supplier_id == 'False'">
                                        <th style="text-align:center">
                                            <p>Sup 2</p>
                                        </th>
                                        <td style="text-align:center">
                                            <field name="b_supplier_id" readonly="1"/>
                                        </td>
                                    </tr>
                                    <tr invisible="c_supplier_id == 'False'">
                                        <th style="text-align:center">
                                            <p>Sup 3</p>
                                        </th>
                                        <td style="text-align:center">
                                            <field name="c_supplier_id" readonly="1"/>
                                        </td>
                                    </tr>
                                </table>
                            </group>
                            <group>
                                <field name="title"/>
                                <field name="material_request_id" readonly="1"
                                       options="{'no_create': True, 'no_create_edit':True}"/>
                                <field name="req_id" readonly="1"/>
                                <field name="date_request" readonly="1"/>
                                <field name="company_id" readonly="1"/>
                            </group>
                        </group>

                        <field name="score_ids"  readonly="state == 'approved'" widget="one2many_list">
                            <tree editable="bottom" create="false" delete="false">
                                <field name="supplier" widget="html" readonly="1" attrs="{'invisible': ['|',
                                '&amp;', ('order_of_supplier', '=', 'c'), ('parent.c_supplier_id', '=', False),
                                '&amp;', ('order_of_supplier', '=', 'b'), ('parent.b_supplier_id', '=', False)]}"/>
                                <field name="price" widget="monetary" attrs="{'invisible': ['|',
                                '&amp;', ('order_of_supplier', '=', 'c'), ('parent.c_supplier_id', '=', False),
                                '&amp;', ('order_of_supplier', '=', 'b'), ('parent.b_supplier_id', '=', False)]}"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       string="Price"/>
                                <field name="payment_term_id" attrs="{'invisible': ['|',
                                '&amp;', ('order_of_supplier', '=', 'c'), ('parent.c_supplier_id', '=', False),
                                '&amp;', ('order_of_supplier', '=', 'b'), ('parent.b_supplier_id', '=', False)]}"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>
                                <field name="product_availability" attrs="{'invisible': ['|',
                                '&amp;', ('order_of_supplier', '=', 'c'), ('parent.c_supplier_id', '=', False),
                                '&amp;', ('order_of_supplier', '=', 'b'), ('parent.b_supplier_id', '=', False)]}"/>
                                <field name="delivery_period" attrs="{'invisible': ['|',
                                '&amp;', ('order_of_supplier', '=', 'c'), ('parent.c_supplier_id', '=', False),
                                '&amp;', ('order_of_supplier', '=', 'b'), ('parent.b_supplier_id', '=', False)]}"/>
                                <field name="type" attrs="{'invisible': ['|',
                                '&amp;', ('order_of_supplier', '=', 'c'), ('parent.c_supplier_id', '=', False),
                                '&amp;', ('order_of_supplier', '=', 'b'), ('parent.b_supplier_id', '=', False)]}"/>
                                <field name="order_of_supplier" invisible="1"/>

                            </tree>
                        </field>
                        <group>
                            <field name="comment" readonly="state == 'approved'"/>
                            <field name="award_supplier" readonly="state != 'done'"/>

                          


                        </group>
                    </sheet>
                         <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>


        <record id="view_lowest_price_evaluation_tree" model="ir.ui.view">
            <field name="name">lowest.price.evaluation.tree</field>
            <field name="model">lowest.price.evaluation</field>
            <field name="arch" type="xml">
                <tree string="Lowest Price Evaluation">
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="material_request_id"/>
                    <field name="title"/>
                    <field name="date_request"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>


        <record id="view_lowest_price_evaluation_search" model="ir.ui.view">
            <field name="name">lowest.price.evaluation.search</field>
            <field name="model">lowest.price.evaluation</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="material_request_id"/>
                </search>
            </field>
        </record>


        <record id="action_lowest_price_evaluation" model="ir.actions.act_window">
            <field name="name">Lowest Price Evaluation</field>
            <field name="res_model">lowest.price.evaluation</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'create': 0}</field>
        </record>

        <menuitem name="Lowest Price Evaluation" id="menu_lowest_price_evaluation"
                  action="action_lowest_price_evaluation"
                  parent="menu_technical_evaluation"
                  groups="material_request.group_buyers"
        />
    </data>
</odoo>