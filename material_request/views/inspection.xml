<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="material_inspection_form" model="ir.ui.view">
            <field name="name">Material Inspection</field>
            <field name="model">material.inspection</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="action_submit" type="object" class="oe_highlight"
                                invisible="state != 'draft'"
                                groups="stock.group_stock_user"
                        />

                        <button string="Validate" name="action_qhse_validate" type="object" class="oe_highlight"
                                invisible="state != 'waiting_qhse_inspection'"/>

                        <button string="Validate" name="action_validate" type="object" class="oe_highlight"
                                invisible="state != 'inspection'"/>
                        <button string="Set to Draft" name="action_draft"
                                groups="stock.group_stock_user,base.group_user"
                                type="object" invisible="state != 'reject'"/>
                        <button string="Return Inspection" name="action_draft"
                                groups="stock.group_stock_user"
                                type="object" invisible="state != 'closed'"
                                confirm="You are about to Return this Inspection. Please confirm!"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state != 'inspection'" string="Reject"
                                groups="stock.group_stock_user,base.group_user"
                        />
                        <field name="state" widget="statusbar" invisible="is_catering == True"
                               statusbar_visible="draft,inspection,closed"/>
                        <field name="state_qhse" widget="statusbar" invisible="is_catering != True"
                               statusbar_visible="draft,waiting_qhse_inspection,inspection,closed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="is_catering"/>
                                <field name="requested_by" readonly="1"/>

                                <field name="vendor_id" readonly="1"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>
                                <field name="department_id"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>
                                <field name="po_number" readonly="1"/>
                                <field name="backorder_picking_id" readonly="1"
                                       invisible="backorder_picking_id == False"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="address" readonly="state == 'closed'"/>
                                <field name="material_request_id" readonly="1"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>
                                <field name="material_request_ids" readonly="1" string="All Material Request"
                                       widget="many2many_tags"/>
                                <field name="inspector" readonly="state == 'closed'"/>

                            </group>
                        </group>
                        <field name="inspection_ids"
                               nolabel="1" readonly="state == 'closed'">
                            <tree string="Inspection" editable="bottom" create="false" delete="false">
                                <field name="sequence"/>
                                <field name="product_id" readonly="1"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>
                                <field name="product_uom_id" readonly="1"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>
                                <field name="qty_on_bill" readonly="1"/>
                                <field name="qty_received" readonly="parent.state != 'draft'"/>
                                <field name="expire_date" column_invisible="parent.is_catering != True or parent.state =='draft'"/>
                                <field name="qhse_qty_accepted" readonly="1"
                                       column_invisible="parent.is_catering != True or parent.state in ['draft','waiting_qhse_inspection']"/>
                                <field name="qhse_qty_rejected" readonly="1"
                                       column_invisible="parent.is_catering != True or parent.state in ['draft','waiting_qhse_inspection']"/>
                                <field name="qty_accepted"
                                       readonly="parent.state not in ['inspection','waiting_qhse_inspection']"/>
                                <field name="qty_rejected"
                                       readonly="parent.state not in ['inspection','waiting_qhse_inspection']"/>
                                <field name="note"
                                       required="qty_rejected > 0"
                                       readonly="parent.state not in ['inspection','waiting_qhse_inspection']"
                                />
                            </tree>
                        </field>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="stock_view_form3" model="ir.ui.view">
            <field name="name">stock.view.form.inherit3</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                    <button name="material_inspection" invisible="inspection_count == 0"
                            type="object" class="oe_stat_button" icon="fa-list-alt">
                        <field name="inspection_count" string="Material Inspection" widget="statinfo"/>
                    </button>
                </div>
            </field>
        </record>

        <record id="material_request_inherit_1" model="ir.ui.view">
            <field name="name">material.request.inherit.1</field>
            <field name="model">material.request</field>
            <field name="inherit_id" ref="material_request.view_material_request_form"/>
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                    <button name="material_inspection" invisible="inspection_count == 0"
                            type="object" class="oe_stat_button" icon="fa-list-alt">
                        <field name="inspection_count" string="Material Inspection" widget="statinfo"/>
                    </button>
                </div>
            </field>
        </record>

        <record id="purchase_order_inherit_1" model="ir.ui.view">
            <field name="name">purchase.order.inherit.1</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                    <button name="material_inspection" invisible="inspection_count == 0"
                            type="object" class="oe_stat_button" icon="fa-list-alt">
                        <field name="inspection_count" string="Material Inspection" widget="statinfo"/>
                    </button>
                </div>
            </field>
        </record>


        <record id="material_inspection_tree" model="ir.ui.view">
            <field name="name">Material Inspection</field>
            <field name="model">material.inspection</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="requested_by"/>
                    <field name="material_request_id"/>
                    <field name="po_number"/>
                    <field name="date"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="material_inspection_form_search" model="ir.ui.view">
            <field name="name">Material Inspection</field>
            <field name="model">material.inspection</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="material_inspection_action" model="ir.actions.act_window">
            <field name="name">Material Inspection</field>
            <field name="res_model">material.inspection</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'create': 0}</field>
        </record>

        <menuitem name="Inspections" id="material_inspetion"
                  parent="stock.menu_stock_root"
                  groups="stock.group_stock_user"
                  action="material_inspection_action"/>

    </data>
</odoo>
