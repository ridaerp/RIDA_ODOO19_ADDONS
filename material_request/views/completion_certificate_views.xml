<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_completion_certificate_tree" model="ir.ui.view">
        <field name="name">completion.certificate.tree</field>
        <field name="model">completion.certificate</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="purchase_order_id"/>
                <field name="state"/>
                <field name="approver_id"/>
            </list>
        </field>
    </record>

    <record id="view_completion_certificate_form" model="ir.ui.view">
        <field name="name">completion.certificate.form</field>
        <field name="model">completion.certificate</field>
        <field name="arch" type="xml">
            <form string="Certificate of Completion">
                <header>
                    <button name="action_submit" type="object" string="Submit"    invisible="state not in  ['draft']" class="btn-primary"/>
                    <button name="action_approve" type="object" string="Approve"    invisible="state not in  ['submitted']" class="btn-primary" groups="purchase.group_purchase_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <h1 class="d-flex">
                            <field name="name" readonly="1"/>
                    </h1>
                    <group>
                        <group>

                            <field name="date"/>
                            <field name="purchase_order_id" options="{'no_open': False, 'no_create': True}"/>
                            <field name="partner_id" />
                            <field name="company_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="contractor_name"/>
                            <field name="phone"/>
                            <field name="total_cost"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="duration_from"/>
                            <field name="duration_to"/>
                        </group>
                        <group>
                            <field name="materials"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Remarks">
                            <field name="remarks"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_completion_certificates" model="ir.actions.act_window">
        <field name="name">Completion Certificates</field>
        <field name="res_model">completion.certificate</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_purchase_certificates_root" name="Certificate of Achievement" parent="menu_material_request_main"  action="action_completion_certificates" />
    
</odoo>
