<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_nonaccept_mr" model="ir.sequence">
        <field name="name">non accept material Refrence</field>
        <field name="code">non_accept_material.sequence</field>
        <field name="prefix">NO-</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
      </record>

        <record id="nonaccept_material_search_view" model="ir.ui.view">
            <field name="name">nonaccept.material.search</field>
            <field name="model">nonaccept.material</field>
            <field name="arch" type="xml">
                <search string="Search Non Accept Material">
                    <field name="name" string="Reference"/>
                    <field name="product_id"/>
                    <field name="location_id"/>
                    <field name="vendor_id"/>
                    <group expand="0" string="Group By">
                        <filter string="Product" name="product" domain="[]" context="{'group_by':'product_id'}"/>
                        <filter string="Location" name="location" domain="[]" context="{'group_by':'location_id'}"/>
                    </group>
                </search>
            </field>
        </record>
        <!-- <record model="ir.actions.act_window" id="stock_to_scrap_action">
            <field name="name">Request for Quotation</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">stock.scrap</field>
            <field name="view_mode">form,tree</field>
            <field name="domain">[('requisition_id','=',active_id)]</field>
            <field name="context">{
                "default_requisition_id":active_id,
                "default_user_id": False,
                }
            </field>
        </record> -->

        <record id="non_accept_material_form_view" model="ir.ui.view">
            <field name="name">nonaccept.material.form</field>
            <field name="model">nonaccept.material</field>
            <field name="arch" type="xml">
                <form string="Scrap">
                    <header>
                        <!-- workflow -->
                        <button name="wharehouse_manager_approval"  string="wharehouse manager approval" type="object"  invisible="state != 'draft'"  class="oe_highlight" />
                        <button name="user_department_manager_approval"  string="user department manager approvall" type="object"  invisible="state != 'wharehouse_manager_approval'"  class="oe_highlight" />
                        <button name="supply_chain_manager_approval" string="Supply chain manager approval" type="object"  invisible="state != 'user_department_manager_approval'" class="oe_highlight" />
                        <field name="state" widget="statusbar" statusbar_visible="draft,done" />
                        <!-- actions -->
                        <field name="click" invisible="1"/>
<!--                        <button name="button_scrap" string="Scrap"  type="object" attrs="{'invisible': ['|',('click','=',True),('state', '!=', 'supply_chain_manager_approval')]}" class="oe_highlight"   />-->
<!--                        <button name="button_repair" string="Repair"  type="object" attrs="{'invisible': ['|',('click','=',True),('state', '!=', 'supply_chain_manager_approval')]}" class="oe_highlight"   />-->
<!--                        <button name="button_return_to_supplier" string="Return To Supplier"  type="object" attrs="{'invisible': ['|',('click','=',True),('state', '!=', 'supply_chain_manager_approval')]}" class="oe_highlight"   />-->
                    </header>
                    
    
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <!-- <button class="oe_stat_button" name="action_see_move_scrap" type="object" icon="fa-arrows-v" attrs="{'invisible': [('scrap_count', '=', 0)]}"> -->
                                <button class="oe_stat_button" name="action_see_move_scrap" type="object" icon="fa-arrows-v" invisible="click == False">
                                    <div class="o_field_widget o_stat_info">
                                    <!-- <span class="o_stat_value"><field name="scrap_count"/></span> -->
                                    <span class="o_stat_text">Scraps</span>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1><field name="name" nolabel="1"/></h1>
                        </div>
                        <group>
                            <group>
                               <field name="picking_id" />
                                <field name="purchase_id" />
                                <field name="vendor_id" />
                                <field name="inspect_date" />
                                <field name="analytic_account_id"  options="{'no_create': 1, 'no_open': 1}"/>

                            </group>
                            <group>

                                <field name="location_id" options="{'no_create': True, 'no_open': True}"  force_save="1"/>
                                <field name="company_id" />
                                <field name="department_id" />
                                <field name="origin"/>
                                 <field name="operation_type" required="1"/>

                            </group>
                        </group>
                        <notebook>
                            <page string="Product lines">
                                <field name="order_line" >
                                    <tree string="Purchase Order Lines" editable="top" create="false">
                                        <field name="product_id" />
                                        <field name="product_qty"/>
                                        <field name="nonaccept_qty" readonly="0"/>
                                        <field name="qty_received" string="Received" />
                                        <field name="qty_invoiced" string="Billed" optional="show"/>
                                        <field name="price_subtotal" widget="monetary"/>
                                    </tree>
                                </field>
                             </page>
                             </notebook>

                    </sheet>
                         <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

       

        <record id="non_accept_material_tree_view" model="ir.ui.view">
            <field name="name">nonaccept.material.tree</field>
            <field name="model">nonaccept.material</field>
            <field name="arch" type="xml">
                <tree multi_edit="1" sample="1">
                    <field name="name" decoration-bf="1"/>
                    <field name="product_id" readonly="1"/>
<!--                    <field name="nonaccept_qty"/>-->
                    <!-- <field name="product_uom_id" /> -->
                    <field name="location_id" options="{'no_create': True}" />
                    <field name="company_id" />
                    <field name="state" widget="badge" />
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_nonaccept_material">
            <field name="name">Non Accept Material</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nonaccept.material</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                non accept materials
              </p><p>
                record list for all non accepted materials
              </p>
            </field>
        </record>

        
    <menuitem
        id="menu_nonaccept_material"
        name="Non Accept Material"
        parent="stock.menu_stock_warehouse_mgmt"
        action="action_nonaccept_material"
        sequence="100"/>

</odoo>
