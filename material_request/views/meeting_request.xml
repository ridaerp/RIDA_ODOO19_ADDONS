<odoo>
  <data>



        <record model="ir.ui.view" id="view_meeting_request_tree">
            <field name="name">meeting.request.tree</field>
            <field name="model">meeting.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name_seq" />
                    <!-- ekhlas code -->
                    <field name="date_request" />
                    <field name="meeting_date" />
                    <field name="start_meeting" />
                    <field name="end_meeting" />
                    <field name="requested_by" />
                    <field name="department_id" />
                    <!-- ekhlas code -->
                    <field name="state" />
                </list>
            </field>
        </record>




    <record id="meeting_request_view_calendar" model="ir.ui.view">
        <field name="name">meeting.request.calendar</field>
        <field name="model">meeting.request</field>
        <field name="arch" type="xml">
            <calendar date_start="meeting_date" date_delay="time_request" color="requested_by" event_limit="5">
                <field name="requested_by" filters="1"/>
                <field name="department_id"/>
                <field name="name_seq"/>
            </calendar>
        </field>
    </record>





        <record id="view_meeting_request_form" model="ir.ui.view">
            <field name="name">Meeting Room Request</field>
            <field name="model">meeting.request</field>
            <field name="arch" type="xml">
            <form string="Meeting Room Request">
                    <header>
                        
                   <!--                    Set to Draft-->
                        <button name="button_draft" states="cancel,reject" string="Set as Draft" type="object" />

                        <!--                    MR User-->
                        <button name="button_to_department_manger" states="draft" string="Submit" type="object" class="oe_highlight" groups="base.group_user"/>

                        <button name="button_cancel" states="draft" string="Cancel" type="object" groups="base.group_user" class="" />


                    <!--                    Line Manager-->
                        <button name="button_to_line_manager" string="Approve" type="object" states="line_approve" groups="base_rida.rida_group_line_manager" class="oe_highlight" />

                        <button name="button_to_Adm_man" string="Approve" type="object" states="Adm_man_approve"  class="oe_highlight" />


                        <button name="button_lm_reject"  type="object" states="line_approve" groups="base_rida.rida_group_line_manager" string="Reject"/>


                        <button name="button_Adm_man_reject"  type="object" states="Adm_man_approve"  string="Reject"/>


                        <button name="button_cancel" state="done"  string="Cancel" type="object"
                                confirm="You are about to cancel this request and its related records. Please confirm!" attrs="{'invisible': [('state','!=','done')]}"
                                class=""/>


                        <field name="state" widget="statusbar" tatusbar_visible="draft,done" statusbar_colors='{"manager_approved":"blue"}'/>


                    </header>


                  
<br /> 
    <b><p align="center">Doc. No. UMC-ADM-QP-ADM/15  
-            
Issue/Rev 02/00</p></b>

    <sheet>



                    <h1 class="oe_title">
                        <field name="name_seq" readonly="1" class="oe_inline"/>
                    </h1>
                    
                
            <group>            

            <group>
                <field name="date_request" attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                <field name="time_request" widget="float_time" attrs="{'readonly': [('state', '!=', 'draft')]}"/>



                


                <field name="meeting_date" attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                <field name="start_meeting" attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                <field name="end_meeting" attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                <field name="type_of_services" widget="radio" attrs="{'readonly': [('state','not in', ('draft'))]}" />
                <field name="specify" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                <field name="lcd_screen" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                <field name="laptop" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                <field name="others_electronic_device" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                 <field name="note" string="Purpose" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                
                            
            </group>





            <group>
               
             <field name="requested_by" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
               
             <field name="department_id"/>

              <field name="meeting_room_id" required="1" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                
           

                 <field name="no_of_attendees" attrs="{'readonly': [('state', '!=', 'draft')]}"/>


             
            </group>


                          
                      </group>



                     <group >
                    </group>
         <group>

             
             <field name="admin_comment" attrs="{'readonly': [('state', '!=', 'Adm_man_approve')]}"/>


             <field name="admin_date" attrs="{'readonly': [('state', '!=', 'Adm_man_approve')]}"/>

             <field name="admin_time" attrs="{'readonly': [('state', '!=', 'Adm_man_approve')]}"/>
  
        </group>



              

              </sheet>
                <chatter/>
           </form>





                        
            
            </field>
          </record>




    <!-- actions opening views on models -->

    <record model="ir.actions.act_window" id="rida_forms.meeting_request">
      <field name="name">Meeting Room Request</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">meeting.request</field>
      <field name="view_mode">list,calendar,form</field>
    </record>







    <menuitem name="Request Forms" id="rida_forms.menu_root"
        web_icon="rida_forms,static/description/icon.png"
            sequence="0"/>

 


  </data>
</odoo>