<odoo>
  <data>
    <!-- Add you code here -->
    <record id="nus_ITB_inherit_form" model="ir.ui.view">
      <field name="name">Bid Selection</field>
      <field name="model">purchase.requisition</field>
      <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_form" />
      <field name="arch" type="xml">
        <xpath expr="//field[@name='vendor_id']" position="after">
          <field name="request_id" string="Main Material Request"/>
          <field name="request_ids" widget="many2many_tags" readonly="1" string="Material Request Merged"/>
        </xpath>
        <xpath expr="//button[@name='770']" position="replace">
            <button name="770" type="action" string="New Quotation" context="{'default_request_id': request_id}" invisible="state != 'open'"/>

            <button name="transfer_data" type="object" string="transfer data"/>

        </xpath>
      </field>
    </record>


    <menuitem id="purchase_requisition.menu_purchase_requisition_pro_mgt" sequence="10" name="Purchase Agreements" parent="purchase.menu_procurement_management" action="purchase_requisition.action_purchase_requisition" />
  </data>
</odoo>
