<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_accouting_purchase_contract_payment" model="ir.actions.act_window">
            <field name="name">Contract Payment</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="search_view_id" ref="purchase.purchase_order_view_search"/>
            <field name="domain">[('contract_purchased','=',True)]</field>
            <field name="context">{'edit': 0,'create': 0}</field>
        </record>
        <record model="ir.actions.act_window" id="action_acc_purchase_contract_payment">
            <field name="name">Purchase Contracts</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.contract</field>
            <field name="view_mode">tree</field>
            <field name="context">{'edit': 0,'create': 0}</field>
            <field name="search_view_id" ref="material_request.view_purchase_contract_filter"/>
        </record>

        <record id="action_account_ore_po_purchase" model="ir.actions.act_window">
            <field name="name">Ore/Rock Purcharses</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="purchase.purchase_order_kpis_tree"/>
            <field name="search_view_id" ref="purchase.purchase_order_view_search"/>
            <field name="context">{'default_ore_purchased':True,'edit': 0,'create': 0}</field>
            <field name="domain">[('ore_purchased','=',True)]</field>
        </record>
        <record id="purchase_form_accounting_action" model="ir.actions.act_window">
            <field name="name">Purchase Orders</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="material_request.purchase_order_view_inherit_tree"/>
            <field name="domain">[('state','in',('purchase', 'done')),('ore_purchased','=',False)]</field>
            <field name="search_view_id" ref="purchase.purchase_order_view_search"/>
            <field name="context">{'edit': 0,'create': 0}</field>
        </record>



        
        <menuitem name="Contract Payment" id="account_contract_payment" parent="account.menu_finance_payables"
                  action="action_accouting_purchase_contract_payment"
                  groups="account.group_account_user"/>
        <menuitem id="menu_account_ore_poo_root" parent="account.menu_finance_payables"
                  action="action_account_ore_po_purchase"
                  groups="account.group_account_user"/>
        <menuitem name="Purchase Contracts" id="menu_acc_purchase_contract_root" parent="account.menu_finance_payables"
                  action="action_acc_purchase_contract_payment"
                  groups="account.group_account_user"/>
        <menuitem action="purchase_form_accounting_action" id="menu_acc_purchase_read_form_action"
                  parent="account.menu_finance_payables" groups="account.group_account_user"/>

                  
        <menuitem action="stock_landed_costs.action_stock_landed_cost" name="Landed Costs"
                  parent="account.menu_finance_payables" groups="account.group_account_user" id="menu_acc_purchase_stock_landed_cost"/>

    </data>
</odoo>