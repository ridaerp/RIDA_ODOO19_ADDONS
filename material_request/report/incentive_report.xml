<?xml version="1.0" encoding="utf-8"?>
<odoo>

 <record id="report_incentive_report_view" model="ir.ui.view">
        <field name="name">Incentive Sechema</field>
        <field name="model">ore.incentive.report</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <div>
                            <div class="o_row o_row_readonly o_hr_holidays_dates">
                                
                                <field name="date_from" class="oe_inline" nolabel="1" required="1"/>
                                <field name="date_to" class="oe_inline" nolabel="1" required="1"/>
                              
                            </div>
                        </div>
                    </group>
                 
                </group>

                <footer>
                    <button name="generate" string="Generate Report" type="object" default_focus="1" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


