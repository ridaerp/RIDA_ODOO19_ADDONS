        <field name="name">Restrict Analytic account /User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_user_product_category" model="res.groups">
        <field name="name">Restrict Product Category/User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>


    <record id="costcenter_user_rule" model="ir.rule">
        <field name="name">Cost Center/User</field>
        <field name="model_id" ref="analytic.model_account_analytic_account"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('id','in',user.analytic_account_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_user_coscenter'))]"/>
    </record>

    <record id="product_category_user_rule" model="ir.rule">
        <field name="name">Product Category/User</field>
        <field name="model_id" ref="product.model_product_category"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('id','in',user.product_category_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_user_product_category'))]"/>
    </record>

    <record id="product_category_user2_rule" model="ir.rule">
        <field name="name">Product Category/User 2</field>
        <field name="model_id" ref="product.model_product_category"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('parent_id.id','in',user.product_category_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_user_product_category'))]"/>
    </record>

    <record id="product_category_user3_rule" model="ir.rule">
        <field name="name">Product Category/User 3</field>
        <field name="model_id" ref="product.model_product_category"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('parent_id.parent_id.id','in',user.product_category_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_user_product_category'))]"/>
    </record>


    <record id="purchase.purchase_user_account_move_rule" model="ir.rule">
        <field name="name">Purchase User Account Move</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="domain_force">[('move_type', 'in', ('in_invoice', 'in_refund', 'in_receipt'))]</field>
        <field name="groups" eval="[(4, ref('purchase.group_purchase_user'))]"/>
    </record>


