<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <record id="weight_scoring_request" model="ir.sequence">
            <field name="name">Weight scorint</field>
            <field name="code">weight.scoring.evaluation</field>
            <field name="prefix">T.EV</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="lowest_price_request" model="ir.sequence">
            <field name="name">lowest price</field>
            <field name="code">lowest.price.evaluation</field>
            <field name="prefix">LPE</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>


        <record id="supplier_evaluation" model="ir.sequence">
            <field name="name">supplier evaluation</field>
            <field name="code">supplier.evaluation.code</field>
            <field name="prefix">SUPE</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_completion_certificate" model="ir.sequence">
            <field name="name">Completion Certificate</field>
            <field name="code">completion.certificate</field>
            <field name="prefix">CC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
