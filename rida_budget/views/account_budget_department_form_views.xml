<odoo>
    <record id="view_budget_department_form_tree" model="ir.ui.view">
        <field name="name">budget.department.form.tree</field>
        <field name="model">budget.department.form</field>
        <field name="arch" type="xml">
           <tree string="Department Budgets">
               <field name="name"/>
                <field name="department_id"/>
                <field name="manager_id" widget="many2one_avatar_user"/>
                <field name="budget_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'confirmed'"/>
           </tree>
        </field>
    </record>
    
    <record id="view_budget_department_form_form" model="ir.ui.view">
        <field name="name">budget.department.form.form</field>
        <field name="model">budget.department.form</field>
        <field name="arch" type="xml">
           <form string="Department Budget Entry">
               <header>
                   <button name="action_submit"
                        string="Submit"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'draft'"
                        groups="rida_budget.group_budget_department_user"
                        confirm="Are you sure you want to approve these figures?"/>
                   <button name="action_approve"
                        string="Approve"
                        type="object"
                        class="oe_highlight"
                        invisible="state != 'submit'"
                        groups="rida_budget.group_budget_department_manager"
                        confirm="Are you sure you want to approve these figures?"/>
                   <button name="action_budget"
                           string="Approve"
                           type="object"
                           class="oe_highlight"
                           invisible="state != 'approve'"
                           groups="base_rida.budget_costing_manager"/>
<!--                   <button name="action_fin_approve"-->
<!--                           string="Approve"-->
<!--                           type="object"-->
<!--                           class="oe_highlight"-->
<!--                           invisible="state != 'fin_approve'"-->
<!--                           groups="base_rida.rida_finance_manager"/>-->
<!--                   <button name="action_dir_approve"-->
<!--                           string="Approve"-->
<!--                           type="object"-->
<!--                           class="oe_highlight"-->
<!--                           invisible="state != 'dir_approve'"-->
<!--                           groups="base_rida.group_finance_director"/>-->
<!--                   <button name="action_ceo_approve"-->
<!--                           string="Confirm &amp; Update Master Budget"-->
<!--                           type="object"-->
<!--                           class="oe_highlight"-->
<!--                           invisible="state != 'ceo_approve'"-->
<!--                           groups="base_rida.rida_group_ceo"/>-->
<!--                   <button name="%(maintenance_fleet_inherit.rejection_wizard_reject_action)d" string="Reject"-->
<!--                                invisible="state in ['confirmed','done']"-->
<!--                                groups="base_rida.budget_costing_manager,base_rida.rida_finance_manager,base_rida.group_finance_director,base_rida.rida_group_ceo"-->
<!--                                type="action"/>-->
                   <button string="Reset to Draft" name="action_draft" type="object" invisible="state != 'cancel'"/>
<!--                   <button string="Cancel" name="action_cancel" type="object" invisible="state in ['draft','confirmed', 'cancel']"/>-->
                <field name="state" widget="statusbar" statusbar_visible="draft,submit,approve,fin_approve,dir_approve,ceo_approve,confirmed"/>
                </header>
                <sheet>
                    <div class="alert alert-warning" role="alert" style="margin-bottom:10px;" invisible="state != 'draft'">
                        <strong>تنبيه الإدخال:</strong>
                        يرجى إدخال المبالغ بـ <strong><field name="currency_id" readonly="1" options="{'no_open': True}"/></strong>.
                        <br/>
                        * للمصروفات: أدخل المبلغ بـ <strong>إشارة سالب (-)</strong> (مثال: -5000).
                        <br/>
                        * للإيرادات: أدخل المبلغ بـ <strong>إشارة موجب</strong> (مثال: 5000).
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="New..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="department_id" readonly="state != 'draft'"/>
                            <field name="manager_id" readonly="state != 'draft'"/>
                            <field name="budget_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date_from" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                            <field name="budget_type" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Budget Lines" name="lines">
                            <field name="line_ids" readonly="state != 'draft'">
                                <tree editable="bottom">
                                    <field name="general_budget_id"/>
                                    <field name="analytic_account_id"/>
                                    <field name="start_from"/>
                                    <field name="end_to"/>
                                    <field name="planned_amount" sum="Total Planned"/>
                                    <field name="practical_amount" sum="Total Practical" readonly="1"/>
                                    <field name="custom_practical_amount" readonly="1"/>
                                    <field name="amendment_amount" sum="Total Practical" readonly="1"/>
                                    <field name="amendment_amount_custom" sum="Total Practical" readonly="1"/>
                                    <field name="theoretical_amount" sum="Total Theoretical" readonly="1"/>
                                    <field name="custom_theoretical_amount" readonly="1"/>
                                    <field name="percentage" widget="percentage" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
           </form>
        </field>
    </record>

    <record id="action_budget_department_form" model="ir.actions.act_window">
        <field name="name">Budget Department</field>
        <field name="res_model">budget.department.form</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem 
        name="Budget" web_icon="rida_budget,static/description/images.png"
        action="action_budget_department_form" id="menu_budget_department_form"
        sequence="20" groups="rida_budget.group_budget_department_manager,rida_budget.group_budget_department_user"/>
</odoo>