<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_budget_transfer_wizard_form" model="ir.ui.view">
        <field name="name">budget.transfer.wizard.form</field>
        <field name="model">budget.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Budget Transfer Request">
                <sheet>
                    <field name="currency_id" invisible="1"/>

                    <div class="alert alert-warning" role="alert"  invisible = "currency_id == False">
                        <i class="fa fa-info-circle"/>
                        تنبيه: جميع المبالغ المدخلة والموضحة أدناه هي
                        <strong>بعملة الموازنة المخصصة (<field name="currency_id" readonly="1" options="{'no_open': True}"/>)</strong>.
                    </div>

                    <group>
                        <group string="Source Information">
                            <field name="request_id" invisible="1"/>
                            <field name="department_id" force_save="1"/>
                            <field name="source_master_line_id"
                                   options="{'no_create': True, 'no_open': True}"
                                   domain="[('department_id', '=', department_id),
                                            ('crossovered_budget_id.state', '=', 'validate')]"/>

                            <field name="source_analytic_account_id" readonly="1" force_save="1"/>

                            <label for="available_amount"/>
                            <div class="o_row">
                                <field name="available_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <span class="text-muted">(Available in Budget Currency)</span>
                            </div>
                        </group>

                        <group string="Transfer Details">
                            <field name="dest_budget_post_id" readonly="1" force_save="1"/>
                            <field name="dest_analytic_account_id" readonly="1" force_save="1"/>

                            <field name="transfer_amount"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_transfer" string="Create Budget Form" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_budget_transfer_wizard" model="ir.actions.act_window">
        <field name="name">Budget Transfer</field>
        <field name="res_model">budget.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>