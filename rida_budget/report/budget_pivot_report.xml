<odoo>
    <data>
        <record id="view_budget_line_pivot_custom" model="ir.ui.view">
            <field name="name">budget.pivot.report.pivot</field>
            <field name="model">budget.pivot.report</field>
            <field name="arch" type="xml">
                <pivot string="Budget Report">

                    <!-- Rows -->
                    <field name="department_id" type="row"/>
                    <field name="account_id" type="row"/>

                    <!-- Columns -->
                    <field name="budget_id" type="col"/>

                    <!-- Measures -->
                    <field name="budget_amount" type="measure"/>
                    <field name="achieved_amount" type="measure"/>
                    <field name="committed_amount" type="measure"/>
                    <field name="amendment_amount" type="measure"/>

                </pivot>
            </field>
        </record>

        <record id="view_budget_pivot_list" model="ir.ui.view">
            <field name="name">budget.pivot.report.lsit</field>
            <field name="model">budget.pivot.report</field>
            <field name="arch" type="xml">
                <list>
                    <field name="budget_id"/>
                    <field name="department_id"/>
                    <field name="account_id"/>
                    <field name="budget_amount"/>
                    <field name="achieved_amount"/>
                    <field name="committed_amount"/>
                </list>
            </field>
        </record>

        <record id="action_budget_pivot_custom" model="ir.actions.act_window">
            <field name="name">Budget Report</field>
            <field name="res_model">budget.pivot.report</field>
            <field name="view_mode">pivot,list</field>
        </record>
        
        <menuitem id="menu_budget_pivot_custom"
            name="Budget Report"
            parent="account.account_transactions_menu"
            action="action_budget_pivot_custom" sequence="99"/>
    </data>
</odoo>