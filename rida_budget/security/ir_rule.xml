<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_budget_department_user" model="ir.rule">
            <field name="name">Budget Department - User</field>
            <field name="model_id" ref="rida_budget.model_budget_department_form"/>
            <field name="domain_force">[
                    '&amp;',
                    ('department_id', 'parent_of', user.employee_id.department_id.id),
                    ('department_id', '!=', False)
                ]
            </field>
            <field name="groups"
                   eval="[(4, ref('rida_budget.group_budget_department_user'))]"/>
        </record>

        <record id="rule_budget_department_section_head" model="ir.rule">
            <field name="name">Budget Department</field>
            <field name="model_id" ref="rida_budget.model_budget_department_form"/>
            <field name="domain_force">
                [
                    '&amp;',
                    ('department_id', 'parent_of', user.employee_id.department_id.id),
                    ('department_id', '!=', False)
                ]
            </field>
            <field name="groups"
                   eval="[(4, ref('rida_budget.group_budget_department_manager'))]"/>
        </record>

        <record id="rule_budget_department_manager_all" model="ir.rule">
            <field name="name">Budget Department - Board of Directors</field>
            <field name="model_id" ref="rida_budget.model_budget_department_form"/>
            <field name="domain_force">[('department_id.director_id', '=', user.id)]</field>
            <field name="groups"
                   eval="[
                     (4, ref('rida_budget.group_budget_bod'))
                   ]"/>
        </record>

        <record id="rule_budget_department_ceo" model="ir.rule">
            <field name="name">CEO Budget</field>
            <field name="model_id" ref="rida_budget.model_budget_department_form"/>
            <field name="domain_force">	[(1,'=',1)]</field>
            <field name="groups"
                   eval="[
                     (4, ref('rida_budget.group_budget_ceo'))
                   ]"/>
        </record>

    </data>
</odoo>