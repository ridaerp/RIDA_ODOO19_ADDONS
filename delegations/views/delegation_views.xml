<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record model="ir.ui.view" id="hr_delegation_tree">
            <field name="name">hr.delegation.tree</field>
            <field name="model">hr.delegation</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="display_name"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record model="ir.ui.view" id="hr_delegation_form">
            <field name="name">hr.delegation.form</field>
            <field name="model">hr.delegation</field>
            <field name="arch" type="xml">
                <form duplicate="false">
                    <header>
                        <button name="submit" string="Submit"  type="object" groups="base.group_user"
                             invisible="state != 'draft'"   class="oe_highlight"/>
                        <button name="submit_ict" string="Approve" type="object"
                           invisible="state != 'department'"      groups="base_rida.rida_group_line_manager" class="oe_highlight"
                               />
                        <button name="action_confirm" string="Grant Access"  type="object"
                           invisible="state != 'w_ict'"      groups="base_rida.rida_group_ict_team" class="oe_highlight"/>
                        <button name="action_cancel" string="Revoke Access"
                           invisible="state != 'confirm'"      groups="base_rida.rida_group_ict_team" type="object"/>
                        <button name="action_draft" string="Set to Draft"
                                invisible="state != 'department' or is_manager == True"
                                groups="base_rida.rida_group_ict_team" type="object"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="employee_id"
                                       options="{'no_create': True, 'no_create_edit':True, 'no_open': True}"
                                       domain="[('user_id', '!=', False)]"
                                       readonly="state != 'draft'"/>
                                <field name="employee_grant_id" domain="[('user_id', '!=', False)]"
                                       options="{'no_create': True, 'no_create_edit':True, 'no_open': True}"
                                       readonly="state != 'draft'"/>
                                <field name="requester_id" invisible="1"/>
                                <field name="is_manager" invisible="1"/>
                                <field name="hr_access" invisible="1"/>
                            </group>
                            <group>
                                <div>
                                    <label for="date_from" string="Period"/>
                                    <field name="date_from" class="oe_inline"
                                           readonly="state != 'draft'"/>
                                    <i class='fa fa-arrow-right' style="margin: 0 20px;"></i>
                                    <field name="date_to" class="oe_inline"
                                           readonly="state != 'draft'"
                                           nolabel="1"/>
                                </div>
                            </group>
                            <group>
                                <field name="justification" readonly="state not in ['draft','department']" />
                                <field name="remarks" readonly="state not in ['draft','department']"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Access Rights" groups="base_rida.rida_group_ict_team">
                                <field name="groups_id" readonly="state not in ['draft']">
                                    <tree create="0">
                                        <field string="Group" name="display_name"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                  <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->

        <record id="view_delegation_filter" model="ir.ui.view">
            <field name="name">delegation.search</field>
            <field name="model">hr.delegation</field>
            <field name="arch" type="xml">
                <search string="Search">
                    <field name="employee_id"/>
                    <field name="employee_grant_id"/>
                    <field name="state"/>
                    <group expand="0" string="Group By">
                        <filter string="Employee" name="employee" domain="[]" context="{'group_by': 'employee_id'}"/>
                        <filter string="Designated" name="employee_grant" domain="[]"
                                context="{'group_by':'employee_grant_id'}"/>
                        <filter string="Status" name="type" domain="[]" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record model="ir.actions.act_window" id="hr_delegation_action">
            <field name="name">Delegations</field>
            <field name="res_model">hr.delegation</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new delegation
                </p>
                <p>
                    Grant access to another employee.
                </p>
            </field>
        </record>
        <!-- This Menu Item will appear in the Upper bar, that's why It needs NO parent or action -->
        <menuitem id="delegations_menu_root" name="Delegation Request" parent="base_rida.cus_menu_hr_root" sequence="3"
                  action="hr_delegation_action" groups="base.group_user"/>

    </data>
</odoo>
