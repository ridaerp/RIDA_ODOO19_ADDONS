<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--  Accounting Loan  rule -->
        <record id="accountant_loan_rule" model="ir.rule">
            <field name="name">Accountant Loan</field>
            <field name="model_id" ref="model_hr_loan"/>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="domain_force">['|',('state', '=','accountant'),'|',('state', '=','approve'),('state',
                '=','paid')]
            </field>
        </record>


        <record id="all_loans_rule" model="ir.rule">
            <field name="name">All Loan</field>
            <field name="model_id" ref="model_hr_loan"/>
            <field name="groups" eval="[(4, ref('account.group_account_manager')),(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.rida_internal_audit')),(4, ref('base_rida.rida_finance_manager')),(4, ref('base_rida.rida_group_site_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
                        
        </record>

    </data>
</odoo>