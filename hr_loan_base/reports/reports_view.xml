<odoo>
    <data>
        <record id="hr_lo_report_pdf" model="ir.actions.report">
            <field name="name">Loan Report</field>
            <field name="model">hr.loan</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hr_loan_base.hr_loan_report_pdf</field>
            <field name="report_file">hr_loan_base.hr_loan_report_pdf</field>
            <field name="print_report_name">'Loan - %s' % (object.name)</field>
