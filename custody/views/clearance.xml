<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_clear_view_form" model="ir.ui.view">
        <field name="name">account.custody.clear.form</field>
        <field name="model">custody.clear</field>
        <field name="arch" type="xml">
            <form string="Custody Clearance">
                <header>


                    <!-- add lines by ekhlas -->
                    <button string='Submit' name="button_submit" invisible="state != 'draft'" type="object"
                            class="btn-primary"/>


                    <!-- add lines by ekhlas -->

                    <button name="button_lm_approve" type="object" invisible="state != 'req_manager'"
                            groups="base_rida.rida_group_line_manager" class="btn-primary" string="Approve"/>
                    <button name="button_lm_reject" type="object" invisible="state != 'req_manager'"
                            groups="base_rida.rida_group_line_manager" string="Reject"/>


                    <!-- add lines by ekhlas -->
                    <button string='Approve' name="action_submit_to_finance_manager"
                            groups="base_rida.rida_finance_manager" invisible="state != 'finance_manager'" type="object"
                            class="btn-primary"/>


                    <button name="button_fin_mgr_reject" type="object" groups="base_rida.rida_finance_manager"
                            invisible="state != 'finance_manager'" string="Reject"/>


                    <!-- added by ekhlas code -->


                    <button name="action_internal_audit_sheets" invisible="state != 'internal_audit'" string="Approve"
                            type="object" groups="base_rida.rida_internal_audit"
                            class="oe_highlight o_expense_sheet_approve"/>

                    <button name="button_audit_reject" type="object" groups="base_rida.rida_internal_audit"
                            invisible="state != 'internal_audit'" string="Reject"/>


                    <button name="button_site_approval" groups="base_rida.rida_group_site_manager" type="object"
                            invisible="state != 'site_approval'" class="btn-primary" string="Approve"/>
                    <button name="button_site_reject" type="object" groups="base_rida.rida_group_site_manager"
                            invisible="state != 'site_approval'" string="Reject"/>


                    <button name="button_ccso_approval" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO" type="object"
                            invisible="state != 'ccso_approval'" class="btn-primary" string="Approve"/>
                    <button name="button_ccso_reject" type="object" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"
                            invisible="state != 'ccso_approval'" nvisible="state != 'ccso_approval'" string="Reject"/>


                    <button name="button_fleet_approval" groups="base_rida.group_fleet_director"
                            invisible="state != 'fleet_approval'" type="object" class="btn-primary" string="Approve"/>
                    <button name="button_fleet_reject" type="object" groups="base_rida.group_fleet_director"
                            invisible="state != 'fleet_approval'" string="Reject"/>

                    <!-- end of ekhlas code  -->


                    <!-- Site Accountant -->
                    <button string='Approve' name="validate" groups="account.group_account_user"
                            invisible="state != 'accountant'" type="object" class="btn-primary"
                    />
                    <button string='Reject' name="action_reject" groups="account.group_account_user" type="object"
                            invisible="state != 'accountant'"
                    />
                    <button string='Set to Draft' name="action_draft" type="object"
                            invisible="state not in ['cancel', 'reject']"/>

                    <button string='cancel' name="button_cancel" type="object"
                            invisible="state != 'accountant'"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,req_manager,finance_manager,approved"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label">Custody Clearance</span>
                        <h1>
                            <field name="ac_id" domain="[('state','=','paid')]" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <field name="id" invisible="1"/>
                    <!--<div class="oe_title">-->
                    <!--<h1>Custody Clearance</h1>-->
                    <!--</div>-->
                    <group>
                        <group>
                            <field name="employee_id" required="1"/>
                            <field name="communication"/>
                            <field name="name"/>
                            <field name="currency_id" invisible="0"/>
                        </group>
                        <group>
                            <field name="cus_amount"/>
                            <!-- old code <field name="journal_id" groups="base_rida.rida_finance_manager"/> -->
                            <field name="journal_id" groups="account.group_account_user"
                                   domain="[('type','=','general'),('company_id','=',company_id)]"
                                   required="state == 'accountant'"/>

                            <field name="company_id" readonly="1"/>
                            <field name="analytic_id"/>
                            <field name="attachment" required="0" invisible="0"/>


                            <!--                                 <field name="is_manager" invisible="1"/>
                             -->
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Clearing Accounts">
                            <!--                            <field name="account_ids"   nolabel="1" widget="one2many_list" context="{'wizard_id': active_id}">-->
                            <field name="account_ids" nolabel="1" widget="one2many_list">
                                <tree editable="bottom" open="false">

                                    <field name="desc"/>
                                    <!-- <field name="parent.company_id" invisible="1"/> -->
                                    <field name="partner_id"/>

                                    <!-- change by ekhlas add domain -->
                                    <field name="account_id" domain="[('company_id','=',parent.company_id)]"
                                           string="Account" invisible="parent.state == 'draft'"
                                           required="parent.state == 'accountant'"/>
                                    <field name="cost_center"/>
                                    <field name="amount" sum="amount"/>
                                    <field name="attachment"
                                           required="0" invisible="1"
                                    />

                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <group class="oe_subtotal_footer oe_right" colspan="2" name="sale_total">
                        <field name="residual" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                    </group>
                </sheet>
                       <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>


            </form>
        </field>
    </record>
    <record id="clear_cash_tree" model="ir.ui.view">
        <field name="name">custody.clear.tree</field>
        <field name="model">custody.clear</field>
        <field name="arch" type="xml">
            <tree default_order='create_date desc' string="Petty Cash Request list">
                <field name="name"/>
                <field name="company_id" invisible="1"/>

                <field name="ac_id"/>
                <field name="clearance_date"/>
                <field name="company_id"/>
                <field name="state" widget="badge"/>
                <field name="amount"/>

            </tree>
        </field>
    </record>
    <!-- Expenses -->
    <record id="account_custody_clear_action" model="ir.actions.act_window">
        <field name="name">Custody Clearance</field>
        <field name="res_model">custody.clear</field>
        <!--             <field name="view_type">form</field>-->
        <field name="view_mode">tree,form</field>
        <field name="domain">[('create_uid','=', uid)]</field>
        <!-- <field name="view_id" ref="account_custody_clear_view_form"/> -->
    </record>

    <menuitem
            id="menu_account_custody_clear_employee"
            action="account_custody_clear_action"
            name="My Clearance"
            sequence="10"
            parent="menu_account_custody"
    />

</odoo>