<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="account_custody_form_view_custom" model="ir.ui.view">
            <field name="name">account.custody.form.custom.view</field>
            <field name="model">account.custody</field>
            <field name="arch" type="xml">
              <form string="Custodies">
                    <header>
                        <button name="button_submit" type="object" invisible="state != 'draft'" class="btn-primary"
                                string="Submit"/>

                        <!--comment by ekhlas code  old code <button name="button_lm_approve"  type="object"  invisible="state != 'lm_approval'" groups="material_request.group_department_manager" class="btn-primary" string="Approve"/>
                         <button name="button_lm_reject"  type="object" invisible="state != 'lm_approval'" groups="material_request.group_department_manager" string="Reject"/>

                     -->
                        <!-- add line by ekhlas -->
                        <button name="button_lm_approve" type="object" invisible="state != 'lm_approval'"
                                groups="base_rida.rida_group_line_manager" class="btn-primary" string="Approve"/>
                        <button name="button_lm_reject" type="object" invisible="state != 'lm_approval'"
                                groups="base_rida.rida_group_line_manager" string="Reject"/>


                        <button name="button_fin_mgr_approval" groups="base_rida.rida_finance_manager" type="object"
                                invisible="state != 'fin_mgr_approval'" class="btn-primary" string="Approve"/>
                        <button name="button_fin_mgr_reject" type="object" groups="account.group_account_user"
                                invisible="state != 'fin_mgr_approval'" string="Reject"/>


                        <button name="action_internal_audit_sheets" invisible="state != 'internal_audit'"
                                string="Approve" type="object" groups="base_rida.rida_internal_audit"
                                class="oe_highlight o_expense_sheet_approve"/>

                        <button name="button_audit_reject" type="object" groups="base_rida.rida_internal_audit"
                                invisible="state != 'internal_audit'" string="Reject"/>


                        <button name="button_site_approval" groups="base_rida.rida_group_site_manager" type="object"
                                invisible="state != 'site_approval'" class="btn-primary" string="Approve"/>
                        <button name="button_site_reject" type="object" groups="base_rida.rida_group_site_manager"
                                invisible="state != 'site_approval'" string="Reject"/>


                        <button name="button_ccso_approval" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO" type="object"
                                invisible="state != 'ccso_approval'" class="btn-primary" string="Approve"/>
                        <button name="button_ccso_reject" type="object" groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"
                                invisible="state != 'ccso_approval'" string="Reject"/>


                        <!-- added by ekhlas code -->

                        <button name="button_fleet_approval" groups="base_rida.group_fleet_director" type="object"
                                invisible="state != 'fleet_approval'" class="btn-primary" string="Approve"/>
                        <button name="button_fleet_reject" type="object" groups="base_rida.group_fleet_director"
                                invisible="state != 'fleet_approval'" string="Reject"/>


                        <!-- <button name="action_post" groups="account.group_account_manager" type="object" states="approve" string="Set as Paid" class="btn-primary"/> -->
                        <button name="action_register_payment" groups="account.group_account_user" type="object"
                                invisible="state != 'treasury_approval'" string="Register Payment" class="btn-primary"/>


                        <button name="button_action_post" groups="account.group_account_user" type="object"
                                invisible="state != 'posted'" string="Paid" class="btn-primary"/>


                        <!-- groups="account.group_account_user" => account.group_account_manager -->
                        <button name="button_cancel" type="object"
                                invisible="state not in ['draft', 'lm_approval', 'fin_mgr_approval', 'treasury_approval', 'ccso_approval', 'site_approval']"
                                string="Cancel"/>
                        <button name="button_set_Draft" type="object" invisible="state != 'cancel'" class="btn-primary"
                                string="set_TO_Draft"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,approve,paid,cleared"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">

                            <button class="oe_stat_button" name="button_payment"
                                    readonly="state not in ['posted', 'paid', 'partially_cleared', 'cleared']"
                                    string="Payment" type="object" icon="fa-usd"/>
                            <button class="oe_stat_button" name="button_journal_entries"
                                    invisible="state not in ['posted', 'paid', 'partially_cleared', 'cleared']"
                                    string="Journal Entiry" type="object" icon="fa-folder-open-o"/>
                            <button class="oe_stat_button" name="button_journals"
                                    invisible="state not in ['partially_cleared', 'cleared']" string="Clearing Entries"
                                    type="object" icon="fa-bars"/>
                        </div>
                        <h1 class="oe_title">
                            Number :
                            <field name="name" readonly="1" class="oe_inline"/>
                        </h1>
                        <group>
                            <group>
                                <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"
                                       readonly="state != 'draft'"/>
                                <field name="date_request" required="1" readonly="state not in ['draft']"/>
                                <field name="requested_by"/>

                                <field name="department_id" required="1" readonly="state not in ['draft']"/>
                                <field name="employee_id" required="1" readonly="state not in ['draft']"/>
                                <field name="description" required="1" readonly="state not in ['draft']"/>
                                <!-- <field name="is_line_manager" invisible="1"/> -->
                            </group>
                            <group>
                                <field name="amount" required="1" readonly="state not in ['draft']"/>
                                <field name="currency_id" invisible="0" required="1"
                                       options="{'no_create': True, 'no_open': True}"
                                       readonly="state not in ['draft']"/>
                                <field name="amount_char" required="1" readonly="1"/>
                                <field name="account_id" domain="[('account_type','=','asset_receivable')]"
                                       groups="account.group_account_user" invisible="state in ['draft','lm_approval']"
                                       readonly="state in ['paid','cleared','partially_cleared']"/>
                                <field name="analytic_id" required="1"/>

                                <field name="journal_id" domain="[('type','in',['bank','cash'])]"
                                       groups="account.group_account_user"
                                       invisible="state in ['draft', 'lm_approval', 'ccso_approval', 'fin_mgr_approval', 'site_approval', 'fleet_approval']"
                                       readonly="state in ['paid', 'cleared', 'partially_cleared']"
                                       required="state == 'treasury_approval'"/>

                                <field name="account_move_id" readonly="1"/>
                                <!-- groups="account.group_account_user" => account.group_account_manager -->
                            </group>
                        </group>
                        <group class="oe_subtotal_footer oe_right" colspan="2" name="sale_total">
                            <field name="clear_amount" readonly="1" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="residual" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </sheet>

                    <chatter/>

                </form>
            </field>
        </record>


