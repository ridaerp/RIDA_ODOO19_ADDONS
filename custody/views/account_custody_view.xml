        <record id="account_custody_tree_view" model="ir.ui.view">
            <field name="name">account.custody.tree.view</field>
            <field name="model">account.custody</field>
            <field name="arch" type="xml">
                <list default_order='create_date desc' string="Custodies">
                    <field name="date_request"/>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="amount" sum="Total"/>
                    <field name="currency_id"/>
                    <field name="state"/>
                    <!-- added in extended custody -->
                    <!-- <field name="state"/> -->
                </list>
            </field>
        </record>

        <record id="view_account_custody_search" model="ir.ui.view">
            <field name="name">account.custody.list.select</field>
            <field name="model">account.custody</field>
            <field name="arch" type="xml">
                <search string="Search Custodies">
                    <field name="employee_id" string="Employee"/>
                    <field name="name" string="Custody Number"/>
                </search>
            </field>
        </record>


        <record id="action_account_custody" model="ir.actions.act_window">
            <field name="name">Custodies</field>
            <!-- <field name="type">ir.actions.act_window</field> -->
            <field name="res_model">account.custody</field>
            <!-- <field name="view_type">form</field> -->
            <field name="view_mode">list,form</field>
            <field name="domain">[('create_uid','=', uid)]</field>
        </record>

        <menuitem
                id="menu_account_custody"
                sequence="2"
                name="Custodies"
                web_icon="fa fa-key,#FFFFFF, #545554"
        />
        <menuitem
                id="menu_account_custody_employee"
                action="action_account_custody"
                name="My Custodies"
                sequence="1"
                parent="menu_account_custody"
        />


    </data>
</odoo>