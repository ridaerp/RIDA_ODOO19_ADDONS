<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="account_custody_clear_view_form" model="ir.ui.view">
            <field name="name">account.custody.clear.wizard.form</field>
            <field name="model">custody.clear.wizard</field>
            <field name="arch" type="xml">
                <form string="Custody Clearance">
                    <sheet>
                        <field name="id" invisible="1"/>
                        <!--<div class="oe_title">-->
                            <!--<h1>Custody Clearance</h1>-->
                        <!--</div>-->
                        <group>
                            <group>
                                <field name="communication"/>

                            </group>
                            <group>
                                <field name="journal_id" invisible="0"/>
                            </group>
                        </group>
                        <notebook>
                        <page string="Clearing Accounts">
                            <field name="account_ids" nolabel="1" widget="one2many_list" context="{'wizard_id':active_id}">
                            <tree editable="bottom" open="false">
                                <field name="account_id" string="Account" required ='1'/>
                                <field name="amount"/>
                                <field name="desc"/>
                           </tree>
                        </field>
                        </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string='Validate' name="validate" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

