<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record model="ir.module.category" id="custody_request">
            <field name="name">Custody</field>
            <!-- <field name="description">User access level for this module</field>
            <field name="sequence">1</field> -->
        </record>

        <record id="group_user" model="res.groups">
            <field name="name">Custody User</field>
            <field name="category_id" ref="custody_request"/>
            <!-- <field name="sequence">1</field> -->
        </record>

        <record id="group_manager" model="res.groups">
            <field name="name">Custody Administrator </field>
            <field name="category_id" ref="custody_request"/>
            <!-- <field name="sequence">2</field> -->
        </record>
      

        <!--  Accounting Custdy  rule -->
        <record id="accountant_custdy_rule" model="ir.rule">
            <field name="name">Accountant Custdy</field>
            <field name="model_id" ref="model_account_custody"/>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="domain_force">[('state', 'in', ['paid','treasury_approval','cleared','cancel','reject','fin_mgr_approval'])]
            </field>
                        <field name="perm_unlink" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="0"/>
        </record>


        <record id="all_custdy_rule" model="ir.rule">
            <field name="name">All Custdy</field>
            <field name="model_id" ref="model_account_custody"/>
            <field name="groups" eval="[(4, ref('account.group_account_manager')),(4, ref('base_rida.rida_group_line_manager')),(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.rida_internal_audit')),(4, ref('base_rida.rida_finance_manager')),(4, ref('base_rida.rida_group_site_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
                        
        </record>


        <!--  Accounting Custdy /Clearance rule -->
        <record id="accountant_custdy__clear_rule" model="ir.rule">
            <field name="name">Accountant Custdy/Clearance</field>
            <field name="model_id" ref="model_custody_clear"/>
            <field name="groups" eval="[(4, ref('account.group_account_user'))]"/>
            <field name="domain_force">[('state', 'in', ['accountant','site_accountant','approved','finance_manager','reject'])]
            </field>
            <field name="perm_unlink" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="0"/>
        </record>


      <record id="all_custdy_clearnace_rule" model="ir.rule">
            <field name="name">All Custdy Clearance</field>
            <field name="model_id" ref="model_custody_clear"/>
            <field name="groups" eval="[(4, ref('account.group_account_manager')),(4, ref('base_rida.rida_group_line_manager')),(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.rida_internal_audit')),(4, ref('base_rida.rida_finance_manager')),(4, ref('base_rida.rida_group_site_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
                        
        </record>




      
    </data>
</odoo>