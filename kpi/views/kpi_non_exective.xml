<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="kpi_no_exective_form" model="ir.ui.view">
            <field name="name">KPI for None Executives</field>
            <field name="model">kpi.non.exective</field>
            <field name="arch" type="xml">
                <form>
                    <header>

                        <button string="Submit" name="action_submit" type="object" class="oe_highlight"
                                invisible="state != 'draft'"
                                groups="hr.group_hr_user,base_rida.rida_group_line_manager"/>
                        <button string="Approve" name="action_emp_approve" type="object" class="oe_highlight"
                                invisible="state != 'emp_approve'"
                        />
                        <button string="Approve" name="action_lmn_approve" type="object" class="oe_highlight"
                                invisible="state != 'wlm_approve'" groups="base_rida.rida_group_line_manager"
                        />

                        <button string="Approve" name="action_director_approve" type="object" class="oe_highlight"
                                invisible="state != 'w_director_approve'" groups="base_rida.rida_group_line_manager"
                        />
                        <button string="Approve" name="action_c_level_approve" type="object" class="oe_highlight"
                                invisible="state != 'w_c_level_approve'" groups="base_rida.rida_group_line_manager"
                        />
                        <button string="Approve" name="action_hr_manager_approve" type="object" class="oe_highlight"
                                invisible="state != 'w_hr_m'" groups="base_rida.rida_hr_manager_notify"
                        />
                        <button string="Set to Draft" name="action_draft"
                                groups="hr.group_hr_user,base_rida.rida_group_line_manager,base_rida.rida_hr_manager_notify"
                                invisible="state != 'reject'" type="object"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['wlm_approve','w_director_approve','w_c_level_approve','w_hr_m']"
                                string="Reject"
                                groups="hr.group_hr_user,base_rida.rida_group_line_manager,base_rida.rida_hr_manager_notify"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,emp_approve,wlm_approve,w_director_approve,w_c_level_approve,w_hr_m,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="req_id" readonly="1"/>
                                <field name="department_id" readonly="state != 'draft'"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                            </group>
                            <group>
                                <field name="review_state" string="Review Period" readonly="state != 'draft'"/>
                                <field name="date" readonly="1"/>
                                <field name="company_id"
                                       required="1" readonly="state != 'draft'"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"/>
                            </group>
                        </group>
                        <group string="PERSONAL">
                            <group>
                                <field name="employee_id"
                                       readonly="department_id == False or state != 'draft'"
                                       domain="['|',('department_id.parent_id', '=',department_id),'|',('department_id.parent_id.parent_id', '=',department_id),('department_id', '=',department_id),('company_id', '=',company_id)]"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                                <field name="job_id"/>
                                <field name="report_emp_id" required="1" readonly="0"
                                />
                            </group>
                            <group>
                                <field name="emp_code"/>
                                <field name="emp_department_id" readonly="1"/>
                                <br/>
                                <br/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <label for="date_from" string="Period of Review "/>
                                <div>
                                    <field name="date_from" invisible="1"/>
                                    <field name="date_to" invisible="1"/>
                                    <div class="o_row o_row_readonly o_hr_holidays_dates">
                                        <span class="oe_inline">
                                            From
                                        </span>
                                        <field name="date_from" required="1"
                                               readonly="state != 'draft'" class="oe_inline"
                                               nolabel="1"/>
                                        <span class="oe_inline">
                                            To
                                        </span>
                                        <field name="date_to" required="1" class="oe_inline"
                                               readonly="state != 'draft'"/>
                                    </div>
                                </div>
                            </group>
                        </group>
                        <group>
                            <field name="lmn_comment" readonly="state != 'draft'"/>
                        </group>
                        <notebook>
                            <page string="Evaluation">
                                <h3>Classification guide دليل التصنيف</h3>
                                <h3 style="color:green">Note :The Weigh for Queation is 10 , وزن السؤال هو 10</h3>
                                <br></br>
                                <table border="1" style="text-align:center">
                                    <tr style="background-color: #f2f2f2;">
                                        <th>
                                            <h6>Evaluation Factors عوامل التقييم</h6>
                                        </th>
                                        <th>
                                            <h6>(1) Far Below Expectations أداء أقل بكثير من المتوقع</h6>
                                        </th>
                                        <th>
                                            <h6>(2) Partially met Expectations جزئيا تم تحقيق ما هو متوقع</h6>
                                        </th>
                                        <th>
                                            <h6>(3) Met Expectations يلبي التوقعات والمتطلبات الوظيفية</h6>
                                        </th>
                                        <th>
                                            <h6>(4) Exceed Expectations فوق التوقعات</h6>
                                        </th>
                                        <th>
                                            <h6>(5) Outstanding أداء ممتاز/ مثالي</h6>
                                        </th>
                                        <th>
                                            <h6>Rating</h6>
                                        </th>
                                        <th>
                                            <h6>Score</h6>
                                        </th>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Quantity of Work (Productivity) معدل و كمية الانتاج</h6>
                                        </td>
                                        <td>
                                            <h6>Does not meet requirements .غير مستوفي للمتطلبات</h6>
                                        </td>
                                        <td>
                                            <h6>Occasionally fails to meets requirements. أحيانا مستوفي المتطلبات</h6>
                                        </td>
                                        <td>
                                            <h6>Meets requirements on a timely basis.مستوفي المتطلبات بصورة دورية</h6>
                                        </td>
                                        <td>
                                            <h6>Occasionally exceeds requirements، Always timely.أحيانا يتجاوز المتطلبات
                                                الوظيفية في أغلب الأوقات
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Highly productive and timely. إنتاجية عالية في كل الأوقات</h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt1"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt1"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Quality of Work جودة العمل</h6>
                                        </td>
                                        <td>
                                            <h6>Well below requirements
                                                Less than 70%
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Approaching requirements
                                                70% - 90%
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Meets requirements
                                                91% - 110%
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Above requirements
                                                111% - 120%
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>High organizational impact
                                                121% - 130%
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt2"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt2"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Occupational Knowledge المعرفة و الالمام بالمهام الوظيفية</h6>
                                        </td>
                                        <td>
                                            <h6>Inadequate comprehension of work. فهم ضعيف لمتطلبات لعمل</h6>
                                        </td>
                                        <td>
                                            <h6>Insufficient knowledge of some of the phases of assigned work.
                                                Satisfactory knowledge of routine phases of assigned work. المعرفة
                                                الوظيفية غير كافية، العامل يحتاج الى التحسين والالمام بالمهام الوظيفية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Knows how and why to do all phases of assigned work. يعرف كيفية أداء
                                                العمل الموكل اليه
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Excellent knowledge of all phases of work. المعرفة التامة بالمهام
                                                الوظيفية وكل جوانب العمل
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Understands work well enough to propose and/or implement
                                                improvement.الفهم الكامل لكل جوانب العمل بحيث يمكن تقديم اي اقتراح و /
                                                أو التحسين في مجال العمل
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt3"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt3"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Response to Supervision الاستجابة للمشرفين و التفاعل مع الاوامر</h6>
                                        </td>
                                        <td>
                                            <h6>Fails to carryout supervisor’s suggestions for improvement. Reluctant to
                                                accept responsibility. الفشل في تنفيذ اقتراحات المشرف لغرض لتحسين.
                                                العامل يقاوم المسؤولية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Needs to be reminded of desired improvements in order to maintain
                                                improvement. يحتاج إلى التحسينات المطلوبة من أجل الحفاظ على التقدم
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Improves work habits and performance when counseled. تحسين عادات العمل
                                                والأداء عند تقديم المشورة
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Willingly accepts suggestions for improvement and occasionally seeks
                                                counsel on performance and work habits. قبول العامل اقتراحات المشرف لغرض
                                                التحسين ويسعى أحيانًا إلى الحصول على مشورة بشأن الأداء .
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Independently puts forth efforts to improve performance and work habits.
                                                Seeks counsel on ways to improve and exceeds suggestions. يبذل مجهودًا
                                                لتحسين الأداء و يسعى للحصول على المشورة لغرض التحسين
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt4"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt4"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Cooperation with Others روح التعاون</h6>
                                        </td>
                                        <td>
                                            <h6>Argumentative with coworkers or supervisors. كثير الجدال مع زملاء العمل
                                                أو المشرفين.
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Has occasional interpersonal difficulties. الصعوبة في التعامل مع الأخرين
                                                من حين لآخر
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Works well with others under normal circumstances. يعمل بشكل جيد مع
                                                الآخرين في ظل الظروف العادية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Works in harmony with others. A very good team worker. يعمل في انسجام مع
                                                الآخرين. عضو جيد جدا ضمن فريق العمل
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Extremely successful working with others. Actively promotes harmony.
                                                يعمل بنجاح مع الآخرين. يعزز الانسجام مع الاخرين بفاعلية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt5"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt5"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Attendance and Reliability الحضور و المصداقية</h6>
                                        </td>
                                        <td>
                                            <h6>Unreliable; frequent unexcused absence.الغياب بدون عذر والمتكرر</h6>
                                        </td>
                                        <td>
                                            <h6>Punctuality irregular. Frequently absent. عدم الالتزام بالمواعيد، كثرة
                                                الغياب
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Normally punctual. Attendance average. عادة ملتزم بالمواعيد و الحضور
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Only occasionally late or absent. Contacts supervisor on a timely basis.
                                                نادرا ما يقوم العامل بالتأخير والغياب. يتواصل مع المشرف بصورة دورية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Always punctual; almost never absent. دائما ملتزم في المواعيد ، يكاد لا
                                                يغيب
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt6"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt6"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Economy of spares / tools / consumables اقتصاد قطع الغيار الأدوات /
                                                المواد الاستهلاكية /
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Lack of economy with tools,spares and consumables. غير مقتصد مع الأدوات
                                                وقطع الغيار والمواد الاستهلاكية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Occasionally Frugal with tools,spares and consumables. مقتصد في بعض
                                                الأحيان مع الأدوات وقطع الغيار والمواد الاستهلاكية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Normally frugal with tools,spares and consumables. عادة ما يكون مقتصدًا
                                                مع الأدوات وقطع الغيار والمواد الاستهلاكية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>highly frugal with tools,spares and consumables. مقتصد غالبا مع الأدوات
                                                وقطع الغيار والمواد الاستهلاكية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Always frugal with tools,spares and consumables. مقتصد جدا و بشكل دائم
                                                مع الأدوات وقطع الغيار والمواد الاستهلاكية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt7"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt7"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Safety and Housekeeping السلامة و النظافة</h6>
                                        </td>
                                        <td>
                                            <h6>Fail to compliance with safety and hygiene. عدم الامتثال للسلامة
                                                والنظافة
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Not always compliance with safety and hygiene. لا يلتزم دائمًا بالسلامة
                                                والنظافة
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Compliance with safety and hygiene. الامتثال للسلامة والنظافة</h6>
                                        </td>
                                        <td>
                                            <h6>Highly compliance with safety and hygiene. الامتثال العالي للسلامة
                                                والنظافة
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Always compliance with safety and hygiene. الامتثال العالي و الدائم
                                                للسلامة والنظافة
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt8"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt8"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Acceptance of authority قبول السلطة</h6>
                                        </td>
                                        <td>
                                            <h6>Unwillingness to accept Line supervisor's right to give orders. عدم
                                                الرغبة في قبول توجيهات المشرف
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Occasionally willingness to accept Line supervisor's right to give
                                                orders and comply with it. في بعض الأحيان قبول توجيهات المشرف والامتثال
                                                لها
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Normally willingness to accept Line supervisor's right to give orders
                                                and comply with it. عادة هناك قبول التوجيهات من المشرف والامتثال لها
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Willingness to accept Line supervisor's right to give orders and comply
                                                with it. غالبا قبول الموظف لتوجيهات المشرف والامتثال لها
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Highly willingness to accept Line supervisor's right to give orders and
                                                comply with it. القبول الفعال لتوجيهات المشرف والامتثال لها
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt9"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt9"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="background-color: #f2f2f2;">
                                            <h6>Initiative and Creativity الابداع و القدرة على حل المشاكل
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Usually waits to be told to do normal works assignments. عادة ينتظر أن
                                                يُطلب منه القيام بمهام العمل العادية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>At time needs prodding in order to do regular work. يحتاج إلى الحث من
                                                أجل القيام بعمل منتظم
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Does regular work without waiting for instruction. يقوم بأداء عمله دون
                                                انتظار التعليمات من المشرف
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Resourceful; alert for opportunities to improve work. يقوم بأدء عمله
                                                ويجد فرص تحسين العمل
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>Highly ingenious and creative. Seeks and sets additional tasks and
                                                improved methods. عبقري وخلاق للغاية، يسعى ويحدد مهام إضافية وأساليب
                                                تحسينية
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="answer_qt10"
                                                       readonly="state != 'draft'"/>
                                            </h6>
                                        </td>
                                        <td>
                                            <h6>
                                                <field name="score_qt10"/>
                                            </h6>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="10" style="background-color: #875A7B;color: white;font-size:18px">
                                            <br/>
                                            <h4 style="color: white;">Total Score</h4>
                                            <field name="total_score"
                                            />
