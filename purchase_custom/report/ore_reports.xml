<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="report_ore_report_view" model="ir.ui.view">
        <field name="name">Ore Report Report</field>
        <field name="model">ore.report</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <label for="date_from" string="Period of Review "/>
                        <div>
                            <field name="date_from" invisible="1"/>
                            <field name="date_to" invisible="1"/>
                            <div class="o_row o_row_readonly o_hr_holidays_dates">
                                <span class="oe_inline">
                                    From
                                </span>
                                <field name="date_from" class="oe_inline" nolabel="1" required="1"/>
                                <span class="oe_inline">
                                    To
                                </span>
                                <field name="date_to" class="oe_inline" required="1"/>
                            </div>
                        </div>
                    </group>
                    <group>
                        <field name="rock_vendor" domain="[('category_id.id','in',[103])]"
                               options="{'no_create': True,'no_open':True}"/>
                    </group>
                    <group>
                        <field name="area_id" options="{'no_create': True,'no_open':True}"/>
                    </group>
                </group>
                <group string="Grade From (0.0 - 100)"
                       groups="base_rida.group_department_ict_hod_manager,material_request.group_ore_rock_db_geology_user">
                    <group>
                        <field name="min_grade" required="max_grade != False"
                               groups="base_rida.group_department_ict_hod_manager,material_request.group_ore_rock_db_geology_user"/>
                    </group>
                    <group>
                        <field name="max_grade" required="max_grade != False"
                               groups="base_rida.group_department_ict_hod_manager,material_request.group_ore_rock_db_geology_user"/>
                    </group>
                </group>
                <footer>
                    <button name="print_report" string="Print" type="object" default_focus="1" class="oe_highlight"/>
<!--                    <button name="view_print" string="View Report" type="object" default_focus="1"-->
<!--                            class="oe_highlight"/>-->
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
<!--    accounting-->
    <record id="report_ore_report_accounting_view" model="ir.ui.view">
        <field name="name">Ore Report Report</field>
        <field name="model">ore.report</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <label for="date_from" string="Period of Review "/>
                        <div>
                            <field name="date_from" invisible="1"/>
                            <field name="date_to" invisible="1"/>
                            <div class="o_row o_row_readonly o_hr_holidays_dates">
                                <span class="oe_inline">
                                    From
                                </span>
                                <field name="date_from" class="oe_inline" nolabel="1" required="1"/>
                                <span class="oe_inline">
                                    To
                                </span>
                                <field name="date_to" class="oe_inline" required="1"/>
                            </div>
                        </div>
                    </group>
                    <group>
                        <field name="rock_vendor" domain="[('category_id.id','in',[103])]"
                               options="{'no_create': True,'no_open':True}"/>
                    </group>
                    <group>
                        <field name="area_id" options="{'no_create': True,'no_open':True}"/>
                    </group>
                </group>
                <footer>
                    <button name="print_report" string="Print" type="object" default_focus="1" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <template id="ore_rock_report">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page" style="direction: rtl; text-align: right;">
                    <h2 class="text-center">Rock Purchases Report</h2>

                    <div class="row mt32 mb32">
                        <div class="col-6">
                            <strong>From: </strong> <span t-esc="form.get('date_from')" t-options='{"widget": "datetime"}'/><br/>
                            <strong>To: </strong> <span t-esc="form.get('date_to')" t-options='{"widget": "datetime"}'/>
                        </div>
                        <div class="col-6 text-right">
                            <t t-if="form.get('rock_vendor')">
                                <strong>Vendor: </strong> <span t-esc="form.get('rock_vendor')"/><br/>
                            </t>
                            <t t-if="form.get('area_id')">
                                <strong>Area: </strong> <span t-esc="form.get('area_id')"/>
                            </t>
                        </div>
                    </div>

                    <style>
                        .custom-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
                        .custom-table th, .custom-table td { border: 1px solid black; padding: 5px; text-align: center; }
                        .custom-table th { background-color: #f2f2f2; }
                    </style>

                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>العدد</th>
                                <th>أسم العميل</th>
                                <th>منطقة الخام</th>
                                <th>تاريخ الأستلام</th>
                                <th>وزن الحمولة بالطن</th>
                                <th>سعر الشراء للطن</th>
                                <t t-if="form.get('show_average')">
                                    <th>سعر الطن</th>
                                </t>
                                <th>تحمل العميل</th>
                                <th>سعر الشراء</th>
                                <th>ملحوظة</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="form.get('list_ore_purchases', [])" t-as="rec">
                                <tr>
                                    <td t-esc="rec[0]"/>
                                    <td t-esc="rec[1]"/>
                                    <td t-esc="rec[2]"/>
                                    <td t-esc="rec[3]"/>
                                    <td t-esc="rec[4]"/>
                                    <td t-esc="rec[5]"/>
                                    <t t-if="form.get('show_average')">
                                        <td t-esc="rec[6]"/>
                                    </t>
                                    <td t-esc="rec[7]"/>
                                    <td t-esc="rec[8]"/>
                                    <td t-esc="rec[9]"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <h4></h4>
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>عدد المعاملات</th>
                                <th>الوزن الكلي (طن)</th>
                                <t t-if="form.get('show_average')">
                                    <th>متوسط التركيز</th>
                                </t>
                                <th>سعر الشراء</th>
                                <th>إجمالي كمية الشهر</th>
                                <th>إجمالي سعر الشهر</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="form.get('list_totals_ore_purchase', [])" t-as="total">
                                <tr>
                                    <td t-esc="total[0]"/>
                                    <td t-esc="total[1]"/>
                                    <t t-if="form.get('show_average')">
                                        <td t-esc="total[2]"/>
                                    </t>
                                    <td t-esc="total[3]"/>
                                    <td t-esc="total[4]"/>
                                    <td t-esc="total[5]"/>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <h4></h4>
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>الكمية غير المشترى بالطن</th>
                                <th>الكمية المشترى بالطن</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="form.get('list_of_purchase_analysis')">
                                <tr>
                                    <td>
                                        <span t-esc="form['list_of_purchase_analysis'][0][1]"/>
                                    </td>
                                    <td>
                                        <span t-esc="form['list_of_purchase_analysis'][0][0]"/>
                                    </td>
                                </tr>
                                <t t-if="form.get('show_average')">
                                    <tr>
                                        <td>
                                            <strong>متوسط التركيز: </strong>
                                            <span t-esc="form['list_of_purchase_analysis'][1][1]"/>
                                        </td>
                                        <td>
                                            <strong>متوسط التركيز: </strong>
                                            <span t-esc="form['list_of_purchase_analysis'][1][0]"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

