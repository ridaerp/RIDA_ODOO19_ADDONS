<odoo>
    <!-- Rule 1: Employees can only see their own profile -->
    <record id="hr_employee_rule_user_see_self" model="ir.rule">
        <field name="name">Employees - See Own Profile</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/> <!-- all internal users -->
        <field name="domain_force">[('user_id', '=', user.id)]</field>
    </record>

    <!-- Rule 2: Managers can see employees in their department -->
    <record id="hr_employee_rule_manager_see_department" model="ir.rule">
        <field name="name">Managers - See Department Employees</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        <field name="domain_force">[
            '|',
            ('department_id.manager_id.user_id', '=', user.id),
            ('user_id', '=', user.id)
        ]</field>
    </record>
</odoo>
