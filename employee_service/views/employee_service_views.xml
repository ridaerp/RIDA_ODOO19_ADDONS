<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Employee -->
    <record id="action_employee_list_in_service" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">kanban,list,form,activity,graph,pivot,hierarchy</field>
        <field name="domain">[]</field>
    </record>

    <!--    my time-off-->
    <record id="action_employee_leaves_in_service_1" model="ir.actions.act_window">
        <field name="name">My Time Off</field>
        <field name="res_model">hr.leave</field>
        <field name="view_mode">list,form,kanban,activity</field>
        <field name="domain">[('user_id', '=', uid)]</field>
    </record>
    <!--    my allocation-->
    <record id="action_employee_leaves_in_service_all" model="ir.actions.act_window">
        <field name="name">My Allocations</field>
        <field name="res_model">hr.leave.allocation</field>
        <field name="view_mode">list,form,kanban,activity</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_year': 1 , 'is_employee_allocation': True}</field>
    </record>

    <!-- time-off Management-->
    <record id="action_employee_leaves_in_service_tim_mang" model="ir.actions.act_window">
        <field name="name">Time Off Management</field>
        <field name="res_model">hr.leave</field>
        <field name="view_mode">list,form,kanban,activity</field>
        <field name="domain">['|', ('employee_id.company_id', 'in', allowed_company_ids), '&amp;',
            ('multi_employee', '=', True), '&amp;', ('state', 'in', ['draft', 'confirm', 'validate1']), ('employee_ids.company_id', 'in', allowed_company_ids)]</field>
        <field name="context">{'search_default_waiting_for_me': 1, 'search_default_waiting_for_me_manager': 2,
            'hide_employee_name': 1, 'holiday_status_display_name': False }</field>
    </record>

    <!--allocation Management-->
    <record id="action_employee_leaves_in_service_all_mang" model="ir.actions.act_window">
        <field name="name">My Allocations</field>
        <field name="res_model">hr.leave.allocation</field>
        <field name="view_mode">list,form,kanban,activity</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_my_team': 1,'search_default_approve': 2, 'search_default_active_employee': 3}</field>
    </record>
    <!--Report of balance leave-->
    <record id="action_employee_leaves_in_service_report" model="ir.actions.act_window">
        <field name="name">Balance Leave Report</field>
        <field name="res_model">report.balance.leave</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <!--Rotation Leave-->
    <record id="action_employee_leaves_in_service_rotation" model="ir.actions.act_window">
        <field name="name">Rotation Leave</field>
        <field name="res_model">rotation.batch</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type','!=','out')]</field>
        <field name="context">{ 'default_type': 'in' }</field>
    </record>
    <!--Arrival Tickets-->
    <record id="action_employee_leaves_in_service_arrival" model="ir.actions.act_window">
        <field name="name">Arrival Tickets</field>
        <field name="res_model">rotation.batch</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('type','=','out')]</field>
        <field name="context">{'default_type': 'out'}</field>
    </record>


    <!--  Delegations  -->
    <record id="action_employee_delegations" model="ir.actions.act_window">
        <field name="name">Delegations Request</field>
        <field name="res_model">hr.delegation</field>
        <field name="view_mode">list,form</field>
    </record>

    <!--  Overtime  -->
    <record id="action_employee_overtime" model="ir.actions.act_window">
        <field name="name">Overtime Authorization Request</field>
        <field name="res_model">overtime.auth</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_employee_overtime_by_batch" model="ir.actions.act_window">
        <field name="name">OverTime By Batch</field>
        <field name="res_model">hr.overtime.batch</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_by_year':1,'search_default_by_month':1}</field>
    </record>

    <record id="action_employee_overtime_bank_batch" model="ir.actions.act_window">
        <field name="name">Overtime Bank Sheet</field>
        <field name="res_model">overtime.batch.line</field>
        <field name="view_mode">list</field>
        <field name="domain">[('request_state','=','posted')]</field>
        <field name="context">{'edit': 0,'create': 0}</field>
    </record>
    <!-- Recruitment   -->
    <record id="action_employee_recruitment" model="ir.actions.act_window">
        <field name="name">Recruitment Plan Request</field>
        <field name="res_model">recruitment.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_employee_recruitment_request" model="ir.actions.act_window">
        <field name="name">Recruitment Request</field>
        <field name="res_model">recruitment.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Loans   -->
    <record id="action_employee_loans_to_approve" model="ir.actions.act_window">
        <field name="name">Loans To Approve</field>
        <field name="res_model">hr.loan</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="action_employee_loans" model="ir.actions.act_window">
        <field name="name">Employee Loans</field>
        <field name="res_model">hr.loan</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain"> [('employee_id.user_id','=',uid)]</field>
    </record>

    <!-- Salary Advance   -->
    <record id="action_employee_salary_advance" model="ir.actions.act_window">
        <field name="name">Salary Advance</field>
        <field name="res_model">salary.advance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('employee_id.user_id', '=', uid)]</field>
        <field name="context">{'search_default_approved':1}</field>
    </record>

    <!-- Trip Permission Request   -->
    <record id="action_employee_trip_permission" model="ir.actions.act_window">
        <field name="name">Trip Permission Request</field>
        <field name="res_model">trip.permission</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Site Visit Request   -->
    <record id="action_employee_site_visit" model="ir.actions.act_window">
        <field name="name">Site Visit Request</field>
        <field name="res_model">visit.request</field>
        <field name="view_mode">list,form,search</field>
    </record>
</odoo>
