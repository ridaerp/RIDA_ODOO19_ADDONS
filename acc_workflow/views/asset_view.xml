<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="account_asset_view" model="ir.ui.view">
            <field name="name">Account Asset</field>
            <field name="model">account.asset</field>
            <field name="inherit_id" ref="account_asset.view_account_asset_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='name']" position="after">
                    <label for="asset_code" name="asset_code" class="oe_edit_only"/>
                    <h6>
                        <field name="asset_code" required="0"/>
                    </h6>
                </xpath>
                <xpath expr="//field[@name='analytic_distribution']" position="after">
                    <field name="analytic_account_ids" widget="many2many_tags"/>
                </xpath>
                <xpath expr="//group[last()]" position="inside">
                    <group >
                        <field name="asset_tags_ids" widget="many2many_tags"/>
                        <field name="description" widget="text"/>
                    </group>
                </xpath>



            </field>
        </record>

        <record id="account_asset_tree" model="ir.ui.view">
            <field name="name">accoun.tree.asset</field>
            <field name="model">account.asset</field>
            <field name="inherit_id" ref="account_asset.view_account_asset_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='book_value']" position="replace">
                    <field name="book_value" sum="Total"/>
                </xpath>
                <xpath expr="//field[@name='value_residual']" position="replace">
                    <field name="value_residual" sum="Total"/>
                </xpath>

            </field>
        </record>



        <record model="ir.actions.server" id="action_assets_confirm">
            <field name="name">Validate</field>
            <field name="model_id" ref="account_asset.model_account_asset"/>
            <field name="binding_model_id" ref="account_asset.model_account_asset"/>
            <field name="state">code</field>
            <field name="code">
                action = records.validate()
            </field>
            <field name='groups_id'
                   eval="[(4, ref('base_rida.rida_finance_manager'))]"/>


        </record>


    </data>
</odoo>