<odoo>
    <data>

        <record id="mod_request_form" model="ir.ui.view">
            <field name="name">modification.request.form</field>
            <field name="model">modification.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="set_submit" type="object" invisible="state not in ['draft']"
                                class="oe_highlight"/>
                        <button string="Approve" name="set_l_mng_confirm" type="object"
                                invisible="state not in ['line_mng']"
                                class="oe_highlight" groups="base_rida.rida_group_line_manager"/>
                        <button string="Approve" name="set_qhse_confirm" type="object" invisible="state not in ['qhse']"
                                class="oe_highlight" groups="base_rida.rida_group_qhse_manager"/>

                        <button string="Approve" name="set_ccso_confirm" type="object" invisible="state not in ['ccso']"
                                class="oe_highlight" groups="base_rida.rida_group_CCSO"/>
                        <button string="Approve" name="set_fleet_confirm" type="object"
                                invisible="state not in ['fleet']"
                                class="oe_highlight" groups="base_rida.group_fleet_director"/>
                        <button string="Approve" name="set_od_confirm" type="object" invisible="state not in ['od']"
                                class="oe_highlight" groups="base_rida.rida_group_site_manager"/>
                        <button string="Approve" name="set_chro" type="object" invisible="state not in ['chro']"
                                class="oe_highlight" groups="base_rida.rida_group_hr_director"/>
                        <button string="Approve" name="set_ceo" type="object" invisible="state not in ['ceo']"
                                class="oe_highlight" groups="base_rida.rida_group_ceo"/>

                        <button string="Approve" name="set_qhse_conf_confirm" type="object"
                                invisible="state not in ['qhse_conf']"
                                class="oe_highlight" groups="base_rida.rida_group_qhse_manager"/>

                        <button string="Compelete" name="set_ict_confirm" type="object" invisible="state not in ['ict']"
                                class="oe_highlight" groups="base_rida.rida_group_ict_team"/>

                        <button string="Confirm" name="set_qhse_validate" type="object"
                                invisible="state not in ['qhse_validated']"
                                class="oe_highlight" groups="base_rida.rida_group_qhse_manager"/>


                        <button string="Close/Accept" name="done" type="object" invisible="state not in ['close']"
                                class="oe_highlight"/>

                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['line_mng', 'qhse', 'ccso', 'od', 'qhse_conf', 'ict', 'close']"
                                string="Reject"
                                groups="base_rida.rida_group_line_manager,base_rida.rida_group_qhse_manager,base_rida.rida_group_CCSO,base_rida.rida_group_site_manager"/>


                        <field name="state" invisible="1"/>
                        <field name="state_ccso" widget="statusbar"
                               statusbar_visible="draft,line_mng,qhse,ccso,qhse_conf,done"
                               invisible="type_approval != 'ccso_approval'"/>
                        <field name="state_od" widget="statusbar"
                               statusbar_visible="draft,line_mng,qhse,od,qhse_conf,done"
                               invisible="type_approval != 'od'"/>
                        <field name="state_fleet" widget="statusbar"
                               statusbar_visible="draft,line_mng,qhse,fleet,qhse_conf,done"
                               invisible="type_approval != 'fleet'"/>
                        <field name="state_chro" widget="statusbar"
                               statusbar_visible="draft,line_mng,qhse,chro,qhse_conf,done"
                               invisible="type_approval != 'chro'"/>
                        <field name="state_ceo" widget="statusbar"
                               statusbar_visible="draft,line_mng,qhse,ceo,qhse_conf,done"
                               invisible="type_approval != 'ceo'"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="code_seq"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="user_type" invisible="1"/>
                                <field name="type_approval" invisible="1"/>
                                <field name="level_of_change"
                                       invisible="state in ['draft','line_mng']" readonly="state not in ['qhse']"
                                       required="state in ['qhse']"
                                       widget="radio"/>
                                <field name="type"
                                       readonly="type not in ['draft','line_mng']"
                                       required="1"/>
                                <field name="pr_cat" readonly="state not in ['draft']"
                                       required="1" options="{'no_create': True}"/>
                                <field name="procedure_id" domain="[('pr_cat','=',pr_cat)]"
                                       readonly="state not in ['draft']"
                                       required="1" options="{'no_create': True}"/>
                                <field name="form_id" domain="[('procedure_id','=',procedure_id)]"
                                       readonly="state not in ['draft']"
                                       options="{'no_create': True}"/>

                            </group>
                            <group>
                                <field name="date"/>

                                <field name="req_id" required="1"/>
                                <field name="department_id"
                                       readonly="state not in ['draft','line_mng']"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="job_id"
                                       readonly="state not in ['draft','line_mng']"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="note"
                                       invisible="state in ['draft','line_mng']" readonly="state not in ['qhse']"
                                       required="state in ['qhse']"/>
                            </group>
                        </group>
                        <group>

                            <field name="description"
                                   readonly="state not in ['draft','line_mng']"
                                   required="1"/>

                            <field name="pr_mo_new"
                                   readonly="state not in ['draft','line_mng']"
                                   required="1"/>
                            <field name="mo_new"
                                   readonly="state not in ['draft','line_mng']"
                                   required="1"/>
                        </group>

                        <notebook>
                            <page string="Approval and Signature">
                                <group>
                                    <group>
                                        <field name="emp_l_mng" invisible="emp_l_mng == False"/>
                                        <field name="emp_l_mng_date"
                                               invisible="emp_l_mng_date == False"/>
                                    </group>
                                    <group>
                                        <field name="emp_ccso" invisible="emp_ccso == False"/>
                                        <field name="emp_fleet"
                                               invisible="emp_fleet == False"/>
                                        <field name="emp_od" invisible="emp_od == False"/>
                                        <field name="ccso_od_date"
                                               invisible="ccso_od_date == False"/>

                                        <field name="qhse_manager"
                                               invisible="qhse_manager == False"/>
                                        <field name="qhse_date" invisible="qhse_date == False"/>
                                    </group>


                                </group>
                            </page>
                            <page string="QHSE Only"
                                  invisible="state not in ['qhse_conf','ict','done','close','qhse_validated','reject']"
                                  readonly="state != 'qhse_conf'">
                                <group>
                                    <field name="qhse_desc"
                                           required="state == 'qhse_conf'" readonly="state != 'qhse_conf'"/>
                                    <field name="n_o_change"
                                           required="state == 'qhse_conf'" readonly="state != 'qhse_conf'"/>
                                    <field name="rel_doc"
                                           readonly="state != 'qhse_conf'"/>
                                </group>
                            </page>


                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>
        <record id="mod_request_tree_view" model="ir.ui.view">
            <field name="name">modification request tree</field>
            <field name="model">modification.request</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="code_seq"/>
                    <field name="date"/>
                    <field name="department_id"/>
                    <field name="type"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="procdure_form" model="ir.ui.view">
            <field name="name">qhse.procedure.form</field>
            <field name="model">qhse.procedure</field>
            <field name="arch" type="xml">
                <form string="Procedure">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="get_mod_change"
                                    type="object" class="oe_stat_button" icon="fa-list-alt">
                                <field name="mod_req_count" string="Modifications" widget="statinfo"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="type_approval"/>
                                <field name="code" required="1"/>
                                <field name="page" required="1"/>
                                <field name="pdf_filename" invisible="1"/>
                            </group>
                            <group>
                                <field name="pr_cat" required="1" options="{'no_create': True}"/>
                                <field name="issue_rev" required="1"/>
                                <field name="date" required="1"/>
                            </group>
                            <field name="pdf_file" filename="pdf_filename" widget="pdf_viewer"/>

                        </group>
                    </sheet>
                </form>
            </field>
        </record>

