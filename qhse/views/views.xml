            <field name="res_model">qhse.procedure</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'create': 0}</field>
            <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('qhse.procdure_tree_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('qhse.readonly_procdure_form')})]"/>
