<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">


        <record id="mod_request" model="ir.sequence">
            <field name="name">Modification Request</field>
            <field name="code">mod.request</field>
            <field name="prefix">MDF/R</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="ncr_request" model="ir.sequence">
            <field name="name">NCR Request</field>
            <field name="code">ncr.request</field>
            <field name="prefix">NCR/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
