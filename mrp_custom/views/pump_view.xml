<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pump_tree" model="ir.ui.view">
        <field name="name">pump.flow.pump.tree</field>
        <field name="model">pump.flow.pump</field>
        <field name="arch" type="xml">
            <list string="Pumps">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="location"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pump_form" model="ir.ui.view">
        <field name="name">pump.flow.pump.form</field>
        <field name="model">pump.flow.pump</field>
        <field name="arch" type="xml">
            <form string="Pump">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="serial_number"/>
                            <field name="location"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="equipment_id"/>
                        </group>

                    </group>
                </sheet>
            </form>
        </field>
    </record>



      <record id="view_reading_tree" model="ir.ui.view">
        <field name="name">pump.flow.reading.tree</field>
        <field name="model">pump.flow.reading</field>
        <field name="arch" type="xml">
            <list string="Flow Readings">
                <field name="pump_id"/>
                <field name="timestamp"/>
                <field name="total_meter_reading"/>
                <field name="hourly_flow"/>
                <field name="daily_flow"/>
            </list>
        </field>
    </record>

    <record id="view_reading_form" model="ir.ui.view">
        <field name="name">pump.flow.reading.form</field>
        <field name="model">pump.flow.reading</field>
        <field name="arch" type="xml">
            <form string="Flow Reading">
                <sheet>
                    <group>
                        <field name="pump_id"/>
                        <field name="timestamp"/>
                        <field name="total_meter_reading"/>
                        <field name="hourly_flow" readonly="1"/>
                        <field name="daily_flow" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


  <!-- Pump Action -->
    <record id="action_pump" model="ir.actions.act_window">
        <field name="name">Pumps</field>
        <field name="res_model">pump.flow.pump</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_flow_reading" model="ir.actions.act_window">
        <field name="name">Hourly Flow Readings</field>
        <field name="res_model">pump.flow.reading</field>
        <field name="view_mode">list,form</field>
    </record>



       <!-- Pump menu -->
    <menuitem id="menu_pump_root" name="Pump Monitoring"  parent="mrp.menu_mrp_root" sequence="30"/>

    <!-- Submenus -->
    <menuitem id="menu_pumps" name="Pumps" parent="menu_pump_root" sequence="20"
              action="action_pump"/>

    <menuitem id="menu_flow_readings" name="Hourly Flow Readings" parent="menu_pump_root" sequence="30"
              action="action_flow_reading"/>


</odoo>
