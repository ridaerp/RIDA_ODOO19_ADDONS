<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_mrp_workcenter_form_inherit" model="ir.ui.view">
            <field name="name">mrp.workcenter.form.inherit</field>
            <field name="model">mrp.workcenter</field>
            <field name="inherit_id" ref="mrp.mrp_workcenter_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='code']" position="after">
                    <field name="default_capacity"/>
                </xpath>
            </field>
        </record>

        <record id="view_mrp_workorder_search_this_week" model="ir.ui.view">
            <field name="name">mrp.workorder.search.this.week</field>
            <field name="model">mrp.workorder</field>
            <field name="inherit_id" ref="mrp.view_mrp_production_work_order_search"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='progress']" position="after">

                    <filter string="This Week" name="this_week" domain="[ ('date_start', '&gt;=', context_today() + relativedelta(weekday=0)), ('date_start', '&lt;', context_today() + relativedelta(weekday=6, days=7)) ]"/>

                    <!-- This Month: from first day of current month to first day of next month -->
                    <filter string="This Month" name="this_month" domain="[ ('date_start', '&gt;=', context_today() + relativedelta(day=1)), ('date_start', '&lt;', context_today() + relativedelta(day=1, months=+1)) ]"/>

                    <!-- This Quarter (approximate) -->
                    <!-- You might want to refine this logic with server code for perfect quarters -->
                    <filter string="This Quarter" name="this_quarter" domain="[ ('date_start', '&gt;=',
                  (context_today() + relativedelta(month=((context_today().month-1) // 3) * 3 + 1, day=1))), ('date_start', '&lt;', (context_today() + relativedelta(month=((context_today().month-1) // 3) * 3 + 1, day=1, months=+3))) ]"/>

                    <!-- This Year -->
                    <filter string="This Year" name="this_year" domain="[ ('date_start', '&gt;=', context_today() + relativedelta(month=1, day=1)), ('date_start', '&lt;', context_today() + relativedelta(years=+1, month=1, day=1)) ]"/>
                </xpath>
            </field>
        </record>


        <record id="mrp_workcenter_block_wizard" model="ir.ui.view">
            <field name="name">mrp workcenter block wizard</field>
            <field name="model">mrp.workcenter.productivity</field>
            <field name="inherit_id" ref="mrp.mrp_workcenter_block_wizard_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='description']" position="after">
                    <field name="equipment_id" options="{'no_create': True,'no_open':True}"/>
                     <!-- domain="[('workcenter_id', '=', workcenter_id)]" -->
                </xpath>

            </field>
        </record>


        <record model="ir.actions.act_window" id="mrp_manfacuring_order_production_report_blocked">
            <field name="name">production Losses</field>
            <field name="res_model">mrp.workcenter.productivity</field>
            <field name="view_mode">list,form,graph,pivot</field>

            <field name="domain">[('production_ref_id', '=', active_id),
                ('loss_id.loss_type', 'in', ['availability', 'performance','quality'])]
            </field>


            <field name="context">{}</field>

            <field name="help" type="html">
                <p class="o_view_nocontent_empty_folder">
                    No productivity loss for this Manfacuring Order
                </p>
            </field>
        </record>


        <!-- Inhert workorder form view  -->


        <record id="view_workorder_tree_inherit" model="ir.ui.view">
            <field name="name">mrp.workorder.form.inherit</field>
            <field name="model">mrp.workorder</field>
            <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_view"/>
            <field name="arch" type="xml">


                <xpath expr="//field[@name='duration']" position="after">

                    <field name="qty_production" optional="show" widget="integer"/>
                    <field name="qty_producing" optional="show" widget="integer"/>
                    <field name="production_target" optional="show" widget="integer"/>
                    <field name="availability_percent" optional="show" widget="percentpie"/>
                    <field name="utilization_percent" optional="show" widget="percentpie"/>
                    <field name="feed_rate" optional="show" widget="integer"/>
                    <field name="cru_ph" optional="show"/>
                    <field name="moisture_" optional="show"/>
                    <field name="sieving_" optional="show"/>
                    <field name="grade_control" optional="show"/>
                </xpath>

            </field>
        </record>


        <record id="view_workorder_form_inherit" model="ir.ui.view">
            <field name="name">mrp.workorder.form.inherit</field>
            <field name="model">mrp.workorder</field>
            <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
            <field name="arch" type="xml">

                <xpath expr="//sheet/notebook" position="inside">

                    <page string="Crusher Parameters" invisible="not is_crusher_staker">
                        <field name="is_crusher_staker" invisible="1"/>

                        <group col="2">


                            <group string="Quality Control Metrics" col="2">
                                <field name="moisture_" readonly="1"/>
                                <field name="moisture_stockpile" readonly="1"/>
                                <field name="moisture_agglomeration" readonly="1"/>
                                <field name="cru_ph" readonly="1"/>
                                <field name="sieving_" readonly="1"/>
                                <field name="grade_control" readonly="1"/>
                                <field name="cement_loaded_" readonly="1"/>
                            </group>

                            <group string="Performance Metrics" col="2">
                                <field name="qty_producing"/>
                                <field name="feed_rate"/>
                                <field name="total_loss"/>
                                <field name="total_time"/>
                                <field name="maintenance_loss"/>
                                <field name="availability_percent" widget="percentpie"/>
                                <field name="utilization_percent" widget="percentpie"/>
                                <field name="production_target"/>
                            </group>
                        </group>

                        <group string="Ore Downtime" col="3">
                            <group string="Cleaning" col="2">
                                <field name="cleaning_operation"/>
                                <field name="over_load"/>
                                <field name="equipment_stuck_jcr"/>
                                <field name="equipment_stuck_cr"/>
                                <field name="stockpile_full"/>
                                <field name="overflow_stuck_cr"/>
                            </group>


                            <group string="Maintenance" col="2">
                                <field name="mechanical_loss"/>
                                <field name="electrical_loss"/>
                                <field name="generation_loss"/>
                                <field name="maintenance_loss"/>
                            </group>


                            <group string="Equipment" col="2">
                                <field name="e_operation"/>
                                <field name="no_equipment"/>
                            </group>

                            <group string="Waiting Materials" col="2">
                                <field name="m_operation"/>
                                <field name="no_trucks"/>
                            </group>

                            <group string="Other" col="2">
                                <field name="other_loss"/>
                                <field name="total_loss_per_minute"/>
                                <field name="explanation_for_other" readonly="state in ['done']"/>
                            </group>
                        </group>
                    </page>

                    <page string="Leaching Parameters" invisible="not is_heap">
                        <group>

                            <group string="Performance Metrics">
                                <field name="is_heap" invisible="1"/>

                                <field name="barren_cyanide"/>
                                <field name="Pregnant_cyanide"/>
                                <field name="cru_ph" readonly="1"/>
                                <field name="ph_Outlet"/>
                                <field name="oxygen_pregnant"/>
                                <field name="oxygen"/>
                            </group>
                            <group string="Grade Control">
                                <field name="grade_pregnant" string="Grade Pregnant"/>
                                <field name="grade_barren" string="Grade Barren"/>
                                <field name="flow" string=" FLOW"/>
                            </group>

                        </group>
                    </page>
                    <page string="ADR Parameters" invisible="not is_adr">
                        <group>

                            <group string="Grade Control">
                                <field name="is_adr" invisible="1"/>

                                <field name="au_Inlet" string="Inlet AU"/>
                                <field name="au_Outlet" string="Outlet AU"/>
                                <field name="au" string="AU "/>
                                <field name="flow" string=" FLOW"/>

                            </group>
                            <group string="Unit Au ">
                                <field name="unit_Outlet"/>
                                <field name="unit_au"/>
                                <field name="carbon_eff"/>
                            </group>

                        </group>
                    </page>

                    <page string="Striping Parameters" invisible="not is_strip">
                        <group>

                            <group>
                                <field name="is_strip" invisible="1"/>
                                <field name="temperature"/>
                                <field name="volt"/>
                                <field name="ampere"/>
                                <field name="recovery_percentage"/>

                            </group>
                            <group>

                                <field name="flow" string=" FLOW"/>
                                <field name="total_metal_recovery"/>

                            </group>
                        </group>

                    </page>

                    <page string="Smelting Parameters" invisible="not is_smelt">
                        <group>

                            <group>
                                <group string="Performance Metrics">
                                    <field name="is_smelt" invisible="1"/>
                                </group>
                            </group>
                        </group>
                    </page>

                </xpath>
            </field>
        </record>

        <!-- Action  crusher  for smart button   -->
        <record id="action_crusher_mrp_smart_button" model="ir.actions.act_window">
            <field name="name">crusher Requests</field>
            <field name="res_model">crusher.log.sheet</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('production_id', '=', active_id)]</field>
        </record>

        <!-- Action  adr  for smart button   -->
        <record id="action_adr_mrp_smart_button" model="ir.actions.act_window">
            <field name="name">ADR Requests</field>
            <field name="res_model">adr.log.sheet</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('production_id', '=', active_id)]</field>
        </record>

         <!-- Action  stripping   for smart button   -->
        <record id="action_stripping_mrp_smart_button" model="ir.actions.act_window">
            <field name="name">Stripping Requests</field>
            <field name="res_model">stripping.log.sheet</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('production_id', '=', active_id)]</field>
        </record>

         <!-- Action  Belt Scale  for smart button   -->
        <record id="action_belt_scale_smart_button" model="ir.actions.act_window">
            <field name="name">Belt Scale Reading</field>
            <field name="res_model">belt.scale.log</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('production_id', '=', active_id)]</field>
        </record>

        <!-- Action  Pregnant  Sample  for smart button   -->
        <record id="action_pregnant_sample_smart_button" model="ir.actions.act_window">
            <field name="name">Pregnant Sample Result</field>
            <field name="res_model">pregnant.sample.result</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('production_id', '=', active_id)]</field>
        </record>

        <!-- Inherit Manufacture Order form  -->


        <record id="view_mrp_smartbuttun_production_form_inherit" model="ir.ui.view">
            <field name="name">mrp.smartbuttun.production.lost.form.inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//button[@name='button_unbuild']" position="before">
                    <button name="action_create_log" type="object" string="Create Log" class="btn-primary"
                            invisible="(state  in ['draft'])"/>
                    <button name="action_create_Belt_reading" type="object" string="Belt Scale Reading" class="btn-primary"
                            invisible="(state not in ['confirmed','progress','to_close']) and (workcenter_id.code not in ['WC-CIC-CRSH','WC-CIC-STKR'])"/>

                    <button name="action_create_Pregnant_sample" type="object" string="PS AND BS Sample" class="btn-primary"
                            invisible="(state not in ['confirmed','progress','to_close'])"/>

                    <button string="Chem-Assay" name="create_checmical_lab_assy" type="object" class="oe_highlight"
                            groups="mrp.group_mrp_user" invisible="state not in ['confirmed','progress','to_close']"/>
                </xpath>

                <xpath expr="//div[@class='oe_button_box']" position="inside">

                    <button type="action"
                            name="%(mrp_custom.action_crusher_mrp_smart_button)d"
                            class="oe_stat_button"
                            icon="fa-book">

                        <field string="Crusher Logs" name="crusher_log" widget="statinfo"/>
                    </button>
                    <button type="action"
                            name="%(mrp_custom.action_belt_scale_smart_button)d"
                            class="oe_stat_button"
                            icon="fa-balance-scale">

                        <field string="Belt Scale" name="belt_log_count" widget="statinfo"/>
                    </button>

                    <button type="action"
                            name="%(mrp_custom.action_adr_mrp_smart_button)d"
                            class="oe_stat_button"
                            icon="fa-table">

                        <field string="ADR Logs" name="adr_log_count" widget="statinfo"/>
                    </button>
                    <button type="action"
                            name="%(mrp_custom.action_stripping_mrp_smart_button)d"
                            class="oe_stat_button"
                            icon="fa-recycle"
                    >
                        <field string="Stripping Logs" name="stripping_log_count" widget="statinfo"/>
                    </button>

                    <button type="action"
                            name="%(mrp_custom.action_pregnant_sample_smart_button)d"
                            class="oe_stat_button"
                            icon="fa-flask">

                        <field string="PS AND BS Sample" name="pregnant_result_count" widget="statinfo"/>
                    </button>

                    <button name="action_view_chemical_sample_requests"
                            type="object" groups="mrp.group_mrp_user"
                            class="oe_stat_button"
                            icon="fa-flask">
                        <field name="chemical_sample_request_count" widget="statinfo"/>
                    </button>

                    <button name="%(mrp_custom.mrp_manfacuring_order_production_report_blocked)d" type="action"
                            class="oe_stat_button" icon="fa-bar-chart">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="blocked_time" nolabel="1"/>
                                Hours
                            </span>
                            <span class="o_stat_text">Lost</span>
                        </div>
                    </button>

                </xpath>
                <xpath expr="//form/sheet/group/group[@name='group_extra_info']/field[@name='user_id']"
                       position="after">
                    <field name="workcenter_id" invisible="1"/>
                    <field name="dry_crushed"/>
                    <field name="achieved"/>
                    <field name="metal_content"/>
                </xpath>
            </field>
        </record>

        <record id="view_oee_production_form_inherit" model="ir.ui.view">
            <field name="name">mrp.oee.lost.form.inherit</field>
            <field name="model">mrp.workcenter.productivity</field>
            <field name="inherit_id" ref="mrp.oee_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='loss_id']" position="after">
                    <field name="equipment_id"/>
                </xpath>
            </field>
        </record>


        <!-- Tree view  Loss Detial -->
        <record id="view_loss_detail_tree" model="ir.ui.view">
            <field name="name">mrp.workcenter.productivity.loss.detail.tree</field>
            <field name="model">mrp.workcenter.productivity.loss.detail</field>
            <field name="arch" type="xml">
                <list string="Loss Detail Reasons">
                    <field name="name"/>
                    <field name="loss_id"/>
                    <field name="code"
                           groups="base_rida.rida_group_master_data_manager'"/>
                    <field name="loss_id"/>
                </list>
            </field>
        </record>

        <!-- Form view  Loss Detial -->
        <record id="view_loss_detail_form" model="ir.ui.view">
            <field name="name">mrp.workcenter.productivity.loss.detail.form</field>
            <field name="model">mrp.workcenter.productivity.loss.detail</field>
            <field name="arch" type="xml">
                <form string="Loss Detail Reason">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="loss_id"/>
                            <field name="code"
                                   groups="base_rida.rida_group_master_data_manager"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Block Wizard -->
        <record id="view_mrp_loss_reason_form_inherit" model="ir.ui.view">
            <field name="name">mrp.loss.reason.form.inherit</field>
            <field name="model">mrp.workcenter.productivity</field>
            <field name="inherit_id" ref="mrp.mrp_workcenter_block_wizard_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='loss_id']" position="after">
                    <field name="loss_detail_id" domain="[('loss_id' ,'=' , loss_id)]" required="1"/>

                </xpath>


            </field>
        </record>


        <!-- No Create No Edit Option -->
        <record id="view_mrp_production_form_inherit" model="ir.ui.view">
            <field name="name">mrp.production.form.inherit</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='product_id']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_edit': True}</attribute>
                </xpath>
                <xpath expr="//field[@name='lot_producing_ids']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_edit': True}</attribute>
                </xpath>
            </field>
        </record>

        <!-- Action loss detail -->
        <record id="action_loss_detail" model="ir.actions.act_window">
            <field name="name">Loss Reasons</field>
            <field name="res_model">mrp.workcenter.productivity.loss.detail</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu loss detail -->
        <menuitem
                id="menu_loss_detail"
                name="Loss Detail Reasons"
                parent="mrp.menu_mrp_configuration"
                sequence="99"
                action="action_loss_detail"
        />

        <!-- Action Productivity/Downtime -->
        <record id="action_loss_reason" model="ir.actions.act_window">
            <field name="name">Loss Reasons</field>
            <field name="res_model">mrp.workcenter.productivity</field>
            <field name="view_mode">list,form</field>
        </record>


        <!-- Menu Productivity/Downtime -->
        <menuitem
                id="menu_loss_reason"
                name="Productivity and Downtime"
                parent="mrp.menu_mrp_manufacturing"
                sequence="100"
                action="action_loss_reason"
        />
        <menuitem id="menu_create_daily_auto_mo"
                  name="Create Daily MOs"
                  parent="mrp.menu_mrp_manufacturing"
                  sequence="110"
                  action="action_create_daily_auto_mo"/>

        <!--        Report al daily plan report  -->
        <record id="action_mrp_production_tree_report_plan" model="ir.actions.act_window">
            <field name="name">CIC and CRUSHER Report PLAN</field>
            <field name="res_model">mrp.production</field>
            <field name="view_mode">list,graph</field>
            <field name="view_id" ref="mrp.mrp_production_tree_view"/>
            <field name="domain">[('state', '=', 'done')]</field>
            <field name="context">{'search_default_filter':1, 'create': False, 'import_file': False}</field>
        </record>

        <!-- Menu -->
        <menuitem id="menu_mrp_report_manufacturing_orders"
                  name="CIC and Crusher Report Plan"
                  parent="mrp.menu_mrp_reporting"
                  action="action_mrp_production_tree_report_plan"
                  sequence="50"/>


    </data>
</odoo>
