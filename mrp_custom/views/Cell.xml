<odoo>
    <!--    Form View for Cell -->
    <record id="view_pond_form" model="ir.ui.view">
        <field name="name">pond.form</field>
        <field name="model">pond.management</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="batch_id"/>
                            <field name="start_date"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="last_checked"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Tree View  For Cell -->
    <record id="view_pond_tree" model="ir.ui.view">
        <field name="name">pond.management.tree</field>
        <field name="model">pond.management</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="batch_id"/>
                 <field name="start_date"/>
                <field name="last_checked"/>
            </list>
        </field>
    </record>


    <!-- Form View Manhole -->
    <record id="view_manhole_sample_form" model="ir.ui.view">
        <field name="name">manhole.form</field>
        <field name="model">manhole.manhole</field>
        <field name="arch" type="xml">
            <form string="Manhole Sample">
                <header>
                    <button string="Chem-Assay" name="create_checmical_lab_assy" type="object" class="oe_highlight" groups="mrp.group_mrp_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,sample,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_open_chemical_samples"
                                class="oe_stat_button"
                                icon="fa-flask">
                            <field name="chemical_sample_request_count" widget="statinfo" string="Chemical Samples"/>
                        </button>
                    </div>
                     <h1 class="d-flex">
                            <field name="name" readonly="1"/>
                    </h1>
                    <group>
                        <field name="date" readonly="state not in ['draft']"/>
                    </group>
                    <group string="Assay Results">
                        <group>
                             <field name="mh1" readonly="1"/>
                            <field name="mh2" readonly="1"/>
                            <field name="mh3"  readonly="1"/>
                            <field name="mh4"  readonly="1"/>
                        </group>
                        <group >
                            <field name="ppo"  readonly="1"/>
                            <field name="ppn"  readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

     <!-- Tree View -->
    <record id="view_manhole_sample_tree" model="ir.ui.view">
        <field name="name">manhole.tree</field>
        <field name="model">manhole.manhole</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="state"/>
                <field name="mh1"/>
                <field name="mh2"/>
                <field name="mh3"/>
                <field name="mh4"/>
                <field name="ppo"/>
                <field name="ppn"/>
            </list>
        </field>
    </record>

    <!-- Action  Cell (Pond) -->
    <record id="action_pond_management" model="ir.actions.act_window">
        <field name="name">Ponds</field>
        <field name="res_model">pond.management</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="action_manhole_sample" model="ir.actions.act_window">
        <field name="name">Manhole Samples</field>
        <field name="res_model">manhole.manhole</field>
        <field name="view_mode">list,form</field>
    </record>



</odoo>