<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
  <t t-inherit="mrp_workorder.MrpDisplayMenuDialog" t-inherit-mode="extension">
    <xpath expr="//div[hasclass('o_mrp_menu_dialog')]//div[hasclass('row')]" position="inside">
      <div class="col-6 p-1">
        <button t-if="props.record.resModel === 'mrp.workorder'"
                class="btn btn-primary d-flex justify-content-between align-items-center p-3 fs-3 w-100 h-100"
                t-on-click="() => this.callAction('action_create_Pregnant_sample')">
          <div class="d-flex align-items-center text-start">
            <span class="me-2">🧪</span>
            <span style="font-size: 0.8em; line-height: 1.2;">PS AND BS Sample</span>
          </div>
          <i class="oi oi-chevron-right fs-4"/>
        </button>
      </div>
    </xpath>
  </t>
</templates>
