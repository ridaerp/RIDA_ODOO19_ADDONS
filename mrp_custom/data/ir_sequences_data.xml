<odoo noupdate="1">
    <!--    Loss Sequence -->
    <record id="seq_productivity_loss_log" model="ir.sequence">
        <field name="name">Productivity Loss Log Sequence</field>
        <field name="code">productivity.loss.log</field>
        <field name="prefix">PLL</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!--  Flowmeter reading loG Sheet  -->
    <record id="seq_flowmeter_logsheet" model="ir.sequence">
        <field name="name">flowmeter Log Sequence</field>
        <field name="code">flowmeter.log.sheet.sequence</field>
        <field name="prefix">R/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

    <!--  ADR loG Sheet  -->
    <record id="seq_adr_logsheet" model="ir.sequence">
        <field name="name">ADR Log Sequence</field>
        <field name="code">adr.log.sheet.sequence</field>
        <field name="prefix">Sequance/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

    <!--  Stripping loG Sheet  -->
    <record id="seq_stripping_logsheet" model="ir.sequence">
        <field name="name">Stripping Log Sequence</field>
        <field name="code">stripping.log.sheet.sequence</field>
        <field name="prefix"> </field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

    <!--  Crusher Log Sheet  -->
    <record id="seq_crusher_logsheet" model="ir.sequence">
        <field name="name">Crusher Log Sequence</field>
        <field name="code">crusher.log.sheet.sequence</field>
        <field name="prefix">Crusher/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

        <!--  Stacker Log Sheet  -->
    <record id="seq_stacker_logsheet" model="ir.sequence">
        <field name="name">Stacker Log Sequence</field>
        <field name="code">stacker.log.sequence</field>
        <field name="prefix">Stacker/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

       <!-- Crusher Belt Scale -->
    <record id="seq_crusher_belt_scale_log" model="ir.sequence">
        <field name="name">Crusher Belt Scale Log</field>
        <field name="code">crusher.belt.scale.reading</field>
        <field name="prefix">BSL-Crusher/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

       <!-- Stacker Belt Scale -->
    <record id="seq_stacker_belt_scale_log" model="ir.sequence">
        <field name="name">Stacker Belt Scale Log</field>
        <field name="code">stacker.belt.scale.reading</field>
        <field name="prefix">BSL-Stacker/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

     <!--   pregnant sample result  Seq -->
    <record id="seq_pregnant_result" model="ir.sequence">
        <field name="name">Pregnant Sample Result</field>
        <field name="code">pregnant.result</field>
        <field name="prefix">PS</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>

    </record>

    <!--   barren sex sample result  Seq -->
    <record id="seq_barren_result" model="ir.sequence">
        <field name="name">Barren sex Sample Result</field>
        <field name="code">barren.result</field>
        <field name="prefix">BS</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>

    </record>

    <!--  Manhole Sample   -->
    <record id="seq_manhole_sample" model="ir.sequence">
        <field name="name">Manhole Sequence</field>
        <field name="code">manhole.sequence</field>
        <field name="prefix">Manhole/%(year)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
    </record>

    <!--   Gold Seq -->
    <record id="seq_gold_21_serial" model="ir.sequence">
        <field name="name">Gold 21 Serial Number</field>
        <field name="code">gold_21_serial_mrp</field>
        <field name="prefix">UM/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="implementation">standard</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
