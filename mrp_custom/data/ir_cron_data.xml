<odoo>
      <data noupdate="1">

    <!--    Daily Manufacture Order -->
    <record id="ir_cron_create_auto_mrp_orders" model="ir.cron">
        <field name="name">Create Auto MRP Orders Daily</field>
        <field name="model_id" ref="mrp.model_mrp_production"/>
        <field name="state">code</field>
        <field name="code">model.create_daily_auto_mo()</field>
        <field name="interval_type">days</field>
        <field name="interval_number">1</field>
        <field name="active" eval="True"/>
    </record>

    <!--    cron job to read fowmater -->
    <record id="ir_cron_update_flowmeter_readings" model="ir.cron">
        <field name="name">Update Flowmeter Readings</field>
        <field name="model_id" ref="model_flowmeter_flowmeter"/>
        <field name="state">code</field>
        <field name="code">model._cron_update_flowmeters()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>


<!--    Update Flow On Work Order-->
    <record id="ir_cron_update_flow_and_workorders" model="ir.cron">
      <field name="name">Update Flowmeters and Workorders</field>
      <field name="model_id" ref="model_flowmeter_flowmeter"/>
      <field name="state">code</field>
      <field name="code">model.cron_update_flow_and_workorders()</field>
      <field name="interval_number">15</field>
      <field name="interval_type">minutes</field>
      <field name="active" eval="True"/>
    </record>


<!--        workorder count in the same workcenter -->
        <record id="ir_cron_update_inprogress_workorder_counts" model="ir.cron">
            <field name="name">Update In Progress Workorders Count</field>
            <field name="model_id" ref="mrp.model_mrp_workcenter"/>
            <field name="state">code</field>
            <field name="code">model.update_inprogress_workorder_counts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    <record id="action_create_daily_auto_mo" model="ir.actions.server">
    <field name="name">Create Daily Auto MOs</field>
    <field name="model_id" ref="mrp.model_mrp_production"/> <!-- أو الموديل اللي عليه الدالة -->
    <field name="state">code</field>

         <field name="code">env['mrp.production'].create_daily_auto_mo()</field>
</record>
</data>

</odoo>
