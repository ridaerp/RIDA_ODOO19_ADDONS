<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <data>
      <record model="ir.ui.view" id="hr_leave_type_view_inherit_form">
         <field name="name">hr.leave.type.form</field>
         <field name="model">hr.leave.type</field>
         <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
         <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
               <field name="leave_type"/>
               <field name="year" invisible="leave_type != 'annual'" required="leave_type == 'annual'"/>
               <field name="attachment_required"/>
               <field name="exclude_weekend"/>
               <field name="exclude_public"/>
               <field name="leave_maximum"/>
               <field name="leave_maximum_number"/>
            </xpath>
            <xpath expr="//field[@name='request_unit']" position="after">
               <field name="expense_account_id" options="{'no_create': True, 'no_create_edit':True}"/>
            </xpath>
            <xpath expr="//field[@name='expense_account_id']" position="after">
               <field name="journal_id" domain="[('type','=','purchase')]" options="{'no_create': True, 'no_create_edit':True}"/>
            </xpath>
         </field>
      </record>

      <record model="ir.ui.view" id="hr_leave_type_view_inherit_tree">
         <field name="name">hr.leave.type.tree</field>
         <field name="model">hr.leave.type</field>
         <field name="inherit_id" ref="hr_holidays.view_holiday_status_normal_tree"/>
         <field name="arch" type="xml">
            <xpath expr="//field[@name='work_entry_type_id']" position="before">
               <field name="leave_type"/>
            </xpath>
         </field>
      </record>

      <!-- Inherit Form View to Modify it -->
      <record id="hr_holidays_view_form_inherit" model="ir.ui.view">
         <field name="name">hr.holidays.view.form.inherit</field>
         <field name="model">hr.leave</field>
         <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
         <field name="arch" type="xml">
            <xpath expr="//form/header" position="replace">
               <!-- new header to check if the leave is unpaid or not -->
               <header invisible="click != 'False'">
                  <!-- <button string="Confirm" name="action_confirm" invisible="state != 'draft'" type="object" class="oe_highlight"/> -->
                  <button string="Approve" name="action_approve" type="object" class="oe_highlight" invisible="click != False"/>
                  <button string="Validate" name="action_approve" invisible="state != 'validate'" type="object" groups="hr_holidays.group_hr_holidays_manager" class="oe_highlight"/>
                  <button string="Cut Leave" name="action_cut_leave" invisible="state != 'validate'"  type="object" groups="hr_holidays.group_hr_holidays_manager" class="oe_highlight"/>
                  <button string="Refuse" name="action_refuse" type="object" invisible="not can_approve or state not in ['confirm', 'validate1', 'validate']"/>
                  <!-- <button string="Mark as Draft" name="action_draft" type="object" invisible="not can_reset or state not in ['confirm', 'refuse']"/> -->
                  <button string="Back to Approval" name="action_back_to_approval" type="object" invisible="True"/>
                  <field name="state" widget="statusbar" statusbar_visible="confirm,validate"/>
               </header>
               <header invisible ="click == 'False'">
                   
                  <field name="state" widget="statusbar" statusbar_visible="draft,validate"/>
                  <!-- draft state buttons for internal users-->
                  <button string="Submit" name="submit" groups = "base.group_user" type="object" class="oe_highlight" invisible="state != 'draft'"></button>
                   <!-- confirm state buttons for internal users-->
                  <button string="Submit" name="submit" groups = "base.group_user" type="object" class="oe_highlight" invisible="state != 'confirm'"></button>
                  <button string="Cancel" name="cancel" groups = "base.group_user"  type="object" invisible="state != 'confirm'"  ></button>
                   <!-- line manager approval state buttons for lm-->
                  <button string="Approve" name="lm_approve" groups = "base_rida.rida_group_line_manager" type="object" class="oe_highlight" invisible="state != 'line_manager'"></button>
                  <button string="Cancel" name="lm_approve_reject" groups = "base_rida.rida_group_line_manager" type="object" invisible="state != 'line_manager'" ></button>
                   <!-- hr officer state buttons for hr officer-->
                  <button string="Change Days | Cut Leave" name="action_cut_leave" type="object" class="oe_highlight" invisible="state != 'validate'" ></button>
                  <button string="HR officer Approve" name="hr_approve" groups = "hr.group_hr_user" type="object" class="oe_highlight" invisible="state != 'hr_officer'" ></button>
                  <button string="HR Manager Approve" name="hr_manager_approve" groups = "base_rida.rida_hr_manager_notify" type="object" class="oe_highlight" invisible="state != 'validate1'" ></button>
                  <button string="Cancel" name="hr_approve_reject" groups = "hr.group_hr_user" type="object" invisible="state != 'hr_officer'" ></button>
                   <!-- ccso approval buttons for ccso-->
                  <button string="CCSO Approve" name="ccso_approve" groups = "base_rida.rida_group_CCSO,base_rida.rida_group_COO" type="object" class="oe_highlight" invisible="state != 'ccso'"></button>
                  <button string="Cancel" name="ccso_approve_reject" groups = "base_rida.rida_group_CCSO,base_rida.rida_group_COO" type="object" invisible="state != 'ccso'"></button>
                  <button string="Refuse" name="action_refuse" type="object" invisible="not can_approve or state not in ['confirm', 'validate1', 'validate']"/>
                   <button string="Cancel" name="cancel" groups = "hr.group_hr_manager"   type="object" invisible="state != 'validate'"></button>
                   <button string="Set TO Draft" name="set_to_draft" groups = "hr.group_hr_manager" type="object" invisible="state != 'refuse'" ></button>
               </header>

            </xpath>
            <xpath expr="//field[@name='name']" position="before">
               <!-- Add your fields or attributes here -->
               <field name="attachment"/>
               <field name="justification"/>
               <field name="click" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="mercy_relation" invisible="not show_mercy_relation"/>
                <field name="show_mercy_relation" invisible="1"/>
            </xpath>
<!--            <xpath expr="//field[@name='duration_display']" position="after">-->
<!--                <field name="delegated_employee_id" invisible="leave_type_test == 'sick'"/>-->
<!--            </xpath>-->
<!--            <xpath expr="//field[@name='delegated_employee_id']" position="after">-->
<!--                <field name="leave_type_test" invisible="1"/>-->
<!--            </xpath>-->
<!--            <xpath expr="//field[@name='attachment']" position="replace">-->
<!--               <field name="attachment" invisible="leave_type_test != 'sick'" required="leave_type_test == 'sick'"/>-->
<!--            </xpath>-->

         </field>
      </record>

   </data>
</odoo>