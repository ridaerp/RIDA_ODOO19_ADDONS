<?xml version="1.0" ?>
<odoo>
    <data>
        <!--  User Time Off By Department -->
        <record model="ir.rule" id="rule_check_timeoff_batch_creator">
            <field name="name">Check Creator</field>
            <field name="model_id" ref="model_rotation_batch"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!--  Line Manager Time Off By Department -->
        <record model="ir.rule" id="rule_check_timeoff_batch_l_mng">
            <field name="name">Line Manager Time off</field>
            <field name="model_id" ref="model_rotation_batch"/>
            <field name="domain_force">[('req_id.line_manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base_rida.rida_group_line_manager'))]"/>
        </record>


        <!--  Manager related to Time Off By Department -->
        <record model="ir.rule" id="rule_check_timeoff_batch_mng">
            <field name="name">Manager Time off</field>
            <field name="model_id" ref="model_rotation_batch"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('base_rida.rida_group_site_manager')),(4, ref('base_rida.rida_group_CCSO')),(4, ref('base_rida.rida_internal_audit')),(4, ref('base_rida.rida_hr_manager_notify')),(4, ref('hr_holidays.group_hr_holidays_manager')),(4, ref('account.group_account_user'))]"/>
        </record>


        <!--  Internal User rule -->
        <record id="internal_user_leave_rule" model="ir.rule">
            <field name="name">Internal User Leave Rule</field>
            <field name="model_id" ref="model_hr_leave"/>
            <field name="domain_force">['|',('employee_id.user_id', '=', 'user_id'),('holiday_status_id.leave_type',
                '=', 'unpaid')]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_unlink" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="1"/>
        </record>

        <!--  HR officer  rule -->
        <record id="hr_officer_leave_rule" model="ir.rule">
            <field name="name">HR officer Leave Rule</field>
            <field name="model_id" ref="model_hr_leave"/>
            <field name="domain_force">[('holiday_status_id.leave_type', '=', 'unpaid')]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="perm_unlink" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="0"/>
        </record>
        <!--  CCSO rule -->
<!--        <record id="CCSO_leave_rule" model="ir.rule">-->
<!--            <field name="name">CCSO Leave Rule</field>-->
<!--            <field name="model_id" ref="model_hr_leave"/>-->
<!--            <field name="domain_force">[('holiday_status_id.leave_type', '=', 'unpaid')]</field>-->
<!--            <field name="groups" eval="[(4, ref('base_rida.rida_group_CCSO'))]"/>-->
<!--            <field name="perm_unlink" eval="0"/>-->
<!--            <field name="perm_write" eval="1"/>-->
<!--            <field name="perm_read" eval="1"/>-->
<!--            <field name="perm_create" eval="0"/>-->
<!--        </record>-->
        <!--  lm rule -->
        <record id="lm_leave_rule" model="ir.rule">
            <field name="name">Line Manager Leave Rule</field>
            <field name="model_id" ref="model_hr_leave"/>
            <field name="domain_force">[('holiday_status_id.leave_type', '=', 'unpaid')]</field>
            <field name="groups" eval="[(4, ref('base_rida.rida_group_line_manager'))]"/>
            <field name="perm_unlink" eval="0"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="0"/>
        </record>


    </data>


</odoo>
