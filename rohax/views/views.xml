<odoo>
    <data>

        <record id="mod_request_form" model="ir.ui.view">
            <field name="name">modification.request.form</field>
            <field name="model">modification.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="set_submit" type="object" states="draft"
                                class="oe_highlight"/>
                        <button string="Approve" name="set_l_mng_confirm" type="object" states="line_mng"
                                class="oe_highlight" groups="base_rida.rida_group_line_manager"/>
                        <button string="Approve" name="set_qhse_confirm" type="object" states="qhse"
                                class="oe_highlight" groups="base_rida.rida_group_qhse_manager"/>
                        <button string="Approve" name="set_ccso_confirm" type="object" states="ccso"
                                class="oe_highlight" groups="base_rida.rida_group_CCSO"/>
                        <button string="Approve" name="set_fleet_confirm" type="object" states="fleet"
                                class="oe_highlight" groups="base_rida.group_fleet_director"/>
                        <button string="Approve" name="set_od_confirm" type="object" states="od"
                                class="oe_highlight" groups="base_rida.rida_group_site_manager"/>

                        <button string="Approve" name="set_qhse_conf_confirm" type="object" states="qhse_conf"
                                class="oe_highlight" groups="base_rida.rida_group_qhse_manager"/>

                        <button string="Compelete" name="set_ict_confirm" type="object" states="ict"
                                class="oe_highlight" groups="base_rida.rida_group_ict_team"/>

                        <button string="Confirm" name="set_qhse_validate" type="object" states="qhse_validated"
                                class="oe_highlight" groups="base_rida.rida_group_qhse_manager"/>


                        <button string="Close/Accept" name="done" type="object" states="close"
                                class="oe_highlight"/>


                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                states="line_mng,qhse,ccso,od,qhse_conf,ict,close" string="Reject"
                                groups="base_rida.rida_group_line_manager,base_rida.rida_group_qhse_manager,base_rida.rida_group_CCSO,base_rida.rida_group_site_manager"
                        />

                        <field name="state" invisible="1"/>
                        <field name="state_ccso" widget="statusbar"
                               statusbar_visible="draft,line_mng,qhse,ccso,qhse_conf,done"
                               attrs="{'invisible': [('user_type', '!=', 'hq')]}"/>
                        <field name="state_od" widget="statusbar"
                               statusbar_visible="draft,line_mng,qhse,od,qhse_conf,done"
                               attrs="{'invisible': [('user_type', '!=', 'site')]}"/>
                        <field name="state_fleet" widget="statusbar"
                               statusbar_visible="draft,line_mng,qhse,fleet,qhse_conf,done"
                               attrs="{'invisible': [('user_type', '!=', 'fleet')]}"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="code_seq"/>
                            </h1>
                        </div>
                        <group>
                            <group>


                                <field name="user_type" invisible="1"/>

                                <field name="level_of_change"
                                       attrs="{'invisible':[('state','in',['draft','line_mng'])],'readonly': [('state','not in',['qhse'])],'required': [('state','in',['qhse'])]}"
                                       widget="radio"/>
                                <field name="type"
                                       attrs="{'readonly': [('state','not in',['draft','line_mng'])]}"
                                       required="1"/>
                                <field name="pr_cat"  attrs="{'readonly': [('state','not in',['draft'])]}"
                                       required="1" options="{'no_create': True}"/>
                                <field name="procedure_id"  domain="[('pr_cat','=',pr_cat)]"  attrs="{'readonly': [('state','not in',['draft'])]}"
                                       required="1" options="{'no_create': True}"/>
                                <field name="form_id" domain="[('procedure_id','=',procedure_id)]" attrs="{'readonly': [('state','not in',['draft'])]}"
                                       options="{'no_create': True}"/>
                            
                            </group>
                            <group>  <field name="date"/>

                                <field name="req_id" required="1"/>
                                <field name="department_id"
                                       attrs="{'readonly': [('state','not in',['draft','line_mng'])]}"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="job_id"
                                       attrs="{'readonly': [('state','not in',['draft','line_mng'])]}"
                                       options="{'no_create': True,'no_open':True}"/>
                                <field name="note"
                                       attrs="{'invisible':[('state','in',['draft','line_mng'])],'readonly': [('state','not in',['qhse'])],'required': [('state','in',['qhse'])]}"/>
                            </group>
                        </group>
                        <group>

                                <field name="description"
                                       attrs="{'readonly': [('state','not in',['draft','line_mng'])]}"
                                       required="1"/>
                                       
                            <field name="pr_mo_new"
                                   attrs="{'readonly': [('state','not in',['draft','line_mng'])]}"
                                   required="1"/>
                            <field name="mo_new"
                                   attrs="{'readonly': [('state','not in',['draft','line_mng'])]}"
                                   required="1"/>
                        </group>

                        <notebook>
                            <page string="Approval and Signature">
                                <group>
                                    <group>
                                        <field name="emp_l_mng" attrs="{'invisible': [('emp_l_mng', '=', False)]}"/>
                                        <field name="emp_l_mng_date"
                                               attrs="{'invisible': [('emp_l_mng_date', '=', False)]}"/>
                                    </group>
                                    <group>
                                        <field name="emp_ccso" attrs="{'invisible': [('emp_ccso', '=', False)]}"/>
                                        <field name="emp_fleet"
                                               attrs="{'invisible': [('emp_fleet', '=', False)]}"/>
                                        <field name="emp_od" attrs="{'invisible': [('emp_od', '=', False)]}"/>
                                        <field name="ccso_od_date"
                                               attrs="{'invisible': [('ccso_od_date', '=', False)]}"/>

                                        <field name="qhse_manager"
                                               attrs="{'invisible': [('qhse_manager', '=', False)]}"/>
                                        <field name="qhse_date" attrs="{'invisible': [('qhse_date', '=', False)]}"/>
                                    </group>


                                </group>
                            </page>
                            <page string="QHSE Only"
                                  attrs="{'invisible': [('state', 'not in',['qhse_conf','ict','done','close','qhse_validated','reject'])],'readonly': [('state', '!=', 'qhse_conf')]}">
                                <group>
                                    <field name="qhse_desc"
                                           attrs="{'required': [('state', '=', 'qhse_conf')],'readonly': [('state','!=','qhse_conf')]}"/>
                                    <field name="n_o_change"
                                           attrs="{'required': [('state', '=', 'qhse_conf')],'readonly': [('state','!=','qhse_conf')]}"/>
                                    <field name="rel_doc"
                                           attrs="{'readonly': [('state','!=','qhse_conf')]}"/>
                                </group>
                            </page>


                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>
        <record id="mod_request_tree_view" model="ir.ui.view">
            <field name="name">modification request tree</field>
            <field name="model">modification.request</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="code_seq"/>
                    <field name="date"/>
                    <field name="department_id"/>
                    <field name="type"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="procdure_form" model="ir.ui.view">
            <field name="name">qhse.procedure.form</field>
            <field name="model">qhse.procedure</field>
            <field name="arch" type="xml">
                <form string="Procedure">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="get_mod_change"
                                    type="object" class="oe_stat_button" icon="fa-list-alt">
                                <field name="mod_req_count" string="Modifications" widget="statinfo"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="code" required="1"/>
                                <field name="page" required="1"/>
                            </group>
                            <group>
                                <field name="pr_cat" required="1" options="{'no_create': True}"/>
                                <field name="issue_rev" required="1"/>
                                <field name="date" required="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="procdure_cat_form" model="ir.ui.view">
            <field name="name">qhse.procedure.cat.form</field>
            <field name="model">procedure.category</field>
            <field name="arch" type="xml">
                <form string="Procedure ">
                    <sheet>
                        <group>
                            <field name="name" required="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ghse_forms_form" model="ir.ui.view">
            <field name="name">qhse.forms.form</field>
            <field name="model">qhse.forms</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="get_mod_change"
                                    type="object" class="oe_stat_button" icon="fa-list-alt">
                                <field name="mod_req_count" string="Modifications" widget="statinfo"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="code" required="1"/>
                                <field name="page" required="1"/>
                            </group>
                            <group>
                                <field name="procedure_id" required="1" options="{'no_create': True}"/>
                                <field name="issue_rev" required="1"/>
                                <field name="date" required="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="procdure_tree_view" model="ir.ui.view">
            <field name="name">Procedure tree</field>
            <field name="model">qhse.procedure</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="pr_cat"/>
                    <field name="page"/>
                    <field name="issue_rev"/>
                    <field name="date"/>
                </tree>
            </field>
        </record>

        <record id="form_tree_view" model="ir.ui.view">
            <field name="name">Form tree</field>
            <field name="model">qhse.forms</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="procedure_id"/>
                    <field name="page"/>
                    <field name="issue_rev"/>
                    <field name="date"/>
                </tree>
            </field>
        </record>

        <record id="mod_re_act_window" model="ir.actions.act_window">
            <field name="name">Modification Request</field>
            <field name="res_model">modification.request</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="qhse_forms_act_window" model="ir.actions.act_window">
            <field name="name">Forms</field>
            <field name="res_model">qhse.forms</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="procdure_cat_act_window" model="ir.actions.act_window">
            <field name="name">Procedure Category</field>
            <field name="res_model">procedure.category</field>
            <field name="view_mode">tree,form</field>
        </record>

        <record id="procdure_act_window" model="ir.actions.act_window">
            <field name="name">Procedure</field>
            <field name="res_model">qhse.procedure</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem name="QHSE" id="qhse_menu" web_icon="qhse,static/description/icon.jpg"/>
        <menuitem name="Forms" id="qhse_form" parent="qhse_menu" sequence="1"/>
        <menuitem name="Modification Request" id="mod_re_menu" parent="qhse_form"
                  action="mod_re_act_window"
        />
        <menuitem name="Configuration" id="qhse_conf_menu" parent="qhse_menu"
                  groups="base_rida.rida_group_qhse_manager"/>
        <menuitem name="Procedure" id="proc_menu" parent="qhse_conf_menu"
                  action="procdure_act_window"
        />
        <menuitem name="Procedure Category" id="proc_cat_menu" parent="qhse_conf_menu"
                  action="procdure_cat_act_window"
        />
        <menuitem name="Forms" id="qhse_form_menu" parent="qhse_conf_menu"
                  action="qhse_forms_act_window"
        />

    </data>
</odoo>