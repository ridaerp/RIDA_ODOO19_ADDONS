<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">


        <!-- Maintenance-specific activities, for automatic generation mainly -->
        <record id="mail_act_itemcode_request" model="mail.activity.type">
            <field name="name">Item Code Request</field>
            <field name="icon">fa-wrench</field>
            <field name="res_model">request.product</field>
        </record>

        <!-- Approval activities -->
        <record id="mail_act_master_data_approval" model="mail.activity.type">
            <field name="name">Action Required</field>
            <field name="icon">fa-check</field>
        </record>


        <record id="item_request" model="ir.sequence">
            <field name="name">Item Request</field>
            <field name="code">item.request</field>
            <field name="prefix">IR</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="item_edit_request" model="ir.sequence">
            <field name="name">Item Edit Request</field>
            <field name="code">edit.product</field>
            <field name="prefix">IR-W/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="vendor_request" model="ir.sequence">
            <field name="name">vendor Request</field>
            <field name="code">vendor.request</field>
            <field name="prefix">SUR</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="location_request" model="ir.sequence">
            <field name="name">location Request</field>
            <field name="code">request.location</field>
            <field name="prefix">LOC</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="analytic_request" model="ir.sequence">
            <field name="name">analytic Request</field>
            <field name="code">analytic.request</field>
            <field name="prefix">ALC</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="account_request" model="ir.sequence">
            <field name="name">account Request</field>
            <field name="code">account.request</field>
            <field name="prefix">ACC</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="pr_cat_request" model="ir.sequence">
            <field name="name">product categ Request</field>
            <field name="code">prod.cat.request</field>
            <field name="prefix">PRC</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="equipment_request" model="ir.sequence">
            <field name="name">Equipment Request</field>
            <field name="code">equipment.request</field>
            <field name="prefix">EQ/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="area_request" model="ir.sequence">
            <field name="name">Area Request</field>
            <field name="code">area.request</field>
            <field name="prefix">ARE/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="update_area_request" model="ir.sequence">
            <field name="name">Update Area Request</field>
            <field name="code">update.area.request</field>
            <field name="prefix">UAR/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="update_area_price" model="ir.sequence">
            <field name="name">Update Area Price</field>
            <field name="code">update.area.prices</field>
            <field name="prefix">UAP/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="update_grade_price" model="ir.sequence">
            <field name="name">Update Grade Prices</field>
            <field name="code">update.grade.prices</field>
            <field name="prefix">UPL/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
        <record id="update_transportation_price" model="ir.sequence">
            <field name="name">Update trasnportation Prices</field>
            <field name="code">update.transportation.prices</field>
            <field name="prefix">UTF</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
