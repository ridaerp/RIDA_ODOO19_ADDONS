<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_permission_request_personal" model="ir.rule">
            <field name="name">Personal Permission Requests</field>
            <field name="model_id" ref="model_permission_request"/>
            <field name="domain_force">['|', ('requester_id', '=', user.id), ('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_permission_request_all" model="ir.rule">
            <field name="name">All Permission Requests (Admin/ICT)</field>
            <field name="model_id" ref="model_permission_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base_rida.rida_group_master_data_manager')), (4, ref('base.group_system'))]"/>
        </record>
    </data>
</odoo>