<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="request_account_analytic_account_status" model="mail.message.subtype">
            <field name="name">Status Changed</field>
            <field name="res_model">request.analytic.account</field>
            <field name="default" eval="True"/>
            <field name="description">Request Account Analytic Has been created</field>
        </record>
        <record id="request_account_analytic_account_rej_status" model="mail.message.subtype">
            <field name="name">Status Changed</field>
            <field name="res_model">request.analytic.account</field>
            <field name="default" eval="True"/>
            <field name="description">Request Account Analytic Has been Rejected</field>
        </record>

        <record id="view_request_account_analytic_account_form" model="ir.ui.view">
            <field name="name">analytic.analytic.account.form</field>
            <field name="model">request.analytic.account</field>
            <field name="arch" type="xml">
                <form string="Analytic Account">
                    <header>
                        <button string="Submit" name="set_confirm" type="object"  invisible="state not in ['draft']"
                                class="oe_highlight" groups="base_rida.rida_group_line_manager"/>

             <button string="Confirm" name="set_validate" type="object" invisible="state not in ['w_adv']"
                                class="oe_highlight" groups="account.group_account_manager"/>





                        <button string="Create Analytic" name="create_analytic" type="object" invisible="state not in ['md']"
                                class="oe_highlight" groups="base_rida.rida_group_master_data_manager"/>

                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['md', 'w_adv']" string="Reject" groups="base_rida.rida_group_master_data_manager,account.group_account_manager"
                        />

                        <field name="state" widget="statusbar" statusbar_visible="draft,w_adv,md,done"/>
                    </header>
                    <sheet string="Analytic Account">
                        <div class="oe_title">
                            <h1>
                                <field name="code_seq"/>
                            </h1>
                        </div>

                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" class="oe_inline" required="1" placeholder="e.g. Project XYZ"
                                    readonly="state == 'done'" />
                            </h1>
                        </div>
                        <br/>
                        <group>
                            <field name="new_analytic" invisible="state != 'done'"/>
                        </group>
                        <div name="project"/>
                        <group name="main">
                            <group>
                                <field name="analytic_type" required="1" readonly="state == 'done'" />

                                <field name="partner_id" required="0" readonly="state == 'done'" />
                                <field name="company_id" options="{'no_create': True}"
                                       groups="base.group_multi_company"
                                   readonly="state == 'done'" />
                            </group>
                            <group>
                                <field name="code"
                                   required="state == 'md'"  readonly="state != 'md'"/>

                                   <field name="type"
                                   required="1"  readonly="state != 'md'"/>
                                   <field name="plan_id"
                                   required="state == 'w_adv'"  readonly="state not in ['md','w_adv']"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>


        <record id="master_analytic_tree_view" model="ir.ui.view">
            <field name="name">master anayltic tree</field>
            <field name="model">request.analytic.account</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code_seq"/>
                    <field name="date"/>
                    <field name="req_id"/>
                    <field name="name"/>
                    <field name="type"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="analytic_request_form_search" model="ir.ui.view">
            <field name="name">analytic.request.search</field>
            <field name="model">request.analytic.account</field>
            <field name="arch" type="xml">
                <search>
                    <field name="code_seq"/>
                </search>
            </field>
        </record>


        <record id="analytic_request_act_window" model="ir.actions.act_window">
            <field name="name">Analytic Account Request</field>
            <field name="res_model">request.analytic.account</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem name="Analytic Account" id="analytic_request_menu" parent="master_data"
                  action="analytic_request_act_window"
                  groups="base_rida.rida_group_line_manager,base_rida.rida_group_master_data_manager,account.group_account_manager"/>

    </data>
</odoo>
