<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="area_request_form_view" model="ir.ui.view">
            <field name="name">area.price.form</field>
            <field name="model">update.area.price</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="get_area"
                                string="Get Area Prices" type="object"
                                class="oe_highlight"
                                groups="material_request.group_ore_reader_planning,base_rida.rida_group_CCSO,base_rida.rida_group_COO"
                           invisible="state != 'draft'" />
                        <button string="Submit" name="action_submit" type="object" class="oe_highlight" invisible="state != 'draft'"
                                groups="material_request.group_ore_reader_planning"/>
                        <button string="Confirm" name="set_confirm" type="object" invisible="state != 'wlm_approve'"
                                class="oe_highlight"
                                groups="base_rida.rida_group_line_manager"/>
                        <button string="Approve" name="ccso_approve" type="object" invisible="state != 'coo'"
                                class="oe_highlight"
                                groups="base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <button string="Approve" name="update_area_price" type="object"  invisible="state != 'md'"
                                class="oe_highlight"
                                groups="base_rida.rida_group_master_data_manager"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['draft', 'wlm_approve', 'coo']" string="Reject"
                                groups="material_request.group_ore_reader_planning,base_rida.rida_group_CCSO,base_rida.rida_group_COO"
                        />
                        <button name="set_draft" string="Set To Draft" type="object" invisible="state != 'reject'"
                                groups="material_request.group_ore_reader_planning,base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,wlm_approve,coo,md,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" name="get_area_with_price"
                                    groups="material_request.group_ore_reader_planning" string="Area" type="object" icon="fa-list"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="req_id"/>
                                <field name="department_id" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="description" readonly="state == 'done'"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Update Area Prices">
                                <field name="update_area_price_line_ids"
                                       nolabel="1">
                                    <list string="Update Area Prices" decoration-success="is_colored" decoration-bf="is_colored" editable="bottom" create="false" delete="false">
                                        <field name="area" readonly="1"/>
                                        <field name="is_colored" invisible="1"/>
                                        <field name="previous_unit_price" readonly="1"/>
                                        <field name="previous_discount_on_ore_price" readonly="1"/>
                                        <field name="previous_discount_on_transportation" readonly="1"/>
                                        <field name="unit_price" readonly="parent.state != 'draft'"/>
                                        <field name="discount_on_ore_price"
                                               readonly="parent.state != 'draft'"/>
                                        <field name="discount_on_transportation"
                                               readonly="parent.state != 'draft'"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="update_area_price_line_tree_view" model="ir.ui.view">
            <field name="name">update area price line tree</field>
            <field name="model">update.area.price.line</field>
            <field name="arch" type="xml">
                <list decoration-success="is_colored" decoration-bf="is_colored">
                    <field name="is_colored" invisible="1"/>
                    <field name="update_price" invisible="1"/>
                    <field name="area"/>
                    <field name="previous_unit_price"/>
                    <field name="previous_discount_on_ore_price"/>
                    <field name="previous_discount_on_transportation"/>
                    <field name="unit_price"/>
                    <field name="discount_on_ore_price"/>
                    <field name="discount_on_transportation"/>
                </list>
            </field>
        </record>

        <record id="master_data_update_area_price_tree_view" model="ir.ui.view">
            <field name="name">update area price tree</field>
            <field name="model">update.area.price</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="department_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="master_data_update_area_price_search" model="ir.ui.view">
            <field name="name">update.area.price.search</field>
            <field name="model">update.area.price</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>


        <record id="master_data_update_area_price_action" model="ir.actions.act_window">
            <field name="name">Update Area Prices</field>
            <field name="res_model">update.area.price</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Area Transportation Prices" id="master_data_update_area_price" parent="master_data_area"
                  action="master_data_update_area_price_action" sequence="1"
                  groups="material_request.group_ore_reader_planning,base_rida.rida_group_CCSO,base_rida.rida_group_COO"/>

    </data>
</odoo>