<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="item_code_status" model="mail.message.subtype">
            <field name="name">Status Changed</field>
            <field name="res_model">request.product</field>
            <field name="default" eval="True"/>
            <field name="description">The item code Has been created</field>
        </record>
        <record id="item_code_rej_status" model="mail.message.subtype">
            <field name="name">Status Changed</field>
            <field name="res_model">request.product</field>
            <field name="default" eval="True"/>
            <field name="description">The item code Request Has been Rejected</field>
        </record>

        <record id="request_edit_form_view" model="ir.ui.view">
            <field name="name">request.edit.product.form</field>
            <field name="model">edit.product</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="set_confirm" type="object" invisible="state not in ['draft']"
                                class="oe_highlight" groups="base_rida.rida_group_line_manager"/>
<!--                        <button string="Confirm" name="set_approve" type="object"invisible="state not in ['scm']'"-->
<!--                                class="oe_highlight" groups="stock.group_stock_manager"/>-->
                        <button string="Set To Draft" name="set_to_draft" type="object"  invisible="state == 'scm' or state == 'reject'"
                                class="oe_highlight"/>
                        <button string="Update Product" name="create_product" type="object" invisible="state not in ['md']"
                                class="oe_highlight"
                                groups="stock.group_stock_manager,base_rida.rida_group_master_data_manager"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['scm','md']" string="Reject"
                                groups="base_rida.rida_group_master_data_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,md,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                                <field name="image_1920" widget="image" class="oe_avatar"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="prod_id" required="1" readonly="state == 'done'"
                                       options="{'no_create': True, 'no_create_edit':True}"/>
                                <field name="default_code" required="1" readonly="state == 'done'" />
                                <field name="product_name" required="1" readonly="state == 'done'" />
                                <field name="req_id" readonly="1" options="{'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                            </group>
                            <group>
                                <field name="part_number" readonly="state == 'done'" />
                                <field name="categ_id"  readonly="state == 'done'" />
                                <field name="description" readonly="state == 'done'" required="1"/>
                                <field name="date"/>

                            </group>
                        </group>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>

        <record id="item_request_form_view" model="ir.ui.view">
            <field name="name">request.product.form</field>
            <field name="model">request.product</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="set_confirm" type="object" invisible="state not in ['draft']"
                                class="oe_highlight" groups="base_rida.rida_group_line_manager"/>


                                
            

                        <button string="Confirm" name="set_approve" type="object" invisible="state not in ['scm']"
                                class="oe_highlight" groups="stock.group_stock_manager"/>
                        <button string="Set To Draft" name="set_to_draft" type="object" invisible="state not in ['scm','reject']"
                                class="oe_highlight"/>
                        <button string="Create Product" name="create_product" type="object" invisible="state not in ['md']"
                                class="oe_highlight"
                                groups="base_rida.rida_group_master_data_manager"/>
                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['scm','md']" string="Reject"
                                groups="base_rida.rida_group_master_data_manager"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,scm,md,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" name="get_product"
                                    string="Products" type="object" icon="fa-list"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                                <field name="image_1920" widget="image" class="oe_avatar"/>
                            </h1>
                        </div>
                        <group>
                                <field name="type" readonly="state == 'done'"
                                       options="{'no_create': True, 'no_create_edit':True}" required="1"/>
                                <field name="product_name" readonly="state == 'done'"  required="1"/>
                                <!-- <field name="is_storable" readonly="state == 'done'"/> -->
                                <field name="purchase_method" widget="radio"
                                       readonly="state == 'done'" />
                                <field name="part_number" readonly="state == 'done'"
                                       required="False"/>

                                <field name="req_id" readonly="1" options="{'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                         </group>

                        <group>
                            <field name="description" readonly="state == 'done'"  required="1"/>


                        </group>
                        <group>
                        <group>
                                <field name="default_code"
                                       readonly="state not in ['scm','md']" required="state in ['md']"
                                />
                                <field name="uom_id" readonly="state == 'done'"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                                <field name="uom_po_id"
                                    invisible="state == 'draft'"  readonly="state == 'done'"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                                <field name="categ_id" readonly="state == 'done'"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                               </group>
                        <group>

                                <field name="date"/>
                                <field name="prod_id"/>
                                <field name="department_id" readonly="1"/>
                        </group>
                        </group>


                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>


        <record id="master_product_tree_view" model="ir.ui.view">
            <field name="name">master product tree</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <list>
                    <field name="default_code" string="Item Code"/>
                    <field name="name"/>
                    <field name="part_number"/>
                    <field name="description"/>
                    <field name="categ_id"/>
                    <field name="uom_id"/>
                </list>
            </field>
        </record>

        <record id="item_request_form_tree" model="ir.ui.view">
            <field name="name">custody.item.request.tree</field>
            <field name="model">request.product</field>
            <field name="arch" type="xml">
                <list>
                    <field name="req_id"/>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="req_id"/>
                    <field name="prod_id"/>
                    <field name="categ_id"/>
                    <field name="uom_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="item_edit_form_tree" model="ir.ui.view">
            <field name="name">Item Edit Product</field>
            <field name="model">edit.product</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="product_name"/>
                    <field name="default_code"/>
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="item_request_form_search" model="ir.ui.view">
            <field name="name">item.request.search</field>
            <field name="model">request.product</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="item_edit_form_search" model="ir.ui.view">
            <field name="name">Item Edit Product</field>
            <field name="model">edit.product</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="item_request_act_window" model="ir.actions.act_window">
            <field name="name">Item Code Request</field>
            <field name="res_model">request.product</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="item_edit_act_window" model="ir.actions.act_window">
            <field name="name">Edit</field>
            <field name="res_model">edit.product</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem name="Master Data" id="master_data" web_icon="master_data,static/description/icon.png"/>
        <menuitem name="Item Code Request" id="item_request_menu" parent="master_data"                   action="item_request_act_window"

                  groups="base_rida.rida_group_line_manager,stock.group_stock_manager"/>
        <menuitem name="Item Edit Request" id="item_request_e_menu" parent="master_data"
                  action="item_edit_act_window"
                  groups="base_rida.rida_group_line_manager,stock.group_stock_manager,maintenance_fleet_inherit.group_maintenance_supervisor"/>
      

    </data>
</odoo>
