<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="vendor_done_status" model="mail.message.subtype">
            <field name="name">Status Changed</field>
            <field name="res_model">request.vendor</field>
            <field name="default" eval="True"/>
            <field name="description">The Vendor Has been created</field>
        </record>
        <record id="vendor_rej_status" model="mail.message.subtype">
            <field name="name">Status Changed</field>
            <field name="res_model">request.vendor</field>
            <field name="default" eval="True"/>
            <field name="description">The Vendor Has been Rejected</field>
        </record>
        <record id="vendor_request_form_view" model="ir.ui.view">
            <field name="name">request.vendor.form</field>
            <field name="model">request.vendor</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Submit" name="set_submit" type="object" invisible="state not in ['draft']"
                                class="oe_highlight"
                                groups="base_rida.rida_group_supply_chain_manager,material_request.group_contract_manager,material_request.group_buyers,material_request.group_ore_rock_purchase_user"/>


                        <button string="Confirm" name="set_confirm" type="object"
                                invisible="is_rock_vendor or state != 'scm'"
                                class="oe_highlight"
                                groups="base_rida.rida_group_supply_chain_manager,material_request.group_contract_manager"/>
                        <button string="Confirm" name="set_confirm" type="object" invisible="state != 'w_ore_rock'"
                                class="oe_highlight"
                                groups="material_request.group_ore_rock_supply_chain_manager"/>

                        <button string="Create Vendor" name="create_vendor" type="object" invisible="state != 'md'"
                                class="oe_highlight" groups="base_rida.rida_group_master_data_manager"/>
                        <button string="Create Vendor" name="create_vendor" type="object" invisible="state != 'w_scm_director'"
                                class="oe_highlight" groups="base_rida.rida_group_supply_chain_director"/>

                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['w_ore_rock', 'w_scm_director', 'scm', 'md']" string="Reject"
                                groups="base_rida.rida_group_supply_chain_manager,material_request.group_ore_rock_supply_chain_manager,material_request.group_contract_manager"
                        />
                        <field name="state" widget="statusbar" invisible="is_rock_vendor"
                               statusbar_visible="draft,scm,w_scm_director,done"/>
                        <field name="state_rock" widget="statusbar"
                               invisible="not is_rock_vendor"
                               statusbar_visible="draft,w_ore_rock,md,done"/>
                    </header>
                    <sheet>
                             


                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="vendor_name" readonly="state == 'done'"/>
                                <field name="partner" string='Suppiler' readonly="1"
                                  invisible="state != 'done'" />
                                <field name="phone" readonly="state == 'done'"/>
                                <field name="email" readonly="state == 'done'" required="is_rock_vendor == False"/>
                                <field name="lang" options="{'no_create': True, 'no_create_edit':True}"
                                  readonly="state == 'done'" />
                                <field name="req_id"/>
                                <field name="is_rock_vendor" readonly="1"/>
                                
                            </group>
                            <group>
                                <field name="category_id" widget="many2many_tags"
                                       options="{'color_field': 'color', 'no_create_edit': True}"
                                       placeholder="Tags..." readonly="state == 'done'" />
                          <field name="analytic_account_req_id"
                                      readonly="True"/>

                                <field name="description" readonly="state == 'done'" />
                                <field name="date"/>
                                <field name="department_id"/>
                                <field name="east" groups="material_request.group_ore_rock_db_geology_user" readonly="state == 'done'"/>
                                <field name="north" groups="material_request.group_ore_rock_db_geology_user" readonly="state == 'done'"/>
                                <field name="rock_type" groups="material_request.group_ore_rock_db_geology_user" readonly="state == 'done'"/>
                                <field name="rea_ids" groups="material_request.group_ore_rock_db_geology_user" widget="many2many_tags" readonly="state == 'done'"/>
                            </group>
                        </group>
                        <br/>
                        <br/>
                        <notebook>

                        <page string="Bank Accounts" name="banks">
                            <field name="bank_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="bank_id" options="{'no_create': True, 'no_create_edit':True}"/>
                                    <field name="acc_number"/>
                                </tree>
                            </field>
                        </page>
                        </notebook>

                    </sheet>
                        <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="master_vendor_tree_view" model="ir.ui.view">
            <field name="name">master vendor tree</field>
            <field name="model">request.vendor</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="req_id"/>
                    <field name="vendor_name"/>
                    <field name="category_id" widget="many2many_tags"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>


        <record id="vendor_request_form_search" model="ir.ui.view">
            <field name="name">vendor.request.search</field>
            <field name="model">request.vendor</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="vendor_request_act_window" model="ir.actions.act_window">
            <field name="name">Supplier Request</field>
            <field name="res_model">request.vendor</field>
            <field name="view_mode">tree,form</field>
        </record>


        <menuitem name="Supplier" id="vendor_request_menu" parent="master_data"
                  action="vendor_request_act_window"
                  groups="base_rida.rida_group_master_data_manager,base_rida.rida_group_supply_chain_manager,material_request.group_buyers,material_request.group_ore_rock_purchase_user,base_rida.group_warehouse_manager,material_request.group_contract_manager,material_request.group_opu_user,material_request.group_ore_rock_db_geology_user"/>

    </data>
</odoo>
