<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="hr_expense_sheet_view_for_inherit" model="ir.ui.view">
            <field name="name">hr.expense.sheet.view.form.inherit</field>
            <field name="model">hr.expense</field>
            <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/header" position="replace">
                    <header>
                        <button name="action_submit_sheet" string="Submit" type="object"
                                class="oe_highlight o_expense_sheet_submit" invisible="state != 'draft'"/>
                        <button name="action_approve_expense_sheets"
                            string="Approve"
                            type="object"
                            data-hotkey="q"
                            context="{'validate_analytic': True}"
                            invisible="not can_approve or state != 'submit'"
                            class="oe_highlight o_expense_sheet_approve"/>
                        <button name="action_approve_sheets"  invisible="state != 'lm'" string="Approve" type="object"
                                groups="base_rida.rida_group_line_manager"
                                class="oe_highlight o_expense_sheet_approve"/>
                        <button name="action_finance_sheets"   invisible="state != 'finance'" string="Approve" type="object"
                                groups="base_rida.rida_finance_manager" class="oe_highlight o_expense_sheet_approve"/>
                        <button name="action_internal_audit_sheets"   invisible="state != 'internal_audit'" string="Approve"
                                type="object" groups="base_rida.rida_internal_audit"
                                class="oe_highlight o_expense_sheet_approve"/>
                        <button name="action_approve_expense_sheets"  data-hotkey="q"  context="{'validate_analytic': True}" invisible="state != 'site'" string="Approve" type="object"
                                groups="base_rida.rida_group_site_manager"
                                class="oe_highlight o_expense_sheet_approve"/>
                        <button name="action_approve_expense_sheets"  data-hotkey="q"  context="{'validate_analytic': True}"   invisible="state != 'ccso'" string="Approve" type="object"
                                groups="base_rida.rida_group_CCSO" class="oe_highlight o_expense_sheet_approve"/>
<!--                        <button name="action_sheet_move_create"   invisible="state not in ['accountant','approve']"  string="Post Journal Entries"-->
<!--                                type="object" class="oe_highlight o_expense_sheet_post"-->
<!--                                groups="account.group_account_invoice"/>-->
<!--                        <button name="action_register_payment" type="object" class="oe_highlight o_expense_sheet_pay"-->
<!--                                invisible="state != 'post'"-->
<!--                                context="{'dont_redirect_to_payments': True}" string="Register Payment"-->
<!--                                groups="account.group_account_invoice"/>-->
                        <button name="%(hr_expense.hr_expense_refuse_wizard_action)d"
                                invisible="state not in ['submit', 'lm', 'site', 'approve', 'ccso', 'internal_audit', 'finance']"
                                context="{'hr_expense_refuse_model':'hr.expense.sheet'}" string="Refuse" type="action"
                                groups="hr_expense.group_hr_expense_team_approver"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    </header>
                </xpath>
                <xpath expr="//field[@name='employee_id']" position="replace">
                    <field name="employee_id"/>
                    <field name="user_type_" invisible="1"/>
                    <field name="department_id"/>
                </xpath>
<!--                <xpath expr="//field[@name='accounting_date']" position="replace">-->
<!--                    <field name="accounting_date" groups="account.group_account_invoice,account.group_account_readonly"-->
<!--                           invisible="state not in ['finance', 'accountant', 'approve', 'post', 'done']"/>-->
<!--                </xpath>-->
            </field>
        </record>


        <!-- Inherit Form View to Modify it -->
        <record id="hr_expense_view_form_inherit" model="ir.ui.view">
            <field name="name">hr.expense.view.form.inherit</field>
            <field name="model">hr.expense</field>
            <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='employee_id']" position="after">
                    <field name="department_id"/>
                </xpath>

                <xpath expr="//field[@name='analytic_distribution']" position="attributes">
                    <attribute name="readonly">state in ['approved', 'done']</attribute>
                            <attribute name="required">1</attribute>
                </xpath>

                <xpath expr="//field[@name='payment_mode']" position="attributes">
                    <attribute name="readonly">0</attribute>
                </xpath>

            </field>
        </record>


        <record id="hr_expense_vie)form_inherit" model="ir.ui.view">
            <field name="name">hr.expense.view.form.inherit</field>
            <field name="model">hr.expense</field>
            <field name="inherit_id" ref="hr_expense.view_my_expenses_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='analytic_distribution']" position="after">
                    <field name="department_id"/>
                </xpath>
            </field>
        </record>

        <!-- <record id="view_hr_expense_sheet_tree_header_inherit" model="ir.ui.view">
            <field name="name">hr.expense.sheet.form.inherit</field>
            <field name="model">hr.expense.sheet</field>
            <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_dashboard_tree_header"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="department_id"/>
                </xpath>
            </field>
        </record> -->

    </data>
</odoo>
