<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mazaya_form" model="ir.ui.view">
        <field name="name">mazaya.form</field>
        <field name="model">rida.mazaya</field>
        <field name="arch" type="xml">
            <form string="Mazaya">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved"/>
                    <button string="Submit" type="object" groups="hr.group_hr_user" name="submit" invisible="state == 'draft'" class="oe_highlight"/>
                    <button string="Approve" type="object" name="approve" groups="hr.group_hr_manager" invisible="state == 'waiting'" class="oe_highlight"/>
                    <button string="Cancel" type="object" name="reject" groups="hr.group_hr_manager" invisible="state in ('approved', 'cancel')"/>
                    <button string="Set To Draft" type="object" name="set_to_draft" groups="hr.group_hr_user" invisible="state not in ('cancel', 'approved')"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Mazaya Name" readonly="state == 'draft'"/></h1>
                    </div>
                    <group>
                        <label for="start_date" string="Period"/>
                        <div>
                            <field name="start_date" class="oe_inline" readonly="state == 'draft'"/> - <field name="end_date" class="oe_inline" readonly="state == 'draft'"/>
                        </div>
                        <field name="based_on" readonly="state == 'draft'"/>
                        <field name="grades" widget="many2many_tags" invisible="1"/>
                        <field name="company" readonly="state == 'draft'"/>
                        <field name="currency_id" readonly="state == 'draft'"/>
                        <field name="active"  invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Mazaya Type"  >
                            <field name="mazaya_lines" readonly="state == 'draft'">
                                <list editable="bottom">
                                    <field name="month"/>
                                    <field name="cash_allow" />
                                    <field name="dress_allow" />
                                    <field name="midical_allow" />
                                    <field name="grant_allow" />
                                    <field name="new_allow" />
                                    <field name="tax_allow" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="mazaya_tree" model="ir.ui.view">
        <field name="name">mazaya.tree</field>
        <field name="model">rida.mazaya</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="based_on" />
                <field name="start_date" />
                <field name="end_date" />
                <field name="company" />
            </list>
        </field>
    </record>

    <record id="inherited_payslip_mzaya" model="ir.ui.view">
        <field name="name">payslip.mazaya.inhereted</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='struct_id']" position="after">
                <field name="mazaya_id" force_save='1'/>
                <field name="mazaya_tax" force_save='1'/>
                <field name="mazaya_total" force_save='1'/>
            </xpath>
        </field>
    </record>

</odoo>
