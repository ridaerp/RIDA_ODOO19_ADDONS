<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="lab_investigations_forms" model="ir.ui.view">
            <field name="name">Lab Investigations form</field>
            <field name="model">lab.investigations</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>

                            <div class="oe_title">
                                <label for="name" string="Name"/>
                                <h1>
                                    <field name="name" required="True"/>
                                </h1>
                            </div>

                        <group string="Investigations List">
                        </group>
                        <field name="invest_list_ids">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="invest_attributes_ids" widget="many2many_tags"/>
                                <field name="price"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="lab_attributes_forms" model="ir.ui.view">
            <field name="name">Lab attributes form</field>
            <field name="model">investigations.attributes</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="investigations_list_id" readonly="1"/>
                                <field name="price"/>
                            </group>
                            <group>
                                <field name="normal_range"/>
                                <field name="is_selected"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="dieases_category_forms" model="ir.ui.view">
            <field name="name">Dieases Category form</field>
            <field name="model">dieases.category</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name" required="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="dieases_forms" model="ir.ui.view">
            <field name="name">Dieases form</field>
            <field name="model">dieases</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="code"/>
                            </group>
                            <group>
                                <field name="dieases_category_id" options="{'no_create': True,'no_open':True}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="dieases_tree" model="ir.ui.view">
            <field name="name">Dieases Tree</field>
            <field name="model">dieases</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="dieases_category_id"/>
                </list>
            </field>
        </record>

        <record id="lab_attributes_tree" model="ir.ui.view">
            <field name="name">Lab attributes Tree</field>
            <field name="model">investigations.attributes</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="normal_range"/>
                    <field name="is_selected"/>
                </list>
            </field>
        </record>

        <record id="lab_investigations_tree" model="ir.ui.view">
            <field name="name">Lab Investigations Tree</field>
            <field name="model">lab.investigations</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="invest_list_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <record id="lab_investingation_act_window" model="ir.actions.act_window">
            <field name="name">Lab Investigations</field>
            <field name="res_model">lab.investigations</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="lab_attribute_act_window" model="ir.actions.act_window">
            <field name="name">Lab Attribute</field>
            <field name="res_model">investigations.attributes</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'create': 0}</field>
        </record>
        <record id="dieases_categ_conf_act_window" model="ir.actions.act_window">
            <field name="name">Dieases Category</field>
            <field name="res_model">dieases.category</field>
            <field name="view_mode">list,form</field>
        </record>
        <record id="dieases_conf_act_window" model="ir.actions.act_window">
            <field name="name">Dieases</field>
            <field name="res_model">dieases</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Dieases" id="dieases_conf" groups="medicare.group_medicare_doctor" sequence="1"
                  parent="medicare.medicare_menu_conf"/>
        <menuitem name="Lab" id="lab_conf" groups="medicare.group_medicare_lab_special" sequence="2"
                  parent="medicare.medicare_menu_conf"/>
        <menuitem name="Lab Investigations" groups="medicare.group_medicare_lab_special" id="lab_invest_conf"
                  sequence="2" action="lab_investingation_act_window"
                  parent="lab_conf"/>
        <menuitem name="Lab Attributes" groups="medicare.group_medicare_lab_special" id="lab_attribute_conf"
                  sequence="1" action="lab_attribute_act_window"
                  parent="lab_conf"/>
        <menuitem name="Dieases Category" groups="medicare.group_medicare_doctor" id="dieases_categ_conf"
                  sequence="2" action="dieases_categ_conf_act_window"
                  parent="dieases_conf"/>
        <menuitem name="Dieases" groups="medicare.group_medicare_doctor" id="dieases_med_conf"
                  sequence="1" action="dieases_conf_act_window"
                  parent="dieases_conf"/>

    </data>
</odoo>