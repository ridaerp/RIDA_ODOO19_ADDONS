<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record model="ir.module.category" id="medicare_medicare">
            <field name="name">Medicare</field>
        </record>
        <record id="group_medicare_medicare" model="res.groups">
            <field name="name">Medicare</field>
            <field name="category_id" ref="medicare_medicare"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_medicare_minor" model="res.groups">
            <field name="name">Nurse</field>
            <field name="category_id" ref="medicare_medicare"/>
            <field name="implied_ids" eval="[(4, ref('group_medicare_medicare'))]"/>
        </record>
        <record id="group_medicare_pharmacy" model="res.groups">
            <field name="name">Pharmacist</field>
            <field name="category_id" ref="medicare_medicare"/>
            <field name="implied_ids" eval="[(4, ref('group_medicare_medicare'))]"/>
        </record>
        <record id="group_medicare_lab_special" model="res.groups">
            <field name="name">MED-LAB Technician</field>
            <field name="category_id" ref="medicare_medicare"/>
            <field name="implied_ids" eval="[(4, ref('group_medicare_medicare'))]"/>
        </record>
        <!-- last -->
        <record id="group_medicare_doctor" model="res.groups">
            <field name="name">Physician</field>
            <field name="implied_ids" eval="[(4, ref('group_medicare_medicare'))]"/>
            <field name="category_id" ref="medicare_medicare"/>
        </record>

    </data>
</odoo>
