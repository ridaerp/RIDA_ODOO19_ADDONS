<odoo>
    <data>


        <record model="ir.ui.view" id="view_air_request_tree">
            <field name="name">air.request.tree</field>
            <field name="model">air.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name_seq"/>
                    <!-- ekhlas code -->
                    <field name="date_request"/>

                    <field name="requested_by"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <!-- ekhlas code -->
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="view_air_request_form" model="ir.ui.view">
            <field name="name">Air Booking Request</field>
            <field name="model">air.request</field>
            <field name="arch" type="xml">
                <form string="Air Booking Request">
                    <header>

                        <!--                    Set to Draft-->
                        <button name="button_draft" invisible="state not in ['cancel','reject']" string="Set as Draft"
                                type="object"/>

                        <!--                    MR User-->
                        <button name="button_to_department_manger" invisible="state != 'draft'" string="Submit"
                                type="object" class="oe_highlight" groups="base.group_user"/>

                        <button name="button_cancel" invisible="state != 'draft'" string="Cancel" type="object"
                                groups="base.group_user" class=""/>


                        <!--                    Line Manager-->
                        <button name="button_to_line_manager" string="Approve" type="object"
                                invisible="state != 'line_approve'" groups="base_rida.rida_group_line_manager"
                                class="oe_highlight"/>


                        <button name="button_to_Adm_man" string="Approve" type="object"
                                invisible="state != 'Adm_man_approve'" class="oe_highlight"/>


                        <button name="button_to_c_level_approval" string="Approve" type="object"
                                invisible="state != 'c-level_approval'" class="oe_highlight"
                                groups="base_rida.group_c_level"/>

                        <button name="button_lm_reject" type="object" invisible="state != 'line_approve'"
                                groups="base_rida.rida_group_line_manager" string="Reject"/>


                        <button name="button_Adm_man_reject" type="object" invisible="state != 'Adm_man_approve'"
                                string="Reject"/>

                        <button name="button_cancel" invisible="state != 'done'" string="Cancel" type="object"
                                confirm="You are about to cancel this request and its related records. Please confirm!"/>
                        class=""/>

                        <field name="state" widget="statusbar" tatusbar_visible="draft,done"
                               statusbar_colors='{"manager_approved":"blue"}'/>


                    </header>


                    <br/>
                    <b>
                        <p align="center">Doc. No. RMC-ADM-QP-ADM/23
                            -
                            Issue/Rev 03/01
                        </p>
                    </b>

                    <sheet>


                        <h1 class="oe_title">
                            <field name="name_seq" readonly="1" class="oe_inline"/>
                        </h1>


                        <group>

                            <group>
                                <field name="date_request" readonly="state != 'draft'"/>


                                <field name="travel_details" widget="radio" readonly="state != 'draft'"/>


                                <field name="travel_date" readonly="state != 'draft'"/>
                                <field name="return_date" readonly="state != 'draft'"/>

                                <field name="destination_from" readonly="state != 'draft'"/>
                                <field name="destination_to" readonly="state != 'draft'"/>


                            </group>


                            <group>

                                <field name="requested_by" readonly="state != 'draft'"/>

                                <field name="department_id"/>

                                <field name="job_id"/>

                                <field name="company_id" readonly="state != 'draft'"/>

                                <!--              <field name="employee_no"  readonly="1"/>-->

                                <field name="duty_station" readonly="state != 'draft'"/>
                            </group>


                        </group>


                        <group>


                            <!-- </div> -->
                        </group>


                        <h3>Amendment</h3>
                        <group colspan="4" col="4">

                            <field name="travel_for_amended_date" readonly="state != 'draft'"/>
                            <field name="travel_amended_date" readonly="state != 'draft'"/>


                        </group>


                        <group>


                            <field name="request_received_date" readonly="state != 'Adm_man_approve'"/>

                            <field name="itinerary" readonly="state != 'Adm_man_approve'"/>

                            <field name="itinerary_date" readonly="state != 'Adm_man_approve'"/>

                            <field name="admin_comment" readonly="state != 'Adm_man_approve'"/>


                        </group>


                    </sheet>
                    <chatter/>
                </form>


            </field>
        </record>


        <!-- actions opening views on models -->

        <record model="ir.actions.act_window" id="rida_forms.air_request">
            <field name="name">Air Booking Request</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">air.request</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem name="Air Booking Request / Amendment" id="rida_forms.menu_11_list"  sequence="2"  parent="rida_forms.gs_admin_form"
              action="rida_forms.air_request"/>


    </data>
</odoo>