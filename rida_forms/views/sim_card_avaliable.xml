<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View for sim.card.available -->
        <record id="sim_card_available_form_view" model="ir.ui.view">
            <field name="name">sim.card.available.form</field>
            <field name="model">sim.card.available</field>
            <field name="arch" type="xml">
                <form string="Available SIM Card">
                    <header>
                        <button name="action_assign" type="object" string="Assign to Employee" class="oe_highlight"
                                invisible="state != 'inactive'"/>
                        <button name="action_mark_blocked" type="object" string="Mark Blocked"
                                invisible="state != 'inactive'"/>
                        <button name="action_mark_lost" type="object" string="Mark Lost"
                                invisible="state != 'inactive'"/>
                        <button name="action_mark_stolen" type="object" string="Mark Stolen"
                                invisible="state != 'inactive'"/>
                        <button name="action_mark_inactive" type="object" string="Mark Inactive"
                                invisible="state not in ['blocked','lost','stolen']"/>

                        <field name="state" widget="statusbar"
                               statusbar_visible="inactive,assigned,blocked,lost,stolen"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" text="Assigned" bg_color="text-bg-success"
                                invisible="state != 'assigned'"/>
                        <widget name="web_ribbon" text="Not Avaliable" bg_color="text-bg-danger"
                                invisible="state not in ['blocked','lost','stolen']"/>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_sim_card_history" type="object" class="oe_stat_button"
                                    icon="fa-sim-card">
                                <field name="sim_card_count" widget="statinfo" string="SIM Cards History"/>
                            </button>
                        </div>
                        <group>
                            <field name="mobile_number"/>
                            <field name="employee_id"/>
                            <field name="emp_type" />
                            <field name="guest_name" invisible="emp_type == False"/>
                            <field name="name"/>
                            <field name="carrier_id" required="1"/>
                            <field name="sim_type_id" required="1"/>
                            <field name="pin"/>
                            <field name="puk"/>
                            <field name="notes"/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Tree View for sim.card.available -->
        <record id="sim_card_available_tree_view" model="ir.ui.view">
            <field name="name">sim.card.available.tree</field>
            <field name="model">sim.card.available</field>
            <field name="arch" type="xml">
                <tree string="SIM Cards" decoration-success="state == 'assigned'"
                      decoration-danger="state in ['blocked','lost','stolen']"
                      decoration-muted="state == 'inactive'" decoration-bf="state">
                    <field name="mobile_number"/>
                    <field name="name"/>
                   <field name="employee_id"/>

                    <field name="carrier_id"/>
                    <field name="sim_type_id"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Search View for sim.card.available -->
        <record id="sim_card_available_search_view" model="ir.ui.view">
            <field name="name">sim.card.available.search</field>
            <field name="model">sim.card.available</field>
            <field name="arch" type="xml">
                <search string="Search SIM Cards">
                    <field name="employee_id"/>
                    <field name="mobile_number"/>
                    <field name="name"/>
                    <field name="sim_type_id"/>
                    <filter string="employee_id" name="Employee"/>

                    <filter string="Inactive" name="inactive" domain="[('state', '=', 'inactive')]"/>
                    <filter string="Assigned" name="assigned" domain="[('state', '=', 'assigned')]"/>
                    <filter string="Blocked" name="blocked" domain="[('state', '=', 'blocked')]"/>
                    <filter string="Lost" name="lost" domain="[('state', '=', 'lost')]"/>
                    <filter string="Stolen" name="stolen" domain="[('state', '=', 'stolen')]"/>
                </search>
            </field>
        </record>

        <!-- Action for sim.card.available -->
        <record id="sim_card_available_action" model="ir.actions.act_window">
            <field name="name">SIM Cards</field>
            <field name="res_model">sim.card.available</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new available SIM card!
                </p>
                <p>
                    Manage SIM cards before assignment.
                </p>
            </field>
        </record>

        <!-- Menu Item for  SIM Cards -->
        <menuitem id="sim_card_available_menu" name="SIM Cards" parent="rida_forms.sim_card_menu_root"
                  action="sim_card_available_action" sequence="10"/>
    </data>
</odoo>