<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_visit_request_tree">
            <field name="name">visit.request.tree</field>
            <field name="model">visit.request</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name_seq"/>
                    <field name="date_request"/>
                    <field name="requested_by"/>
                    <field name="department_id"/>
                    <field name="employee_id"/>
                    <field name="company_id"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_visit_request_form" model="ir.ui.view">
            <field name="name">Visit Request</field>
            <field name="model">visit.request</field>
            <field name="arch" type="xml">
                <form string="Visit Request">
                    <header>
                        <button name="action_submit" string="Submit" type="object"
                                class="oe_highlight" groups="base.group_user"
                                invisible="state != 'draft'"/>
                        <button name="action_dep_approve" string="Approve" type="object"
                                class="oe_highlight" invisible="state != 'dep_approve'"
                                groups="base_rida.rida_group_line_manager"/>

                        <button name="action_hr_approve" string="Approve" type="object"
                                class="oe_highlight"
                                groups="base_rida.rida_hr_manager_notify"
                                invisible="state != 'hr_approve'"/>

                        <button name="action_site_manager_approve" string="Approve" type="object"
                                class="oe_highlight"
                                groups="base_rida.rida_group_COO,base_rida.rida_group_site_manager"
                                invisible="state != 'c_level_approval'"/>

                        <button name="action_done" string="approve" type="object"
                                class="oe_highlight" invisible="state != 'adm_man_approve'"
                                groups="maintenance_fleet_inherit.group_admin_user"/>


                        <button name="action_cancel" string="Cancel" type="object"
                                invisible="state not in ['approve','adm_man_approve']"
                                confirm="You are about to cancel this request. Confirm?"/>
                        <button name="%(material_request.purchase_order_reject_action)d"
                                type="action"
                                string="Reject"
                                invisible="state not in ['dep_approve','hr_approve', 'c_level_approval', 'adm_man_approve']"
                                groups="base_rida.rida_hr_manager_notify, base_rida.rida_group_COO"/>

                        <button name="action_draft" string="Set To Draft" type="object"
                                class="oe_highlight" groups="maintenance_fleet_inherit.group_admin_user"
                                invisible="state != 'reject'"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,hr_approve,c_level_approval,adm_man_approve,approve"/>
                    </header>
                    <sheet>
                        <h1><field name="name_seq" readonly="1"/></h1>
                        <group>
                            <group>

                                
                                <field name="date_request" readonly="1"/>

                             <field name="ugrently" readonly="state != 'draft'"/>

                                <field name="date_from" readonly="state != 'draft'"/>
                                <field name="date_to" readonly="state != 'draft'"/>
                                <field name="num_of_days" readonly="state != 'draft'"/>
                                <field name="purpose" readonly="state != 'draft'"/>
                                <field name="visit_type" readonly="state != 'draft'"/>
                                <field name="activity" readonly="state != 'draft'"/>
                                    <field name="other" invisible="activity != 'other'"/>

                                <field name="analytic_account_id" readonly="state != 'draft'"/>

                            </group>
                            <group>
                                <field name="requested_by" readonly="1"/>
                                <field name="employee_id" readonly="state != 'draft'"/>
                                <field name="department_id" readonly="1"/>
                                <field name="job_id" readonly="1"/>
                                <field name="company_id" readonly="1"/>
                                <field name="department_involved" readonly="state != 'draft'" widget="many2many_tags"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Visit Lines">
                                <field name="visit_line_ids" readonly="state != 'draft'">
                                    <tree editable="bottom">
                                        <field name="visit_name"/>
                                        <field name="job"/>
                                        <field name="degree"/>
                                        <field name="disease"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View for Visit Request -->
        <record model="ir.ui.view" id="view_visit_request_search">
            <field name="name">visit.request.search</field>
            <field name="model">visit.request</field>
            <field name="arch" type="xml">
                <search string="Search Visit Requests">
                    <!-- Search fields -->
                    <field name="name_seq" string="Reference"/>
                    <field name="requested_by" string="Requested By"/>
                    <field name="employee_id" string="Employee"/>
                    <field name="department_id" string="Department"/>
                    <field name="company_id" string="Company"/>
                    <field name="purpose" string="Purpose"/>
                    <field name="visit_type" string="Visit Type"/>
                    <field name="activity" string="Activity"/>
                    
                    <!-- Group By options -->
                    <group expand="0" string="Group By">
                        <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                        <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
                        <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
                        <filter string="Visit Type" name="group_by_visit_type" context="{'group_by': 'visit_type'}"/>
                        <filter string="Requested By" name="group_by_requested_by" context="{'group_by': 'requested_by'}"/>
                        <filter string="Date Request" name="group_by_date_request" context="{'group_by': 'date_request:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="visit_request_action">
          <field name="name">Visit Request</field>
          <field name="type">ir.actions.act_window</field>
          <field name="res_model">visit.request</field>
          <field name="view_mode">tree,form,search</field>
        </record>

        <menuitem name="Site Visit Request" id="visit_request_menu"
        parent="rida_forms.form_document_admin" action="visit_request_action"
            sequence="4"/>
    </data>
</odoo>
