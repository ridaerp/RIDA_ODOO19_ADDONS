<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_stationary_request_tree">
            <field name="name">stationary.request.tree</field>
            <field name="model">stationary.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name_seq"/>
                    <field name="date_request"/>
                    <field name="requested_by"/>
                    <field name="department_id"/>
                    <field name="employee_id"/>
                    <field name="company_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_stationary_request_form" model="ir.ui.view">
            <field name="name">stationary.request.form</field>
            <field name="model">stationary.request</field>
            <field name="arch" type="xml">
                <form string="Stationary Request">
                    <header>
                        <button name="action_submit" string="Submit" type="object"
                                class="oe_highlight" groups="base.group_user"
                                invisible="state != 'draft'"/>

                        <button name="action_close" string="Approve" type="object"
                                class="oe_highlight" invisible="state != 'adm_man_approve'"
                                groups="maintenance_fleet_inherit.group_admin_user"/>

                        <button name="action_cancel" string="Cancel" type="object"
                                invisible="state not in ['draft','adm_man_approve']"
                                confirm="You are about to cancel this request. Confirm?"/>
                        <button name="%(material_request.purchase_order_reject_action)d"
                                type="action"
                                string="Reject"
                                invisible="state not in ['adm_man_approve']"
                                groups="base_rida.rida_hr_manager_notify"/>

                        <button name="action_draft" string="Set To Draft" type="object"
                                class="oe_highlight" groups="maintenance_fleet_inherit.group_admin_user"
                                invisible="state != 'reject'"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,adm_man_approve,close"/>
                    </header>
                    <sheet>
                        <h1><field name="name_seq" readonly="1"/></h1>
                        <group>
                            <group>
                                <field name="date_request" readonly="1"/>
                                <field name="requested_by" readonly="1"/>
                            </group>
                            <group>
                                <field name="employee_id" readonly="state != 'draft'"/>
                                <field name="department_id" readonly="state != 'draft'"/>
                                <field name="job_id" readonly="state != 'draft'"/>
                                <field name="company_id" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Stationary Lines">
                                <field name="stationary_line_ids">
                                    <list editable="bottom">
                                        <field name="product_id" required="1"/>
                                        <field name="qty_req" required="1"/>
                                        <field name="qty_rec" readonly="parent.state not in ('adm_man_approve')"/>
                                        <field name="remark" readonly="parent.state not in ('adm_man_approve')"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Search View for Visit Request -->
        <record model="ir.ui.view" id="view_stationary_request_search">
            <field name="name">stationary.request.search</field>
            <field name="model">stationary.request</field>
            <field name="arch" type="xml">
                <search string="Search Stationary Requests">
                    <!-- Search fields -->
                    <field name="name_seq" string="Reference"/>
                    <field name="requested_by" string="Requested By"/>
                    <field name="employee_id" string="Employee"/>
                    <field name="department_id" string="Department"/>
                    <field name="company_id" string="Company"/>

                    <!-- Group By options -->
                        <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                        <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
                        <filter string="Company" name="group_by_company" context="{'group_by': 'company_id'}"/>
                        <filter string="Requested By" name="group_by_requested_by" context="{'group_by': 'requested_by'}"/>
                        <filter string="Date Request" name="group_by_date_request" context="{'group_by': 'date_request:month'}"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="stationary_request_action">
          <field name="name">Stationary Request</field>
          <field name="type">ir.actions.act_window</field>
          <field name="res_model">stationary.request</field>
          <field name="view_mode">list,form</field>
        </record>

        <menuitem name="Stationary Request" id="stationary_request_menu"
        parent="rida_forms.form_document_admin" action="stationary_request_action"
            sequence="5"/>
    </data>
</odoo>
