<odoo>
  <data>



<record model="ir.ui.view" id="view_vehicle_request_tree">
            <field name="name">vehicle.request.tree</field>
            <field name="model">vehicle.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name_seq" />
                    <!-- ekhlas code -->
                    <field name="date_request" />
                    <field name="started_from" />
                    <field name="to" />
                    <field name="requested_by" />
                    <field name="department_id" />
                    <field name="state" />
                </list>
            </field>
        </record>


<record id="view_vehicle_request_form" model="ir.ui.view">
            <field name="name">Vehicle/ Equipment Request</field>
            <field name="model">vehicle.request</field>
            <field name="arch" type="xml">
            <form string="Vehicle/ Equipment Request">
                    <header>
                        
                   <!--                    Set to Draft-->
                        <button name="button_draft" states="cancel,reject" string="Set as Draft" type="object" />

                        <!--                    MR User-->
                        <button name="button_to_officer" states="draft" string="Submit" type="object" class="oe_highlight" groups="base.group_user"/>

                        <button name="button_cancel" states="draft" string="Cancel" type="object" groups="base.group_user" class="" />

<!--                    Line Manager-->
                        <button name="button_to_operation_officer" string="Approve" type="object" states="operation_officer_approve"  class="oe_highlight" />


                      


                        <button name="button_to_movement_manager" string="Approve" type="object" states="movement_manager_approve"  class="oe_highlight" />


                        <button name="%(rida_forms.order_reject_action)d" string="Reject" states="operation_officer_approve"  type="action" />

                        <button name="%(rida_forms.order_reject_action)d" string="Reject" states="movement_manager_approve" type="action" />

                        <button name="button_cancel" state="done" string="Cancel" type="object"
                                confirm="You are about to cancel this request and its related records. Please confirm!" attrs="{'invisible': [('state','!=','done')]}"
                                class=""/>

                        <field name="state" widget="statusbar" tatusbar_visible="draft,done" statusbar_colors='{"manager_approved":"blue"}'/>


                    </header>


                  
<br /> 
    <!-- <b><p align="center">Doc. No. UMC-ADM-QP-ADM/15  
-            
Issue/Rev 02/00</p></b> -->

    <sheet>



                    <h1 class="oe_title">
                        <field name="name_seq" readonly="1" class="oe_inline"/>
                    </h1>
                    
                    



<!-- <div class="oe_edit_only"> -->
                                      
                        

            <!-- <group colspan="4" col="4"> -->
            <group>            

            <group>
                <field name="date_request" attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                <field name="equipment_id" attrs="{'readonly': [('state', '!=', 'operation_officer_approve')], 'required': [('state','=','operation_officer_approve')]}"/>

                <field name="equipment_code"/>

                <field name="category_id"  attrs="{'readonly': [('state', 'not in',['draft','operation_officer_approve'])]}"/>





                


                <field name="started_from" attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                <field name="to" attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                <field name="purpose" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                
                 <field name="capacity" attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                <field name="priority" widget="priority" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                <field name="period" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                
                
            </group>





            <group>
               
             <field name="requested_by" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
               
             <field name="department_id"/>

             <field name="location" attrs="{'readonly': [('state', '!=', 'draft')]}"/>


              
            </group>
        </group>



                     <group >
                    </group>

        <group>
         <group>

             <field name="movement_receiving_request_time" attrs="{'readonly': [('state', '!=', 'operation_officer_approve')], 'required': [('state','=','operation_officer_approve')]}"/>


             <field name="operator_driver_name" attrs="{'readonly': [('state', '!=', 'operation_officer_approve')], 'required': [('state','=','operation_officer_approve')]}"/>

             <field name="movement_delivery_time" attrs="{'readonly': [('state', '!=', 'operation_officer_approve')], 'required': [('state','=','operation_officer_approve')]}"/>

  
</group>

<group>
</group>



</group>
              

              </sheet>
                <chatter/>
           </form>





                        
            
            </field>
          </record>




    <!-- actions opening views on models -->

    <record model="ir.actions.act_window" id="rida_forms.vehicle_request">
      <field name="name">Vehicle/ Equipment Request</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">vehicle.request</field>
      <field name="view_mode">list,form</field>
    </record>







<menuitem name="Request Forms" id="rida_forms.menu_root"
        web_icon="rida_forms,static/description/icon.png"
            sequence="0"/>




  </data>
</odoo>