<odoo>
    <data>
        <record id="exit_vehicle_form" model="ir.ui.view">
            <field name="name">exit.vehicle.form</field>
            <field name="model">exit.vehicle</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_submit" type="object" string="Submit to Security" class="btn-primary"
                                invisible="state != 'draft'"/>

                        <button name="action_approve_by_security" type="object" string="Confirm Vehicle Exit/Entry"
                                class="btn-success" invisible="state != 'security_approve'"
                                groups="rida_forms.group_security_personnel"/>

                        <button name="action_draft" type="object" string="Reset to Draft"
                                invisible="state not in ['reject']"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,security_approve,approved"/>
                    </header>
                    <sheet>
                        <div class="alert alert-warning" role="alert" style="margin-bottom: 20px;">
                            <h4 style="margin-top: 0; color: #856404;">⚠️ ضوابط أساسية:</h4>
                            <ul style="margin-bottom: 0;">
                                <li><strong>القيادة بإهمال:</strong> قد تؤدي للفصل من العمل.</li>
                                <li><strong>السرعة المسموحة:</strong> 40 كلم داخل الموقع، 70 كلم خارج الموقع.</li>
                                <li><strong>جاهزية العربة:</strong> يرجى مراجعة العربة والتأكد من جاهزيتها قبل التحرك.</li>
                            </ul>
                        </div>

                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="Requester Info">
                                <field name="req_id" readonly="1" options="{'no_open': True}"/>
                                <field name="department_id" readonly="1" force_save="1"/>
                                <field name="date" readonly="1"/>
                            </group>
                            <group string="Vehicle &amp; Driver">
                                <field name="drive_name" readonly="state != 'draft'" required="1"/>
                                <field name="vehicle_num" readonly="state != 'draft'" required="1"/>
                                <field name="destination" readonly="state != 'draft'" required="1"/>
                            </group>
                        </group>
                        <group string="Trip Details">
                            <field name="reason_for_exit" readonly="state != 'draft'" placeholder="Reason For Leaving/Entering..."/>
                            <field name="items" readonly="state != 'draft'" placeholder="Tools, materials, etc..."/>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="exit_vehicle_tree" model="ir.ui.view">
            <field name="name">exit.vehicle.tree</field>
            <field name="model">exit.vehicle</field>
            <field name="arch" type="xml">
                <tree decoration-info="state == 'draft'" decoration-success="state == 'approved'" decoration-danger="state == 'reject'">
                    <field name="name"/>
                    <field name="drive_name"/>
                    <field name="vehicle_num"/>
                    <field name="destination"/>
                    <field name="req_id"/>
                    <field name="date"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'approved'"/>
                </tree>
            </field>
        </record>

        <record id="exit_vehicle_search" model="ir.ui.view">
            <field name="name">exit.vehicle.search</field>
            <field name="model">exit.vehicle</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="drive_name"/>
                    <field name="vehicle_num"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_by_dept" string="Department" context="{'group_by': 'department_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="exit_vehicle_action" model="ir.actions.act_window">
            <field name="name">Entering / EXIT Vehicle Permissions</field>
            <field name="res_model">exit.vehicle</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="exit_vehicle_main_menu" name="Vehicle Entering / EXIT PERMISSION" parent="exit_permission_root" action="exit_vehicle_action"
                  groups="rida_forms.group_security_personnel,maintenance_fleet_inherit.group_operation_fleet_user,stock.group_stock_user" sequence="4"/>
    </data>
</odoo>