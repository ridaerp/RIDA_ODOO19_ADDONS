<record model="ir.ui.view" id="view_material_request_tree">
            <field name="name">material.request.tree</field>
            <field name="model">ict.device.request</field>
            <field name="arch" type="xml">
                <tree>
                    <!-- <field name="message_needaction" invisible="1" /> -->
                    <field name="name_seq" />
                    <field name="name" />
                    <!-- ekhlas code -->
                     <!-- <field name="title" /> -->
                    <field name="date_request" />

                    <!-- <field name="item_type" /> -->
                    <field name="employee_id" />
                    <field name="department_id" />
                    <!-- ekhlas code -->
                    <!-- <field name="assigned_to_supply" />
                    <field name="assigned_date" />
                    

                    <field name="priority" /> -->
                    <field name="state" />
                    <!-- <field name="amount_total" /> -->
                    <field name="company_id" />
                </tree>
            </field>
        </record>




        <record model="ir.ui.view" id="view_ict_service_tree">
            <field name="name">ict.service.tree</field>
            <field name="model">ict.service</field>
            <field name="arch" type="xml">
                <tree>


                    <field name="name" />
                    <field name="description" />
                    
                </tree>
            </field>
        </record>



        <record model="ir.ui.view" id="view_ict_service_tree">
            <field name="name">emplate.service</field>
            <field name="model">ict.template.service</field>
            <field name="arch" type="xml">
                <tree>


                    <field name="service_id" />
                    <field name="name" />
                    
                </tree>
            </field>
        </record>





<record id="view_material_request_form" model="ir.ui.view">
            <field name="name">Material Request</field>
            <field name="model">ict.device.request</field>
            <field name="arch" type="xml">
            <form string="Material Request">
                    <header>
                        
                   <!--                    Set to Draft-->
                        <button name="button_draft" states="cancel,reject" string="Set as Draft" type="object" />

                        <!--                    MR User-->
                        <button name="button_to_department_manger" states="draft" string="Submit" type="object" class="oe_highlight" groups="base.group_user"/>

                        <button name="button_cancel" states="draft" string="Cancel" type="object" groups="base.group_user" class="" />




<!--                    Line Manager-->
                        <button name="button_to_line_manager" string="Approve" type="object" states="line_approve" groups="base_rida.rida_group_line_manager" class="oe_highlight" />


                        <button name="button_to_ict_HOD" string="Approve" type="object" states="ict_HOD_approve" groups="base_rida.group_department_ict_hod_manager" class="oe_highlight" />


                        <button name="%(rida_forms.order_reject_action)d" string="Reject" states="line_approve" groups="base_rida.rida_group_line_manager" type="action" />


                        <button name="%(rida_forms.order_reject_action)d" string="Reject" states="ict_HOD_approve" groups="base_rida.group_department_ict_hod_manager" type="action" />




                        <field name="state" widget="statusbar" tatusbar_visible="draft,done" statusbar_colors='{"manager_approved":"blue"}'/>


                    </header>


                  <br /> 
    <b><p align="center">Doc. No. UMC-IT-QP-USP/01  
-            
Issue/Rev 02/00</p></b>



    <sheet>



                    <h1 class="oe_title">
                        <field name="name_seq" readonly="1" class="oe_inline"/>
                    </h1>
                    
                    




        









        <group>

            
            <group>
             <!-- <field name="name"/> -->
             <field name="requested_by" groups="base_rida.group_department_ict_hod_manager" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
             <field name="department_id"/>
             <field name="job_id"/>
             <field name="company_id"/>
             <field name="email"/>
             <field name="phone"/>



         </group>
    
    <group>
       <field name="date_request" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
       <field name="service_ids" widget="one2many_list" attrs="{'readonly': [('state', '!=', 'draft')]}" required="1">
                <tree editable="bottom">
                <field name="ict_service_id" required="1"/>
                <field name="service_type_id"  domain="[('service_id','=',ict_service_id)]"/>
                </tree>
            </field>
            



       

</group>
</group>



<group>

              


                

                
          

</group>


<group>


     <group>

         <field name="requirements"/>
             <field name="relocation_from"/>
             <field name="relocation_to"/>
             
        </group>



         <group>

        </group>
             
             
             </group>





              

              </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
           </form>





                        
            
            </field>
          </record>




