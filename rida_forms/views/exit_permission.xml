<odoo>
    <data>

        <record id="exit_permission_form" model="ir.ui.view">
            <field name="name">Exit Permission Form</field>
            <field name="model">exit.permission</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_submit" type="object" string="Submit" class="btn-primary"
                                invisible="state != 'draft'"/>

                        <button name="action_approve_by_manager" type="object" string="Approve"
                                class="btn-primary" invisible="state != 'wlm_approve'"/>

                        <button name="action_approve_by_hr" type="object" string="Verify" class="btn-primary"
                                invisible="state != 'w_hr_off'" groups="hr.group_hr_user"
                        />

                        <button name="action_approve_by_security" type="object" string="Confirm"
                                invisible="state != 'security_approve'" groups="rida_forms.group_security_admin"
                                class="btn-success"/>


                        <button name="%(material_request.purchase_order_reject_action)d" type="action"
                                invisible="state not in ['wlm_approve', 'w_hr_off', 'security_approve']"
                                string="Reject"
                        />
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,wlm_approve,w_hr_off,security_approve,approved"/>
                    </header>
                    <sheet>

                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="req_id" readonly="1"/>
                                <field name="department_id" readonly="state not in ['draft','wlm_approve']"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                       required="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="company_id"
                                       required="1" readonly="state not in ['draft','wlm_approve']"
                                       options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                />
                            </group>
                        </group>
                        <group>
                            <group string="Exit Info">
                                <field name="exit_date" readonly="state not in ['draft','wlm_approve']" required="1"/>
                                <field name="exit_time" widget="float_time"
                                       readonly="state not in ['draft','wlm_approve']" required="1"/>
                                <field name="reason_for_exit" readonly="state not in ['draft','wlm_approve']"
                                       required="1"/>
                            </group>
                            <group string="Return Info">
                                <field name="return_date" readonly="state not in ['draft','wlm_approve']"/>
                                <field name="return_time" widget="float_time"
                                       readonly="state not in ['draft','wlm_approve']"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Employees">
                                <field name="employees_line_ids" nolabel="1"
                                       readonly="state not in ['draft','wlm_approve']" required="1">
                                    <list string="Employees" editable="bottom">
                                        <field name="employee_id"
                                               domain="['|',('department_id.parent_id', '=',parent.department_id),'|',('department_id.parent_id.parent_id', '=',parent.department_id),('department_id', '=',parent.department_id),('company_id', '=',parent.company_id)]"
                                               readonly="not parent.department_id"
                                               options="{'no_open':True,'no_create': True, 'no_create_edit':True}"
                                               required="1"/>
                                        <field name="job_id" readonly="1"/>
                                    </list>
                                </field>

                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="exit_permission_tree" model="ir.ui.view">
            <field name="name">Exit Permission Tree</field>
            <field name="model">exit.permission</field>
            <field name="arch" type="xml">
                <list decoration-success="state == 'approved'" decoration-bf="state == 'approved'">
                    <field name="name"/>
                    <field name="req_id"/>
                    <field name="exit_date"/>
                    <field name="exit_time"/>
                    <field name="destination"/>
                    <field name="approved_employees_ids" widget="many2many_tags"/>
                    <field name="date"/>
                    <field name="department_id"/>
                    <field name="company_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>


        <record id="action_exit_permission_security" model="ir.actions.act_window">
            <field name="name">Exit Permissions - Today</field>
            <field name="res_model">exit.permission</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state','=','approved')]</field>
            <field name="context">{'search_default_today_request':1,'edit': 0,'create': 0}</field>
        </record>


        <record id="exit_permission_action" model="ir.actions.act_window">
            <field name="name">Exit Permission Form</field>
            <field name="res_model">exit.permission</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="exit_permission_search" model="ir.ui.view">
            <field name="name">Exit Permission Search</field>
            <field name="model">exit.permission</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="req_id"/>
                    <filter name="today_request" string="Today Exit Permission"
                            domain="[('exit_date', '=', context_today())]"/>
                    <filter name="by_state" string="By State" domain="[]" context="{'group_by':'state'}"/>
                    <filter name="department_id" string="By Department" domain="[]"
                            context="{'group_by':'department_id'}"/>
                    <filter name="by_company" string="By Company" context="{'group_by':'company_id'}"/>
                </search>
            </field>
        </record>

        <menuitem name="Exit Permission" id="exit_permission_root"
        />
        <menuitem name="Exit Permission" id="exit_permission" parent="exit_permission_root"
                  action="exit_permission_action"/>
        <menuitem id="menu_exit_permission_security"
                  name="Security Personnel Screen"
                  parent="exit_permission_root" groups="rida_forms.group_security_personnel"
                  action="action_exit_permission_security"/>
    </data>
</odoo>