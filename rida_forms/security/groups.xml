    <record id="group_security_personnel" model="res.groups">
        <field name="name">Security Personnel</field>
    </record>

    <record id="group_security_admin" model="res.groups">
        <field name="name">Security Admin</field>
        <field name="implied_ids" eval="[(4, ref('group_security_personnel'))]"/>
    </record>

    <record id="access_exit_permission_security" model="ir.model.access">
        <field name="name">exit.permission read only security</field>
        <field name="model_id" ref="rida_forms.model_exit_permission"/>
        <field name="group_id" ref="rida_forms.group_security_personnel"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="visit_request_rule_read_done" model="ir.rule">
        <field name="name">Read Done Visit Requests Only</field>
        <field name="model_id" ref="model_visit_request"/>
        <field name="groups" eval="[(4, ref('rida_forms.group_security_admin'))]"/>
        <field name="domain_force">[('state', '=', 'done')]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

