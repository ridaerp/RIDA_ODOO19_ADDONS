<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- add sequenc for work oder-->
        <record id="seq_maintenance_request" model="ir.sequence">
            <field name="name">maintenance Request Refrence</field>
            <field name="code">maintenance_request.sequence</field>
            <field name="prefix">WO-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>


        <record id="zone_form_view" model="ir.ui.view">
            <field name="name">zone.form</field>
            <field name="model">zone</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="admin_approval"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="block_form_view" model="ir.ui.view">
            <field name="name">block.form</field>
            <field name="model">block</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="zone_id" options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="block_tree_view" model="ir.ui.view">
            <field name="name">block.tree</field>
            <field name="model">block</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="zone_id"/>

                </tree>
            </field>
        </record>

        <record id="office_room_form_view" model="ir.ui.view">
            <field name="name">office.room.form</field>
            <field name="model">office.room</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="block_id" options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                            <field name="analytic_account_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="office_room_tree_view" model="ir.ui.view">
            <field name="name">office.room.tree</field>
            <field name="model">office.room</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="description"/>

                    <field name="block_id"/>
                    <field name="analytic_account_id"/>

                </tree>
            </field>
        </record>

        <!-- change team members-->
        <record id="maintenance_team_view_tree_inherit" model="ir.ui.view">
            <field name="model">maintenance.team</field>
            <field name="inherit_id" ref="maintenance.maintenance_team_view_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='member_ids']" position="replace">
                    <field name="member_ids" string="Team Users" widget="many2many_tags"
                           options="{'color_field': 'color', 'no_create': True}" domain="[('share', '=', False)]"/>
                    <field name="members_ids" widget="many2many_tags"
                           options="{'color_field': 'color', 'no_create': True}"/>
                </xpath>
            </field>
        </record>

        <record id="maintenance_team_view_form_inherit" model="ir.ui.view">
            <field name="model">maintenance.team</field>
            <field name="inherit_id" ref="maintenance.maintenance_team_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='member_ids']" position="replace">
                    <field name="member_ids" string="Team Users" widget="many2many_tags"
                           options="{'color_field': 'color', 'no_create': True}" domain="[('share', '=', False)]"/>
                    <field name="members_ids" widget="many2many_tags"
                           options="{'color_field': 'color', 'no_create': True}"/>
                    <field name="calendar_id"/>
                    <field name="shift_type"/>
                    <field name="start_shift"/>
                    <field name="end_shift"/>



                </xpath>
            </field>
        </record>


        <record id="equipment_request_view_form_inherit_custom" model="ir.ui.view">
            <field name="model">maintenance.request</field>
            <field name="inherit_id"
                   ref="maintenance.hr_equipment_request_view_form"/>
            <field name="arch" type="xml">


                <xpath expr="//field[@name='equipment_id']" position="before">

                    <field name="block_id" readonly="sequence != 1"/>
                    <field name="office_room_id" readonly="sequence != 1"
                           domain="[('block_id','=',block_id)]"
                           options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                </xpath>


                <xpath expr="//button[@name='archive_equipment_request']" position="after">
                    <button type="object" class="oe_highlight" invisible="sequence not in [3,5,6]"
                            name="create_vehicle_request"
                            groups="maintenance_fleet_inherit.group_maintenance_technician,maintenance_fleet_inherit.group_maintenance_supervisor"
                            string="Equipment Request"/>
                </xpath>

                <xpath expr="//field[@name='equipment_id']" position="after">


                    <field name="zone_id" readonly="1"
                           options="{'no_quick_create': True, 'no_create_edit' : True}"/>


                </xpath>
                <xpath expr="//button[@name='archive_equipment_request']" position="before">


                    <button string="Confirm" name="admin_submit" type="object"
                            invisible="sequence != 15"

                            groups="maintenance_fleet_inherit.group_admin_user"/>

                    <button string="Confirm" name="manager_submit" type="object"
                            invisible="sequence != 14"

                            groups="base_rida.rida_group_line_manager"/>


                    <button string="Submit" name="button_submit" type="object"
                            invisible="sequence != 1"
                            groups="base_maintenance_group.group_maintenance_user"/>

                   

                    <button string="Assign Tehnican" name="button_receive_wo" type="object"
                            invisible="sequence != 2"
                            groups="maintenance_fleet_inherit.group_maintenance_supervisor"/>


                    <button string="Start Maintenance" name="button_inspect" type="object"
                            invisible="sequence != 3"
                            groups="maintenance_fleet_inherit.group_maintenance_technician"/>


                <button string="Create Issuance" name="create_issuance" type="object"
                            invisible="sequence not in [5,6,7]"
                            groups="maintenance_fleet_inherit.group_maintenance_supervisor"/>


                    <button string="Create MR/SR" name="create_mr" type="object"
                            invisible="sequence not in [5,6,7]"
                            groups="maintenance_fleet_inherit.group_maintenance_supervisor"/>


                    <button string="Resuming" name="button_execute" type="object"
                            invisible="sequence not in [5,3]"
                            groups="maintenance_fleet_inherit.group_maintenance_supervisor"/>




                    <button string="Complete Job" name="complete" type="object"
                            invisible="sequence != 6"
                            groups="maintenance_fleet_inherit.group_maintenance_technician"/>


                

                    <button string="Close/Accept" name="close" type="object"
                            invisible="sequence != 7"
                            groups="base_maintenance_group.group_maintenance_user"/>

                    <button string="Return" name="button_return_maintenance" type="object"
                            invisible="sequence != 7"
                            groups="base_maintenance_group.group_maintenance_user,maintenance_fleet_inherit.group_maintenance_oper_mov"/>


                    <button string="Reject" name="button_reject" type="object"
                            invisible="1"/>


                </xpath>

                <xpath expr="//button[@name='archive_equipment_request']" position="replace">

                    <button string="Cancel" name="archive_equipment_request" type="object"
                            invisible="archive or sequence not in (1, 2, 3, 5)"/>

                </xpath>


                <xpath expr="//field[@name='name']" position="before">
                    <field name="wo_number"/>
                </xpath>


                <xpath expr="//field[@name='employee_id']" position="attributes">
                    <attribute name="required">1</attribute>
                </xpath>



                <xpath expr="//field[@name='equipment_id']" position="attributes">
                    <attribute name="required">1</attribute>
                </xpath>

                <xpath expr="//field[@name='maintenance_team_id']" position="attributes">
                    <attribute name="readonly">sequence != 1</attribute>
                </xpath>


                <xpath expr="//field[@name='employee_id']" position="attributes">
                    <attribute name="readonly">sequence != 1</attribute>
                </xpath>

                <xpath expr="//field[@name='company_id']" position="attributes">
                    <attribute name="readonly">sequence != 1</attribute>
                </xpath>


                <xpath expr="//field[@name='request_date']" position="after">
                    <field name="request_date_time" readonly="True"/>
                    <field name="department_id" readonly="sequence != 1"/>
                    <field name="equipment_type" invisible="1"/>
                    <field name="sequence" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='email_cc']" position="after">
                    <field name="location" required="equipment_type != 'Utilities'"/>
                    <field name="analytic_account_id" required="1" readonly="sequence != 1"/>
                </xpath>

                <xpath expr="//field[@name='workcenter_id']" position="replace">

                    <field name="workcenter_id" invisible="maintenance_for != 'workcenter'"
                           required="maintenance_for == 'workcenter'"/>
                </xpath>


                <xpath expr="//field[@name='email_cc']" position="after">


                    <field name="team_users" invisible="1"/>

                    <field name="technican_users" required="sequence == 3" invisible="sequence == 1"
                           widget="many2many_tags" domain="[('id','in',team_users)]"/>

                    <field name="wo_receive_datetime"
                           invisible="sequence == 1"
                           readonly="1"/>


                    <field name="assigned_datetime"
                           invisible="sequence == 1"
                           readonly="1"/>
                    <field name="complete_datetime" invisible="sequence == 1"
                           readonly="1"/>

                    <field name="insepect_datetime" invisible="1"/>

                    <field name="complete_datetime" invisible="sequence == 1"
                           readonly="1"/>


                    <field name="m_e_datetime" invisible="sequence == 1"
                           readonly="1"/>


                </xpath>
                <xpath expr="//field[@name='location']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>
                <xpath expr="//field[@name='schedule_date']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>
                <xpath expr="//field[@name='technican_users']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>

                <xpath expr="//field[@name='email_cc']" position="after">
                    <field name="cat_type"
                           invisible="1"/>

                    <field name="m_s_datetime" invisible="sequence == 1"
                           readonly="1"/>




                    <field name="period" required="equipment_type == 'vechicles'"/>


                    <field name="odometer" invisible="equipment_type != 'vechicles'"
                           required="equipment_type == 'vechicles'" readonly="sequence != 1"/>
                </xpath>

                <xpath expr="//field[@name='maintenance_type']" position="after">
                    <field name="defect_type" invisible="1"/>
                    <field name="defect_type_id" required="1"
                           domain="['|',('equipment_type','=',equipment_type),('equipment_type','=',False)]"/>
                    <field name="maintenance_defect" options="{'no_edit': True, 'no_create': True}"
                           domain="[('category_type_id','=',defect_type_id)]"
                           invisible="sequence == 1" required="sequence == 2"/>


                    <field name="maintenance_type_id"
                           required="sequence == 3" readonly="sequence == 1" invisible="sequence == 1"
                    />

                    <field name="std_durattion" required="sequence == 3" readonly="sequence == 1" invisible="sequence == 1" widget="float_time" />


                    <field name="need_spare" required="sequence == 3 or maintenance_type_id == 'internal'"
                           invisible="maintenance_type_id != 'internal'" readonly="sequence != 3"
                    />

                    <field name="name_state" invisible="1"/>

               

                </xpath>
                <xpath expr="//field[@name='defect_type']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>
                <xpath expr="//field[@name='period']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>
                <xpath expr="//field[@name='maintenance_type_id']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>
                <xpath expr="//field[@name='stage_id']" position="replace">
                    <field name="stage_id" widget="statusbar"
                           readonly="True"
                           domain="[('stage_visible','=','True')]"
                           invisible="archive == True"/>

                  
                </xpath>

                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="string">Operator/Driver</attribute>
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>

                <xpath expr="//field[@name='equipment_id']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>
                <xpath expr="//field[@name='duration']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>


            </field>
        </record>


        <record id="equipment_request_view_form_custom_inheirt" model="ir.ui.view">
            <field name="model">maintenance.request</field>
            <field name="inherit_id"
                   ref="base_maintenance.equipment_request_view_form"/>
            <field name="arch" type="xml">

                <field name="equipment_id" position="attributes">
                    <attribute name="domain">[('office_room_id','=',office_room_id),'|', (not workorder_id and 1 or
                        0, '=', 1), '|', ('workcenter_id', '=', False), ('workcenter_id.order_ids', 'in',
                        workorder_id)]
                    </attribute>
                </field>

              
              
                <xpath expr="//field[@name='equipment_id']" position="after">
                    <field name="x_studio_equipment_code" help="Equipment Code" string="Equipment Code"/>
                </xpath>
                <xpath expr="//field[@name='email_cc']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>



<xpath expr="//notebook" position="inside">
    <page name="report_element" string="Maintenance Timeline &amp; Lead Times">
        <!-- Main container -->
        <group col="3">

            <!-- Request / Completion -->
            <group string="Request">
                
                <field name="request_date_time" readonly="1"
                       help="Exact date and time the maintenance request was created."/>
                <field name="request_date" readonly="1"
                       help="Request date only (local time)."/>
                <field name="request_time" readonly="1"
                       help="Request time only (local time)."/>
               
                <field name="wo_receive_datetime" readonly="1"
                    help="Time when the maintenance team received the work order"/>


                  <field name="assigned_datetime" readonly="1"
                    help="Date and time when the request was assigned Tehnican."/>

            <field name="assigned_date" readonly="1"
                                help="Date when the request was assigned Tehnican."/>

            <field name="assigned_time" readonly="1"
                                help="Time when the request was assigned Tehnican."/>


                <field name="reponse_time" readonly="1"
                       help="Time taken (in minutes) from request creation to assignment."/>

            </group>

            <group string="Completion / Closing">
              
                <field name="complete_datetime" readonly="1"
                       help="Date and time when the maintenance work was completed."/>
                <field name="complete_date" readonly="1"
                       help="Completion date only."/>
                <field name="complete_time" readonly="1"
                       help="Completion time only."/>
                <field name="m_e_datetime" readonly="1"
                       help="Date and time when the maintenance order was officially closed."/>
                <field name="m_e_time" readonly="1"
                       help="Closing time only."/>

                        <field name="maintenance_time" readonly="1"
                       help="Actual elapsed time from Maintenance Start to completion (minutes)."/>
            </group>

            <!-- Duration -->
            <group string="Duration">
              
                <field name="std_durattion" readonly="1"
                       help="Standard expected duration for this maintenance task."/>
                <field name="duration" readonly="1"
                       help="Actual maintenance duration entered by technician."/>
                <field name="duration_minutes" readonly="1"
                       help="Maintenance duration converted to minutes."/>
             

                <field name="actual_duration" readonly="1"
                       help="Actual elapsed time from assignment to completion (minutes)."/>
              
               

            </group>

            <!-- Equipment -->
            <group string="Equipment">
            <field name="waiting_equipment" readonly="1"/>
              <field name="equipment_leadtime" readonly="1"
                       help="Waiting time (minutes) between equipment request and receipt."/>


               <separator string="Equipment Request"/>
                <field name="equipment_request_datetime" readonly="1"
                       help="Date and time when equipment was requested."/>


                <field name="equipment_request_date" readonly="1"
                       help="Date when equipment was requested."/>


                <field name="equipment_request_time" readonly="1"
                       help="Time when equipment was requested."/>

                <separator string="Equipment Receipt"/>

                <field name="equipment_recevied_date_time" readonly="1"
                       help="Date and time when equipment was received."/>


                 <field name="equipment_recevied_date" readonly="1"
                         help="Date  when equipment was received."/>

                 <field name="equipment_recevied_time" readonly="1"
                             help="Time when equipment was received."/>


              
        </group>

            <!-- Material Request -->
            <group string="Material-Service Request (MR/SR)">
                <field name="waiting_material" readonly="1"/>

                <field name="mr_leadtime" readonly="1"
                       help="Lead time in minutes: duration between MR/ST request and MR receipt."/>

                   <separator string="MR / SR Request"/>     
                <field name="mr_request_datetime" readonly="1"
                       help="Date and time when the Material Request (MR/SR) was created."/>

                <field name="mr_request_date" readonly="1"
                       help="Date and time when the Material Request (MR/SR) was created."/>

                <field name="mr_request_time" readonly="1"
                       help="Date when the Material Request (MR/SR) was created."/>

                         <separator string="MR / SR Receipt"/>

                <field name="mr_recevied_date_time" readonly="1"
                       help="time when the requested materials-Service were received."/>

                <field name="mr_recevied_date" readonly="1"
                       help="Date and time when the requested materials-Service were received."/>  
                <field name="mr_recevied_time" readonly="1"
                       help="Date and time when the requested materials-Service were received."/>

            </group>

            <!-- Issuance -->
            <group string="Issuance Request">
                <field name="waiting_issuance" readonly="1"/>

                 <field name="issuance_leadtime" readonly="1"
                       help="Lead time in minutes: duration between Issuance request and receipt of items."/> 


                <separator string="Issuance Request"/> 
                <field name="issuance_request_datetime" readonly="1"
                       help="Date and time when the Issuance request was submitted."/>
                <field name="issuance_request_date" readonly="1"
               help="Date  when the Issuance request was submitted."/>

                 <field name="issuance_request_time" readonly="1"
                help="Time when the Issuance request was submitted."/>
                       

                     <separator string="Issuance Receipt"/>

                <field name="issuance_recevied_datetime" readonly="1"
                       help="Date and time when the issued items were received."/>
                <field name="issuance_recevied_date" readonly="1"
                       help="Date  when the issued items were received."/>
                       <field name="issuance_recevied_time" readonly="1"
                       help="Time  when the issued items were received."/>

               
            </group>

        </group>
    </page>
</xpath>

                    <xpath expr="//notebook/page[1]" position="before">
                      <page name="maintenace_task_page" string="Inspection-Maintenance" invisible="sequence == 1" group="maintenance_fleet_inherit.group_maintenance_supervisor,maintenance_fleet_inherit.group_maintenance_technician">
                                <group>
                                    <field name="inspect_note"
                                           required="sequence == 3" readonly="name_state == 'Closed'" invisible="sequence == 1"/>

                                    <field name="maintenance_note"
                                           readonly="name_state == 'Closed'" invisible="sequence == 1"/>
                                </group>
                                  </page>





                            </xpath>
                <xpath expr="//field[@name='description']" position="attributes">
                    <attribute name="readonly">name_state == 'Closed'</attribute>
                </xpath>
              
            </field>
        </record>


        <record id="hr_equipment_stage_view_tree_inherit" model="ir.ui.view">
            <field name="model">maintenance.stage</field>
            <field name="inherit_id"
                   ref="maintenance.hr_equipment_stage_view_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='done']" position="after">
                    <field name="stage_visible"/>
                </xpath>
            </field>
        </record>


        <!-- equipment defect -->

        <record id="maintenance_equipment_defect_view_form" model="ir.ui.view">
            <field name="name">Maintenance Defect</field>
            <field name="model">maintenance.defect</field>
            <field name="arch" type="xml">
                <form string="Equipment Status">
                    <header/>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button
                                    name="toggle_active"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-archive"
                            >
                                <field
                                        name="active"
                                        widget="boolean_button"
                                        options="{&quot;terminology&quot;: &quot;archive&quot;}"
                                />
                            </button>
                        </div>

                        <group>


                            <field name="name" placeholder="e.g. Operational"/>

                            <field name="type_id" invisible="1"/>
                            <field name="category_type_id"/>

                        </group>


                    </sheet>
                </form>
            </field>
        </record>
        <record id="maintenance_equipment_defect_view_tree" model="ir.ui.view">
            <field name="name">Maintenance Defect</field>
            <field name="model">maintenance.defect</field>
            <field name="arch" type="xml">
                <tree string="Maintenance Defect">
                    <field name="name"/>
                    <field name="type_id" invisible="1"/>
                    <field name="category_type_id"/>

                </tree>
            </field>
        </record>
        <record id="maintenance_equipment_defect_view_search" model="ir.ui.view">
            <field name="name">Maintenance Defect</field>
            <field name="model">maintenance.defect</field>
            <field name="arch" type="xml">
                <search string="Maintenance Defect">
                    <field name="name"/>
                    <field name="type_id" invisible="1"/>
                    <field name="category_type_id"/>


                </search>
            </field>
        </record>


        <record id="maintenance_equipment_defect_action" model="ir.actions.act_window">
            <field name="name">Maintenance Defect</field>
            <field name="res_model">maintenance.defect</field>
            <field
                    name="view_id"
                    ref="maintenance_equipment_defect_view_tree"
            />
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to set a new Defect for your equipments.
                </p>
            </field>
        </record>

        <record id="maintenance_equipment_defect_category_action" model="ir.actions.act_window">
            <field name="name">Maintenance Defect Category</field>
            <field name="res_model">defect.category</field>

            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to set a new Defect for your equipments.
                </p>
            </field>
        </record>
        <!--        Location Model -->
        <record id="view_vehicle_location_tree" model="ir.ui.view">
            <field name="name">vehicle.location.tree</field>
            <field name="model">vehicle.location</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="view_vehicle_location_form" model="ir.ui.view">
            <field name="name">vehicle.location.form</field>
            <field name="model">vehicle.location</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name" required="True"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="maintenance_equipment_office_room" model="ir.actions.act_window">
            <field name="name">Offices And Rooms</field>
            <field name="res_model">office.room</field>
            <field name="view_mode">tree,form</field>
        </record>
        <record id="maintenance_equipment_block_action" model="ir.actions.act_window">
            <field name="name">Block</field>
            <field name="res_model">block</field>
            <field name="view_mode">tree,form</field>
        </record>
        <record id="maintenance_equipment_zone_action" model="ir.actions.act_window">
            <field name="name">Zone</field>
            <field name="res_model">zone</field>
            <field name="view_mode">tree,form</field>
        </record>
    <!--        Location Model-->
        <record id="vehicle_location_action" model="ir.actions.act_window">
            <field name="name">Vehicle location</field>
            <field name="res_model">vehicle.location</field>
            <field name="view_mode">tree,form</field>
        </record>


        <menuitem
                id="menu_maintenance_equipment_defect_act"
                name="Maintenance Defect"
                action="maintenance_equipment_defect_action"
                parent="maintenance.menu_maintenance_configuration"
                groups="maintenance.group_equipment_manager"
