<odoo>
    <data>

        <record id="fleet_vehicle_odometer_view_tree_inherit2" model="ir.ui.view">
            <field name="name">fleet.vehicle.odometer.tree.inherit2</field>
            <field name="model">fleet.vehicle.odometer</field>
            <field name="inherit_id" ref="fleet.fleet_vehicle_odometer_view_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='vehicle_id']" position="after">
                    <field name="equipment_id"/>
                </xpath>
                <xpath expr="//field[@name='driver_id']" position="after">
                    <field name="location_id"/>
                    <field name="start_value"/>
                </xpath>

            </field>
        </record>

        <record id="fleet_vehicle_odometer_view_from_inherit2" model="ir.ui.view">
            <field name="name">fleet.vehicle.odometer.form.inherit2</field>
            <field name="model">fleet.vehicle.odometer</field>
            <field name="inherit_id" ref="fleet.fleet_vehicle_odometer_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='vehicle_id']" position="after">
                    <field name="equipment_id"/>
                    <field name="location_id"/>
                    <field name="start_value"/>
                </xpath>
<!--                <xpath expr="//field[@name='driver_id']" position="after">-->
<!--                    <field name="location_id"/>-->
<!--                    <field name="start_value"/>-->
<!--                </xpath>-->

            </field>
        </record>

        <!-- add code and other info about equipment in equipment form view-->
        <record id="m_equipment_view_form" model="ir.ui.view">
            <field name="model">maintenance.equipment</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='category_id']" position="before">
                    <field name="custom_sequence"/>
                    <field name="zone_id" options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                    <field name="block_id" domain="[('zone_id','=',zone_id)]"
                           options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                    <field name="office_room_id" domain="[('block_id','=',block_id)]"
                           options="{'no_quick_create': True, 'no_create_edit' : True}"/>
                </xpath>
                <xpath expr="//field[@name='location']" position="after">
                    <field name="asset_id"/>
                    <label for="odometer"/>
                    <div class="o_row">
                        <field name="odometer"/>
                        <field name="start_odometer"/>
                        <field name="odometer_unit"/>
                    </div>
                </xpath>

                <xpath expr="//div[@name='button_box']" position="inside">
                    <button
                            name="preview_fleet_list"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-car"
                            string="vechicle">

                    </button>
                    <button
                            name="set_odometer"
                            context="{'xml_id':'fleet_vehicle_odometer_action'}"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-tachometer"
                            string="Odometer">
                        <field name="odometer_count" widget="statinfo" nolabel="1"/>
                    </button>

                    <button
                            name="preview_location_list"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-exchange"
                            string="Equipment Move">

                    </button>
                    <button
                            name="preview_issuance_list"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-exchange"
                            string="Fuel Consumption">
                    </button>
                </xpath>


                <xpath expr="//div[@class='oe_title']" position="before">
                    <div class="oe_title">
                        <label for="code" class="oe_edit_only"/>
                        <h1>
                            <field name="code" string="Code" placeholder="Equipment Code"/>
                        </h1>
                    </div>
                </xpath>
                <xpath expr="//field[@name='cost']" position="after">
                    <field name="equipment_type" invisible="1"/>
                    <field name="vechicle_model" required="equipment_type != 'vechicles'"
                           invisible="equipment_type != 'vechicles'"/>
                    <field name="brand" invisible="equipment_type != 'vechicles'"/>
                    <field name="equipment_fleet_type" invisible="equipment_type != 'vechicles'"/>
                </xpath>

                <xpath expr="//field[@name='category_id']" position="attributes">
                    <attribute name="required">1</attribute>
                </xpath>
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="fleet_category"
                           invisible="equipment_type != 'vechicles'" required="equipment_type == 'vechicles'"/>
                    <field name="analytic_account_id" required="1"/>
                    <field name="vechicle_id" invisible="equipment_type != 'vechicles'"/>
                </xpath>

                <xpath expr="//field[@name='serial_no']" position="after">
                    <field name="plate" invisible="equipment_type != 'vechicles'"/>
                    <field name="vin"/>
                    <field name="year" invisible="equipment_type != 'vechicles'"/>

                    <field name="c_b_type" invisible="1"/>
                    <field name="c_b_rating" invisible="1"/>
                    <field name="voltage_transfer" invisible="1"/>
                    <field name="B_DIM" invisible="1"/>
                    <field name="AC" invisible="1"/>
                    <field name="U_DIM" invisible="1"/>
                    <field name="rated_power_kva" invisible="1"/>

                </xpath>

                <xpath expr="//field[@name='warranty_date']" position="after">
                    <field name="engine" invisible="equipment_type != 'vechicles'"/>
                    <field name="engine_serial" invisible="equipment_type != 'vechicles'"/>
                    <field name="TYPE" invisible="1"/>
                    <field name="UNIT_NAME" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='asset_id']" position="after">
                    <field name="type_of_equipment"/>
                    <field name="stander_fuel"/>
                </xpath>


            </field>
        </record>

        <!-- add code in equipment tree view-->

        <record id="hr_equipment_view_tree_inehrit" model="ir.ui.view">
            <field name="model">maintenance.equipment</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="code"/>

                </xpath>

            </field>
        </record>
        <!-- add code in equipment kanban view-->

        <record id="m_equipment_view_kanban" model="ir.ui.view">
            <field name="model">maintenance.equipment</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_view_kanban"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='name']" position="after">
                    <field name="code"/>
                </xpath>
                <xpath expr="//templates//field[@name='employee_id']" position="after">
                    <field name="code"/>
                </xpath>

                <div t-if="record.serial_no.raw_value" position='after'>

                    <div t-if="record.code">
                        <field name="code"/>
                    </div>
                </div>

            </field>
        </record>


        <record id="hr_equipment_view_search" model="ir.ui.view">
            <field name="model">maintenance.equipment</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_view_search"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='name']" position="after">
                    <field name="code"/>
                </xpath>
            </field>
        </record>


        <!-- add type mahcines or vehciles  in equipment category form view-->

        <record id="equipment_category_view_form_inherit" model="ir.ui.view">
            <field name="model">maintenance.equipment.category</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_category_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='technician_user_id']" position="after">
                    <field name="equipment_type"/>
                </xpath>

            </field>
        </record>


        <!-- add type mahcines or vehciles  in equipment category tree view-->

        <record id="hr_equipment_category_view_tree_inherit" model="ir.ui.view">
            <field name="model">maintenance.equipment.category</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_category_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="equipment_type"/>
                </xpath>

            </field>
        </record>
        <!-- add type mahcines or vehciles  in equipment category kanan view-->

        <record id="m_equipment_view_kanban_inherit" model="ir.ui.view">
            <field name="model">maintenance.equipment.category</field>
            <field name="inherit_id" ref="maintenance.view_maintenance_equipment_category_kanban"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@t-attf-class='oe_kanban_global_click']" position="inside">
                    <div class="mb4">
                        <field name="equipment_type"/>
                    </div>
                </xpath>
            </field>
        </record>


    </data>
</odoo>

