<odoo>
    <record id="view_fleet_operation_tree" model="ir.ui.view">
        <field name="name">fleet.operation.tree</field>
        <field name="model">fleet.operation</field>
        <field name="arch" type="xml">
            <list>
                <field name="date" />
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="odometer_ids"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_operation_form" model="ir.ui.view">
        <field name="name">fleet.operation.form</field>
        <field name="model">fleet.operation</field>
        <field name="arch" type="xml">
            <form string="Fleet Operation">
                <header>
                    <button name="action_draft_fleet" type="object" string="Rest To Draft"  invisible="state != 'cancel'"/>
                    <button name="action_closed_fleet" type="object" string="submit" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel_fleet" type="object" string="Cancel"  invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,closed" nolabel="1" readonly="1"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="date" reqiured="1"/>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="start_day"/>
                            <field name="end_day"/>
                            <field name="start_night"/>
                            <field name="end_night"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Odometers">
                            <field name="odometer_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="custom_sequence"/>
                                    <field name="equipment_code"/>
                                    <field name="equipment_id"/>
                                    <field name="type_of"/>
                                    <field name="location_id"/>
                                    <field name="operation_type"/>
                                    <field name="day_type"/>
                                    <field name="day_duration"/>
                                    <field name="start_value"/>
                                    <field name="end_value"/>
                                    <field name="distance"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="fleet_operation_action" model="ir.actions.act_window">
        <field name="name">Fleet Operation</field>
        <field name="res_model">fleet.operation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="fleet_operation_location" name="Fleet Operation Log" parent="fleet.menu_root"
                  action="maintenance_fleet_inherit.fleet_operation_action" sequence="3"/>
</odoo>
