<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record model="ir.cron" id="maintenance_close_button_cron">
            <field name="name">Maintenance Close Automation</field>
            <field name="model_id" ref="model_maintenance_request"/>
            <field name="state">code</field>
            <field name="code">model._cron_close()</field>
            <field name="interval_number">48</field>
            <field name="interval_type">hours</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(hours=48)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
    </data>
</odoo>