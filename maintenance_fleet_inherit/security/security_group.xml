<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- <record id="module_base_maintenance_category" model="ir.module.category">
            <field name="name">Maintenance Groups</field>
        </record> -->

        <record id="module_base_maintenance_privilege" model="res.groups.privilege">
            <field name="name">Maintenance Groups</field>
            <field name="category_id" ref="base_rida.module_base_rida_category"/>
        </record>

        <record id="group_admin_user" model="res.groups">
            <field name="name">Admin Affairs Officer</field>
            <field name="privilege_id" ref="module_base_maintenance_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base_maintenance_group.group_maintenance_user'))]"/>
        </record>

        <record id="read_group_maintenace" model="res.groups">
            <field name="name">Read Maintenance</field>
            <field name="privilege_id" ref="module_base_maintenance_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base_maintenance_group.group_maintenance_user'))]"/>
        </record>

        <record id="readonly_only_subscribe_maintenance_team" model="ir.rule">
            <field name="name">Read Maintenance Team</field>
            <field name="model_id" ref="maintenance.model_maintenance_team"/>
            <field name="groups" eval="[(6, 0, [ref('read_group_maintenace')])]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="perm_create" eval="False"/>
        </record>

        <record id="readonly_only_subscribe_maintenance_request" model="ir.rule">
            <field name="name">Read Maintenance Request</field>
            <field name="model_id" ref="maintenance.model_maintenance_request"/>
            <field name="groups" eval="[(6, 0, [ref('read_group_maintenace')])]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="perm_create" eval="False"/>
        </record>

        <record id="group_operation_fleet_user" model="res.groups">
            <field name="name">Fleet Operation Engineer</field>
            <field name="privilege_id" ref="module_base_maintenance_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base_maintenance_group.group_maintenance_user'))]"/>
        </record>

        <record id="group_maintenance_supervisor" model="res.groups">
            <field name="name">Maintenance Engineer</field>
            <field name="privilege_id" ref="module_base_maintenance_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base_maintenance_group.group_maintenance_user'))]"/>
        </record>

        <record id="group_maintenance_technician" model="res.groups">
            <field name="name">Technician</field>
            <field name="privilege_id" ref="module_base_maintenance_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base_maintenance_group.group_maintenance_user'))]"/>
        </record>

        <record id="group_maintenance_oper_mov" model="res.groups">
            <field name="name">Movement or operation User</field>
            <field name="privilege_id" ref="module_base_maintenance_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base_maintenance_group.group_maintenance_user'))]"/>
        </record>


        <record id="equipment_rule_user" model="ir.rule">
            <field name="name">Equipments Engineer</field>
            <field name="model_id" ref="model_maintenance_equipment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base_maintenance_group.group_maintenance_user'))]"/>
        </record>

        <record id="requester_rule_eng_user" model="ir.rule">
            <field name="name">Requester</field>
            <field name="model_id" ref="model_maintenance_equipment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base_maintenance_group.group_maintenance_user'))]"/>
        </record>

        <record id="requester_team_eng_user" model="ir.rule">
            <field name="name">Engineer</field>
            <field name="model_id" ref="model_maintenance_team"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_supervisor'))]"/>
        </record>

        <record id="equipment_rule_eng_user" model="ir.rule">
            <field name="name">Equipments Engineer</field>
            <field name="model_id" ref="model_maintenance_equipment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_supervisor'))]"/>
        </record>

        <record id="equipment_rule_oper_user" model="ir.rule">
            <field name="name">Equipments Operation/Movement</field>
            <field name="model_id" ref="model_maintenance_equipment"/>
            <field name="domain_force">[('equipment_type', '=', 'vechicles')]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_oper_mov'))]"/>
        </record>

        <record id="request_rule_oper_user" model="ir.rule">
            <field name="name">Maintenance Request</field>
            <field name="model_id" ref="model_maintenance_request"/>
            <field name="domain_force">[('equipment_type', '=', 'vechicles')]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_oper_mov'))]"/>
        </record>

        <record id="request_rule_engineer_user" model="ir.rule">
            <field name="name">Maintenance Request</field>
            <field name="model_id" ref="model_maintenance_request"/>
            <field name="domain_force">[('mr_members_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('group_maintenance_supervisor'))]"/>
        </record>

        <record id="hr.group_hr_user" model="res.groups">
            <field name="implied_ids" eval="[(3, ref('maintenance.group_equipment_manager'))]"/>
        </record>


        <record id="request_rule_admin_user" model="ir.rule">
            <field name="name">Maintenance Request</field>
            <field name="model_id" ref="model_maintenance_request"/>
            <field name="domain_force">['|',('equipment_type', '=', 'utilities'),('equipment_id','=',False)]</field>
            <field name="groups" eval="[(4, ref('group_admin_user'))]"/>
        </record>

        <record id="equipment_rule_admin_user" model="ir.rule">
            <field name="name">Equipments Utitiles</field>
            <field name="model_id" ref="model_maintenance_equipment"/>
            <field name="domain_force">[('equipment_type', '=', 'utilities')]</field>
            <field name="groups" eval="[(4, ref('group_admin_user'))]"/>
        </record>


    </data>
</odoo>
