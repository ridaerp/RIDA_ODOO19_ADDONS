<odoo>
    <data>

        <record model="ir.ui.view" id="view_employee_form_inherit_custom_contract_date_start">
            <field name="name">hr.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="before">
                    <group>
                        <group>
                            <field name="contract_date_start"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="hr_employee_view_form_inherited2" model="ir.ui.view">
            <field name="name">hr.employee.form.inherited</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr_contract_benefit.hr_employee_view_form_inherited_benefit"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='work_email']" position="after">
                    <field name="is_worker"/>
                    <field name="is_section_head"/>
                    <field name="band_id" invisible="1" />
                </xpath>
                <xpath expr="//notebook" position="before">
                    <group>
                        <group>
                            <field name="contract_date_start" groups="hr.group_hr_user"/>
                        </group>
                    </group>
                </xpath>

                <xpath expr="//page[@name='payroll_information']" position="attributes">
                    <attribute name="groups">hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site</attribute>
                </xpath>
            

                <xpath expr="//group[@name='benefits_group']" position="after">
                    <group name="group_top">
                        <group name="group_left">
                            <field name="basic"/>
                            <field name="grade_id"/>
                            <field name="min"/>
                            <field name="max"/>
                            <field name="salary_currency" groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site"/>
                            <!-- <field name="currency_id" readonly="0" groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site"/> -->

                        </group>
                        <group name="group_right">
                            <field name="payroll_wage" groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site"/>
                        </group>
                    </group>
                       
                        <group>
                            <field name="total_allowance"/>
                            <field name="wage" string="Take Home/Month"/>
                        </group>
                        <group string="Salary Calculations" name="salary_calculation"   groups="hr_payroll.group_hr_payroll_manager,base_rida.rida_payroll_site">
                            <group name="group_left">
                                <field name="payroll_wage" invisible="1" />
                                <field name="basic_percentage" />
                                <field name="cola_percentage" />
                                <field name="housing_percentage" />
                                <field name="transportion_percentage" />
                            </group>
                            <group name="group_right">
                                <field name="basic_salary"   force_save="1"/>
                                <field name="cola"   force_save="1"/>
                                <field name="housing"   force_save="1"/>
                                <field name="transportion"   force_save="1"/>
                            </group>
                        </group>

                         <group>
                            <field name="grade_line_id" nolabel="1" colspan="2" class="o_full_width">
                                <list editable="top" >
                                    <field name="name" readonly="True" force_save="1" required="1"/>
                                    <field name="code" readonly="True" force_save="1" required="1"/>
                                    <field name="type" readonly="1" force_save="1"/>
                                    <field name="percentage" readonly="type == 'fixed'"  force_save="1"/>
                                    <field name="amount" readonly="type != 'fixed'"  force_save="1"/>
                                </list>
                            </field>
                        </group>
                    </xpath>
            </field>
        </record>

        <record id="inherited_version_view_id" model="ir.ui.view">
        <field name="name">version.inherit.view.form</field>
        <field name="model">hr.version</field>
        <field name="inherit_id" ref="hr.hr_contract_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='top_info_right']" position="after">
                <group>
                    <field name="grade_id" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="has_transport_allows" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="transportion_allowance" invisible="not has_transport_allows"
                           groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="has_car_allows" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="car_allowance" invisible="not has_car_allows"
                           groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="has_fuel_allows" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="fuel_allowance" invisible="not has_fuel_allows"
                           groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="has_phone_allows" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="phone_allowance" invisible="not has_phone_allows"
                           groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="has_scarcity_allowance" groups="hr_payroll.group_hr_payroll_user"/>
                </group>
                <group>
                    <field name="seconment_allowance" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="acting_allowance" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="acting_type" invisible="not acting_allowance"
                           groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="acting_amount" invisible="1" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="workeddays" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="medical_allowance" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="medicine_allowance" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="other_recevible" groups="hr_payroll.group_hr_payroll_user"/>
                    <field name="other_deductions" groups="hr_payroll.group_hr_payroll_user"/>
                </group>
            </xpath>
        </field>
    </record>

    </data>
</odoo>