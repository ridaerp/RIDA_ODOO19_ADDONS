<odoo>
    <record id="view_travel_zone_tree" model="ir.ui.view">
        <field name="name">travel.zone.tree</field>
        <field name="model">travel.zone</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="country_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="view_travel_zone_form" model="ir.ui.view">
        <field name="name">travel.zone.form</field>
        <field name="model">travel.zone</field>
        <field name="arch" type="xml">
            <form string="Travel Zone Setup">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="country_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employees">
                            <field name="travel_line_id">
                                <list string="Employees" editable="bottom">
                                    <field name="grade_ids"  widget="many2many_tags"/>
                                    <field name="accommodation"/>
                                    <field name="amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_travel_zone" model="ir.actions.act_window">
        <field name="name">Travel Zones</field>
        <field name="res_model">travel.zone</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_travel_zone"
              name="Travel Zones"
              parent="hr.menu_human_resources_configuration"
              action="action_travel_zone"
              sequence="10"/>
</odoo>
